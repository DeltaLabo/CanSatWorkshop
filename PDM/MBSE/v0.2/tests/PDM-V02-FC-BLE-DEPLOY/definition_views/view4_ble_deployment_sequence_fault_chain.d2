vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional chain for the BLE/manual deployment verification sequence. The
# chain includes the test means as functions and carries pass/fail, statistical,
# and fault-hardening constraints as modeled notes.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDM-V02-FC-BLE-DEPLOY — BLE/manual parachute deployment sequence and fault-hardening\nrefs: PDM v0.2 view4; PDM v0.2 views 1-3; PDM-BLK-006" {
  class: chain
  direction: down

  note_ble_preflight: "[C] Pass: BLE connection and command/control path\nverified at >=20 m LOS before airborne/release" { class: note; shape: page }
  note_no_precommand: "[C] Pass: no parachute open actuation\nbefore command + airborne condition" { class: note; shape: page }
  note_airborne_command: "[C] Pass: while airborne, BLE open command\ncauses OBCC PWM open position and\nservo/parachute mechanism reaches open state" { class: note; shape: page }
  note_power: "[C] Pass: servo rail power satisfies\n`PDM-BLK-006`: `5.0 V +/- 10%` (`4.5 V` to `5.5 V`)\nduring command and actuation at servo/nearest measurable point\nNo OBCC/XIAO reset, brownout, BLE reconnect,\ntelemetry/log discontinuity, current-limit collapse,\nor thermal shutdown due to actuation\nVoltage/current trace starts at pre-command baseline\nand continues for >=2 s after open/failure" { class: note; shape: page }
  note_terminal_speed: "[C] Terminal-speed criterion `<= 11 m/s`\nDeployment chain in this run verifies command/open support only\nQuantitative descent-speed closure must be in-run\nor linked to `PDM-V02-TEST-TERMINAL-SPEED` and/or applicable\n`PDM-V01-FC-FALL` evidence with as-tested mass/\nparachute/config applicability; otherwise hold/gap" { class: note; shape: page }
  note_statistics: "[C] Statistical viewpoint\n3 successful reps = development screening only;\nreliability/confidence claims require binomial basis\nand independent representative trials" { class: note; shape: page }
  note_fault_hardening: "[C] Fault-hardening viewpoint\nconsider BLE loss/out-of-range, late/missed command,\nlow battery/boost sag, servo jam/stall, antenna orientation,\nwind/gusts, partial deployment" { class: note; shape: page }
  note_evidence: "[C] Evidence package\nsource model baseline, source/UUT IDs\nBLE device/configuration, range/LOS data\npredefined environment/wind context\nBLE/PWM/power traces with timestamps\ncontinuity/log markers, deviations/anomalies" { class: note; shape: page }

  read_ambient_conditions: "[F] Read and log\nambient conditions" { class: func }
  set_range_los_20m: "[F] Set >=20 m\nline-of-sight range" { class: func }
  configure_uut_logging: "[F] Configure UUT, BLE device,\nand evidence logging\n(record source/UUT IDs, calibration,\nlogger settings)" { class: func }
  establish_ble_connection: "[F] Establish BLE\nconnection" { class: func }
  maintain_ble_connection: "[F] Maintain BLE\nconnection" { class: func }
  verify_preflight_ble_path: "[F] Verify pre-flight\nBLE command/control path" { class: func }
  start_evidence_recording: "[F] Start BLE/PWM/power/video\nevidence recording" { class: func }
  monitor_no_precommand_open: "[F] Monitor no pre-command\nopen actuation" { class: func }
  mark_airborne_condition: "[F] Release or mark\nairborne condition" { class: func }
  send_ble_open_command: "[F] Send BLE open\ncommand" { class: func }
  set_pwm_open_position: "[F] Set PWM to open\nposition" { class: func }
  capture_pwm_power_response: "[F] Capture PWM and\npower traces and markers" { class: func }
  open_parachute: "[F] Open parachute" { class: func }
  observe_open_state: "[F] Observe servo/parachute\nopen state" { class: func }
  link_terminal_speed_evidence: "[F] Link terminal-speed evidence\nto `<= 11 m/s` criterion" { class: func }
  limit_terminal_speed: "[F] Limit terminal speed\nor bind linked evidence" { class: func }
  calculate_trial_outcome: "[F] Calculate pass/fail\ntrial outcome" { class: func }
  evaluate_fault_cases: "[F] Evaluate fault-hardening\nobservations" { class: func }
  archive_evidence_report: "[F] Archive evidence and\nreport reference" { class: func }
}

chain.read_ambient_conditions -> chain.set_range_los_20m: "[FE] Environmental record []" { class: fe }
chain.set_range_los_20m -> chain.configure_uut_logging: "[FE] Range/LOS ready []" { class: fe }
chain.configure_uut_logging -> chain.establish_ble_connection: "[FE] BLE config [BLE]" { class: fe }
chain.establish_ble_connection -> chain.maintain_ble_connection: "[FE] Connection status [BLE]" { class: fe }
chain.maintain_ble_connection -> chain.verify_preflight_ble_path: "[FE] BLE ready []" { class: fe }
chain.verify_preflight_ble_path -> chain.start_evidence_recording: "[FE] Pre-flight ready []" { class: fe }
chain.start_evidence_recording -> chain.monitor_no_precommand_open: "[FE] Baseline evidence []" { class: fe }
chain.monitor_no_precommand_open -> chain.mark_airborne_condition: "[FE] No-open baseline []" { class: fe }
chain.mark_airborne_condition -> chain.send_ble_open_command: "[FE] Airborne condition []" { class: fe }
chain.send_ble_open_command -> chain.set_pwm_open_position: "[FE] Open command [BLE]" { class: fe }
chain.set_pwm_open_position -> chain.capture_pwm_power_response: "[FE] Open signal [PWM]" { class: fe }
chain.capture_pwm_power_response -> chain.open_parachute: "[FE] PWM/power evidence []" { class: fe }
chain.open_parachute -> chain.observe_open_state: "[FE] Parachute opened []" { class: fe }
chain.observe_open_state -> chain.link_terminal_speed_evidence: "[FE] Open-state evidence []" { class: fe }
chain.link_terminal_speed_evidence -> chain.limit_terminal_speed: "[FE] Link terminal-speed evidence []" { class: fe }
chain.limit_terminal_speed -> chain.calculate_trial_outcome: "[FE] Deployment outcome []" { class: fe }
chain.calculate_trial_outcome -> chain.evaluate_fault_cases: "[FE] Pass/fail rationale []" { class: fe }
chain.evaluate_fault_cases -> chain.archive_evidence_report: "[FE] Record []" { class: fe }

chain.note_ble_preflight -> chain.set_range_los_20m { class: cstr }
chain.note_ble_preflight -> chain.establish_ble_connection { class: cstr }
chain.note_ble_preflight -> chain.verify_preflight_ble_path { class: cstr }
chain.note_no_precommand -> chain.monitor_no_precommand_open { class: cstr }
chain.note_airborne_command -> chain.mark_airborne_condition { class: cstr }
chain.note_airborne_command -> chain.send_ble_open_command { class: cstr }
chain.note_airborne_command -> chain.set_pwm_open_position { class: cstr }
chain.note_airborne_command -> chain.open_parachute { class: cstr }
chain.note_power -> chain.capture_pwm_power_response { class: cstr }
chain.note_terminal_speed -> chain.observe_open_state { class: cstr }
chain.note_terminal_speed -> chain.link_terminal_speed_evidence { class: cstr }
chain.note_terminal_speed -> chain.limit_terminal_speed { class: cstr }
chain.note_statistics -> chain.calculate_trial_outcome { class: cstr }
chain.note_fault_hardening -> chain.evaluate_fault_cases { class: cstr }
chain.note_evidence -> chain.start_evidence_recording { class: cstr }
