vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-002 verification-only Physical Architecture PV2.
# Logical/interface view for rail, testpoint, netlist, measurement, and evidence exchanges.
# References cited in the rendered system title: IVV, SAA-R4, SAA-R5.
# These logical components and exchanges define the verification means only; they are not baseline S&A design exchanges.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
witness: "[EA] QA Witness" { class: ea }
fixture: "[EA] Mate / Demate Fixture\nand Alignment Jig" { class: ea }
supply: "[EA] Current-limited\nBench Supply" { class: ea }
safe_load: "[EA] Safe Load /\nNo-load Adapter" { class: ea }
dmm_daq: "[EA] DMM / DAQ" { class: ea }
continuity: "[EA] Continuity /\nIsolation Tester" { class: ea }
scope_la: "[EA] Oscilloscope /\nLogic Analyzer" { class: ea }
tp_probes: "[EA] Testpoint Probe Set" { class: ea }
netlist_pkg: "[EA] Released Netlist /\nPinout Evidence" { class: ea }
ambient_meter: "[EA] Ambient Thermo-\nHygrometer" { class: ea }
camera: "[EA] Camera / Evidence\nLight Box" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-FC-002" { class: ea }

system: "[System] SAA-VV-FC-002 Logical Rail/Testpoint/Measurement Exchange\nRefs: IVV; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  uut: "[PC] v1.0 S&A Backplane\nMating and Access Boundary" {
    class: pc
    direction: down

    config_record: "[LC] Article / Baseline\nand Fixture Configuration\nverification-only" { class: lc }
    mating_record: "[LC] Header and Connector\nMating Status\nverification-only" { class: lc }
    endpoint_census: "[LC] Header/Testpoint\nEndpoint Census\nverification-only" { class: lc }
    continuity_matrix: "[LC] Continuity / Isolation\nMatrix\nverification-only" { class: lc }
    safe_power_state: "[LC] Safe Power / Load\nState\nverification-only" { class: lc }
    rail_record: "[LC] 5 V / 3.3 V Rail\nMeasurement Record\nverification-only" { class: lc }
    testpoint_access: "[LC] Required Testpoint\nAccess Status\nverification-only" { class: lc }
    fast_line_access: "[LC] SPI / I2C / UART\nFast-Line Probe Access\nverification-only" { class: lc }
    anomaly_record: "[LC] Anomaly / Hold\nDisposition Record\nverification-only" { class: lc }
    evidence_gate: "[LC] Backplane Access\nAcceptance Gate\nverification-only" { class: lc }
    evidence_package: "[LC] Evidence Package\nverification-only" { class: lc }
  }

  verification_scope: "[C] Verification-only CEs:\nThese exchanges carry procedure, measurement,\nnetlist, and evidence information for\nSAA-VV-FC-002 only. They do not create\nor close baseline S&A component exchanges." {
    class: note
    shape: page
  }

  pass_fail: "[C] Pass/fail data required:\nAll ADS/AMS/OBCC/PDS headers and the\nPDM servo connector are seated/aligned to\nthe model with no force or bent pins; 100%\nrequired net/rail/testpoint checks show no\nshort/open/swapped endpoint anomaly; rails\nmeasure 5.0 ±0.1 V and 3.3 ±0.1 V under\ncontrolled safe load or documented no-load;\nall required testpoints are reachable and\nevidence/anomalies are complete." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\n100% released net, rail, connector, and\nrequired testpoint checks. Mate-cycle\nrepetition is a screen unless an approved\nindependent-cycle statistical plan exists." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nRecords explicitly screen wrong orientation,\nmisalignment, forced insertion, bent pins,\nshorts, opens, swapped endpoints, inaccessible\ntestpoints, overcurrent/rail drop, and fast-line\nprobe loading or rise-time concern." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nSAA-UC-BackplaneIntegration;\nSAA-FE-BackplaneMisMate;\nv1.0 Backplane PCB constraints for defined\npin interface, 5.0 ±0.1 V, 3.3 ±0.1 V,\ntestpoints, low-capacitance SPI/I2C/UART,\nand ERC + DRC clean." {
    class: note
    shape: page
  }
}

operator -> system.uut.config_record: "[CE] Article ID, baseline,\noperator steps" { class: ce }
operator -> system.uut.mating_record: "[CE] Mate/demate action\nand no-force observation" { class: ce }
operator -> system.uut.anomaly_record: "[CE] Observed anomaly,\nhold, or rework note" { class: ce }
witness -> system.uut.evidence_gate: "[CE] Witness review,\npass/hold/fail decision" { class: ce }
fixture -> system.uut.mating_record: "[CE] Orientation, seating,\nalignment datum" { class: ce }
netlist_pkg -> system.uut.endpoint_census: "[CE] Released pinout,\nnetlist, testpoint list" { class: ce }
continuity -> system.uut.continuity_matrix: "[CE] 100% continuity,\nisolation, swapped-endpoint results" { class: ce }
supply -> system.uut.safe_power_state: "[CE] Voltage setting,\ncurrent limit, enable state" { class: ce }
safe_load -> system.uut.safe_power_state: "[CE] Safe-load value or\ndocumented no-load rationale" { class: ce }
dmm_daq -> system.uut.rail_record: "[CE] 5 V / 3.3 V readings,\ncalibration status" { class: ce }
tp_probes -> system.uut.testpoint_access: "[CE] Reachability and\nprobe-contact status" { class: ce }
scope_la -> system.uut.fast_line_access: "[CE] Critical fast-line\nprobe access and loading note" { class: ce }
ambient_meter -> system.uut.evidence_package: "[CE] Ambient temperature,\nhumidity, condition flag" { class: ce }
camera -> system.uut.evidence_package: "[CE] Photos/video of\nseating, probes, readings" { class: ce }

system.uut.config_record -> system.uut.mating_record: "[CE] Confirmed UUT\nconfiguration" { class: ce }
system.uut.endpoint_census -> system.uut.continuity_matrix: "[CE] Required endpoint\nchecklist" { class: ce }
system.uut.endpoint_census -> system.uut.testpoint_access: "[CE] Required testpoint\nchecklist" { class: ce }
system.uut.mating_record -> system.uut.continuity_matrix: "[CE] Pre-power seating\nstatus" { class: ce }
system.uut.continuity_matrix -> system.uut.safe_power_state: "[CE] Power-enable\npermission or inhibit" { class: ce }
system.uut.safe_power_state -> system.uut.rail_record: "[CE] Safe power applied\nor no-load condition" { class: ce }
system.uut.rail_record -> system.uut.evidence_gate: "[CE] Guard-banded\nrail results" { class: ce }
system.uut.testpoint_access -> system.uut.evidence_gate: "[CE] Reachability\nresult" { class: ce }
system.uut.fast_line_access -> system.uut.evidence_gate: "[CE] Probe-access /\nanalysis-dependency result" { class: ce }
system.uut.continuity_matrix -> system.uut.evidence_gate: "[CE] Short/open/swap\nstatus" { class: ce }
system.uut.mating_record -> system.uut.evidence_gate: "[CE] Alignment/no-force\nstatus" { class: ce }
system.uut.anomaly_record -> system.uut.evidence_gate: "[CE] Open or closed\ndisposition" { class: ce }
system.uut.evidence_package -> system.uut.evidence_gate: "[CE] Evidence\ncompleteness status" { class: ce }
system.uut.evidence_gate -> repo: "[CE] Released report-by-reference\npackage" { class: ce }
system.uut.anomaly_record -> repo: "[CE] Anomaly, rework,\nwaiver, re-run evidence" { class: ce }

system.verification_scope -> system.uut.config_record { class: cstr }
system.pass_fail -> system.uut.evidence_gate { class: cstr }
system.pass_fail -> system.uut.rail_record { class: cstr }
system.pass_fail -> system.uut.continuity_matrix { class: cstr }
system.pass_fail -> system.uut.testpoint_access { class: cstr }
system.statistical -> system.uut.endpoint_census { class: cstr }
system.fault_hardening -> system.uut.anomaly_record { class: cstr }
system.fault_hardening -> system.uut.evidence_gate { class: cstr }
system.traceability -> system.uut.evidence_gate { class: cstr }

# Layout-only edges keep actors, evidence sources, UUT records, and notes in a readable order.
operator -> witness { style: { opacity: 0 } }
witness -> fixture { style: { opacity: 0 } }
fixture -> supply { style: { opacity: 0 } }
supply -> safe_load { style: { opacity: 0 } }
safe_load -> dmm_daq { style: { opacity: 0 } }
dmm_daq -> continuity { style: { opacity: 0 } }
continuity -> scope_la { style: { opacity: 0 } }
scope_la -> tp_probes { style: { opacity: 0 } }
tp_probes -> netlist_pkg { style: { opacity: 0 } }
netlist_pkg -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> camera { style: { opacity: 0 } }
camera -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.uut.config_record -> system.uut.mating_record { style: { opacity: 0 } }
system.uut.mating_record -> system.uut.endpoint_census { style: { opacity: 0 } }
system.uut.endpoint_census -> system.uut.continuity_matrix { style: { opacity: 0 } }
system.uut.continuity_matrix -> system.uut.safe_power_state { style: { opacity: 0 } }
system.uut.safe_power_state -> system.uut.rail_record { style: { opacity: 0 } }
system.uut.rail_record -> system.uut.testpoint_access { style: { opacity: 0 } }
system.uut.testpoint_access -> system.uut.fast_line_access { style: { opacity: 0 } }
system.uut.fast_line_access -> system.uut.anomaly_record { style: { opacity: 0 } }
system.uut.anomaly_record -> system.uut.evidence_package { style: { opacity: 0 } }
system.uut.evidence_package -> system.uut.evidence_gate { style: { opacity: 0 } }
system.uut -> system.verification_scope { style: { opacity: 0 } }
system.verification_scope -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.traceability { style: { opacity: 0 } }
