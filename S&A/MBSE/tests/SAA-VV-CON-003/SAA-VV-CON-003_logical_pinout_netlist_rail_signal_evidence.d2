vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-CON-003 verification-only Physical Architecture PV2.
# Logical/interface view for pinout, netlist, rail, testpoint, ERC/DRC, and low-capacitance signal evidence.
# References cited in the rendered system title: IVV, SAA-R4, SAA-R5.
# These logical components and component exchanges define verification evidence flow only; they are not baseline S&A design exchanges.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
design_reviewer: "[EA] PCB Design Reviewer" { class: ea }
witness: "[EA] QA Witness" { class: ea }
model_baseline: "[EA] Baseline D2 Copies\nv0.1 and v1.0" { class: ea }
cad_package: "[EA] Released PCB CAD /\nGerber / Stackup Package" { class: ea }
pinout_netlist: "[EA] Released Pinout /\nNetlist / BOM Evidence" { class: ea }
erc_drc_tool: "[EA] ERC / DRC Tool\nReports" { class: ea }
instruments: "[EA] Measurement Instruments\nDMM, DAQ, continuity,\nscope / C meter" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-CON-003" { class: ea }

system: "[System] SAA-VV-CON-003 Logical Pinout / Netlist / Rail / Signal\nEvidence\nRefs: IVV; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  verification_boundary: "[PC] S&A Backplane Constraint\nVerification Boundary\nv0.1 readiness + v1.0\nacceptance" {
    class: pc
    direction: down

    baseline_scope: "[LC] Baseline and Version\nSelection Record\nverification-only" { class: lc }
    allocation_geometry: "[LC] v0.1 Allocation and\nv1.0 Geometry / Stackup\nEvidence\nverification-only" { class: lc }
    header_pinout: "[LC] 2 mm 2×6 Header\nPin Interface Matrix\nADS / AMS / OBCC / PDS\nverification-only" { class: lc }
    servo_connector: "[LC] PDM Servo Connector\nEndpoint Matrix\nverification-only" { class: lc }
    netlist_quality: "[LC] Netlist Consistency /\nERC / DRC Disposition\nverification-only" { class: lc }
    continuity_matrix: "[LC] Continuity / Isolation\nMatrix for Every Released\nBackplane Board\nverification-only" { class: lc }
    rail_contract: "[LC] 5 V / 3.3 V Rail\nMeasurement Contract\nverification-only" { class: lc }
    testpoint_contract: "[LC] Required Testpoint\nPresence and Reachability\nRecord\nverification-only" { class: lc }
    fast_line_record: "[LC] Low-capacitance\nSPI / I2C / UART Evidence\nverification-only" { class: lc }
    anomaly_record: "[LC] Anomaly / Waiver /\nRework Disposition\nverification-only" { class: lc }
    acceptance_gate: "[LC] Backplane Constraint\nAcceptance Gate\nverification-only" { class: lc }
    evidence_package: "[LC] Report-by-reference\nEvidence Package\nverification-only" { class: lc }
  }

  verification_scope: "[C] Verification-only scope:\nThese CEs carry model-selection, design-review, instrument\nand evidence data for\nSAA-VV-CON-003. They do not create baseline S&A component\nexchanges. Missing\nbaseline CE ownership is recorded as a controlled\ndependency or model update need." {
    class: note
    shape: page
  }

  pass_fail: "[C] Pass/fail evidence required:\nv0.1 allocation supports perpendicular 100 mm × 28 mm\nbackplane; v1.0 PCB is\n100 mm × 28 mm and two-layer; 2 mm 2×6 header pinout and\nPDM servo endpoint\nmatrices match released netlist/model; ERC/DRC are clean\nor dispositioned;\n5.0 ±0.1 V and 3.3 ±0.1 V rail records pass; required\ntestpoints are present,\nreachable and mapped; low-capacitance SPI/I2C/UART\nevidence is accepted." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\n100% DRC/ERC/netlist/pinout/testpoint review for the\nreleased design package and\n100% continuity/isolation on every released backplane\nboard. Rail readings are\ncontrolled measurements. This activity makes no population\nreliability claim." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nRecords explicitly screen wrong header pitch, swapped\npinout, missing or\nunreachable testpoint, rail short/open/drop, unowned extra\nnet, PDM servo\nmiswire, excessive I2C capacitance/rise time, SPI/UART\nloading concern, and\nundispositioned ERC/DRC warning." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nModeled Backplane allowance / Backplane PCB constraints;\nSAA-UC-BackplaneIntegration; SAA-FE-BackplaneMisMate." {
    class: note
    shape: page
  }
}

operator -> system.verification_boundary.baseline_scope: "[CE] Gate selection,\narticle ID, execution\ncontext" { class: ce }
model_baseline -> system.verification_boundary.baseline_scope: "[CE] Frozen v0.1/v1.0\nD2 baseline copies" { class: ce }
cad_package -> system.verification_boundary.allocation_geometry: "[CE] Board outline,\nstackup, placement\ndrawings" { class: ce }
cad_package -> system.verification_boundary.fast_line_record: "[CE] Layout/routing,\ntrace length, capacitance\ndata" { class: ce }
pinout_netlist -> system.verification_boundary.header_pinout: "[CE] ADS/AMS/OBCC/PDS\npinout and net names" { class: ce }
pinout_netlist -> system.verification_boundary.servo_connector: "[CE] PDM servo connector\nendpoint names" { class: ce }
pinout_netlist -> system.verification_boundary.netlist_quality: "[CE] Netlist cross-check\nand extra-net list" { class: ce }
erc_drc_tool -> system.verification_boundary.netlist_quality: "[CE] ERC/DRC clean report\nor warning dispositions" { class: ce }
instruments -> system.verification_boundary.continuity_matrix: "[CE] Continuity/isolation\nresults for every board" { class: ce }
instruments -> system.verification_boundary.rail_contract: "[CE] 5 V / 3.3 V readings,\ncalibration and load state" { class: ce }
instruments -> system.verification_boundary.testpoint_contract: "[CE] Testpoint probe\nreachability observations" { class: ce }
instruments -> system.verification_boundary.fast_line_record: "[CE]\nScope/capacitance/rise-time\nobservations when measured" { class: ce }
design_reviewer -> system.verification_boundary.anomaly_record: "[CE] Review comments,\nwaivers, rework rationale" { class: ce }
witness -> system.verification_boundary.acceptance_gate: "[CE] Witness decision,\npass/fail/hold" { class: ce }

system.verification_boundary.baseline_scope -> system.verification_boundary.allocation_geometry: "[CE] Applicable v0.1/v1.0\nconstraints" { class: ce }
system.verification_boundary.allocation_geometry -> system.verification_boundary.header_pinout: "[CE] Placement and\nconnector\nconstraints" { class: ce }
system.verification_boundary.header_pinout -> system.verification_boundary.netlist_quality: "[CE] Expected endpoints\nand\nnet names" { class: ce }
system.verification_boundary.servo_connector -> system.verification_boundary.netlist_quality: "[CE] Servo endpoint\nexpectations" { class: ce }
system.verification_boundary.netlist_quality -> system.verification_boundary.continuity_matrix: "[CE] Released endpoint\nchecklist" { class: ce }
system.verification_boundary.netlist_quality -> system.verification_boundary.rail_contract: "[CE] Rail net and\ntestpoint\nchecklist" { class: ce }
system.verification_boundary.netlist_quality -> system.verification_boundary.testpoint_contract: "[CE] Required testpoint\nchecklist" { class: ce }
system.verification_boundary.netlist_quality -> system.verification_boundary.fast_line_record: "[CE] Critical SPI/I2C/UART\nnet list" { class: ce }
system.verification_boundary.continuity_matrix -> system.verification_boundary.acceptance_gate: "[CE] Short/open/swap\nstatus" { class: ce }
system.verification_boundary.rail_contract -> system.verification_boundary.acceptance_gate: "[CE] Guard-banded rail\nstatus" { class: ce }
system.verification_boundary.testpoint_contract -> system.verification_boundary.acceptance_gate: "[CE] Testpoint presence /\nreachability status" { class: ce }
system.verification_boundary.fast_line_record -> system.verification_boundary.acceptance_gate: "[CE] Low-capacitance /\nrise-time status" { class: ce }
system.verification_boundary.anomaly_record -> system.verification_boundary.acceptance_gate: "[CE] Open/closed\nanomaly disposition" { class: ce }
system.verification_boundary.acceptance_gate -> system.verification_boundary.evidence_package: "[CE] Accepted or held\nreport package" { class: ce }
system.verification_boundary.evidence_package -> repo: "[CE] Released\nreport-by-reference\npackage" { class: ce }
system.verification_boundary.anomaly_record -> repo: "[CE] Waiver, rework,\nre-run evidence" { class: ce }

system.verification_scope -> system.verification_boundary.baseline_scope { class: cstr }
system.pass_fail -> system.verification_boundary.acceptance_gate { class: cstr }
system.pass_fail -> system.verification_boundary.netlist_quality { class: cstr }
system.pass_fail -> system.verification_boundary.rail_contract { class: cstr }
system.pass_fail -> system.verification_boundary.fast_line_record { class: cstr }
system.statistical -> system.verification_boundary.continuity_matrix { class: cstr }
system.statistical -> system.verification_boundary.netlist_quality { class: cstr }
system.fault_hardening -> system.verification_boundary.anomaly_record { class: cstr }
system.fault_hardening -> system.verification_boundary.acceptance_gate { class: cstr }
system.traceability -> system.verification_boundary.acceptance_gate { class: cstr }

# Layout-only edges keep sources, records, acceptance gate and notes readable.
operator -> design_reviewer { style: { opacity: 0 } }
design_reviewer -> witness { style: { opacity: 0 } }
witness -> model_baseline { style: { opacity: 0 } }
model_baseline -> cad_package { style: { opacity: 0 } }
cad_package -> pinout_netlist { style: { opacity: 0 } }
pinout_netlist -> erc_drc_tool { style: { opacity: 0 } }
erc_drc_tool -> instruments { style: { opacity: 0 } }
instruments -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.verification_boundary.baseline_scope -> system.verification_boundary.allocation_geometry { style: { opacity: 0 } }
system.verification_boundary.allocation_geometry -> system.verification_boundary.header_pinout { style: { opacity: 0 } }
system.verification_boundary.header_pinout -> system.verification_boundary.servo_connector { style: { opacity: 0 } }
system.verification_boundary.servo_connector -> system.verification_boundary.netlist_quality { style: { opacity: 0 } }
system.verification_boundary.netlist_quality -> system.verification_boundary.continuity_matrix { style: { opacity: 0 } }
system.verification_boundary.continuity_matrix -> system.verification_boundary.rail_contract { style: { opacity: 0 } }
system.verification_boundary.rail_contract -> system.verification_boundary.testpoint_contract { style: { opacity: 0 } }
system.verification_boundary.testpoint_contract -> system.verification_boundary.fast_line_record { style: { opacity: 0 } }
system.verification_boundary.fast_line_record -> system.verification_boundary.anomaly_record { style: { opacity: 0 } }
system.verification_boundary.anomaly_record -> system.verification_boundary.acceptance_gate { style: { opacity: 0 } }
system.verification_boundary.acceptance_gate -> system.verification_boundary.evidence_package { style: { opacity: 0 } }
system.verification_boundary -> system.verification_scope { style: { opacity: 0 } }
system.verification_scope -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.traceability { style: { opacity: 0 } }
