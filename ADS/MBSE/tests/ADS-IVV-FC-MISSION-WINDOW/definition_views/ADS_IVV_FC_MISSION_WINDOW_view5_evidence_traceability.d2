vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Evidence and traceability view for ADS-IVV-FC-MISSION-WINDOW.
# Ensures execution reports reference modeled views, source baselines, constraints, and traceability targets.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

ivv_reviewer: "[EA] IVV authority /\nreviewer" { class: ea }
reference_corpus: "[EA] Reference corpus\nIVV; NASA-SE; GEVS; ESA-CANSAT; SW/stats" { class: ea }
configuration_source: "[EA] Configuration source\nfirmware repo, BOM, build record" { class: ea }
results_repository: "[EA] Results repository\ntests/results/ADS-IVV-FC-MISSION-WINDOW" { class: ea }

system: "[System] ADS-IVV-FC-MISSION-WINDOW\nEvidence and traceability view\nRefs: IVV; NASA-SE; GEVS; ESA-CANSAT; SW/stats; ADS MBSE plan" {
  class: sys
  direction: down

  record_pkg: "[PC] Mission-window verification\nrecord package" {
    class: pc
    direction: down
    grid-columns: 2

    trace_matrix: "[LC] Traceability matrix" {
      class: lc
      direction: down
      map_sources: "[F] Map source views,\nversions, chains, constraints" { class: func }
      map_targets: "[F] Map mission, capabilities,\nfeared events, N/A branch" { class: func }
    }

    evidence_record: "[LC] Raw evidence record" {
      class: lc
      direction: down
      store_ads_logs: "[F] Store Serial0 or\nOBCC ADS records" { class: func }
      store_truth_logs: "[F] Store truth/stimulus,\ntimer, power, ambient logs" { class: func }
    }

    analysis_record: "[LC] Analysis record" {
      class: lc
      direction: down
      store_coverage: "[F] Store field presence,\ntime-correlation analysis" { class: func }
      store_cadence_faults: "[F] Store cycle/frame, gap,\nreset and fault analysis" { class: func }
    }

    disposition_record: "[LC] Result and disposition" {
      class: lc
      direction: down
      store_verdict: "[F] Store pass/fail,\nN/A, or BLOCKED verdict" { class: func }
      store_limits: "[F] Store deviations, anomalies,\nwaivers, assumptions, retest" { class: func }
    }
  }
}

c_targets: "[C] Traceability targets\nADS-MSN-CANSAT-DESCENT; ADS-CAP-GPS, ADS-CAP-IMU,\nADS-CAP-ATT, ADS-CAP-INIT, ADS-CAP-DELIVERY;\nfeared events ADS-FE-SILENT-SENSOR-FAIL,\nADS-FE-STUCK-LOOP, ADS-FE-CORRUPT-MEASUREMENT.\nv0.3 N/A also references ADS-CAP-PCB/DELIVERY." { class: note; shape: page }
c_reports: "[C] Report rule\nReports reference this modeled definition and record selected SSIV/version,\nas-tested configuration, actual conditions, raw evidence, analysis settings,\npass/fail rationale, deviations, anomalies, waivers, limitations, and retest." { class: note; shape: page }
c_expected_locations: "[C] Expected report locations\n../results/ADS-IVV-FC-MISSION-WINDOW/v0.1/\n../results/ADS-IVV-FC-MISSION-WINDOW/v0.2/\n../results/ADS-IVV-FC-MISSION-WINDOW/v0.3/\n../results/ADS-IVV-FC-MISSION-WINDOW/v1.0/" { class: note; shape: page }
c_blocked: "[C] Selected mission-window evidence gate\nProject mission duration is 10 min / 600 s and maximum internal\nprogress/freshness gap is 400 ms. Reports must bind actual duration,\n3000 expected 5 Hz opportunities or measured equivalent, and deviations." { class: note; shape: page }

reference_corpus -> system { class: ce }
configuration_source -> system { class: ce }
system.record_pkg.trace_matrix -> system.record_pkg.disposition_record { class: ce }
system.record_pkg.evidence_record -> system.record_pkg.analysis_record { class: ce }
system.record_pkg.analysis_record -> system.record_pkg.disposition_record { class: ce }
ivv_reviewer -> system { class: ce }
system.record_pkg.disposition_record -> results_repository { class: ce }

c_targets -> system.record_pkg.trace_matrix { class: cstr }
c_reports -> system.record_pkg.disposition_record { class: cstr }
c_expected_locations -> results_repository { class: cstr }
c_blocked -> system.record_pkg.disposition_record { class: cstr }

# Layout-only rank hints to keep the traceability package readable top-to-bottom.
ivv_reviewer -> reference_corpus { style: { opacity: 0 } }
reference_corpus -> configuration_source { style: { opacity: 0 } }
configuration_source -> system { style: { opacity: 0 } }
system -> c_targets { style: { opacity: 0 } }
c_targets -> c_reports { style: { opacity: 0 } }
c_reports -> c_expected_locations { style: { opacity: 0 } }
c_expected_locations -> c_blocked { style: { opacity: 0 } }
c_blocked -> results_repository { style: { opacity: 0 } }
