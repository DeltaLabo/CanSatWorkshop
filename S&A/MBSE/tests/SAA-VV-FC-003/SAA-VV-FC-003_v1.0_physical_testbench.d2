vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-003 verification-only Physical Architecture PV1.
# v1.0 parachute/top-module clearance and deployment-interference demonstration/testing testbench.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# This file is a test-definition view and does not modify the v1.0 baseline model.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
witness: "[EA] Safety / QA Witness" { class: ea }
pack_fixture: "[EA] Parachute Pack /\nReset Fixture\nrepeatable fold + service tool" { class: ea }
servo_interface: "[EA] Servo Command Interface /\nManual Actuation Tool\nopen-cap command source" { class: ea }
camera: "[EA] High-speed / Video Camera\nwith evidence lighting" { class: ea }
clearance_gauge: "[EA] Clearance Gauge /\nSnag Witness Markers\ncap path + backplane keep-out" { class: ea }
inspection_kit: "[EA] Pre/Post PC-PL\nInspection Kit\ntorque stripe + movement gauge" { class: ea }
env_screen_record: "[EA] Vibration / Drop\nScreen Record\npre/post condition input" { class: ea }
ambient_meter: "[EA] Ambient Thermo-\nHygrometer" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-FC-003" { class: ea }

system: "[System] SAA-VV-FC-003 v1.0 Parachute / Top-Module Clearance and Deployment-Interference Testbench\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  cansat: "[PC] v1.0 CanSat Assembly\nUUT for deployment clearance" {
    class: pc
    direction: right

    standard_stack: "[PC] Standard Carrier\nModule Stack\n(Type 1)" {
      class: pc
      direction: down

      ads_module: "[PC] ADS Module" {
        class: pc
        direction: right
        ads_pcb: "[PC] ADS PCB\n44 mm × 44 mm" { class: pc }
      }

      ams_module: "[PC] AMS Module" {
        class: pc
        direction: right
        ams_pcb: "[PC] AMS PCB\n44 mm × 44 mm" { class: pc }
      }

      obcc_module: "[PC] OBCC Module" {
        class: pc
        direction: right
        obcc_pcb: "[PC] OBCC PCB\n44 mm × 44 mm" { class: pc }
      }

      pds_module: "[PC] PDS Module" {
        class: pc
        direction: right
        pds_pcb: "[PC] PDS PCB\n44 mm × 44 mm" { class: pc }
      }

      ess_module: "[PC] ESS Module" {
        class: pc
        direction: right
        battery_pack: "[PC] ESS Battery Pack" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB\n100 mm × 28 mm\n2-layer stackup" {
      class: pc
      direction: down
      grid-columns: 1

      ads_headers: "[PC] 2 mm 2×6\nADS Headers" { class: pc }
      ams_headers: "[PC] 2 mm 2×6\nAMS Headers" { class: pc }
      obcc_headers: "[PC] 2 mm 2×6\nOBCC Headers" { class: pc }
      pds_headers: "[PC] 2 mm 2×6\nPDS Headers" { class: pc }
      pdm_servo_header: "[PC] PDM Servo\nConnector" { class: pc }
      spine: "[PC] Backplane Spine" { class: pc }
      keepout_marker: "[PC] Verification Keep-Out\nWitness Marker\nfor cap/servo clearance\nverification-only" { class: pc }
    }

    parachute_module: "[PC] Parachute / Top\nModule\n(Type 2)" {
      class: pc
      direction: down

      cap: "[PC] Cap" { class: pc }
      parachute: "[PC] Parachute" { class: pc }
      servo: "[PC] Servo" { class: pc }
      pack_marker: "[PC] Verification Pack /\nRub Witness Marker\nverification-only" { class: pc }
    }
  }

  deployment_constraint: "[C] Deployment pass/fail: For every accepted trial the\ncap and servo motion clear the top-module structure,\nstandard stack, backplane spine and PDM servo connector;\nthe parachute extracts without snagging, hang-up,\ndragging a module, or requiring hand assistance." {
    class: note
    shape: page
  }

  retention_constraint: "[C] Retention/serviceability pass/fail: Before and after\nrepeated deployments, and after any referenced\nvibration/drop screen, stack screws, top-module\nattachment, backplane fixture, PDM servo connector, PCB\nstandoffs, battery fixture and modules remain secure.\nReset/packing returns the article to a serviceable\nclosed state without unapproved rework or permanent\ndeformation." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint: Workshop screen\n= 10 repeated deployments with identical acceptance\ncriteria and all zero-snag passes required. Claim\nR90/C95 only with 29 representative independent\nzero-snag trials and controlled pack/reset variability.\nCount any snag, rub causing movement, no-release,\nambiguous video, or uncommanded movement as a\nfailure/hold." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint: Explicitly screen cap\nrub, servo travel loss, packed-parachute variability,\ninterference with backplane spine or PDM servo\nconnector, loose stack/top-module links after vibration\nor drop screens, and evidence-control escape. Do not\nforce deployment through a snag." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental / equipment conditions: Record ambient\ntemperature/humidity, article configuration, pack/reset\nfixture setting, servo command/manual actuation method,\nlighting/FOV, camera frame rate, gauge IDs, witness\nidentity and pre/post screen status before repetitions\nbegin." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability targets: SAA-UC-ParachuteClearance;\nSAA-FE-StructuralLoosening; SAA-FE-LandingDamage; v1.0\nphysical links for stack screws, backplane fixture +\nservo connector; modeled envelope, landing-impact and\nassembly/printing constraints." {
    class: note
    shape: page
  }
}

system.cansat.standard_stack.ads_module -- system.cansat.standard_stack.ams_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.ams_module -- system.cansat.standard_stack.obcc_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.obcc_module -- system.cansat.standard_stack.pds_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.pds_module -- system.cansat.standard_stack.ess_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack -- system.cansat.parachute_module: "[PL] Stack screws" { class: pl }

system.cansat.standard_stack -- system.cansat.backplane_pcb: "[PL] Perpendicular fixture\n+ header mating" { class: pl }
system.cansat.parachute_module -- system.cansat.backplane_pcb: "[PL] Backplane fixture\n+ servo connector" { class: pl }

system.cansat.standard_stack.ads_module.ads_pcb -- system.cansat.standard_stack.ads_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.ams_module.ams_pcb -- system.cansat.standard_stack.ams_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.obcc_module.obcc_pcb -- system.cansat.standard_stack.obcc_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.pds_module.pds_pcb -- system.cansat.standard_stack.pds_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.ess_module.battery_pack -- system.cansat.standard_stack.ess_module: "[PL] Battery fixture" { class: pl }

operator -- system.cansat.parachute_module: "[PL] Manual pack/reset\nand safety handling" { class: pl }
witness -- system.cansat: "[PL] Witness line-of-sight\nand exclusion control" { class: pl }
pack_fixture -- system.cansat.parachute_module.parachute: "[PL] Repeatable pack /\nreset contact" { class: pl }
pack_fixture -- system.cansat.parachute_module.cap: "[PL] Closed-state\nreset contact" { class: pl }
servo_interface -- system.cansat.parachute_module.servo: "[PL] Servo command /\nmanual actuation coupling" { class: pl }
servo_interface -- system.cansat.backplane_pcb.pdm_servo_header: "[PL] PDM servo\nconnector interface" { class: pl }
camera -- system.cansat.parachute_module: "[PL] High-speed optical\nmotion evidence" { class: pl }
clearance_gauge -- system.cansat.parachute_module.cap: "[PL] Cap-path gauge /\nrub witness" { class: pl }
clearance_gauge -- system.cansat.backplane_pcb.keepout_marker: "[PL] Backplane / connector\nkeep-out witness" { class: pl }
inspection_kit -- system.cansat.standard_stack: "[PL] Pre/post stack\nmovement check" { class: pl }
inspection_kit -- system.cansat.backplane_pcb: "[PL] Pre/post backplane\nand connector movement check" { class: pl }
inspection_kit -- system.cansat.parachute_module: "[PL] Pre/post top-module\nretention check" { class: pl }
env_screen_record -- system.cansat: "[PL] Post vibration/drop\ncondition reference" { class: pl }
ambient_meter -- system.cansat: "[PL] Shared ambient\nmeasurement field" { class: pl }
repo -- camera: "[PL] Video / photo\nmedia transfer path" { class: pl }
repo -- servo_interface: "[PL] Command log\ntransfer path" { class: pl }

system.deployment_constraint -> system.cansat.parachute_module.cap { class: cstr }
system.deployment_constraint -> system.cansat.parachute_module.servo { class: cstr }
system.deployment_constraint -> system.cansat.parachute_module.parachute { class: cstr }
system.deployment_constraint -> system.cansat.backplane_pcb.pdm_servo_header { class: cstr }
system.retention_constraint -> system.cansat.standard_stack { class: cstr }
system.retention_constraint -> system.cansat.backplane_pcb { class: cstr }
system.retention_constraint -> system.cansat.parachute_module { class: cstr }
system.statistical -> system.cansat.parachute_module.parachute { class: cstr }
system.fault_hardening -> system.cansat.backplane_pcb.keepout_marker { class: cstr }
system.fault_hardening -> system.cansat.parachute_module.pack_marker { class: cstr }
system.conditions -> ambient_meter { class: cstr }
system.conditions -> camera { class: cstr }
system.traceability -> system.cansat.parachute_module { class: cstr }

# Layout-only edges keep the test equipment, UUT, repository, and notes in a stable reading order.
operator -> witness { style: { opacity: 0 } }
witness -> pack_fixture { style: { opacity: 0 } }
pack_fixture -> servo_interface { style: { opacity: 0 } }
servo_interface -> camera { style: { opacity: 0 } }
camera -> clearance_gauge { style: { opacity: 0 } }
clearance_gauge -> inspection_kit { style: { opacity: 0 } }
inspection_kit -> env_screen_record { style: { opacity: 0 } }
env_screen_record -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.cansat -> system.deployment_constraint { style: { opacity: 0 } }
system.deployment_constraint -> system.retention_constraint { style: { opacity: 0 } }
system.retention_constraint -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.conditions { style: { opacity: 0 } }
system.conditions -> system.traceability { style: { opacity: 0 } }
