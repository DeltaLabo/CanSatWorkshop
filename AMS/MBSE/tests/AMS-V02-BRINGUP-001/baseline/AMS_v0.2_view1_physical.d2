vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view
# AMS v0.2 only delivers the AMS PCB and the physical components inside it.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS v0.2 PCB Delivery" {
  class: sys
  direction: right

  ams_pcb: "[PC] AMS PCB" {
    class: pc
    direction: down

    bme280: "[PC] BME280" { class: pc }
    ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
  }
}

note_manufacturing: "[C] Can be manufactured\nin a Carvera Air CNC,\nand soldered via reflux\nor manually" {
  class: note
  shape: page
}

system.ams_pcb.bme280 -- system.ams_pcb: "[PL] BME280\nFootprint" { class: pl }
system.ams_pcb.ams_backplane_connector -- system.ams_pcb: "[PL] Connector\nfootprint" { class: pl }
system.ams_pcb.bme280 -- system.ams_pcb.ams_backplane_connector: "[PL] I2C + 3V3\ntraces" { class: pl }

note_manufacturing -> system.ams_pcb { class: cstr }
