vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view — AMS-VV-FC-002 peripheral initialisation testbench
# Verification references: IVV, AMS-R1 (BME280), AMS-R2 (I2C), AMS-R5 (statistics).
# IADT: Testing / Demonstration. Traceability: AMS-UC-InitializePeripheral,
# AMS-FE-SensorBusFault, AMS-FE-StartupFault, variable-getter/I2C-timeout/no-blocking constraints.
# Preserve the original PA hierarchy and add VV-only external test means.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-FC-002 Peripheral initialisation\nFinal acceptance; Refs: IVV, AMS-R1, AMS-R2, AMS-R5" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: right

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down

        bme280: "[PC] BME280" { class: pc }
        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      grid-columns: 1

      ams_headers: "[PC] 2mm 2x6 AMS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down

        xiao: "[PC] XIAO ESP32-S3" { class: pc }
        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }
  }
}

host_pc_logger: "[EA] Host PC /\nBoot Logger" { class: ea }
power_cycle_fixture: "[EA] Bench Power /\nPower-Cycle Fixture" { class: ea }
fault_fixture: "[EA] I2C Fault /\nBME280 Disconnect Fixture" { class: ea }
ambient_thermometer: "[EA] Ambient Thermometer\n/ Logger" { class: ea }

note_airflow: "[C] Block sunlight,\nallow airflow" {
  class: note
  shape: page
}
note_testbench: "[C] VV-only bench links shall not bypass the\nmodeled BME280-to-XIAO I2C path; record\nfixture pullups, bus capacitance, and disconnect mode" {
  class: note
  shape: page
}
note_power_env: "[C] Stable 3V3/common ground and controlled\npower-cycle/reset stimulus required; record\nvoltage/current and ambient 20-30 °C before repetitions" {
  class: note
  shape: page
}
note_scope: "[C] Physical testbench supports nominal boot\nand startup-fault trials only; detailed environmental-read\ntimeout proof remains AMS-VV-CON-003" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb -- system.cansat.ams_module: "[PL] Screws" { class: pl }
system.cansat.obcc_module.obcc_pcb -- system.cansat.obcc_module: "[PL] Screws" { class: pl }

system.cansat.ams_module -- system.cansat.backplane_pcb: "[PL] Backplane\nFixture" { class: pl }
system.cansat.obcc_module -- system.cansat.backplane_pcb: "[PL] Backplane\nFixture" { class: pl }

system.cansat.ams_module.ams_pcb.bme280 -- system.cansat.ams_module.ams_pcb: "[PL] BME280\nFootprint" { class: pl }
system.cansat.ams_module.ams_pcb.ams_backplane_connector -- system.cansat.ams_module.ams_pcb: "[PL] Connector\nfootprint" { class: pl }
system.cansat.ams_module.ams_pcb.bme280 -- system.cansat.ams_module.ams_pcb.ams_backplane_connector: "[PL] I2C + 3V3\ntraces" { class: pl }
system.cansat.ams_module.ams_pcb.ams_backplane_connector -- system.cansat.backplane_pcb.ams_headers: "[PL] Parallel\nConnector" { class: pl }

system.cansat.obcc_module.obcc_pcb.xiao -- system.cansat.obcc_module.obcc_pcb: "[PL] XIAO\nFootprint" { class: pl }
system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector -- system.cansat.obcc_module.obcc_pcb: "[PL] Connector\nfootprint" { class: pl }
system.cansat.obcc_module.obcc_pcb.xiao -- system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] I2C + 3V3\ntraces" { class: pl }
system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector -- system.cansat.backplane_pcb.obcc_headers: "[PL] Parallel\nCable" { class: pl }

system.cansat.backplane_pcb.ams_headers -- system.cansat.backplane_pcb.spine: "[PL] Footprint" { class: pl }
system.cansat.backplane_pcb.obcc_headers -- system.cansat.backplane_pcb.spine: "[PL] Footprint" { class: pl }

host_pc_logger -- system.cansat.obcc_module: "[PL] USB/UART\nboot log" { class: pl }
power_cycle_fixture -- system.cansat.backplane_pcb: "[PL] 3V3/GND +\nreset control" { class: pl }
fault_fixture -- system.cansat.ams_module: "[PL] I2C inline\ndisconnect / pull-down" { class: pl }
ambient_thermometer -- system.cansat.ams_module: "[PL] Bench ambient\nprobe nearby" { class: pl }

note_airflow -> system.cansat.ams_module { class: cstr }
note_testbench -> fault_fixture { class: cstr }
note_testbench -> system.cansat.ams_module.ams_pcb.bme280 { class: cstr }
note_power_env -> power_cycle_fixture { class: cstr }
note_power_env -> ambient_thermometer { class: cstr }
note_scope -> host_pc_logger { class: cstr }
