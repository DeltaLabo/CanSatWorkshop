// Getters
// ─────────────────────────────────────────────

/**
 * @brief Returns current latitude multiplied by 1,000,000
 *        to preserve 6 decimal places.
 * @param output 32-bit integer address to save the measurement to.
 * @return result Byte containing the result of the get operation.
 *               0: Success
 *               1: Overflow
 *               2: Underflow
 */
unsigned short getLatitude(long* output) {
  acquireGPSData();

  double multipliedLatitude = gps.location.lat() * 1000000.0;

  if (multipliedLatitude > INT32_MAX) {
    *output = INT32_MAX;
    return 1;
  } else if (multipliedLatitude < -(INT32_MAX + 1)) {
    *output = -(INT32_MAX + 1);
    return 2;
  } else {jjjjjjjjjjjjjjjjjjjjj
    *output = (long)multipliedLatitude;
    return 0;
  }
}

