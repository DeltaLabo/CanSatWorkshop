vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PV1 — PDS-VV-FC-002 physical testbench for PDS & ESS v1.0 battery supervision.
# References: IVV, PDS-R9 INA219, PDS-R10 I2C. Source v1.0 views are copied in baseline/.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

test_operator: "[EA] Test Operator" { class: ea }
host_pc: "[EA] Host PC /\nserial logger" { class: ea }
logic_analyzer: "[EA] I2C /\nlogic analyzer" { class: ea }
fault_harness: "[EA] I2C fault\ninjection harness" { class: ea }
battery_emulator: "[EA] Battery emulator /\nsource-load" { class: ea }
dmm_reference: "[EA] Precision DMM /\ncurrent reference" { class: ea }
ambient_meter: "[EA] Ambient thermometer /\nhygrometer" { class: ea }
evidence_repository: "[EA] Evidence\nrepository" { class: ea }

system: "[System] PDS-VV-FC-002 battery-supervision physical testbench\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R9; PDS-R10" {
  class: sys
  direction: down
  grid-columns: 2

  uut: "[PC] CanSat UUT\nPDS & ESS v1.0" {
    class: pc
    direction: down

    ess_module: "[PC] ESS Module" {
      class: pc
      direction: down
      battery_pack: "[PC] 1S1P Li-Ion" { class: pc }
    }

    pds_module: "[PC] PDS Module" {
      class: pc
      direction: down

      pds_pcb: "[PC] PDS PCB" {
        class: pc
        direction: down

        battery_connector: "[PC] Battery Connector" { class: pc }
        protection: "[PC] Protection Circuit" { class: pc }
        ina219: "[PC] INA219" { class: pc }
        regulator: "[PC] Regulator" { class: pc }
        pds_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        xiao: "[PC] XIAO ESP32-S3" { class: pc }
        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      pds_headers: "[PC] 2mm 2x6 PDS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }
  }

  test_harness: "[PC] PDS-VV-FC-002\nverification test harness" {
    class: pc
    direction: down
    operator_access: "[PC] Safe manual\naccess zone" { class: pc }
    serial_adapter: "[PC] USB/UART\nserial adapter" { class: pc }
    i2c_probe_clip: "[PC] SDA/SCL\nprobe clip" { class: pc }
    i2c_fault_adapter: "[PC] SDA/SCL\nfault adapter" { class: pc }
    battery_fixture: "[PC] Battery-emulator\nfixture leads" { class: pc }
    reference_leads: "[PC] Reference\nsense leads" { class: pc }
    environment_station: "[PC] Ambient\nrecord station" { class: pc }
    log_storage: "[PC] Log export /\nremovable media" { class: pc }
  }

  setup_note: "[C] PDS-VV-FC-002 setup:\nTesting/Demonstration with Analysis;\nSSIV PDS & ESS v1.0 final flight acceptance;\ntrace PDS-UC-SuperviseBattery,\nPDS-FE-SensorBusFault;\nrefs IVV, PDS-R9, PDS-R10" {
    class: note
    shape: page
  }

  env_note: "[C] Before repetitions:\nrecord ambient T/RH,\nstable supply/load,\ninstrument calibration IDs,\nI2C pullups/cable/capacitance proxy" {
    class: note
    shape: page
  }

  gap_note: "[C] Source-model alignment:\nv1.0 baseline includes explicit INA219 I2C CE;\nthis testbench verifies implemented bus evidence,\ntimeout/status mapping, and logs before CE credit" {
    class: note
    shape: page
  }
}

system.uut.ess_module.battery_pack -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] Battery cable" { class: pl }
system.uut.ess_module -- system.uut.backplane_pcb: "[PL] Backplane fixture" { class: pl }
system.uut.pds_module -- system.uut.backplane_pcb: "[PL] Backplane fixture" { class: pl }
system.uut.obcc_module -- system.uut.backplane_pcb: "[PL] Backplane fixture" { class: pl }
system.uut.pds_module.pds_pcb.battery_connector -- system.uut.pds_module.pds_pcb.protection: "[PL] Battery ± traces" { class: pl }
system.uut.pds_module.pds_pcb.protection -- system.uut.pds_module.pds_pcb.ina219: "[PL] PC out trace" { class: pl }
system.uut.pds_module.pds_pcb.ina219 -- system.uut.pds_module.pds_pcb.regulator: "[PL] INA out trace" { class: pl }
system.uut.pds_module.pds_pcb.regulator -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] 5V / 3V3 traces" { class: pl }
system.uut.obcc_module.obcc_pcb.xiao -- system.uut.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] 3V3 / PWM traces" { class: pl }
system.uut.pds_module.pds_pcb.pds_backplane_connector -- system.uut.backplane_pcb.pds_headers: "[PL] Parallel cable" { class: pl }
system.uut.obcc_module.obcc_pcb.obcc_backplane_connector -- system.uut.backplane_pcb.obcc_headers: "[PL] Parallel cable" { class: pl }

test_operator -- system.test_harness.operator_access: "[PL] Manual access /\nsafety controls" { class: pl }
host_pc -- system.test_harness.serial_adapter: "[PL] USB/UART cable" { class: pl }
logic_analyzer -- system.test_harness.i2c_probe_clip: "[PL] Probe pod leads" { class: pl }
fault_harness -- system.test_harness.i2c_fault_adapter: "[PL] Fault injection leads" { class: pl }
battery_emulator -- system.test_harness.battery_fixture: "[PL] Current-limited\nsource/load leads" { class: pl }
dmm_reference -- system.test_harness.reference_leads: "[PL] Kelvin/reference leads" { class: pl }
ambient_meter -- system.test_harness.environment_station: "[PL] Ambient meter link" { class: pl }
evidence_repository -- system.test_harness.log_storage: "[PL] Network/removable\nmedia transfer" { class: pl }

system.test_harness.serial_adapter -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] Serial log /\ncommand cable" { class: pl }
system.test_harness.i2c_probe_clip -- system.uut.pds_module.pds_pcb.ina219: "[PL] SDA/SCL probe clip" { class: pl }
system.test_harness.i2c_probe_clip -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] SDA/SCL probe clip" { class: pl }
system.test_harness.i2c_fault_adapter -- system.uut.pds_module.pds_pcb.ina219: "[PL] Faultable SDA/SCL" { class: pl }
system.test_harness.i2c_fault_adapter -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] Faultable SDA/SCL" { class: pl }
system.test_harness.battery_fixture -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] Emulator battery input" { class: pl }
system.test_harness.reference_leads -- system.uut.pds_module.pds_pcb.ina219: "[PL] Reference V/I sense" { class: pl }
system.test_harness.environment_station -- system.uut: "[PL] Test-cell proximity" { class: pl }
system.test_harness.log_storage -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] Log artifact export" { class: pl }

system.setup_note -> system.uut { class: cstr }
system.setup_note -> system.test_harness { class: cstr }
system.env_note -> system.test_harness.environment_station { class: cstr }
system.env_note -> system.test_harness.battery_fixture { class: cstr }
system.env_note -> system.test_harness.reference_leads { class: cstr }
system.gap_note -> system.uut.pds_module.pds_pcb.ina219 { class: cstr }
system.gap_note -> system.uut.obcc_module.obcc_pcb.xiao { class: cstr }
