vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-002 verification-only Physical Architecture PV3.
# Functional allocation/procedure view for v1.0 backplane mating and rail/testpoint/signal-access checks.
# References cited in the rendered system title: IVV, SAA-R4, SAA-R5.
# Functions and LCs here define the verification activity only; they are not baseline S&A design edits.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" {
  class: ea
  direction: down
  identify_article: "[F] Identify v1.0 article,\nbuild record, baseline copy,\nand test definition" { class: func }
  prepare_esd: "[F] Prepare ESD handling,\nfixture, tools, and ambient record" { class: func }
  mate_backplane: "[F] Mate/demate backplane\nthrough alignment jig without force" { class: func }
  inspect_seating: "[F] Inspect seating, orientation,\nconnector flushness, and bent pins" { class: func }
  configure_load: "[F] Configure safe load or\ndocument no-load condition" { class: func }
  move_probes: "[F] Place probes on required\nrail and signal testpoints" { class: func }
  record_anomaly: "[F] Record anomaly, hold,\nrework, or waiver condition" { class: func }
}

witness: "[EA] QA Witness" {
  class: ea
  direction: down
  witness_setup: "[F] Witness setup, calibration\nIDs, current limits, and no-force condition" { class: func }
  witness_checks: "[F] Witness 100% net/rail/\ntestpoint check completion" { class: func }
  approve_gate: "[F] Approve pass, fail,\nor execution hold" { class: func }
}

fixture: "[EA] Mate / Demate Fixture\nand Alignment Jig" {
  class: ea
  direction: down
  constrain_orientation: "[F] Constrain connector\norientation and seating datum" { class: func }
  support_cycles: "[F] Support repeated mate cycles\nas screening when invoked" { class: func }
}

supply: "[EA] Current-limited\nBench Supply" {
  class: ea
  direction: down
  set_limits: "[F] Set voltage and current\nlimits before rail enable" { class: func }
  apply_safe_power: "[F] Apply and remove\nsafe 5 V / 3.3 V power" { class: func }
}

safe_load: "[EA] Campaign Safe Load\n/ No-load Adapter" {
  class: ea
  direction: down
  present_load: "[F] Present campaign-defined\nsafe load or no-load marker" { class: func }
}

dmm_daq: "[EA] Calibrated DMM / DAQ" {
  class: ea
  direction: down
  measure_5v: "[F] Measure 5.0 V rail\nat required testpoints" { class: func }
  measure_3v3: "[F] Measure 3.3 V rail\nat required testpoints" { class: func }
  log_readings: "[F] Log raw readings,\ncalibration status, and timestamps" { class: func }
}

continuity: "[EA] Continuity / Isolation\nTester" {
  class: ea
  direction: down
  check_nets: "[F] Check 100% required\ncontinuity/isolation endpoints" { class: func }
  detect_swaps: "[F] Detect short, open,\nor swapped endpoint anomaly" { class: func }
}

scope_la: "[EA] Oscilloscope /\nLogic Analyzer" {
  class: ea
  direction: down
  probe_fast_lines: "[F] Probe critical SPI/I2C/UART\naccess with low-capacitance probes" { class: func }
  record_dependency: "[F] Record rise-time or\ncapacitance analysis dependency" { class: func }
}

tp_probes: "[EA] Testpoint Probe Set" {
  class: ea
  direction: down
  contact_testpoints: "[F] Contact required\ntestpoints without adjacent shorts" { class: func }
}

ambient_meter: "[EA] Ambient Thermo-\nHygrometer" {
  class: ea
  direction: down
  record_ambient: "[F] Record ambient temperature\nand humidity before checks" { class: func }
}

camera: "[EA] Camera / Evidence\nLight Box" {
  class: ea
  direction: down
  capture_evidence: "[F] Capture seating, pin,\nprobe, instrument, and anomaly evidence" { class: func }
}

repo: "[EA] Evidence Repository" {
  class: ea
  direction: down
  store_package: "[F] Store controlled report,\nraw readings, photos, matrices,\nand dispositions" { class: func }
}

system: "[System] SAA-VV-FC-002 Functional Allocation / Demonstration-Testing Procedure\nRefs: IVV; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  cansat: "[PC] v1.0 CanSat Assembly\nUUT" {
    class: pc
    direction: down

    backplane_pcb: "[PC] Backplane PCB\n100 mm × 28 mm" {
      class: pc
      direction: down

      mating_lc: "[LC] Backplane Mating\nand Alignment\nverification-only" {
        class: lc
        direction: down
        present_headers: "[F] Present ADS/AMS/OBCC/PDS\n2 mm 2×6 headers and\nPDM servo connector for mating" { class: func }
        seat_perpendicular: "[F] Seat perpendicular\nbackplane in modeled fixture" { class: func }
        expose_alignment: "[F] Expose alignment,\nflushness, and pin condition" { class: func }
      }

      rail_lc: "[LC] Rail Access\nverification-only" {
        class: lc
        direction: down
        accept_safe_power: "[F] Accept current-limited\n5 V / 3.3 V test power" { class: func }
        expose_rails: "[F] Expose 5 V and 3.3 V\nrail testpoints for measurement" { class: func }
        hold_on_rail_fault: "[F] Enter hold on overcurrent,\nrail drop, or out-of-tolerance rail" { class: func }
      }

      signal_lc: "[LC] Testpoint and Signal\nAccess\nverification-only" {
        class: lc
        direction: down
        expose_required_tps: "[F] Expose required rail and\ncritical signal testpoints" { class: func }
        provide_endpoints: "[F] Provide continuity/isolation\nendpoints for 100% checks" { class: func }
        provide_fast_access: "[F] Provide non-invasive\nSPI/I2C/UART fast-line access" { class: func }
      }
    }

    acceptance_lc: "[LC] Backplane Access\nAcceptance Gate\nverification-only" {
      class: lc
      direction: down
      apply_pass_fail: "[F] Apply mating, continuity,\nrail, and testpoint pass/fail criteria" { class: func }
      require_rerun: "[F] Require disposition and\nre-run after any anomaly or rework" { class: func }
      bind_evidence: "[F] Bind raw data, photos,\nambient record, and witness decision" { class: func }
    }
  }

  pass_fail: "[C] Pass/fail constraint:\nPass only if the perpendicular backplane seats and mates ADS, AMS, OBCC, PDS headers and the PDM servo connector to the modeled orientation/alignment with no forced insertion or bent pins; 100% required continuity/isolation checks find no short/open/swapped endpoint; required testpoints are reachable; and 5.0 ±0.1 V plus 3.3 ±0.1 V rails are measured under campaign safe load or documented no-load condition." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\n100% net, rail, connector, and required testpoint checks for this v1.0 article. Repeated mate cycles are screening only unless an independent-cycle statistical plan is later referenced." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nControls detect wrong orientation, misalignment, forced insertion, bent pins, inaccessible testpoints, shorts, opens, swapped endpoints, overcurrent, rail drop, and fast-line probe loading concerns. Any such finding triggers hold/disposition/re-run." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental/equipment condition:\nRecord ambient temperature/humidity, ESD setup, calibration status, probe condition, and bench-supply current limits before checks. De-energize before mate/demate and before continuity/isolation measurements." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nSAA-UC-BackplaneIntegration; SAA-FE-BackplaneMisMate; v1.0 Backplane PCB constraints for defined pin interface, 5.0 ±0.1 V, 3.3 ±0.1 V, testpoints, low-capacitance SPI/I2C/UART, and ERC + DRC clean." {
    class: note
    shape: page
  }
}

system.pass_fail -> system.cansat.backplane_pcb.mating_lc.seat_perpendicular { class: cstr }
system.pass_fail -> system.cansat.backplane_pcb.mating_lc.present_headers { class: cstr }
system.pass_fail -> system.cansat.backplane_pcb.rail_lc.expose_rails { class: cstr }
system.pass_fail -> system.cansat.backplane_pcb.signal_lc.expose_required_tps { class: cstr }
system.pass_fail -> system.cansat.backplane_pcb.signal_lc.provide_endpoints { class: cstr }
system.statistical -> system.cansat.backplane_pcb.signal_lc.provide_endpoints { class: cstr }
system.statistical -> system.cansat.acceptance_lc.bind_evidence { class: cstr }
system.fault_hardening -> system.cansat.backplane_pcb.mating_lc.expose_alignment { class: cstr }
system.fault_hardening -> system.cansat.backplane_pcb.rail_lc.hold_on_rail_fault { class: cstr }
system.fault_hardening -> system.cansat.acceptance_lc.require_rerun { class: cstr }
system.conditions -> system.cansat.acceptance_lc.bind_evidence { class: cstr }
system.traceability -> system.cansat.acceptance_lc.apply_pass_fail { class: cstr }

# Layout-only edges keep actors and system allocations in procedure order.
operator -> witness { style: { opacity: 0 } }
witness -> fixture { style: { opacity: 0 } }
fixture -> supply { style: { opacity: 0 } }
supply -> safe_load { style: { opacity: 0 } }
safe_load -> dmm_daq { style: { opacity: 0 } }
dmm_daq -> continuity { style: { opacity: 0 } }
continuity -> scope_la { style: { opacity: 0 } }
scope_la -> tp_probes { style: { opacity: 0 } }
tp_probes -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> camera { style: { opacity: 0 } }
camera -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.cansat.backplane_pcb.mating_lc -> system.cansat.backplane_pcb.rail_lc { style: { opacity: 0 } }
system.cansat.backplane_pcb.rail_lc -> system.cansat.backplane_pcb.signal_lc { style: { opacity: 0 } }
system.cansat.backplane_pcb -> system.cansat.acceptance_lc { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.conditions { style: { opacity: 0 } }
system.conditions -> system.traceability { style: { opacity: 0 } }
