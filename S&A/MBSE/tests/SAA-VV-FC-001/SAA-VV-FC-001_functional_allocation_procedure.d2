vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-001 verification-only Physical Architecture PV3.
# Functional allocation/procedure view for v1.0 integrated fit, mass, envelope, and module accommodation.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R3, SAA-R4, SAA-R5.
# Functions and LCs here define the verification activity only; they are not baseline S&A design edits.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" {
  class: ea
  direction: down
  identify: "[F] Identify v1.0 article,\nbuild record, and baseline copy" { class: func }
  configure: "[F] Confirm full as-flown\nconfiguration before final checks" { class: func }
  operate_gauges: "[F] Operate can gauge,\ncaliper, height gauge,\nscale, and fit gauges" { class: func }
  inspect_interference: "[F] Inspect backplane,\ncap, parachute, servo,\nbattery and stack coexistence" { class: func }
  record_anomaly: "[F] Record anomaly,\ndeviation, or hold condition" { class: func }
}

witness: "[EA] QA Witness" {
  class: ea
  direction: down
  witness_setup: "[F] Witness article setup,\ninstrument IDs, and calibration status" { class: func }
  witness_measurements: "[F] Witness measurements\nand fit/no-force observations" { class: func }
  approve_gate: "[F] Approve pass, fail,\nor hold disposition" { class: func }
}

envelope_gauge: "[EA] 355 ml Envelope /\nCan Gauge" {
  class: ea
  direction: down
  check_free_fit: "[F] Check free fit within\nØ66.0 mm × H122.0 mm gauge" { class: func }
}

caliper_height: "[EA] Calibrated Caliper /\nHeight Gauge" {
  class: ea
  direction: down
  measure_diameter: "[F] Measure maximum\ndiameter and U_D" { class: func }
  measure_height: "[F] Measure maximum\nheight and U_H" { class: func }
}

scale: "[EA] Calibrated Scale" {
  class: ea
  direction: down
  measure_mass: "[F] Measure total as-flown\nmass and U_M" { class: func }
}

pcb_fit_gauges: "[EA] PCB Fit Gauges /\nDummy PCBs" {
  class: ea
  direction: down
  verify_pcb_fit: "[F] Verify all Type 1\nstandard modules have\n44 mm × 44 mm PCB accommodation\nwithout forced fit" { class: func }
}

camera: "[EA] Calibrated Camera /\nEvidence Light Box" {
  class: ea
  direction: down
  capture_evidence: "[F] Capture configuration,\nmeasurement, fit, and anomaly evidence" { class: func }
}

ambient_meter: "[EA] Ambient Thermo-\nHygrometer" {
  class: ea
  direction: down
  record_ambient: "[F] Record ambient temperature\nand humidity before checks" { class: func }
}

repo: "[EA] Evidence Repository" {
  class: ea
  direction: down
  store_package: "[F] Store controlled report,\nraw readings, photos, and dispositions" { class: func }
}

system: "[System] SAA-VV-FC-001 Functional Allocation / Demonstration-Inspection Procedure\nRefs: IVV; SAA-R1; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  cansat: "[PC] v1.0 CanSat Assembly\nUUT" {
    class: pc
    direction: right

    configuration_lc: "[LC] As-Flown Configuration\nverification-only" {
      class: lc
      direction: down
      present_full_article: "[F] Present full as-flown article:\nstack, PCBs, battery, backplane,\ncap, parachute, servo" { class: func }
      expose_coexistence: "[F] Expose integrated\ninterference state" { class: func }
    }

    envelope_mass_lc: "[LC] Envelope / Mass\nAcceptance Gate\nverification-only" {
      class: lc
      direction: down
      provide_diameter: "[F] Provide maximum\ndiameter for measurement" { class: func }
      provide_height: "[F] Provide maximum\nheight for measurement" { class: func }
      provide_mass: "[F] Provide total assembled\nmass for measurement" { class: func }
      apply_guardbands: "[F] Apply envelope and\nmass guard-band criteria" { class: func }
    }

    standard_stack: "[PC] Standard Carrier\nModule Stack" {
      class: pc
      direction: down
      module_lc: "[LC] Module / PCB Accommodation\nverification-only" {
        class: lc
        direction: down
        accommodate_pcbs: "[F] Accommodate 44 mm × 44 mm\nPCBs / gauges in all Type 1\nstandard modules" { class: func }
        maintain_stack: "[F] Maintain module stack,\nmodule type count, and alignment" { class: func }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      backplane_lc: "[LC] Backplane Placement\nverification-only" {
        class: lc
        direction: down
        occupy_allocation: "[F] Occupy 100 mm × 28 mm\nbackplane allocation" { class: func }
        mate_headers: "[F] Mate headers and PDM\nservo connector without protrusion" { class: func }
      }
    }

    parachute_module: "[PC] Parachute / Top Module" {
      class: pc
      direction: down
      coexist_lc: "[LC] Parachute / Cap / Servo\nCoexistence\nverification-only" {
        class: lc
        direction: down
        coexist: "[F] Coexist cap, parachute,\nservo and backplane with no interference" { class: func }
      }
    }

    evidence_gate_lc: "[LC] Evidence and Anomaly Gate\nverification-only" {
      class: lc
      direction: down
      bind_evidence: "[F] Bind measurements,\nphotos, ambient data, and calibration IDs" { class: func }
      classify_gate: "[F] Classify pass, fail,\nor execution hold" { class: func }
      require_rerun: "[F] Require re-run after any\nrework or temporary omission" { class: func }
    }
  }

  pass_fail: "[C] Pass/fail constraint:\nFinal article passes only if diameter + U_D ≤ 66.0 mm,\nheight + U_H ≤ modeled 122.0 mm, measured mass + U_M < 350.0 g,\nall standard module/PCB accommodation checks pass without forced fit,\nbackplane placement/header mating is contained, cap/parachute/servo/battery\ncoexist without interference, evidence is complete, and all anomalies are closed." {
    class: note
    shape: page
  }

  mass_interpretation: "[C] Mass interpretation:\nModeled '<350 ±0.1 g' is treated as\nactual total mass < 350.0 g with a\nscale/measurement uncertainty guard band.\nIf U_M = 0.1 g, displayed mass must be\n< 349.9 g; otherwise use the reported U_M.\nAmbiguity remains documented in the report." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\n100% measurement of the final v1.0 article.\nDiameter, height and mass are continuous\nmeasurements and must report expanded uncertainty.\nThis activity makes no population reliability\nor repeated-fit-cycle reliability claim." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nChecks are valid only with full as-flown\nconfiguration: battery, parachute, cap, servo,\nbackplane, headers and PCBs present.\nNo temporary omissions, alternate fixtures,\nor external protrusion exceptions may be used\nfor a pass unless the gate is held and re-run." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental/equipment condition:\nRecord ambient temperature/humidity and\ninstrument calibration status before checks.\nHold if ambient or handling state can affect\nmeasurement, if gauge calibration is expired,\nor if evidence quality prevents independent review." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nSAA-UC-IntegratedAssembly;\nSAA-UC-BackplaneIntegration;\nSAA-UC-ParachuteClearance;\nSAA-FE-EnvelopeNonCompliance;\nSAA-FE-MassNonCompliance;\nSAA-FE-BackplaneMisMate;\nmodeled envelope, mass, module,\nbackplane and assembly constraints." {
    class: note
    shape: page
  }
}

system.pass_fail -> system.cansat.envelope_mass_lc.apply_guardbands { class: cstr }
system.pass_fail -> system.cansat.standard_stack.module_lc.accommodate_pcbs { class: cstr }
system.pass_fail -> system.cansat.backplane_pcb.backplane_lc.occupy_allocation { class: cstr }
system.pass_fail -> system.cansat.parachute_module.coexist_lc.coexist { class: cstr }
system.mass_interpretation -> system.cansat.envelope_mass_lc.apply_guardbands { class: cstr }
system.statistical -> system.cansat.envelope_mass_lc.provide_diameter { class: cstr }
system.statistical -> system.cansat.envelope_mass_lc.provide_height { class: cstr }
system.statistical -> system.cansat.envelope_mass_lc.provide_mass { class: cstr }
system.fault_hardening -> system.cansat.configuration_lc.present_full_article { class: cstr }
system.fault_hardening -> system.cansat.evidence_gate_lc.require_rerun { class: cstr }
system.conditions -> system.cansat.evidence_gate_lc.bind_evidence { class: cstr }
system.traceability -> system.cansat.evidence_gate_lc.classify_gate { class: cstr }

# Layout-only edges keep actors and system allocations in procedure order.
operator -> witness { style: { opacity: 0 } }
witness -> envelope_gauge { style: { opacity: 0 } }
envelope_gauge -> caliper_height { style: { opacity: 0 } }
caliper_height -> scale { style: { opacity: 0 } }
scale -> pcb_fit_gauges { style: { opacity: 0 } }
pcb_fit_gauges -> camera { style: { opacity: 0 } }
camera -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.cansat.configuration_lc -> system.cansat.envelope_mass_lc { style: { opacity: 0 } }
system.cansat.envelope_mass_lc -> system.cansat.standard_stack { style: { opacity: 0 } }
system.cansat.standard_stack -> system.cansat.backplane_pcb { style: { opacity: 0 } }
system.cansat.backplane_pcb -> system.cansat.parachute_module { style: { opacity: 0 } }
system.cansat.parachute_module -> system.cansat.evidence_gate_lc { style: { opacity: 0 } }
system.pass_fail -> system.mass_interpretation { style: { opacity: 0 } }
system.mass_interpretation -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.conditions { style: { opacity: 0 } }
system.conditions -> system.traceability { style: { opacity: 0 } }
