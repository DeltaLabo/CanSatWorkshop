vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-002 verification-only Functional Chain view.
# Fault-hardening scenario for v1.0 backplane mating: misalignment, short/open/swap, rail drop, and access-dependency holds.
# References cited in the rendered chain title: IVV, SAA-R4, SAA-R5.
# This chain defines the verification activity only; it is not a baseline S&A functional chain.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

fault_chain: "[Functional Chain] SAA-VV-FC-002 Backplane Fault-Hardening Hold Checks\nRefs: IVV; SAA-R4; SAA-R5" {
  class: chain
  direction: down

  load_checklist: "[F] Operator/Witness: load\nfault-hardening checklist and\nconfirm power output is off" { class: func }
  pre_mate_screen: "[F] Fixture/Operator: screen\norientation keying, alignment datum,\nand entry path before insertion" { class: func }
  reject_misalignment: "[F] Acceptance gate: reject\nwrong orientation, misalignment,\nforced insertion, or bent-pin risk" { class: func }
  inspect_after_mate: "[F] Operator/Witness: inspect\npost-mate connector flushness,\npartial seat, and pin damage" { class: func }
  continuity_fault_screen: "[F] Continuity tester: screen\n100% required nets for shorts,\nopens, and swapped endpoints" { class: func }
  inhibit_power: "[F] Acceptance gate: inhibit\npower on any short/open/swap,\npartial seat, or unknown endpoint" { class: func }
  enable_current_limit: "[F] Bench supply: enable\nonly after continuity pass, with\ncurrent limits and safe load/no-load" { class: func }
  rail_drop_screen: "[F] DMM/DAQ: screen 5 V / 3.3 V\nfor out-of-tolerance, overcurrent,\nor rail-drop condition" { class: func }
  testpoint_access_screen: "[F] Probe set: screen\nblocked/inaccessible testpoints\nand adjacent-pin short risk" { class: func }
  fast_line_dependency: "[F] Scope/logic analyzer: record\nexcessive capacitance/rise-time\nconcern as analysis dependency" { class: func }
  open_anomaly: "[F] Operator: open anomaly\nrecord with affected header, net,\nrail, testpoint, or connector" { class: func }
  disposition: "[F] Engineering/QA: classify\nrework, model/update dependency,\nwaiver request, hold, or fail" { class: func }
  rerun_nominal: "[F] Test team: re-run affected\nnominal chain steps after approved\nrework or dependency closure" { class: func }
  archive: "[F] Evidence repository: archive\nfault-screen, anomaly, disposition,\nand re-run evidence" { class: func }

  fault_triggers: "[C] Fault-hardening trigger constraint:\nTrigger hold/fail for wrong orientation, visible misalignment, forced insertion, bent pin, connector damage, partial seat, any short, open, swapped endpoint, inaccessible required testpoint, adjacent-pin short risk, overcurrent, rail drop, out-of-tolerance 5 V / 3.3 V, or unresolved SPI/I2C/UART capacitance/rise-time issue. Do not intentionally short the flight article; use inspection, continuity, current limits, and controlled probes to screen for faults." {
    class: note
    shape: page
  }

  closure_rule: "[C] Closure constraint:\nNo fault-screen anomaly may be closed as pass until the affected connector/net/rail/testpoint is corrected or formally dispositioned and the affected nominal checks are re-run with complete evidence. Open analysis dependency to SAA-VV-CE-001 or SAA-VV-CON-003 keeps this activity on hold unless approved by the flight-readiness authority." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\nFault-hardening checks are 100% article-specific screens of modeled endpoints and rails. Repeated mate cycles or re-runs after rework are not independent reliability trials unless a separate statistical plan defines independence, sample size, and acceptance criteria." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nThe chain demonstrates that the procedure fails safe: power is inhibited before a detected short/open/swap or mis-mate, current limits bound energy during rail checks, inaccessible testpoints block acceptance, and fast-line loading concerns are not hidden but transferred to controlled analysis dependency." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nSAA-UC-BackplaneIntegration; SAA-FE-BackplaneMisMate; v1.0 Backplane PCB constraints for defined pin interface, 5.0 ±0.1 V, 3.3 ±0.1 V, testpoints, low-capacitance SPI/I2C/UART, and ERC + DRC clean." {
    class: note
    shape: page
  }
}

fault_chain.load_checklist -> fault_chain.pre_mate_screen: "[FE] Power-off state\nand fault checklist" { class: fe }
fault_chain.pre_mate_screen -> fault_chain.reject_misalignment: "[FE] Orientation /\nalignment observation" { class: fe }
fault_chain.reject_misalignment -> fault_chain.inspect_after_mate: "[FE] Allowed mate\nor misalignment hold" { class: fe }
fault_chain.inspect_after_mate -> fault_chain.continuity_fault_screen: "[FE] Post-mate\ninspection result" { class: fe }
fault_chain.continuity_fault_screen -> fault_chain.inhibit_power: "[FE] Short/open/swap\nfinding or pass" { class: fe }
fault_chain.inhibit_power -> fault_chain.enable_current_limit: "[FE] Power permission\nor inhibit state" { class: fe }
fault_chain.enable_current_limit -> fault_chain.rail_drop_screen: "[FE] Current-limited\nrail condition" { class: fe }
fault_chain.rail_drop_screen -> fault_chain.testpoint_access_screen: "[FE] Rail drop /\nvoltage status" { class: fe }
fault_chain.testpoint_access_screen -> fault_chain.fast_line_dependency: "[FE] Testpoint access\nstatus" { class: fe }
fault_chain.fast_line_dependency -> fault_chain.open_anomaly: "[FE] Dependency or\naccess anomaly status" { class: fe }
fault_chain.open_anomaly -> fault_chain.disposition: "[FE] Affected model\nelements and evidence" { class: fe }
fault_chain.disposition -> fault_chain.rerun_nominal: "[FE] Approved disposition\nor hold/fail" { class: fe }
fault_chain.rerun_nominal -> fault_chain.archive: "[FE] Re-run results\nand closure evidence" { class: fe }

# Layout-only edges keep notes after the executable fault-hardening flow.
fault_chain.archive -> fault_chain.fault_triggers { style: { opacity: 0 } }
fault_chain.fault_triggers -> fault_chain.closure_rule { style: { opacity: 0 } }
fault_chain.closure_rule -> fault_chain.statistical { style: { opacity: 0 } }
fault_chain.statistical -> fault_chain.fault_hardening { style: { opacity: 0 } }
fault_chain.fault_hardening -> fault_chain.traceability { style: { opacity: 0 } }
