vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Historical Capella functional-chain view reconstructed from PDM/PDM_v0.2_FC.jpg.
# Source label: "Parachute deployment test (3 reps)".
# The source shows a physical-actor icon for Human Tester; this D2 uses the repo's [EA] external-actor prefix.
# The source top-level visible system owner is [PC] CanSat; this chain view does not add the
# [System] Physical System wrapper used by the v0.2 physical D2 reconstruction.
# This raster is a functional-chain view with allocation and physical-link context visible, so those visible
# PCs/LCs/EAs, CEs, and PLs are preserved instead of reducing the view to functions only.
#
# Source/XML drift documented for review:
# - Raster labels the MCU as XIAO ESP32-C3; current PDM v1.0 XML labels the equivalent component XIAO ESP32-S3.
#   The historical C3 label is preserved.
# - Raster includes Human Tester, Power Module, Battery, Boost Converter, BLE, 5V Power Cable Pair,
#   soldered cables, and soldered power cables; these are not present in current PDM v1.0 XML.
# - Raster uses historical function/exchange names "Trigger PWM Signal", "Set PWM to open position",
#   "Open parachute", "Trigger enable", "Parachute open signal", and "Parachute opened".
#   Current PDM v1.0 XML uses different open/closed servo-state functions and exchanges, so the raster names are kept.
# - Raster label "Parachute trigger" is kept rather than normalized to current XML "Trigger".
# - The red BLE link is semantically borderline: it is drawn like the other physical links but carries the
#   actor-to-MCU communication interface, so it is represented as [CE] BLE in this functional-chain view.
# - The visible dashed PDS v0.1 constraint points into the CanSat near the Power Module; the exact target is ambiguous.
# - Layout order favors FE readability: OBCC is placed before Parachute Module, and Servo before Parachute,
#   while preserving the source hierarchy and all exchange directions.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDM v0.2 — Parachute deployment test (3 reps)" {
  class: chain
  direction: right

  note_airborne: "[C] While CanSat\nis airborne" { class: note; shape: page }
  note_pds_v0_1: "[C] PDS\nv0.1" { class: note; shape: page }

  human_tester: "[EA] Human Tester" {
    class: ea
    direction: down
    grid-columns: 1

    release_dummy: "[F] Release\ndummy" { class: func }
    trigger_pwm_signal: "[F] Trigger PWM\nSignal" { class: func }
  }

  cansat: "[PC] CanSat" {
    class: pc
    direction: right
    grid-columns: 2

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      xiao_esp32_c3: "[PC] XIAO ESP32-C3" {
        class: pc
        direction: down

        obcc: "[LC] OBCC" {
          class: lc
          direction: down

          set_pwm_open_position: "[F] Set PWM to open\nposition" { class: func }
        }
      }
    }

    parachute_module: "[PC] Parachute Module" {
      class: pc
      direction: right

      servo: "[PC] Servo" {
        class: pc
        direction: down

        parachute_trigger: "[LC] Parachute trigger" {
          class: lc
          direction: down

          open_parachute: "[F] Open parachute" { class: func }
        }
      }

      parachute: "[PC] Parachute" {
        class: pc
        direction: down

        descent_speed_control: "[LC] Descent speed control" {
          class: lc
          direction: down

          limit_terminal_speed: "[F] Limit terminal speed" { class: func }
        }
      }
    }

    power_module: "[PC] Power Module" {
      class: pc
      direction: right

      battery: "[PC] Battery" {
        class: pc
        direction: down

        power_storage: "[LC] Power storage" {
          class: lc
          direction: down

          provide_power: "[F] Provide power" { class: func }
        }
      }

      boost_converter: "[PC] Boost Converter" {
        class: pc
        direction: down

        voltage_regulation: "[LC] Voltage regulation" {
          class: lc
          direction: down

          step_up_voltage: "[F] Step up voltage" { class: func }
        }
      }
    }
  }
}

chain.human_tester.trigger_pwm_signal -> chain.cansat.obcc_module.xiao_esp32_c3.obcc.set_pwm_open_position: "[FE] Trigger enable []" { class: fe }
chain.cansat.obcc_module.xiao_esp32_c3.obcc.set_pwm_open_position -> chain.cansat.parachute_module.servo.parachute_trigger.open_parachute: "[FE] Parachute open\nsignal []" { class: fe }
chain.cansat.parachute_module.servo.parachute_trigger.open_parachute -> chain.cansat.parachute_module.parachute.descent_speed_control.limit_terminal_speed: "[FE] Parachute opened []" { class: fe }

chain.human_tester -> chain.cansat.obcc_module.xiao_esp32_c3: "[CE] BLE" { class: ce; style: { font-size: 24 } }
chain.cansat.obcc_module.xiao_esp32_c3.obcc -> chain.cansat.parachute_module.servo.parachute_trigger: "[CE] PWM" { class: ce; style: { font-size: 24 } }

chain.cansat.parachute_module.parachute -- chain.cansat.parachute_module.servo: "[PL] Deployment\nmechanism" { class: pl; style: { font-size: 24 } }
chain.cansat.obcc_module.xiao_esp32_c3 -- chain.cansat.parachute_module.servo: "[PL] Soldered\ncables (3x)" { class: pl; style: { font-size: 24 } }
chain.cansat.obcc_module.xiao_esp32_c3 -- chain.cansat.power_module.boost_converter: "[PL] 5V Power\nCable Pair" { class: pl; style: { font-size: 24 } }
chain.cansat.power_module.battery -- chain.cansat.power_module.boost_converter: "[PL] Soldered Power\nCables (2x)" { class: pl; style: { font-size: 24 } }

# Source dashed constraint targets the Trigger PWM Signal function.
chain.note_airborne -> chain.human_tester.trigger_pwm_signal { class: cstr }

# Source dashed constraint points toward the CanSat around the Power Module; attach it to Power Module.
chain.note_pds_v0_1 -> chain.cansat.power_module { class: cstr }

# Layout-only edges to keep the notes, external actor, and CanSat in a readable left-to-right band.
# These carry no Capella semantics.
chain.note_airborne -> chain.note_pds_v0_1 { style: { opacity: 0 } }
chain.note_pds_v0_1 -> chain.human_tester { style: { opacity: 0 } }
chain.human_tester -> chain.cansat { style: { opacity: 0 } }
