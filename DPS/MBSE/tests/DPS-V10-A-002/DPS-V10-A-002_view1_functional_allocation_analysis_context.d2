vars: {
  d2-config: {
    layout-engine: elk
  }
}

# DPS-V10-A-002 PV3 functional-allocation analysis context.
# Shows the full DPS v1.0 allocation baseline plus verification-only analysis actors and record functions.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 34 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 38
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 38 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 46 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 38
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 30 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

model_repository: "[EA] Model Baseline Repository" {
  class: ea
  direction: down
  provide_v1_model: "[F] Provide frozen DPS v1.0\nPV2/PV3/chain views" { class: func }
}

implementation_repository: "[EA] Implementation Artifact Repository" {
  class: ea
  direction: down
  grid-columns: 2
  provide_firmware_mapping: "[F] Provide firmware\nfunction mapping" { class: func }
  provide_pc_mapping: "[F] Provide PC software\nmodule mapping" { class: func }
  provide_scheduling_evidence: "[F] Provide task/timer/\ninterrupt evidence" { class: func }
  provide_build_revision: "[F] Provide analyzed\nbuild revision" { class: func }
}

runtime_trace_collector: "[EA] Runtime Trace Collector" {
  class: ea
  direction: down
  grid-columns: 2
  capture_shared_load: "[F] Capture representative\nshared-load trace" { class: func }
  export_trace_metrics: "[F] Export service-gap,\nqueue and error metrics" { class: func }
}

analyst: "[EA] IVV Allocation Analyst" {
  class: ea
  direction: down
  grid-columns: 2
  select_baseline: "[F] Select model and\nimplementation baseline" { class: func }
  extract_allocation_matrix: "[F] Extract LC/function\nallocation matrix" { class: func }
  check_intended_functions: "[F] Check intended\nfunctions are allocated" { class: func }
  check_foreign_functions: "[F] Check no foreign\nfunctions are allocated" { class: func }
  analyze_lc_boundary_flows: "[F] Analyze cross-LC\nflow responsibility" { class: func }
  analyze_context_load: "[F] Analyze ESS/ADS/PDM/AMS\nload-starvation risk" { class: func }
  document_verdict: "[F] Document allocation\nrationale and verdict" { class: func }
}

reviewer: "[EA] IVV Reviewer" {
  class: ea
  direction: down
  review_allocation_package: "[F] Review allocation\nanalysis package" { class: func }
  approve_allocation_disposition: "[F] Approve or reject\nallocation disposition" { class: func }
}

system: "[System] DPS v1.0\nDPS-V10-A-002 PV3 functional-allocation analysis\nIADT: Analysis; Refs: P0,R1-R5,R8-R13; Trace: responsibility partition/shared-load behavior" {
  class: sys
  direction: down
  grid-columns: 1

  cansat: "[PC] CanSat" {
    class: pc
    direction: down

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: right

        cansat_rfm: "[PC] RFM96W LoRa" {
          class: pc
          direction: down

          cansat_lora: "[LC] LoRa Transceiver" {
            class: lc
            direction: down
            cansat_receive_incoming_data: "[F] Receive incoming data" { class: func }
            cansat_transmit_outgoing_data: "[F] Transmit outgoing data" { class: func }
          }
        }

        cansat_xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down
          grid-columns: 2

          obcc: "[LC] OBCC" {
            class: lc
            direction: down
            cansat_receive_lora_rx_interrupt: "[F] Receive LoRa\nRX Interrupt" { class: func }
            send_lora_packet: "[F] Send LoRa packet" { class: func }
            obcc_read_command: "[F] Read command" { class: func }
          }

          ess_processing: "[LC] ESS Processing\n(context, no DPS-owned functions)" { class: lc }
          ads_processing: "[LC] ADS Processing\n(context, no DPS-owned functions)" { class: lc }
          pdm_processing: "[LC] PDM Processing\n(context, no DPS-owned functions)" { class: lc }
          ams_processing: "[LC] AMS Processing\n(context, no DPS-owned functions)" { class: lc }
        }

        cansat_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }
  }

  ground_station_pcb: "[PC] Ground Station PCB" {
    class: pc
    direction: right

    ground_rfm: "[PC] RFM96W LoRa" {
      class: pc
      direction: down

      ground_lora: "[LC] LoRa Transceiver" {
        class: lc
        direction: down
        ground_store_incoming_data: "[F] Store incoming data" { class: func }
        ground_transmit_outgoing_data: "[F] Transmit outgoing data" { class: func }
      }
    }

    ground_xiao: "[PC] XIAO ESP32" {
      class: pc
      direction: down

      ground_forwarder: "[LC] LoRa Forwarder" {
        class: lc
        direction: down
        grid-columns: 3

        init_serial0_with_interrupts: "[F] Init Serial0 with\ninterrupts" { class: func }
        init_spi_with_interrupts: "[F] Init SPI with\ninterrupts" { class: func }
        log_error: "[F] Log error" { class: func }
        ground_receive_lora_rx_interrupt: "[F] Receive LoRa\nRX Interrupt" { class: func }
        read_payload: "[F] Read payload" { class: func }
        forward_to_pc: "[F] Forward to PC" { class: func }
        store_incoming_uart_data: "[F] Store incoming\nUART data" { class: func }
        receive_serial0_rx_interrupt: "[F] Receive Serial0\nRX Interrupt" { class: func }
        forwarder_read_command: "[F] Read command" { class: func }
        generate_frame: "[F] Generate frame" { class: func }
        write_to_lora_radio: "[F] Write to\nLoRa Radio" { class: func }
      }
    }
  }

  pc: "[PC] PC" {
    class: pc
    direction: down
    grid-columns: 2

    decoder: "[LC] Decoder" {
      class: lc
      direction: down
      grid-columns: 3

      check_if_data_is_available: "[F] Check if data\nis available" { class: func }
      read_and_decode_frame: "[F] Read and\ndecode frame" { class: func }
      push_to_payload_queue: "[F] Push to\npayload queue" { class: func }
      get_rx_timestamp: "[F] Get RX\ntimestamp" { class: func }
      calculate_latency: "[F] Calculate\nlatency" { class: func }
      forward_to_transceiver: "[F] Forward to\ntransceiver" { class: func }
      consume_command_queue: "[F] Consume\ncommand queue" { class: func }
    }

    csv_writer: "[LC] CSV Writer" {
      class: lc
      direction: down

      csv_consume_payload_queue: "[F] Consume\npayload queue" { class: func }
      append_to_csv: "[F] Append to CSV" { class: func }

      note_csv_name: "[C] Give each CSV a\nunique name based\non the initial\ntimestamp" {
        class: note
        shape: page
      }
    }

    dashboard: "[LC] Dashboard" {
      class: lc
      direction: down
      grid-columns: 2

      dashboard_consume_payload_queue: "[F] Consume\npayload queue" { class: func }
      update_orientation_3d_plot: "[F] Update CanSat\norientation 3D model" { class: func }
      push_to_command_queue: "[F] Push to\ncommand queue" { class: func }
      update_temperature_2d_plot: "[F] Update temperature\n2D plot" { class: func }
      update_altitude_2d_plot: "[F] Update altitude\n2D plot" { class: func }
      catch_state_toggle: "[F] Catch State\ntoggle" { class: func }
      update_latency_alert: "[F] Update latency\nalert" { class: func }
      disable_toggle: "[F] Disable\ntoggle" { class: func }
      enable_toggle: "[F] Enable\ntoggle" { class: func }
      cooldown: "[F] Cooldown" { class: func }
      create_plots: "[F] Create plots" { class: func }
    }

    allocation_analysis_record: "[LC] Allocation Analysis Record\n(verification-only)" {
      class: lc
      direction: down
      grid-columns: 2
      store_allocation_matrix: "[F] Store LC/function\ncoverage matrix" { class: func }
      store_static_mapping: "[F] Store code/module\nallocation evidence" { class: func }
      store_boundary_review: "[F] Store cross-LC\nboundary-flow review" { class: func }
      store_context_load_review: "[F] Store shared-load\nstarvation review" { class: func }
      compute_coverage_verdict: "[F] Compute allocation\ncoverage and verdict" { class: func }
      archive_report_inputs: "[F] Archive analysis\nreport inputs" { class: func }
    }

    note_alert: "[C] Show text alert at\nthe top of the\ndashboard when\nLatency > 1s" {
      class: note
      shape: page
    }

    note_cooldown: "[C] 5 seconds" {
      class: note
      shape: page
    }

    note_plots: "[C] 4x4 plot matrix;\ntop-left cell shows\nthe 3D CanSat attitude\nmodel" {
      class: note
      shape: page
    }

    usb_port: "[PC] USB Port" {
      class: pc
      direction: down

      usb_power: "[LC] USB Power" {
        class: lc
        direction: down
        provide_power: "[F] Provide power" { class: func }
      }
    }

    note_concurrent: "[C] Concurrent\nexecution" {
      class: note
      shape: page
    }

    note_browser: "[C] Accessible via\na web browser" {
      class: note
      shape: page
    }
  }

  note_pass: "[C] Allocation pass constraint: every intended DPS function is\nallocated to exactly the modeled LC, no LC owns a foreign DPS function,\nand each cross-LC functional responsibility uses the modeled LC boundary." {
    class: note
    shape: page
  }

  note_context_load: "[C] Context-load constraint: ESS/ADS/PDM/AMS remain context LCs\nwith no DPS-owned functions and do not starve OBCC radio/command handling\nat the v1.0 2 s cadence under representative shared load evidence." {
    class: note
    shape: page
  }

  note_statistics_fault: "[C] Statistics/fault viewpoint: primary basis is 100% allocation\nchecklist coverage, not a stochastic claim; fault-hardening review covers\nforeign function, missing function, command bypass, queue overload and starvation." {
    class: note
    shape: page
  }

  note_environment: "[C] Analysis environment: freeze DPS v1.0 model, implementation\ncommit/build revision, artifact IDs, analyzed runtime traces, assumptions,\nopen discrepancies and waivers in tests/results/DPS-V10-A-002/." {
    class: note
    shape: page
  }
}

system.pc.csv_writer.note_csv_name -> system.pc.csv_writer.append_to_csv { class: cstr }
system.pc.note_alert -> system.pc.dashboard.update_latency_alert { class: cstr }
system.pc.note_cooldown -> system.pc.dashboard.cooldown { class: cstr }
system.pc.note_plots -> system.pc.dashboard.create_plots { class: cstr }
system.pc.note_concurrent -> system.pc.decoder { class: cstr }
system.pc.note_concurrent -> system.pc.csv_writer { class: cstr }
system.pc.note_concurrent -> system.pc.dashboard { class: cstr }
system.pc.note_browser -> system.pc.dashboard { class: cstr }
system.note_pass -> system.pc.allocation_analysis_record.compute_coverage_verdict { class: cstr }
system.note_context_load -> system.cansat.obcc_module.obcc_pcb.cansat_xiao { class: cstr }
system.note_context_load -> system.pc.allocation_analysis_record.store_context_load_review { class: cstr }
system.note_statistics_fault -> system.pc.allocation_analysis_record.compute_coverage_verdict { class: cstr }
system.note_environment -> system.pc.allocation_analysis_record.archive_report_inputs { class: cstr }

# Layout-only edges to preserve evidence source, analyst/reviewer and UUT banding.
model_repository -> implementation_repository { style: { opacity: 0 } }
implementation_repository -> runtime_trace_collector { style: { opacity: 0 } }
runtime_trace_collector -> analyst { style: { opacity: 0 } }
analyst -> reviewer { style: { opacity: 0 } }
reviewer -> system { style: { opacity: 0 } }
system.cansat -> system.ground_station_pcb { style: { opacity: 0 } }
system.ground_station_pcb -> system.pc { style: { opacity: 0 } }
