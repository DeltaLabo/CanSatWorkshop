vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical mission-window verification setup for ADS-IVV-FC-MISSION-WINDOW.
# Defines UUT, external verification actors, temporary PLs/CEs, environment, and pass/fail constraints.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-FC-MISSION-WINDOW\nPhysical mission-window setup\nRefs: IVV; NASA-SE; GEVS; ESA-CANSAT; SW/stats" {
  class: sys
  direction: down

  uut: "[PC] Selected ADS UUT\none version per execution" {
    class: pc
    direction: down
    grid-columns: 2
    v01: "[PC] v0.1 GPS + XIAO\nSerial0 article" { class: pc }
    v02: "[PC] v0.2 GPS + IMU + XIAO\nSerial0 article" { class: pc }
    v03: "[PC] v0.3 ADS PCB\nN/A runtime article" { class: pc }
    v10: "[PC] v1.0 integrated CanSat\nADS/backplane/OBCC article" { class: pc }
  }
}

test_conductor: "[EA] Human test conductor\nselects version and starts run" { class: ea }
run_controller: "[EA] Mission-window run\ncontroller / timer" { class: ea }
stimulus_truth: "[EA] GPS/IMU stimulus and\ntruth/reference tools" { class: ea }
power_source: "[EA] Current-limited power\nsource / battery simulator" { class: ea }
logger: "[EA] PC or OBCC logger\nSerial0 and delivery capture" { class: ea }
ambient_monitor: "[EA] Ambient monitor\nthermometer / hygrometer" { class: ea }
analysis_station: "[EA] Analysis and review station\ncoverage, statistics, verdict" { class: ea }

c_runtime_pass: "[C] Mission-window pass intent\nFor v0.1/v0.2/v1.0, selected ADS version runs the\nrepresentative descent window with no reset, no stuck loop,\nand no unrecovered peripheral failure. Expected modeled fields\nfor that version are present and time-correlated." { class: note; shape: page }
c_cadence: "[C] Cadence / gap prerequisite\nIf a cadence is claimed, at least 95% of expected cycles/frames\nshall be present and no gap may exceed the project-defined maximum.\nv0.1/v0.2 use modeled 5 Hz; v1.0 cadence is blocked until selected.\nIf mission duration or max gap is not chosen, verdict is BLOCKED." { class: note; shape: page }
c_environment: "[C] Execution conditions\nRecord UUT version, hardware revision, firmware commit, power mode,\nmission-window duration, timebase, ambient temperature/humidity,\nstimulus/truth calibration, and logger configuration before running." { class: note; shape: page }
c_faults: "[C] Fault-hardening conditions\nExercise or disposition silent GPS/IMU, UART/I2C timeout, corrupt\nmeasurement, stale data, loop stall, reset/brownout, and v1.0\nOBCC pointer/return integrity. Invalid data shall not be accepted as valid." { class: note; shape: page }

# Temporary physical links used by the verification setup.
power_source -- system.uut: "[PL] power leads /\nbattery harness" { class: pl }
logger -- system.uut: "[PL] USB serial, debug,\nor OBCC log interface" { class: pl }
stimulus_truth -- system.uut: "[PL] RF feed, sensor fixture,\nor stimulus harness" { class: pl }
run_controller -- logger: "[PL] trigger/timebase\nlink" { class: pl }
ambient_monitor -- logger: "[PL] readout capture\nor photo link" { class: pl }

# Verification component exchanges / records.
test_conductor -> system.uut: "[CE] version selection\nand run sheet" { class: ce }
test_conductor -> run_controller: "[CE] start/stop\ncommands" { class: ce }
run_controller -> logger: "[CE] mission-window\ntime markers" { class: ce }
stimulus_truth -> logger: "[CE] truth/reference\nand fault markers" { class: ce }
system.uut -> logger: "[CE] ADS serial/OBCC\nrecords and health markers" { class: ce }
power_source -> logger: "[CE] voltage/current\nand reset evidence" { class: ce }
ambient_monitor -> logger: "[CE] temperature /\nhumidity readings" { class: ce }
logger -> analysis_station: "[CE] raw evidence\npackage" { class: ce }
analysis_station -> test_conductor: "[CE] preliminary\nverdict and gaps" { class: ce }

c_runtime_pass -> system.uut { class: cstr }
c_cadence -> run_controller { class: cstr }
c_cadence -> logger { class: cstr }
c_environment -> ambient_monitor { class: cstr }
c_environment -> power_source { class: cstr }
c_faults -> stimulus_truth { class: cstr }
c_faults -> analysis_station { class: cstr }

# Layout-only rank hints.
test_conductor -> run_controller { style: { opacity: 0 } }
run_controller -> stimulus_truth { style: { opacity: 0 } }
stimulus_truth -> power_source { style: { opacity: 0 } }
power_source -> logger { style: { opacity: 0 } }
logger -> ambient_monitor { style: { opacity: 0 } }
ambient_monitor -> analysis_station { style: { opacity: 0 } }
system -> c_runtime_pass { style: { opacity: 0 } }
c_runtime_pass -> c_cadence { style: { opacity: 0 } }
c_cadence -> c_environment { style: { opacity: 0 } }
c_environment -> c_faults { style: { opacity: 0 } }
