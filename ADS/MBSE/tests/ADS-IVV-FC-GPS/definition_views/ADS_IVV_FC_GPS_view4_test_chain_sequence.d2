vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional-chain style verification sequence for ADS-IVV-FC-GPS.
# IADT method: Testing with supporting Analysis.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "ADS-IVV-FC-GPS\nGPS functional-chain verification sequence\nRefs: IVV; NASA-SE; GPS/UBX; SW/stats" {
  class: chain
  direction: down
  grid-columns: 1

  select_version: "[F] Select ADS version\nand source baseline" { class: func }
  confirm_applicability: "[F] Confirm GPS-chain\napplicability or v0.3 N/A" { class: func }
  configure_truth: "[F] Configure GPS truth\nsource and uncertainty" { class: func }
  configure_uut: "[F] Configure UUT, firmware,\npower, logger, timebase" { class: func }
  acquire_nominal: "[F] Acquire nominal GPS\nADS and truth samples" { class: func }
  align_filter: "[F] Align samples and\nfilter invalid/no-fix data" { class: func }
  compute_hpe: "[F] Compute horizontal\nposition error" { class: func }
  evaluate_accuracy: "[F] Evaluate <5 m\naccuracy pass condition" { class: func }
  evaluate_rate: "[F] Evaluate 5 Hz\nrate/gaps where modeled" { class: func }
  inject_faults: "[F] Inject no-fix, malformed,\nsilent/stale GPS cases" { class: func }
  evaluate_faults: "[F] Evaluate fault response\nand recovery" { class: func }
  decide_result: "[F] Decide GPS chain\npass/fail or N/A" { class: func }
  record_report: "[F] Record evidence, anomalies,\nwaivers, limitations, retest" { class: func }

  note_accuracy: "[C] Accuracy constraint\nPass if accepted horizontal error criterion,\nincluding uncertainty or 95/95 bound where claimed,\nis <5 m for valid matched samples." { class: note; shape: page }
  note_rate: "[C] Rate constraint\nv0.1/v0.2 only: At 5 Hz.\nPass if selected 5 Hz timing rule is met.\nv1.0 rate is informational unless a separate\nconstraint is added." { class: note; shape: page }
  note_stats: "[C] Statistical significance\nUse complete campaign records. Minimum >=30\nmatched valid samples for accuracy; record rate/gap\nstatistics and justify any 95/95 claim." { class: note; shape: page }
  note_faults: "[C] Fault hardening\nNo-fix, malformed, silent, stale, and timeout cases\nshall not be accepted as valid GPS positions and\nshall not cause unrecovered loop/OBCC blockage." { class: note; shape: page }
  note_v03: "[C] v0.3 N/A branch\nIf selected version is v0.3, stop after confirming\n1/1 source view has no GPS functional chain or LC/CE\nbehavior; record N/A rationale." { class: note; shape: page }
}

chain.select_version -> chain.confirm_applicability: "[FE] Baseline" { class: fe }
chain.confirm_applicability -> chain.configure_truth: "[FE] Applicable" { class: fe }
chain.configure_truth -> chain.configure_uut: "[FE] Truth setup" { class: fe }
chain.configure_uut -> chain.acquire_nominal: "[FE] Ready" { class: fe }
chain.acquire_nominal -> chain.align_filter: "[FE] ADS/truth logs" { class: fe }
chain.align_filter -> chain.compute_hpe: "[FE] Matched valid samples" { class: fe }
chain.compute_hpe -> chain.evaluate_accuracy: "[FE] Error set" { class: fe }
chain.evaluate_accuracy -> chain.evaluate_rate: "[FE] Accuracy result" { class: fe }
chain.evaluate_rate -> chain.inject_faults: "[FE] Rate result" { class: fe }
chain.inject_faults -> chain.evaluate_faults: "[FE] Fault evidence" { class: fe }
chain.evaluate_faults -> chain.decide_result: "[FE] Fault result" { class: fe }
chain.decide_result -> chain.record_report: "[FE] Verdict" { class: fe }

