vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional Chain — PDS-VV-FC-001 overvoltage cut-off and restore.
# Only functions, FEs, and constraints are inside the chain container.
# References: IVV, PDS-R2, PDS-R4, PDS-R5, PDS-R6, PDS-R7, PDS-R8.
# Traceability: PDS-FE-OvercurrentOvervoltage; PDS-FE-RailBrownout; PDS-FE-LiIonUnsafeCondition; PDS-UC-ProvideRegulatedPower.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDS-VV-FC-001 — overvoltage cut-off and restore chain\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R2; PDS-R4; PDS-R5; PDS-R6; PDS-R7; PDS-R8" {
  class: chain
  direction: down
  grid-columns: 1

  read_ambient: "[F] Read ambient\nbefore demand trials" { class: func }
  verify_calibration_status: "[F] Verify source/load/\ninstrument status" { class: func }
  configure_battery_emulator: "[F] Configure battery emulator\nor current-limited source" { class: func }
  configure_overvoltage_source: "[F] Configure current-limited\novervoltage source" { class: func }
  set_overvoltage_limits: "[F] Set safe overvoltage\nand current limits" { class: func }
  arm_logging_safety: "[F] Arm logging, thermal,\nand E-stop watch" { class: func }
  switch_power_on: "[F] Switch power on" { class: func }
  restore_power_initial: "[F] Restore power" { class: func }
  regulate_nominal_rails: "[F] Regulate nominal\n5 V / 3V3 rails" { class: func }
  verify_pre_fault_nominal: "[F] Verify pre-fault\nnominal state" { class: func }
  command_overvoltage_demand: "[F] Command safe overvoltage\ndemand" { class: func }
  inject_overvoltage: "[F] Inject current-limited\novervoltage" { class: func }
  detect_overvoltage: "[F] Detect overvoltage" { class: func }
  cut_off_power: "[F] Cut off power" { class: func }
  verify_safe_state: "[F] Verify safe state:\nrails off/current limited" { class: func }
  monitor_temperature_cell: "[F] Monitor no unsafe\ntemperature or cell behavior" { class: func }
  record_cutoff_evidence: "[F] Record cut-off\nwaveforms and status" { class: func }
  remove_overvoltage_demand: "[F] Remove overvoltage\ndemand" { class: func }
  inhibit_restore_until_cleared: "[F] Inhibit unsafe restore\nuntil fault cleared" { class: func }
  command_controlled_restore: "[F] Command controlled\nrestore" { class: func }
  restore_power_after_clear: "[F] Restore power" { class: func }
  verify_nominal_recovery: "[F] Verify nominal recovery\nwith no reset/restart" { class: func }
  classify_trial: "[F] Classify demanded\nprotection trial" { class: func }
  archive_evidence: "[F] Archive trial evidence\nand binomial basis" { class: func }

  note_definition: "[C] Definition scope:\nOvervoltage protection demand for PDS-VV-FC-001; trace\nPDS-FE-OvercurrentOvervoltage, PDS-FE-RailBrownout,\nPDS-FE-LiIonUnsafeCondition, PDS-UC-ProvideRegulatedPower." {
    class: note
    shape: page
  }
  note_pass: "[C] Pass/fail:\neach demanded overvoltage event shall be detected, cut off safely,\nremain safe after cut-off, and restore only after overvoltage is removed\nand controlled restore is commanded. No missed unsafe action." {
    class: note
    shape: page
  }
  note_safety: "[C] Safety constraints:\novervoltage source shall be current-limited and configured before connection;\nbattery emulator preferred for fault injection; flight Li-ion overcharge or\ndestructive abuse is out of scope and requires certified/accredited evidence." {
    class: note
    shape: page
  }
  note_stats: "[C] Statistical significance:\nbinary protection trials use exact one-sided binomial bounds;\n299 independent zero-missed-demand trials are required to claim\nprotection failure probability <1% at 95% confidence; smaller samples are\nfinal-acceptance functional screening only." {
    class: note
    shape: page
  }
  note_fault: "[C] Fault-hardening coverage:\novervoltage, wrong/reverse charger hold, unsafe restore prevention,\nrail brownout/reset, overheating, and Li-ion unsafe condition shall be\nobserved or dispositioned." {
    class: note
    shape: page
  }
}

chain.read_ambient -> chain.verify_calibration_status: "[FE] Ambient precheck" { class: fe }
chain.verify_calibration_status -> chain.configure_battery_emulator: "[FE] Verified equipment" { class: fe }
chain.configure_battery_emulator -> chain.configure_overvoltage_source: "[FE] Safe supply baseline" { class: fe }
chain.configure_overvoltage_source -> chain.set_overvoltage_limits: "[FE] Source configured" { class: fe }
chain.set_overvoltage_limits -> chain.arm_logging_safety: "[FE] Safe demand limits" { class: fe }
chain.arm_logging_safety -> chain.switch_power_on: "[FE] Ready for energized trial" { class: fe }
chain.switch_power_on -> chain.restore_power_initial: "[FE] Power-on command" { class: fe }
chain.restore_power_initial -> chain.regulate_nominal_rails: "[FE] Protected power restored" { class: fe }
chain.regulate_nominal_rails -> chain.verify_pre_fault_nominal: "[FE] Nominal rails" { class: fe }
chain.verify_pre_fault_nominal -> chain.command_overvoltage_demand: "[FE] Pre-fault state accepted" { class: fe }
chain.command_overvoltage_demand -> chain.inject_overvoltage: "[FE] Overvoltage profile" { class: fe }
chain.inject_overvoltage -> chain.detect_overvoltage: "[FE] Current-limited overvoltage" { class: fe }
chain.detect_overvoltage -> chain.cut_off_power: "[FE] Overvoltage detected" { class: fe }
chain.cut_off_power -> chain.verify_safe_state: "[FE] Power cut-off state" { class: fe }
chain.verify_safe_state -> chain.monitor_temperature_cell: "[FE] Rails/current safe" { class: fe }
chain.monitor_temperature_cell -> chain.record_cutoff_evidence: "[FE] Thermal/cell safe" { class: fe }
chain.record_cutoff_evidence -> chain.remove_overvoltage_demand: "[FE] Fault trial recorded" { class: fe }
chain.remove_overvoltage_demand -> chain.inhibit_restore_until_cleared: "[FE] Cleared overvoltage status" { class: fe }
chain.inhibit_restore_until_cleared -> chain.command_controlled_restore: "[FE] Restore permitted" { class: fe }
chain.command_controlled_restore -> chain.restore_power_after_clear: "[FE] Controlled restore command" { class: fe }
chain.restore_power_after_clear -> chain.verify_nominal_recovery: "[FE] Recovered protected power" { class: fe }
chain.verify_nominal_recovery -> chain.classify_trial: "[FE] Recovery/no-reset evidence" { class: fe }
chain.classify_trial -> chain.archive_evidence: "[FE] Pass/fail trial classification" { class: fe }
