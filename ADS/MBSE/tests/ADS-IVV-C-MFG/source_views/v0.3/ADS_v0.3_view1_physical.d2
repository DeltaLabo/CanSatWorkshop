vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view
# ADS v0.3 only delivers the ADS PCB and the physical components mounted on it.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS v0.3 PCB Delivery" {
  class: sys
  direction: right

  ads_pcb: "[PC] ADS PCB" {
    class: pc
    direction: right

    gps: "[PC] UBX-G7020-KT GPS" { class: pc }
    backplane_connector: "[PC] Backplane Connector" { class: pc }
    imu: "[PC] ICM20948 IMU" { class: pc }
  }
}

manufacturing_note: "[C] Can be manufactured\nin a Carvera Air CNC,\nand soldered via reflux\nor manually" {
  class: note
  shape: page
}

system.ads_pcb.gps -- system.ads_pcb: "[PL] GPS\nFootprint" { class: pl }
system.ads_pcb.imu -- system.ads_pcb: "[PL] ICM20948\nFootprint" { class: pl }
system.ads_pcb.backplane_connector -- system.ads_pcb: "[PL] Connector\nFootprint" { class: pl }

system.ads_pcb.backplane_connector -- system.ads_pcb.gps: "[PL] UART\ntraces" { class: pl }
system.ads_pcb.backplane_connector -- system.ads_pcb.gps: "[PL] 3V3 power\ntraces" { class: pl }
system.ads_pcb.backplane_connector -- system.ads_pcb.imu: "[PL] I2C\ntraces" { class: pl }
system.ads_pcb.backplane_connector -- system.ads_pcb.imu: "[PL] 3V3 power\ntraces" { class: pl }

manufacturing_note -> system.ads_pcb { class: cstr }
