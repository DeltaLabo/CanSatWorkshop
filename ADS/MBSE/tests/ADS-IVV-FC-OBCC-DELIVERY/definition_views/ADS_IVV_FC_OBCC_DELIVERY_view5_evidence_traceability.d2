vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Evidence and traceability view for ADS-IVV-FC-OBCC-DELIVERY.
# PV2-style view: evidence-producing interfaces, traceability targets, and expected report artifacts.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-FC-OBCC-DELIVERY\nevidence and traceability view\nRefs: IVV; ADS MBSE plan; NASA-SE; SW/stats" {
  class: sys
  direction: down

  uut: "[PC] v1.0 integrated ADS/OBCC UUT" {
    class: pc
    direction: down
    xiao: "[PC] OBCC XIAO ESP32-S3" {
      class: pc
      direction: down
      grid-columns: 3
      ads_processing: "[LC] ADS Processing\nsource data/handles" { class: lc }
      obcc: "[LC] OBCC\ncollection consumer" { class: lc }
      evidence_if: "[LC] Verification evidence\ninterface" { class: lc }
    }
  }
}

source_baseline: "[EA] Source-view baseline package\nsource_views/v0.1..v1.0" { class: ea }
obcc_log_harness: "[EA] OBCC firmware / log harness\nraw logs + timing + heartbeat" { class: ea }
ads_stim_logger: "[EA] ADS stimulus/logger\nfault markers + ADS data context" { class: ea }
pointer_review_station: "[EA] Pointer/freshness monitor\nand code-review station" { class: ea }
analysis_script: "[EA] Analysis script\ncoverage, timing, fault verdicts" { class: ea }
report_store: "[EA] Expected report store\n../results/ADS-IVV-FC-OBCC-DELIVERY/v1.0/" { class: ea }
configuration_authority: "[EA] Quality / configuration authority\nreview, waivers, retest status" { class: ea }

trace_delivery: "[C] Trace target: ADS-CAP-DELIVERY\nOBCC receives only modeled ADS data/handles through\nPointers/Returns with explicit status/error behavior." { class: note; shape: page }
trace_corrupt: "[C] Trace target: ADS-FE-CORRUPT-MEASUREMENT\nNull, dangling, stale, corrupt, and invalid-return cases\nshall not be consumed as valid measurements." { class: note; shape: page }
trace_stuck: "[C] Trace target: ADS-FE-STUCK-LOOP\nNo unexpected blocking; timing watchdog and linked source\nconstraints are reported with actual evidence." { class: note; shape: page }
trace_constraints: "[C] Linked constraints\nNo blocking except I2C/UART; Variable Getter template;\nprocess/calculate <5 ms; UART read timeout <=5 ms;\nI2C read timeout <=5 ms. Accuracy constraints are covered\nby GPS/ANG tests and preserved here by non-corruption checks." { class: note; shape: page }
trace_status: "[C] Report status data\nReport shall identify model baseline, source views, UUT serial,\nhardware revision, firmware commit, equipment IDs, actual\nconditions, raw evidence, analysis settings, deviations,\nanomalies, waivers, pass/fail rationale, and retest status." { class: note; shape: page }

source_baseline -> system.uut.xiao.ads_processing: "[CE] copied source inventory\nviews 1-7 and N/A rationale" { class: ce }
system.uut.xiao.ads_processing -> system.uut.xiao.obcc: "[CE] P/R" { class: ce }
system.uut.xiao.obcc -> system.uut.xiao.evidence_if: "[CE] Ev." { class: ce }
system.uut.xiao.evidence_if -> obcc_log_harness: "[CE] raw delivery logs\ntimestamps + heartbeat" { class: ce }
ads_stim_logger -> obcc_log_harness: "[CE] stimulus and fault\ncase markers" { class: ce }
pointer_review_station -> analysis_script: "[CE] contract analysis\nand lifetime findings" { class: ce }
obcc_log_harness -> analysis_script: "[CE] log files and\ntiming records" { class: ce }
ads_stim_logger -> analysis_script: "[CE] ADS data context\nand fault annotations" { class: ce }
analysis_script -> report_store: "[CE] metrics, plots,\npass/fail inputs" { class: ce }
configuration_authority -> report_store: "[CE] review disposition\nwaivers / retest status" { class: ce }

trace_delivery -> system.uut.xiao.ads_processing { class: cstr }
trace_delivery -> system.uut.xiao.obcc { class: cstr }
trace_corrupt -> pointer_review_station { class: cstr }
trace_corrupt -> analysis_script { class: cstr }
trace_stuck -> obcc_log_harness { class: cstr }
trace_stuck -> analysis_script { class: cstr }
trace_constraints -> system.uut.xiao.ads_processing { class: cstr }
trace_constraints -> system.uut.xiao.obcc { class: cstr }
trace_status -> report_store { class: cstr }

# Layout-only rank hints.
source_baseline -> obcc_log_harness { style: { opacity: 0 } }
obcc_log_harness -> ads_stim_logger { style: { opacity: 0 } }
ads_stim_logger -> pointer_review_station { style: { opacity: 0 } }
pointer_review_station -> analysis_script { style: { opacity: 0 } }
analysis_script -> report_store { style: { opacity: 0 } }
report_store -> configuration_authority { style: { opacity: 0 } }
system -> trace_delivery { style: { opacity: 0 } }
trace_delivery -> trace_corrupt { style: { opacity: 0 } }
trace_corrupt -> trace_stuck { style: { opacity: 0 } }
trace_stuck -> trace_constraints { style: { opacity: 0 } }
trace_constraints -> trace_status { style: { opacity: 0 } }
