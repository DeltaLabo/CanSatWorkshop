vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PDM-V01-FC-FALL evidence/report and traceability chain.
# Functional chain view: chain, functions, FEs, and constraints only.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDM-V01-FC-FALL — Evidence/report and traceability chain\nRefs: PDM_v0.1 views 1-4; PM&SE/IVV.md; PM&SE/CON-003_Candidates_and_Definition_Blockers.md" {
  class: chain
  direction: down

  reference_model: "[F] Reference modeled\nverification definition" { class: func }
  retain_raw_video: "[F] Retain raw video\nand calibration media" { class: func }
  retain_raw_calibrations: "[F] Retain scale records\nand calibration artifacts" { class: func }
  retain_mass: "[F] Retain as-tested\nUUT mass/configuration" { class: func }
  retain_environment: "[F] Retain ambient\nand wind records" { class: func }
  retain_analysis: "[F] Retain speed trace\n+ uncertainty method" { class: func }
  retain_analysis_script: "[F] Retain analysis\nworksheets/scripts" { class: func }
  retain_segment_rationale: "[F] Retain accepted/rejected\nsegment rationale" { class: func }
  retain_repeat_results: "[F] Retain per-run\nrepeat-level results" { class: func }
  record_deviations: "[F] Record deviations,\nanomalies, waivers" { class: func }
  generate_report: "[F] Generate verification\nreport under results/PDM-V01-FC-FALL/" { class: func }
  trace_result: "[F] Trace result to use case,\nfeared event, and constraints" { class: func }

  report_path: "[C] Expected report/evidence location:\nPDM/MBSE/v0.1/tests/results/\nPDM-V01-FC-FALL/" { class: note; shape: page }
  traceability_targets: "[C] Traceability targets:\nPDM-UC-V01-FallTestTerminalSpeed;\nPDM-UC-V01-PrepareManualParachute;\nPDM-FE-V01-ExcessDescentSpeed;\nconstraints in source views." { class: note; shape: page }
  report_minimum: "[C] Report minimum:\nmodel baseline; as-tested configuration;\nraw evidence; pass/fail rationale;\ndeviations/anomalies/waivers;\nassumptions/limitations\nand repeat-level interpretation." { class: note; shape: page }
  status_constraint: "[C] Definition status:\nModel defined; execution/report pending\nuntil evidence is captured." { class: note; shape: page }
  required_evidence_gate: "[C] Strict evidence requirements:\nraw video + calibration artifacts;\nscale IDs, IDs/calibration and results;\nmass/config records; environment/wind records;\nanalysis worksheet/script; accepted/rejected\nsegment rationale; repeat-level results;\ndeviations/anomalies/waivers." { class: note; shape: page }
}

chain.reference_model -> chain.retain_raw_video: "[FE] model definition reference []" { class: fe }
chain.retain_raw_video -> chain.retain_raw_calibrations: "[FE] raw evidence index []" { class: fe }
chain.retain_raw_calibrations -> chain.retain_mass: "[FE] scale evidence index []" { class: fe }
chain.retain_mass -> chain.retain_environment: "[FE] mass/config record []" { class: fe }
chain.retain_environment -> chain.retain_analysis: "[FE] environment log []" { class: fe }
chain.retain_analysis -> chain.retain_analysis_script: "[FE] trace method []" { class: fe }
chain.retain_analysis_script -> chain.retain_segment_rationale: "[FE] segment rationale []" { class: fe }
chain.retain_segment_rationale -> chain.retain_repeat_results: "[FE] per-run results []" { class: fe }
chain.retain_repeat_results -> chain.record_deviations: "[FE] deviations/anomalies []" { class: fe }
chain.record_deviations -> chain.generate_report: "[FE] evidence complete []" { class: fe }
chain.generate_report -> chain.trace_result: "[FE] report []" { class: fe }

chain.report_path -> chain.generate_report { class: cstr }
chain.traceability_targets -> chain.trace_result { class: cstr }
chain.report_minimum -> chain.generate_report { class: cstr }
chain.status_constraint -> chain.reference_model { class: cstr }
chain.required_evidence_gate -> chain.generate_report { class: cstr }
