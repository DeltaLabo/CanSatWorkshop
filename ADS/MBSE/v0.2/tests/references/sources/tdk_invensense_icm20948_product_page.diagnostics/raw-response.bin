eld_app_key_highlight_title\":null,\"field_application_section_title\":\"Applications in action\",\"field_app_section_paragraphs\":[],\"field_app_section_sub_title\":null,\"field_apps_related_to_category\":[{\"id\":\"18\",\"label\":\"Hearables\"},{\"id\":\"39\",\"label\":\"Wearables\"},{\"id\":\"115\",\"label\":\"Robotics \u0026 Drones \"},{\"id\":\"55\",\"label\":\"Gaming\"},{\"id\":\"89\",\"label\":\"Drones\"}],\"field_category_header_image\":null,\"field_category_image\":null,\"field_category_short_description\":null,\"field_category_thumbnail_image\":null,\"field_category_title\":\" 6-Axis MEMS Motion Sensors\",\"field_dedicated_bundled_software\":null,\"field_dedicated_softwares\":[],\"field_dedicate_software_subtitle\":null,\"field_description\":\"$32\",\"field_development_hardware_title\":null,\"field_development_products\":[],\"field_dev_hardware_subtitle\":null,\"field_explore_more_apps\":{\"title\":\"Explore more applications\",\"url\":\"\"},\"field_external_url\":null,\"field_featured_news_section\":[],\"field_featured_products\":[{\"id\":\"27\",\"label\":\"ICM-42686-P\"}],\"field_featured_section_sub_title\":null,\"field_featured_section_title\":null,\"field_featured_video_section\":null,\"field_features_and_benefits_grid\":[],\"field_features_and_benefit_subti\":null,\"field_features_and_benefit_title\":null,\"field_git_hub_resources_section\":[],\"field_github_resources_title\":null,\"field_hero_primary_button\":{\"title\":\"Contact Us\",\"url\":\"\"},\"field_hero_secondary_button\":{\"title\":\"Browse Products\",\"url\":\"\"},\"field_hero_section_sub_title\":\"6-Axis MotionTracking\",\"field_key_features_highlights\":[{\"id\":\"93\",\"label\":\"6-Axis \u003e key features highlights\"}],\"field_link\":null,\"field_meta_tags\":null,\"field_product_spotlight_sub_titl\":null,\"field_product_spotlight_title\":\"Product spotlight\",\"field_published_date\":null,\"field_short_description\":\"InvenSense’s 6-axis family of motion sensors with a 3‑axis gyroscope and a 3‑axis accelerometer on the same silicon die are the highest performance sensors in the market with the lowest noise, best temperature stability, and highest sensitivity accuracy.\",\"field_spotlight_products\":[{\"id\":\"9\",\"label\":\"EV_ICM-42686‐P\"}],\"field_sub_category_grid_section\":[],\"field_sub_category_intro_paras\":[],\"field_sub_category_intro_title\":null,\"field_sub_category_section_subti\":null,\"field_sub_category_section_title\":null,\"field_video_alignment\":null},\"field_description\":\"\u003cp\u003eThe BalancedGyro technology by TDK is the first‑of‑its‑kind gyroscope MEMS architecture that enables supreme vibration rejection and temperature stability performance, an enhancement never seen before in a consumer\u0026nbsp;gyroscope.\u003c/p\u003e\u003cp\u003eThis family offers the world’s lowest power 6‑axis motion sensor. This allows the gyroscope to be on 40% of the times more than any other gyroscope in the industry. This also offers the very first Gyroscope Low Power Mode, enabling ~200 µA of 6-axis IMU current consumption, making it the top choice for wearables, hearables and any battery driven IoT application.\u003c/p\u003e\",\"field_documentation_resource\":[{\"id\":\"144\",\"label\":\"DS-000576 – ICM-45605 Datasheet\",\"slug\":\"/ds-000576-icm-45605-datasheet\",\"nid\":\"144\",\"uuid\":\"2d0e5f53-8c7d-4834-8cfc-5bcac0e8df36\",\"vid\":\"9316\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1773849472\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"0\",\"label\":\"Anonymous\"},\"title\":\"DS-000576 – ICM-45605 Datasheet\",\"created\":\"1761077879\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"Datasheet for the ICM-45605, a high-precision 6-axis MEMS MotionTracking® device\",\"field_file\":{\"id\":\"971\",\"label\":\"1a92775a-a4f7-4655-a6ba-8e423417d579.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"25\",\"label\":\"Datasheet\"},\"field_updated_date\":\"2024-07-25\",\"field_version\":\"1.0\"},{\"id\":\"2169\",\"label\":\"AN-000393 – IMU PCB Design and MEMS Assembly Guidelines\",\"slug\":\"/000393-imu-pcb-design-and-mems-assembly-guidelines\",\"nid\":\"2169\",\"uuid\":\"8c9f57db-7a66-437e-9db2-6984494fbf32\",\"vid\":\"10161\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1780333281\",\"revision_uid\":{\"id\":\"124658\",\"label\":\"jimlin\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000393 – IMU PCB Design and MEMS Assembly Guidelines\",\"created\":\"1771635625\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"This document provides high-level PCB design, sensor mounting, and handling guidelines for TDK IMU Products, which incorporate a combination of gyroscopes and accelerometers. Each sensor has specific requirements to ensure the highest performance in a finished product. For a layout assessment of your design, including placement and estimated temperature disturbances, please contact TDK.\",\"field_file\":{\"id\":\"1225\",\"label\":\"AN-000393 TDK InvenSense IMU PCB Design and MEMS Assembly Guidelines v2.4.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2026-06-01\",\"field_version\":\"2.4\"},{\"id\":\"2121\",\"label\":\"AN-000257 – Understanding IMU Sensor Offset\",\"slug\":\"/000257-understanding-imu-sensor-offset-1\",\"nid\":\"2121\",\"uuid\":\"d56e5631-13a7-478c-899c-3f713010251e\",\"vid\":\"2894\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_tim