vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view — AMS-V01-INTEG-001 v0.1 breadboard readiness inspection
# IADT: Inspection with supporting analysis. SSIV gate: AMS v0.1 breadboard/subsystem to v0.2 PCB delivery.
# References: IVV, AMS-R1 (BME280), AMS-R2 (I2C), AMS-R6 (CanSat build environment).
# Traceability: AMS-v0.1-to-v0.2-readiness; AMS-UC-MeasureAtmosphere; AMS-UC-InitializePeripheral; AMS-FE-SensorBusFault.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

test_operator: "[EA] Test operator\ninspection authority" { class: ea }
esd_bench: "[EA] ESD bench\nmat + wrist strap" { class: ea }
dmm: "[EA] DMM /\ncontinuity meter" { class: ea }

system: "[System] AMS-V01-INTEG-001 readiness inspection\nAMS v0.1 → v0.2 PCB gate\nRefs: IVV, AMS-R1, AMS-R2, AMS-R6" {
  class: sys
  direction: right

  bme280: "[PC] BME280\nv0.1 breadboard item" { class: pc }
  xiao: "[PC] XIAO ESP32\nv0.1 controller" { class: pc }
}

i2c_scanner: "[EA] I2C scanner /\nlogic analyzer" { class: ea }
bench_power: "[EA] Bench power\nUSB/5V source" { class: ea }
host_pc: "[EA] PC / USB host\nSerial terminal" { class: ea }
inspection_camera: "[EA] Camera /\nchecklist station" { class: ea }

note_scope: "[C] Inspection scope: 100% census of v0.1\nUUT PCs and PLs. VV-only equipment links\nare excluded from target counts." {
  class: note
  shape: page
}
note_identity: "[C] Pass iff BME280, XIAO ESP32, and\nhost PC/serial terminal are present, identifiable,\ncorrect for v0.1, and undamaged." {
  class: note
  shape: page
}
note_wiring: "[C] Pass iff I2C SDA/SCL, 3V3, and GND\nwiring connects the modeled endpoints with\ncorrect pin identity and polarity." {
  class: note
  shape: page
}
note_no_open_short: "[C] Fail on open conductor, short to adjacent\nline/rail, reversed SDA/SCL, reversed 3V3/GND,\nloose jumper, or unaudited bypass." {
  class: note
  shape: page
}
note_usb_serial: "[C] Pass iff the USB-C cable to the host PC\nis present and supports serial-terminal evidence\nfor init and measurement logging." {
  class: note
  shape: page
}
note_pcb_ready: "[C] v0.2 PCB-readiness pass condition:\nwire colors/routes/endpoints are documented well\nenough to convert jumpers into PCB traces." {
  class: note
  shape: page
}
note_stat_fault: "[C] Statistical viewpoint: 100% census of\n3 target PCs and 4 target PLs, no sampling claim.\nFault hardening: wrong item, open, short, reversed,\nintermittent, or unapproved substitution fails." {
  class: note
  shape: page
}
note_environment: "[C] Inspection environment: UUT on ESD bench;\nbench power current-limited; continuity checks power-off\nunless serial/I2C evidence is intentionally captured." {
  class: note
  shape: page
}

# Target v0.1 physical links from the source model.
system.bme280 -- system.xiao: "[PL] I2C Cables\nTARGET" { class: pl }
system.bme280 -- system.xiao: "[PL] 3V3\nTARGET" { class: pl }
system.bme280 -- system.xiao: "[PL] GND\nTARGET" { class: pl }
system.xiao -- host_pc: "[PL] USB-C Cable\nTARGET" { class: pl }

# Verification-only physical links to inspection/test means.
test_operator -- system: "[PL] manual\ninspection access" { class: pl }
esd_bench -- system: "[PL] ESD-safe\nsupport" { class: pl }
dmm -- system: "[PL] probe contact\nfor continuity" { class: pl }
i2c_scanner -- system.xiao: "[PL] SDA/SCL\nprobe clip" { class: pl }
bench_power -- system.xiao: "[PL] controlled\nUSB/5V supply" { class: pl }
inspection_camera -- system: "[PL] optical\ninspection" { class: pl }

note_scope -> system { class: cstr }
note_identity -> system { class: cstr }
note_identity -> host_pc { class: cstr }
note_wiring -> dmm { class: cstr }
note_wiring -> system { class: cstr }
note_no_open_short -> dmm { class: cstr }
note_no_open_short -> i2c_scanner { class: cstr }
note_usb_serial -> system.xiao { class: cstr }
note_usb_serial -> host_pc { class: cstr }
note_pcb_ready -> system { class: cstr }
note_stat_fault -> system { class: cstr }
note_environment -> esd_bench { class: cstr }
note_environment -> bench_power { class: cstr }
