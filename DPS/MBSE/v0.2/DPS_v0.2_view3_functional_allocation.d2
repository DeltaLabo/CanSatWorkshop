vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional allocation view
# DPS v0.2 adds IMU-only processing and downlink data while keeping all hardware on circuitboards.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] Physical System" {
  class: sys
  direction: down
  grid-columns: 1

  datalogger_board: "[PC] Datalogger Circuitboard" {
    class: pc
    direction: right
    grid-columns: 3

    imu: "[PC] ICM20948 IMU" {
      class: pc
      direction: down

      imu_sensing: "[LC] IMU Sensing" {
        class: lc
        direction: down
        grid-columns: 2

        measure_angular_velocities: "[F] Measure angular\nvelocities" { class: func }
        measure_accelerations: "[F] Measure\naccelerations" { class: func }
        measure_magnetic_field_intensities: "[F] Measure magnetic\nfield intensities" { class: func }
        respond_i2c_requests: "[F] Respond to I2C\nRequests" { class: func }
      }

      note_accuracy_angular_rate: "[C] Accuracy\n< 30 deg/s" {
        class: note
        shape: page
      }
    }

    cansat_xiao: "[PC] XIAO ESP32-S3" {
      class: pc
      direction: down
      grid-columns: 2

      dummy_datalogger: "[LC] Dummy Datalogger" {
        class: lc
        direction: down
        cansat_receive_lora_rx_interrupt: "[F] Receive LoRa\nRX Interrupt" { class: func }
        send_lora_packet: "[F] Send LoRa packet" { class: func }
        datalogger_read_command: "[F] Read command" { class: func }
      }

      ams_processing_imu_only: "[LC] AMS Processing IMU Only" {
        class: lc
        direction: down
        grid-columns: 3

        read_angular_velocities: "[F] Read angular\nvelocities" { class: func }
        read_accelerations: "[F] Read\naccelerations" { class: func }
        read_field_intensities: "[F] Read field\nintensities" { class: func }
        process_angular_velocities: "[F] Process angular\nvelocities" { class: func }
        process_accelerations: "[F] Process\naccelerations" { class: func }
        calculate_pitch_roll_yaw: "[F] Calculate\npitch, roll, yaw" { class: func }
        collect_measurements: "[F] Collect IMU\nmeasurements" { class: func }

        note_at_5hz: "[C] At 5 Hz" {
          class: note
          shape: page
        }
      }

      note_no_blocking: "[C] No blocking\noperations besides\nI2C or SPI comms" {
        class: note
        shape: page
      }
      note_variable_getter: "[C] Implement each\n(Read X, Process X) or\n(Read X, Calculate Y)\npair as a Variable\nGetter template" {
        class: note
        shape: page
      }
      note_process_time: "[C] All Process or\nCalculate functions\nmust take < 5 ms" {
        class: note
        shape: page
      }
    }

    cansat_rfm: "[PC] RFM95W LoRa" {
      class: pc
      direction: down

      cansat_lora: "[LC] LoRa Transceiver" {
        class: lc
        direction: down
        cansat_receive_incoming_data: "[F] Receive incoming data" { class: func }
        cansat_transmit_outgoing_data: "[F] Transmit outgoing data" { class: func }
      }
    }
  }

  note_separation: "[C] Max. separation of 500m\nbetween datalogger circuitboard\nand ground station" {
    class: note
    shape: page
  }

  ground_station_board: "[PC] Ground Station Circuitboard" {
    class: pc
    direction: right
    grid-columns: 2

    ground_rfm: "[PC] RFM95W LoRa" {
      class: pc
      direction: down

      ground_lora: "[LC] LoRa Transceiver" {
        class: lc
        direction: down
        ground_store_incoming_data: "[F] Store incoming data" { class: func }
        ground_transmit_outgoing_data: "[F] Transmit outgoing data" { class: func }
      }
    }

    ground_xiao: "[PC] XIAO ESP32" {
      class: pc
      direction: down

      ground_forwarder: "[LC] LoRa Forwarder" {
        class: lc
        direction: down
        grid-columns: 3

        init_serial0_with_interrupts: "[F] Init Serial0 with\ninterrupts" { class: func }
        init_spi_with_interrupts: "[F] Init SPI with\ninterrupts" { class: func }
        log_error: "[F] Log error" { class: func }
        ground_receive_lora_rx_interrupt: "[F] Receive LoRa\nRX Interrupt" { class: func }
        read_payload: "[F] Read payload" { class: func }
        forward_to_pc: "[F] Forward to PC" { class: func }
        store_incoming_uart_data: "[F] Store incoming\nUART data" { class: func }
        receive_serial0_rx_interrupt: "[F] Receive Serial0\nRX Interrupt" { class: func }
        forwarder_read_command: "[F] Read command" { class: func }
        generate_frame: "[F] Generate frame" { class: func }
        write_to_lora_radio: "[F] Write to\nLoRa Radio" { class: func }
      }
    }
  }

  pc: "[PC] PC" {
    class: pc
    direction: down
    grid-columns: 2

    decoder: "[LC] Decoder" {
      class: lc
      direction: down
      grid-columns: 3

      check_if_data_is_available: "[F] Check if data\nis available" { class: func }
      read_and_decode_frame: "[F] Read and\ndecode frame" { class: func }
      push_to_payload_queue: "[F] Push to\npayload queue" { class: func }
      get_rx_timestamp: "[F] Get RX\ntimestamp" { class: func }
      calculate_latency: "[F] Calculate\nlatency" { class: func }
      forward_to_transceiver: "[F] Forward to\ntransceiver" { class: func }
      consume_command_queue: "[F] Consume\ncommand queue" { class: func }
    }

    csv_writer: "[LC] CSV Writer" {
      class: lc
      direction: down

      csv_consume_payload_queue: "[F] Consume\npayload queue" { class: func }
      append_to_csv: "[F] Append to CSV" { class: func }

      note_csv_name: "[C] Give each CSV a\nunique name based\non the initial\ntimestamp" {
        class: note
        shape: page
      }
    }

    dashboard: "[LC] Dashboard" {
      class: lc
      direction: down
      grid-columns: 2

      dashboard_consume_payload_queue: "[F] Consume\npayload queue" { class: func }
      update_orientation_3d_plot: "[F] Update orientation\n3D plot" { class: func }
      update_rel_humidity_2d_plot: "[F] Update rel.\nhumidity 2D plot" { class: func }
      push_to_command_queue: "[F] Push to\ncommand queue" { class: func }
      update_temperature_2d_plot: "[F] Update temperature\n2D plot" { class: func }
      update_altitude_2d_plot: "[F] Update altitude\n2D plot" { class: func }
      catch_state_toggle: "[F] Catch State\ntoggle" { class: func }
      update_latency_alert: "[F] Update latency\nalert" { class: func }
      disable_toggle: "[F] Disable\ntoggle" { class: func }
      enable_toggle: "[F] Enable\ntoggle" { class: func }
      cooldown: "[F] Cooldown" { class: func }
      create_plots: "[F] Create plots" { class: func }

      note_orientation_jitter: "[C] No perceptible\norientation jitter" {
        class: note
        shape: page
      }
    }

    note_alert: "[C] Show text alert at\nthe top of the\ndashboard when\nLatency > 1s" {
      class: note
      shape: page
    }

    note_cooldown: "[C] 5 seconds" {
      class: note
      shape: page
    }

    note_plots: "[C] A 4x4 matrix of\nplots, 3D on top left" {
      class: note
      shape: page
    }

    usb_port: "[PC] USB Port" {
      class: pc
      direction: down

      usb_power: "[LC] USB Power" {
        class: lc
        direction: down
        provide_power: "[F] Provide power" { class: func }
      }
    }

    note_concurrent: "[C] Concurrent\nexecution" {
      class: note
      shape: page
    }

    note_browser: "[C] Accesible via\na web browser" {
      class: note
      shape: page
    }
  }
}

system.datalogger_board.imu.note_accuracy_angular_rate -> system.datalogger_board.imu.imu_sensing.measure_angular_velocities { class: cstr }
system.datalogger_board.cansat_xiao.ams_processing_imu_only.note_at_5hz -> system.datalogger_board.cansat_xiao.ams_processing_imu_only.collect_measurements { class: cstr }
system.datalogger_board.cansat_xiao.note_no_blocking -> system.datalogger_board.cansat_xiao.ams_processing_imu_only { class: cstr }
system.datalogger_board.cansat_xiao.note_variable_getter -> system.datalogger_board.cansat_xiao.ams_processing_imu_only { class: cstr }
system.datalogger_board.cansat_xiao.note_process_time -> system.datalogger_board.cansat_xiao.ams_processing_imu_only { class: cstr }
system.pc.csv_writer.note_csv_name -> system.pc.csv_writer.append_to_csv { class: cstr }
system.pc.dashboard.note_orientation_jitter -> system.pc.dashboard.update_orientation_3d_plot { class: cstr }
system.pc.note_alert -> system.pc.dashboard.update_latency_alert { class: cstr }
system.pc.note_cooldown -> system.pc.dashboard.cooldown { class: cstr }
system.pc.note_plots -> system.pc.dashboard.create_plots { class: cstr }
system.pc.note_concurrent -> system.pc.decoder { class: cstr }
system.pc.note_concurrent -> system.pc.csv_writer { class: cstr }
system.pc.note_concurrent -> system.pc.dashboard { class: cstr }
system.pc.note_browser -> system.pc.dashboard { class: cstr }
system.note_separation -- system.datalogger_board { class: cstr }
system.note_separation -- system.ground_station_board { class: cstr }

# Layout-only edges to preserve the physical deployment bands.
system.datalogger_board -> system.note_separation { style: { opacity: 0 } }
system.note_separation -> system.ground_station_board { style: { opacity: 0 } }
system.ground_station_board -> system.pc { style: { opacity: 0 } }
