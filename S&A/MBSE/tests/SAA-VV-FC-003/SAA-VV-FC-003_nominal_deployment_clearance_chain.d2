vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-003 verification-only Functional Chain view.
# Nominal demonstration/testing scenario for v1.0 parachute/top-module clearance and deployment-interference.
# References cited in the rendered chain title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# This chain defines the verification activity only; it is not a baseline S&A functional chain.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

nominal_chain: "[Functional Chain] SAA-VV-FC-003 Nominal Parachute Deployment / Clearance Demonstration-Test\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: chain
  direction: down

  identify: "[F] Operator: identify v1.0\narticle, build record, baseline copy,\nand SAA-VV-FC-003 definition" { class: func }
  record_ambient: "[F] Ambient meter: record\ntemperature, humidity, fixture setting,\nactuation method, camera settings,\nand pre/post screen status" { class: func }
  pre_inspect: "[F] Operator/Witness: inspect\npre-test PCs/PLs: stack screws,\ntop module, backplane fixture,\nPDM servo connector, PCBs,\nstandoffs, and battery fixture" { class: func }
  setup_camera_gauges: "[F] Camera / gauge team:\nset FOV, lighting, frame rate,\nclearance gauge and snag witness\nmarkers for cap/backplane path" { class: func }
  pack_close: "[F] Operator: pack parachute\nwith reset fixture, close cap,\nand verify serviceable ready state" { class: func }
  command_open: "[F] Servo interface: command\nor manually actuate open-cap / servo\nmotion with hands clear" { class: func }
  observe_motion: "[F] Camera: capture cap,\nservo and parachute extraction path" { class: func }
  assess_clearance: "[F] Gauge/Witness: assess\ncap and servo clearance to structure,\nbackplane spine and PDM servo connector" { class: func }
  assess_extraction: "[F] Operator/Witness: confirm\nparachute extracted without snag,\nhang-up, hand assist, or dragging UUT" { class: func }
  post_inspect: "[F] Inspection kit: check\nno connector, backplane, module,\nscrew, standoff, or battery-fixture\nmovement after the trial" { class: func }
  reset: "[F] Operator: reset cap, servo\nand parachute to serviceable closed state\nwithout unapproved rework" { class: func }
  log_trial: "[F] Trial log: record pass/fail,\npack condition, command method,\nvideo/evidence IDs and reset result" { class: func }
  repeat: "[F] Test team: repeat until\n10/10 workshop screen or 29/29\nR90/C95 zero-snag plan is complete" { class: func }
  apply_gate: "[F] Acceptance gate: apply\nclearance, extraction, retention,\nserviceability, statistical and evidence\npass/fail criteria" { class: func }
  witness_review: "[F] Safety / QA Witness:\napprove pass, fail, or execution hold" { class: func }
  release_package: "[F] Evidence repository:\nrelease report-by-reference package\nunder results/SAA-VV-FC-003" { class: func }

  pass_fail: "[C] Pass/fail constraints: Every accepted trial requires\ncap and servo motion to clear the top-module structure,\nstandard stack, backplane spine and PDM servo connector;\nparachute extraction without snagging, hang-up, hand\nassistance, dragging the UUT, or ambiguous video;\nreset/serviceability preserved; no connector, backplane,\nmodule, screw, PCB standoff or battery-fixture movement\nintroduced; pre/post PC-PL checks complete; all\nanomalies closed and affected trials re-run." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint: Workshop screen\nrequires 10 repeated deployments with zero snags and\nzero disallowed movement. Do not claim R90/C95\nreliability unless 29 representative independent\nzero-snag deployments are executed and documented.\nRepeated trials on one pack/setup are screening unless\nindependence is justified in the report." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint: The nominal chain blocks\nfalse pass by using pre/post PC-PL inspection, visible\ncap/backplane/PDM connector clearance markers,\nhigh-speed video, no-hand-assist witness control, and\nhold on cap rub, packed-parachute variability,\npost-vibration/drop looseness, ambiguous evidence, or\nany movement." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental/equipment conditions: Record ambient\ntemperature/humidity, camera frame rate/FOV/lighting,\nfixture setting, gauge IDs, actuation method,\noperator/witness identity, pre/post environmental-screen\nstatus, and evidence IDs before and during repetitions." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target: SAA-UC-ParachuteClearance;\nSAA-FE-StructuralLoosening; SAA-FE-LandingDamage; v1.0\ntop-module/backplane physical links and modeled\nenvelope, landing-impact, assembly/printing and\nbackplane/servo-connector constraints." {
    class: note
    shape: page
  }
}

nominal_chain.identify -> nominal_chain.record_ambient: "[FE] Article and baseline\nidentified" { class: fe }
nominal_chain.record_ambient -> nominal_chain.pre_inspect: "[FE] Controlled setup\nand equipment status" { class: fe }
nominal_chain.pre_inspect -> nominal_chain.setup_camera_gauges: "[FE] Pre-test retention\nand configuration status" { class: fe }
nominal_chain.setup_camera_gauges -> nominal_chain.pack_close: "[FE] Observation and\nclearance references ready" { class: fe }
nominal_chain.pack_close -> nominal_chain.command_open: "[FE] Packed and closed\nready state" { class: fe }
nominal_chain.command_open -> nominal_chain.observe_motion: "[FE] Actuation event\nand timestamp" { class: fe }
nominal_chain.observe_motion -> nominal_chain.assess_clearance: "[FE] Cap/servo path\nvideo" { class: fe }
nominal_chain.assess_clearance -> nominal_chain.assess_extraction: "[FE] Clearance/no-rub\nstatus" { class: fe }
nominal_chain.assess_extraction -> nominal_chain.post_inspect: "[FE] Extraction/no-snag\nstatus" { class: fe }
nominal_chain.post_inspect -> nominal_chain.reset: "[FE] No-movement\nretention status" { class: fe }
nominal_chain.reset -> nominal_chain.log_trial: "[FE] Serviceable reset\nstatus" { class: fe }
nominal_chain.log_trial -> nominal_chain.repeat: "[FE] Trial result and\nevidence IDs" { class: fe }
nominal_chain.repeat -> nominal_chain.apply_gate: "[FE] Completed trial count\nor hold/fail condition" { class: fe }
nominal_chain.apply_gate -> nominal_chain.witness_review: "[FE] Pass/fail/hold\nrecommendation" { class: fe }
nominal_chain.witness_review -> nominal_chain.release_package: "[FE] Witness decision\nand evidence release" { class: fe }

# Layout-only edges keep notes after the executable chain flow.
nominal_chain.release_package -> nominal_chain.pass_fail { style: { opacity: 0 } }
nominal_chain.pass_fail -> nominal_chain.statistical { style: { opacity: 0 } }
nominal_chain.statistical -> nominal_chain.fault_hardening { style: { opacity: 0 } }
nominal_chain.fault_hardening -> nominal_chain.conditions { style: { opacity: 0 } }
nominal_chain.conditions -> nominal_chain.traceability { style: { opacity: 0 } }
