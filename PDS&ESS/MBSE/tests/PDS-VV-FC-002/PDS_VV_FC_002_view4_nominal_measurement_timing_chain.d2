vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional Chain — PDS-VV-FC-002 nominal battery-supervision measurement and timing.
# References: IVV, PDS-R9 INA219, PDS-R10 I2C.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDS-VV-FC-002 — nominal measurement and timing chain\nRefs: IVV, PDS-R9, PDS-R10" {
  class: chain
  direction: right

  command_test_case: "[F] Command nominal\ntest case" { class: func }
  read_ambient: "[F] Read ambient\nbefore repetitions" { class: func }
  configure_operating_point: "[F] Configure voltage/current\noperating point" { class: func }
  stabilize_supply_load: "[F] Stabilize supply\nand load" { class: func }
  measure_reference_vi: "[F] Measure reference\nvoltage/current" { class: func }

  get_init_state: "[F] Get INA219\ninit state" { class: func }
  read_voltage: "[F] Read voltage" { class: func }
  read_current: "[F] Read current" { class: func }
  measure_voltage: "[F] Measure voltage" { class: func }
  measure_current: "[F] Measure current" { class: func }
  respond_i2c: "[F] Respond to I2C\nrequests" { class: func }
  process_voltage: "[F] Process voltage" { class: func }
  process_current: "[F] Process current" { class: func }
  collect_init_states: "[F] Collect peripheral\ninit states" { class: func }
  collect_measurements: "[F] Collect measurements" { class: func }
  timestamp_durations: "[F] Timestamp I2C read\nand process durations" { class: func }
  log_samples: "[F] Log paired samples,\nstatus, and timing" { class: func }
  archive_evidence: "[F] Archive controlled\nevidence package" { class: func }

  definition_note: "[C] PDS-VV-FC-002 nominal path:\nTesting/Demonstration with supporting Analysis;\ntrace PDS-UC-SuperviseBattery;\nSSIV PDS & ESS v1.0 final flight acceptance" {
    class: note
    shape: page
  }
  sample_note: "[C] Statistical significance:\ncollect ≥30 paired voltage/current samples\nper operating point; raw data retained\nwith ambient and reference values" {
    class: note
    shape: page
  }
  timing_note: "[C] Deadlines:\nI2C read ≤ 5 ms;\nProcess/Calculate < 5 ms;\nuse 59/59 in-limit samples for 95/95 claim" {
    class: note
    shape: page
  }
  getter_note: "[C] Variable Getter pattern:\nall read/process pairs expose units,\nfreshness, bounded status/result;\nno stale value reported valid" {
    class: note
    shape: page
  }
  accuracy_note: "[C] Accuracy evidence:\nwithin declared INA219/shunt/reference\nuncertainty budget from PDS-R9 and campaign setup;\ndo not invent a tighter requirement" {
    class: note
    shape: page
  }
  blocking_note: "[C] No unbounded blocking\nexcept modeled I2C or UART waits;\nscheduler/logging remains live" {
    class: note
    shape: page
  }
}

chain.command_test_case -> chain.read_ambient: "[FE] Start repetition set" { class: fe }
chain.command_test_case -> chain.configure_operating_point: "[FE] Operating-point command" { class: fe }
chain.configure_operating_point -> chain.stabilize_supply_load: "[FE] Voltage/load setpoint" { class: fe }
chain.stabilize_supply_load -> chain.measure_reference_vi: "[FE] Stable reference condition" { class: fe }
chain.stabilize_supply_load -> chain.measure_voltage: "[FE] Stable bus voltage" { class: fe }
chain.stabilize_supply_load -> chain.measure_current: "[FE] Stable bus current" { class: fe }

chain.get_init_state -> chain.respond_i2c: "[FE] Init req" { class: fe }
chain.respond_i2c -> chain.get_init_state: "[FE] Init rsp" { class: fe }
chain.get_init_state -> chain.collect_init_states: "[FE] Init result" { class: fe }

chain.read_voltage -> chain.respond_i2c: "[FE] V read req" { class: fe }
chain.measure_voltage -> chain.respond_i2c: "[FE] V sample" { class: fe }
chain.respond_i2c -> chain.process_voltage: "[FE] V raw/status" { class: fe }
chain.process_voltage -> chain.collect_measurements: "[FE] V result/status" { class: fe }

chain.read_current -> chain.respond_i2c: "[FE] I read req" { class: fe }
chain.measure_current -> chain.respond_i2c: "[FE] I sample" { class: fe }
chain.respond_i2c -> chain.process_current: "[FE] I raw/status" { class: fe }
chain.process_current -> chain.collect_measurements: "[FE] I result/status" { class: fe }

chain.read_voltage -> chain.timestamp_durations: "[FE] V read duration" { class: fe }
chain.read_current -> chain.timestamp_durations: "[FE] I read duration" { class: fe }
chain.process_voltage -> chain.timestamp_durations: "[FE] V process duration" { class: fe }
chain.process_current -> chain.timestamp_durations: "[FE] I process duration" { class: fe }

chain.read_ambient -> chain.log_samples: "[FE] Ambient T/RH" { class: fe }
chain.measure_reference_vi -> chain.log_samples: "[FE] Reference V/I" { class: fe }
chain.collect_init_states -> chain.log_samples: "[FE] Init status" { class: fe }
chain.collect_measurements -> chain.log_samples: "[FE] Paired V/I results" { class: fe }
chain.timestamp_durations -> chain.log_samples: "[FE] Timing samples" { class: fe }
chain.log_samples -> chain.archive_evidence: "[FE] Raw evidence" { class: fe }
