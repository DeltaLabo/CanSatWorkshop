vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PDM-V01-FC-FALL verification functional allocation.
# Functional allocation view: PCs, LCs, functions, EAs, and constraints only.
direction: down
grid-columns: 3

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] PDM-V01-FC-FALL verification allocation\nRefs: PDM_v0.1 views 2-3; PDM-UC-V01-FallTestTerminalSpeed; PM&SE/IVV.md" {
  class: sys
  direction: down

  dummy_cansat: "[PC] Dummy CanSat\nUUT" {
    class: pc
    direction: down

    top_module: "[PC] Top module" {
      class: pc
      direction: down

      parachute: "[PC] Parachute" {
        class: pc
        direction: down

        descent_speed_control: "[LC] Descent speed control" {
          class: lc
          direction: down

          limit_terminal_speed: "[F] Limit terminal speed" { class: func }
          terminal_speed_max: "[C] Source constraint:\n11 m/s max." { class: note; shape: page }
          allocation_analysis: "[C] Allocation analysis:\nLC is allocated to Parachute\nand contains only this source\nfunction in v0.1." { class: note; shape: page }
        }
      }
    }
  }
}

human_test_conductor: "[EA] Human Test Conductor" {
  class: ea
  direction: down
  grid-columns: 1

  confirm_baseline: "[F] Confirm source\nmodel baseline" { class: func }
  record_configuration: "[F] Record UUT\nconfiguration" { class: func }
  inspect_parachute: "[F] Inspect manual fold\nand open condition" { class: func }
  read_environment: "[F] Read ambient\nand wind meter" { class: func }
  release_dummy: "[F] Release dummy" { class: func }
  record_anomalies: "[F] Record deviations\nand anomalies" { class: func }

  manual_open: "[C] Pass: parachute is\nfolded/released manually and\nopen for accepted segment." { class: note; shape: page }
  fault_hardening: "[C] Fault-hardening checks:\nmisfold/tangle, partial opening,\nrelease bias, wind/gusts, and\ndrop damage." { class: note; shape: page }
}

calibrated_scale: "[EA] Calibrated Scale" {
  class: ea
  direction: down
  grid-columns: 1

  measure_mass: "[F] Measure dummy\nmass/configuration" { class: func }
  mass_input: "[C] Final-estimate mass/configuration\nis a pre-execution input; pass if\nmeasured UUT matches it or documented\ntolerance." { class: note; shape: page }
}

release_fixture: "[EA] Release/Drop Fixture" {
  class: ea
  direction: down
  grid-columns: 1

  hold_drop_height: "[F] Hold configured\ndrop height" { class: func }
  release_without_bias: "[F] Release without\nfixture bias" { class: func }
}

video_camera: "[EA] Calibrated Video Camera" {
  class: ea
  direction: down
  grid-columns: 1

  capture_video: "[F] Capture fall video\nwith time reference" { class: func }
  calibration_check: "[C] Pass: video scale/time\nreference is visible and retained\nwith equipment identifiers." { class: note; shape: page }
}

reference_target: "[EA] Time/Distance\nReference Target" {
  class: ea
  direction: down
  grid-columns: 1

  provide_reference: "[F] Provide calibrated\ntime-distance reference" { class: func }
}

analysis_workstation: "[EA] Video Analysis Workstation" {
  class: ea
  direction: down
  grid-columns: 1

  extract_speed_trace: "[F] Extract descent\nspeed trace" { class: func }
  compare_limit: "[F] Compare speed\nagainst 11 m/s" { class: func }
  speed_limit: "[C] Pass: terminal descent speed\nfrom retained video/time-distance\nevidence <= 11 m/s over accepted\nmeasurement segment." { class: note; shape: page }
  stat_viewpoint: "[C] Statistical viewpoint:\n3 repetitions are development screening\nonly; reliability/confidence claims need\na stated statistical basis." { class: note; shape: page }
}

report_repository: "[EA] Verification Report\nRepository" {
  class: ea
  direction: down
  grid-columns: 1

  archive_evidence: "[F] Archive evidence\nand report" { class: func }
  evidence_required: "[C] Evidence includes model version,\nUUT configuration, video/log files,\nmeasurement method, environment,\ndeviations, and anomalies." { class: note; shape: page }
}

system.dummy_cansat.top_module.parachute.descent_speed_control.terminal_speed_max -> system.dummy_cansat.top_module.parachute.descent_speed_control.limit_terminal_speed { class: cstr }
system.dummy_cansat.top_module.parachute.descent_speed_control.allocation_analysis -> system.dummy_cansat.top_module.parachute.descent_speed_control.limit_terminal_speed { class: cstr }
human_test_conductor.manual_open -> human_test_conductor.inspect_parachute { class: cstr }
human_test_conductor.manual_open -> human_test_conductor.release_dummy { class: cstr }
human_test_conductor.fault_hardening -> human_test_conductor.inspect_parachute { class: cstr }
calibrated_scale.mass_input -> calibrated_scale.measure_mass { class: cstr }
video_camera.calibration_check -> video_camera.capture_video { class: cstr }
analysis_workstation.speed_limit -> analysis_workstation.compare_limit { class: cstr }
analysis_workstation.stat_viewpoint -> analysis_workstation.compare_limit { class: cstr }
report_repository.evidence_required -> report_repository.archive_evidence { class: cstr }
