th\":null,\"menu_link\":null,\"field_dp_short_description\":\"The ICM-45686 is a high-performance dual interface (UI + AUX) 6-axis MEMS MotionTracking device. It has a configurable host interface that supports I3C℠, I²C, and SPI serial communication, and an AUX interface that supports SPI slave mode for connection to OIS controllers or I²C master mode for connection to external sensors. The device features up to 8 Kbytes FIFO and 2 programmable interrupts.\",\"field_file\":{\"id\":\"1146\",\"label\":\"ds-000577-icm-45686-datasheet.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"25\",\"label\":\"Datasheet\"},\"field_updated_date\":\"2024-07-25\",\"field_version\":\"1.0\"},{\"id\":\"2121\",\"label\":\"AN-000257 – Understanding IMU Sensor Offset\",\"slug\":\"/000257-understanding-imu-sensor-offset-1\",\"nid\":\"2121\",\"uuid\":\"d56e5631-13a7-478c-899c-3f713010251e\",\"vid\":\"2894\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1771473767\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000257 – Understanding IMU Sensor Offset\",\"created\":\"1771473767\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"305\",\"label\":\"an-000257_understanding-imu-sensor-offset (2).pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2023-03-16\",\"field_version\":\"1.3\"},{\"id\":\"2122\",\"label\":\"AN-000478 – ICM-45605 \u0026 ICM-45686 User Guide\",\"slug\":\"/000478-icm-45605-icm-45686-user-guide\",\"nid\":\"2122\",\"uuid\":\"fc7f0fec-e069-4c25-bb46-6d5e38baad1e\",\"vid\":\"9799\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1775161192\",\"revision_uid\":{\"id\":\"123783\",\"label\":\"robertvargas\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000478 – ICM-45605 \u0026 ICM-45686 User Guide\",\"created\":\"1771473820\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"306\",\"label\":\"AN-000478_ICM-45605-ICM-45686-User-Guide (2).pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2024-07-25\",\"field_version\":\"1.0\"},{\"id\":\"2123\",\"label\":\"AN-000479 – SmartMotion Development Platform (Ver. I) Hardware User Guide\",\"slug\":\"/000479-smartmotion-development-platform-ver-i-hardware-user-guide-1\",\"nid\":\"2123\",\"uuid\":\"4236d37c-bb26-461e-9997-153240a517ad\",\"vid\":\"2896\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1771473857\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000479 – SmartMotion Development Platform (Ver. I) Hardware User Guide\",\"created\":\"1771473857\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"307\",\"label\":\"AN-000479_DK-45605-DK-45686-SmartMotion-Platform-ver.-I-User-Guide (2).pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2024-07-26\",\"field_version\":\"1.0\"},{\"id\":\"2169\",\"label\":\"AN-000393 – IMU PCB Design and MEMS Assembly Guidelines\",\"slug\":\"/000393-imu-pcb-design-and-mems-assembly-guidelines\",\"nid\":\"2169\",\"uuid\":\"8c9f57db-7a66-437e-9db2-6984494fbf32\",\"vid\":\"10161\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1780333281\",\"revision_uid\":{\"id\":\"124658\",\"label\":\"jimlin\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000393 – IMU PCB Design and MEMS Assembly Guidelines\",\"created\":\"1771635625\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"This document provides high-level PCB design, sensor mounting, and handling guidelines for TDK IMU Products, which incorporate a combination of gyroscopes and accelerometers. Each sensor has specific requirements to ensure the highest performance in a finished product. For a layout assessment of your design, including placement and estimated temperature disturbances, please contact TDK.\",\"field_file\":{\"id\":\"1225\",\"label\":\"AN-000393 TDK InvenSense IMU PCB Design and MEMS Assembly Guidelines v2.4.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2026-06-01\",\"field_version\":\"2.4\"},{\"id\":\"8726\",\"label\":\"AN-000265 TDK IMU Calibration Application Note\",\"slug\":\"/000265-tdk-imu-calibration-application-note\",\"nid\":\"8726\",\"uuid\":\"735e91fc-4b5a-4f0f-aa71-1319d1b257ea\",\"vid\":\"10164\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1780334761\",\"revision_uid\":{\"id\":\"124658\",\"label\":\"jimlin\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"124658\",\"label\":\"jimlin\"},\"title\":\"AN-000265 TDK IMU Calibration Application Note\",\"created\":\"1780334745\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\