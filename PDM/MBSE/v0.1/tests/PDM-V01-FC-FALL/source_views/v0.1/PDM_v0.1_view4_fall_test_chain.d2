vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional chain reconstructed from PDM/PDM_v0.1_FC.png.
# Source label: v0.1 fall test (3 reps).
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDM v0.1 — Fall test chain (3 reps)" {
  class: chain
  direction: right

  record_fall: "[F] Record fall" { class: func }
  release_dummy: "[F] Release dummy" { class: func }
  limit_terminal_speed: "[F] Limit terminal speed" { class: func }
  measure_terminal_speed: "[F] Measure\nterminal speed\nfrom video" { class: func }

  with_parachute_open: "[C] With\nparachute open" { class: note; shape: page }
  terminal_speed_max: "[C] Terminal speed\n<= 11 m/s\n(measured + uncertainty/guard band)" { class: note; shape: page }
  mass_tolerance: "[C] Dummy mass/config\nwithin +/-5% or +/-10 g\n(whichever is tighter)" { class: note; shape: page }
  scale_resolution: "[C] Mass scale\nresolution <= 1 g\nor equivalent uncertainty" { class: note; shape: page }
  video_timebase: "[C] Retained video\nwith known frame rate\nor timestamped frames\n>= 30 fps unless\ncalibrated timebase" { class: note; shape: page }
  distance_uncertainty: "[C] Distance calibration\nuncertainty <= 5%" { class: note; shape: page }
  accepted_measure_segment: "[C] Accepted measurement\nsegment after\nparachute open/stable\nbefore ground effect" { class: note; shape: page }
  wind_condition: "[C] Wind <= 3 m/s\nor justified indoor/still-air\nequivalent" { class: note; shape: page }
  anomaly_rules: "[C] Predeclared\nanomaly/exclusion rules" { class: note; shape: page }
  repetitions_scope: "[C] 3 repetitions\nare development\nscreening only" { class: note; shape: page }
}

chain.record_fall -> chain.release_dummy: "[FE] Test Ready []" { class: fe }
chain.release_dummy -> chain.limit_terminal_speed: "[FE] Manual release []" { class: fe }
chain.limit_terminal_speed -> chain.measure_terminal_speed: "[FE] Landing []" { class: fe }

chain.with_parachute_open -> chain.release_dummy { class: cstr }
chain.terminal_speed_max -> chain.limit_terminal_speed { class: cstr }
chain.mass_tolerance -> chain.measure_terminal_speed { class: cstr }
chain.scale_resolution -> chain.measure_terminal_speed { class: cstr }
chain.video_timebase -> chain.measure_terminal_speed { class: cstr }
chain.distance_uncertainty -> chain.measure_terminal_speed { class: cstr }
chain.accepted_measure_segment -> chain.measure_terminal_speed { class: cstr }
chain.wind_condition -> chain.measure_terminal_speed { class: cstr }
chain.anomaly_rules -> chain.measure_terminal_speed { class: cstr }
chain.repetitions_scope -> chain.measure_terminal_speed { class: cstr }
