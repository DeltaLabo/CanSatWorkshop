vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PDS-VV-CON-004 PV2 logical test interfaces.
# References: IVV, PDS-R2, PDS-R6, PDS-R8.
# Traceability: [C] Supply both 5±0.1 V and 3.3±0.1 V, 1 A;
# PDS-UC-ProvideRegulatedPower; PDS-FE-RailBrownout.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

test_operator: "[EA] Test Operator" { class: ea }
ambient_meter: "[EA] Ambient thermometer /\nhygrometer" { class: ea }
thermal_camera: "[EA] Thermocouple or\nIR camera" { class: ea }
dmm_daq: "[EA] Calibrated DMM / DAQ" { class: ea }
scope_logger: "[EA] Oscilloscope / logger" { class: ea }
host_pc: "[EA] Evidence repository /\nhost PC" { class: ea }

system: "[System] PDS-VV-CON-004 regulated-rail logical test interfaces\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R2; PDS-R6; PDS-R8" {
  class: sys
  direction: down
  grid-columns: 2

  pds_module: "[PC] PDS Module" {
    class: pc
    direction: down

    test_environment: "[LC] Verification\nenvironment context" { class: lc }

    pds_pcb: "[PC] PDS PCB" {
      class: pc
      direction: down
      grid-columns: 2

      battery_connector: "[PC] Battery Connector" {
        class: pc
        emulated_battery_input: "[LC] Emulated\nbattery input interface" { class: lc }
      }

      protection: "[PC] Protection Circuit" {
        class: pc
        direction: down
        power_protection: "[LC] Power Protection" { class: lc }
      }

      ina219: "[PC] INA219" {
        class: pc
        battery_monitoring: "[LC] Battery monitoring" { class: lc }
      }

      regulator: "[PC] Regulator" {
        class: pc
        regulator_lc: "[LC] Regulator" { class: lc }
      }

      pds_backplane_connector: "[PC] Backplane Connector" {
        class: pc
        rail_test_interface: "[LC] Rail test interface\n5 V / 3V3" { class: lc }
      }
    }
  }

  backplane_pcb: "[PC] Backplane PCB" {
    class: pc
    backplane_distribution: "[LC] Backplane power\ndistribution" { class: lc }
  }

  obcc_module: "[PC] OBCC Module" {
    class: pc
    direction: down
    obcc_pcb: "[PC] OBCC PCB" {
      class: pc
      xiao: "[PC] XIAO ESP32-S3" {
        class: pc
        direction: down
        obcc: "[LC] OBCC" { class: lc }
        reset_observer: "[LC] Brownout /\nreset observer" { class: lc }
      }
    }
  }

  note_supply: "[C] Constraint under test:\nSupply both 5±0.1 V and\n3.3±0.1 V, 1 A.\nVerify at rail test interface\nand across regulator/backplane path." {
    class: note
    shape: page
  }

  note_stats: "[C] Statistical significance:\nfor each no-load, nominal-load,\nand 1 A load case, collect ≥30\nsettled samples per rail; pass\nwith expanded uncertainty inside limits." {
    class: note
    shape: page
  }

  note_fault: "[C] Fault-hardening viewpoint:\nstartup and load-step checks show\nno brownout/reset, no unsafe\ntemperature, and no uncontrolled current.\nBattery emulator only; no destructive\nLi-ion abuse." {
    class: note
    shape: page
  }
}

test_operator -> system.pds_module.pds_pcb.protection.power_protection: "[CE] switch cmd" { class: ce }
ambient_meter -> system.pds_module.test_environment: "[CE] ambient" { class: ce }
system.pds_module.pds_pcb.regulator.regulator_lc -> thermal_camera: "[CE] temp" { class: ce }
system.pds_module.pds_pcb.pds_backplane_connector.rail_test_interface -> dmm_daq: "[CE] rail samples" { class: ce }
system.pds_module.pds_pcb.pds_backplane_connector.rail_test_interface -> scope_logger: "[CE] waveforms" { class: ce }
system.pds_module.pds_pcb.pds_backplane_connector.rail_test_interface -> host_pc: "[CE] evidence" { class: ce }
system.obcc_module.obcc_pcb.xiao.reset_observer -> host_pc: "[CE] reset log" { class: ce }

system.pds_module.pds_pcb.battery_connector.emulated_battery_input -> system.pds_module.pds_pcb.protection.power_protection: "[CE] input" { class: ce }
system.pds_module.pds_pcb.protection.power_protection -> system.pds_module.pds_pcb.ina219.battery_monitoring: "[CE] monitored power" { class: ce }
system.pds_module.pds_pcb.ina219.battery_monitoring -> system.pds_module.pds_pcb.regulator.regulator_lc: "[CE] conditioned input" { class: ce }
system.pds_module.pds_pcb.regulator.regulator_lc -> system.pds_module.pds_pcb.pds_backplane_connector.rail_test_interface: "[CE] rail interface" { class: ce }
system.pds_module.pds_pcb.pds_backplane_connector.rail_test_interface -> system.backplane_pcb.backplane_distribution: "[CE] backplane rails" { class: ce }
system.backplane_pcb.backplane_distribution -> system.obcc_module.obcc_pcb.xiao.reset_observer: "[CE] supply / reset" { class: ce }

system.note_supply -> system.pds_module.pds_pcb.regulator.regulator_lc { class: cstr }
system.note_supply -> system.pds_module.pds_pcb.pds_backplane_connector.rail_test_interface { class: cstr }

# Layout-only edges to separate external logical actors from the system.
test_operator -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> thermal_camera { style: { opacity: 0 } }
thermal_camera -> dmm_daq { style: { opacity: 0 } }
dmm_daq -> scope_logger { style: { opacity: 0 } }
scope_logger -> host_pc { style: { opacity: 0 } }
