vars: {
  d2-config: {
    layout-engine: elk
  }
}

# S&A v0.1 physical view.
# Shows the reusable structural module models used by the other subsystems,
# before mounting subsystem PCBs.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] S&A Physical System" {
  class: sys
  direction: down

  cansat: "[PC] CanSat Structural Envelope" {
    class: pc
    direction: right

    standard_stack: "[PC] Standard Carrier\nModule Stack\n(Type 1)" {
      class: pc
      direction: down
      grid-columns: 1

      ads_module: "[PC] ADS Module" { class: pc }
      ams_module: "[PC] AMS Module" { class: pc }
      obcc_module: "[PC] OBCC Module" { class: pc }
      pds_module: "[PC] PDS Module" { class: pc }
      ess_module: "[PC] ESS Module" { class: pc }
    }

    backplane_volume: "[PC] Perpendicular\nBackplane Volume" { class: pc }

    parachute_module: "[PC] Parachute / Top\nModule\n(Type 2)" { class: pc }
  }

  envelope_limits: "[C] 355 ml can envelope:\nØ 6.6 cm × H 12.2 cm\nTotal mass < 350 ±0.1 g\nWithstand landing impact" {
    class: note
    shape: page
  }

  module_limits: "[C] Modular structure:\nmaximum two module types\nEach standard module\naccommodates 44 mm × 44 mm PCB" {
    class: note
    shape: page
  }

  assembly_limits: "[C] Assembly / printing:\nmax. two self-tapping\nscrew types\n0.2 mm print precision\n15% print fill" {
    class: note
    shape: page
  }

  backplane_limits: "[C] Backplane allowance:\nperpendicular PCB allocation\n100 mm × 28 mm, 2-layer\n2 mm 2×6 headers + pin interface\n5.0 ±0.1 V and 3.3 ±0.1 V\ntestpoints, low-cap. fast lines\nERC + DRC clean" {
    class: note
    shape: page
  }
}

system.cansat.standard_stack.ads_module -- system.cansat.standard_stack.ams_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.ams_module -- system.cansat.standard_stack.obcc_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.obcc_module -- system.cansat.standard_stack.pds_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.pds_module -- system.cansat.standard_stack.ess_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack -- system.cansat.parachute_module: "[PL] Stack screws" { class: pl }

system.cansat.standard_stack -- system.cansat.backplane_volume: "[PL] Perpendicular\nbackplane slot" { class: pl }
system.cansat.parachute_module -- system.cansat.backplane_volume: "[PL] Backplane\nclearance" { class: pl }

system.envelope_limits -> system.cansat { class: cstr }
system.module_limits -> system.cansat.standard_stack { class: cstr }
system.module_limits -> system.cansat.parachute_module { class: cstr }
system.assembly_limits -> system.cansat.standard_stack { class: cstr }
system.assembly_limits -> system.cansat.parachute_module { class: cstr }
system.backplane_limits -> system.cansat.backplane_volume { class: cstr }

# Layout-only edges keep constraints below the structural model.
system.cansat -> system.envelope_limits { style: { opacity: 0 } }
system.envelope_limits -> system.module_limits { style: { opacity: 0 } }
system.module_limits -> system.assembly_limits { style: { opacity: 0 } }
system.assembly_limits -> system.backplane_limits { style: { opacity: 0 } }
