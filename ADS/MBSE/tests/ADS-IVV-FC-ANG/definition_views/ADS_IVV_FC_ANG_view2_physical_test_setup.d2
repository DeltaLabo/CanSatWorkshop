vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical test setup view for ADS-IVV-FC-ANG.
# Defines UUT, angular-rate truth/stimulus means, logging means, temporary PLs/CEs, and environment constraints.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-FC-ANG\nPhysical angular-rate test setup\nRefs: IVV; NASA-SE; IMU/I2C; SW/stats" {
  class: sys
  direction: down

  uut: "[PC] Selected ADS UUT\n(one version per execution)" {
    class: pc
    direction: right
    grid-columns: 2
    v01: "[PC] v0.1 GPS + XIAO\nN/A: no IMU chain" { class: pc }
    v02: "[PC] v0.2 GPS + IMU + XIAO\nprototype" { class: pc }
    v03: "[PC] v0.3 ADS PCB\nN/A behavior article" { class: pc }
    v10: "[PC] v1.0 integrated\nCanSat / ADS / OBCC" { class: pc }
  }
}

test_conductor: "[EA] IVV angular-rate\ntest conductor" { class: ea }
rate_reference: "[EA] Angular-rate truth source\ncalibrated rate table / turntable\nor static zero-rate fixture" { class: ea }
imu_fault_injector: "[EA] I2C / IMU\nfault injector" { class: ea }
data_logger: "[EA] Data-acquisition PC\nserial/I2C/debug logger\nand timestamp source" { class: ea }
obcc_logger: "[EA] OBCC log capture\n(v1.0 delivery evidence)" { class: ea }
power_supply: "[EA] Current-limited\nbench supply / battery simulator" { class: ea }

note_accuracy: "[C] Angular-rate pass condition\nFor each tested version, axis, and accepted rate condition,\ncollect >=30 matched valid ADS and truth samples.\nPass only if the accepted angular-rate error criterion,\nincluding reference/instrument uncertainty or 95/95 bound\nwhere claimed, is <30 deg/s." { class: note; shape: page }
note_environment: "[C] Environment constraints\nRecord rate-reference method, axis alignment, mounting,\nvibration/slip, temperature, warm-up, power mode, timebase,\nfirmware commit, calibration status, and uncertainty.\nDo not execute if reference calibration or axis convention\nis unknown." { class: note; shape: page }
note_faults: "[C] Fault-hardening conditions\nInject or simulate I2C NACK, stuck bus, wrong address,\npartial read, saturation/out-of-range value, stale sample,\nand recovery. Fail if invalid/stale angular rate is accepted\nas valid, outputs become non-finite without error state,\nor loop/OBCC progress blocks unexpectedly." { class: note; shape: page }
note_i2c: "[C] I2C timing viewpoint\nv1.0 explicitly requires I2C read timeout <=5 ms.\nv0.2 has no modeled I2C timeout and shall record this\nas a modeling gap while still observing no-blocking behavior." { class: note; shape: page }

# Temporary physical links used by the verification setup.
rate_reference -- system.uut: "[PL] mechanical fixture /\nrate stimulus" { class: pl }
imu_fault_injector -- system.uut: "[PL] I2C/fault\nharness" { class: pl }
data_logger -- system.uut: "[PL] USB/UART/debug\nlog cable" { class: pl }
obcc_logger -- system.uut: "[PL] OBCC debug\nlog interface" { class: pl }
power_supply -- system.uut: "[PL] power leads" { class: pl }

# Verification component exchanges / records.
test_conductor -> system.uut: "[CE] test run sheet\nand version selection" { class: ce }
rate_reference -> data_logger: "[CE] truth angular\nrate and timestamps" { class: ce }
system.uut -> data_logger: "[CE] ADS angular-rate\nsamples/status/time" { class: ce }
system.uut -> obcc_logger: "[CE] v1.0 OBCC\ncollected IMU record" { class: ce }
imu_fault_injector -> data_logger: "[CE] injected fault\nmarkers" { class: ce }

note_accuracy -> data_logger { class: cstr }
note_environment -> system { class: cstr }
note_faults -> imu_fault_injector { class: cstr }
note_faults -> obcc_logger { class: cstr }
note_i2c -> data_logger { class: cstr }

# Layout-only rank hints.
test_conductor -> rate_reference { style: { opacity: 0 } }
rate_reference -> imu_fault_injector { style: { opacity: 0 } }
imu_fault_injector -> data_logger { style: { opacity: 0 } }
data_logger -> obcc_logger { style: { opacity: 0 } }
obcc_logger -> power_supply { style: { opacity: 0 } }
system -> note_accuracy { style: { opacity: 0 } }
note_accuracy -> note_environment { style: { opacity: 0 } }
note_environment -> note_faults { style: { opacity: 0 } }
note_faults -> note_i2c { style: { opacity: 0 } }
