vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Logical view — AMS-VV-CON-003 I2C read timeout testbench
# Verification references: IVV, AMS-R2 (I2C), AMS-R5 (statistics).
# Final acceptance scope: environmental measurement I2C reads only.
# Traceability: constraint; AMS-FE-SensorBusFault; AMS-UC-MeasureAtmosphere.
# Show deployed logical components and their component exchanges while preserving the PA containment.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-CON-003 I2C timeout\nFinal acceptance; Refs: IVV, AMS-R2, AMS-R5" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: down
    grid-columns: 1

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        bme280: "[PC] BME280" {
          class: pc
          direction: down

          ams_sensing: "[LC] AMS Sensing" { class: lc }
        }

        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        grid-columns: 2

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down

          ams_processing: "[LC] AMS Processing" { class: lc }
          obcc: "[LC] OBCC" { class: lc }
          timeout_test_instrumentation: "[LC] AMS Timeout\nTest Instrumentation\n(VV-only)" { class: lc }
        }

        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }

        note_variable_getter: "[C] Implement each\n(Read X, Process X) or\n(Read X, Calculate Y)\npair as a Variable\nGetter template" {
          class: note
          shape: page
        }
        note_i2c_timeout: "[C] All I2C read\nfunctions must have\na timeout ≤ 5 ms" {
          class: note
          shape: page
        }
        note_process_time: "[C] All Process or\nCalculate functions\nmust take < 5 ms" {
          class: note
          shape: page
        }
        note_no_blocking: "[C] No blocking\noperations besides\nI2C or UART comms" {
          class: note
          shape: page
        }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" { class: pc }
  }
}

test_operator: "[EA] AMS-VV\nTest Operator" { class: ea }

note_test_scope: "[C] AMS-VV-CON-003 analyzes and tests environmental\nmeasurement I2C read paths only: Read pressure and\nRead temperature; init/chip-ID reads are out of scope" {
  class: note
  shape: page
}
note_iadt: "[C] Final acceptance IADT: Testing with supporting Analysis;\nrecovery without reset is mandatory;\nreport by reference to this model definition" {
  class: note
  shape: page
}
note_status_mapping: "[C] External status mapping: timeout/no-response -> TIMEOUT;\nruntime sensor/bus/value fault -> SENSOR_FAULT or applicable\nnon-VALID; init/no-data -> INIT_FAIL or NO_DATA.\nNo stale/old/default data as VALID; record sample IDs,\ntimestamps/age where freshness is claimed, and low-level causes." {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb.bme280.ams_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] I2C" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Pointers" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Returns" { class: ce }

test_operator -> system.cansat.obcc_module.obcc_pcb.xiao.timeout_test_instrumentation: "[CE] Procedure ↔\nresults/anomalies" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.timeout_test_instrumentation -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] Timed read ↔\nresult record" { class: ce }

system.cansat.obcc_module.obcc_pcb.note_variable_getter -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_i2c_timeout -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_process_time -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_no_blocking -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }

note_test_scope -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
note_test_scope -> system.cansat.obcc_module.obcc_pcb.xiao.timeout_test_instrumentation { class: cstr }
note_iadt -> test_operator { class: cstr }
note_status_mapping -> system.cansat.obcc_module.obcc_pcb.xiao.timeout_test_instrumentation { class: cstr }
note_status_mapping -> system.cansat.obcc_module.obcc_pcb.xiao.obcc { class: cstr }

# Layout-only edge keeps status mapping near the IADT note.
note_iadt -> note_status_mapping { style: { opacity: 0 } }
