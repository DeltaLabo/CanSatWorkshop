vars: {
  d2-config: {
    layout-engine: elk
  }
}

# DPS-V10-T-003 logical test context.
# Verification additions: Command Test Transmitter, OBCC Debug Monitor, Test Operator, and verification-only evidence collector LC.
# The unmodified full DPS v1.0 PV2 is retained in ./baseline/.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 20 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

test_operator: "[EA] Test Operator" { class: ea }
command_test_transmitter: "[EA] Command Test Transmitter\nRFM95W/SX1276" { class: ea }
obcc_debug_monitor: "[EA] OBCC Debug Monitor" { class: ea }

system: "[System] DPS v1.0\nDPS-V10-T-003 PV2 logical test context\nIADT: Testing; Refs: P0,R1-R5,R8-R13; Trace: FC03" {
  class: sys
  direction: down
  grid-columns: 1

  cansat: "[PC] CanSat" {
    class: pc
    direction: down

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: right

        cansat_rfm: "[PC] RFM95W LoRa" {
          class: pc
          direction: down
          cansat_lora: "[LC] LoRa Transceiver" { class: lc }
        }

        cansat_xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down
          obcc: "[LC] OBCC" { class: lc }
        }
      }
    }
  }

  pc: "[PC] Test/Evidence PC" {
    class: pc
    direction: down
    evidence_collector: "[LC] Command Receive Evidence Collector\n(verification-only)" { class: lc }
  }

  note_scope: "[C] Focused test context: FC03 CanSat radio receive and OBCC command read.\nFull v1.0 baseline architecture remains copied in ./baseline/." {
    class: note
    shape: page
  }

  note_valid_pass: "[C] Valid-command pass: at least 60 valid command frames are transmitted;\neach is read by OBCC exactly once with the expected state/sequence; zero missing,\nwrong, duplicate or stale command acceptances are allowed." {
    class: note
    shape: page
  }

  note_fault_pass: "[C] Fault-hardening pass: at least 60 spoof/no-frame/old-buffer/invalid cases;\nzero invalid cases are accepted as commands; no stale command is re-read;\nvalid follow-up command is accepted once." {
    class: note
    shape: page
  }

  note_statistics: "[C] Statistics viewpoint: 60/60 valid accepts gives exact-binomial\nscreening evidence; invalid-case rejection is counted by fault class.\nReport k/N, timing, anomalies and limitations." {
    class: note
    shape: page
  }
}

command_test_transmitter -> system.cansat.obcc_module.obcc_pcb.cansat_rfm.cansat_lora: "[CE] LoRa PHY\ncommand frames" { class: ce }
system.cansat.obcc_module.obcc_pcb.cansat_rfm.cansat_lora -> system.cansat.obcc_module.obcc_pcb.cansat_xiao.obcc: "[CE-01] SPI" { class: ce }
command_test_transmitter -> system.pc.evidence_collector: "[CE] TX command log" { class: ce }
obcc_debug_monitor -> system.pc.evidence_collector: "[CE] OBCC debug\naccept/reject log" { class: ce }
system.cansat.obcc_module.obcc_pcb.cansat_xiao.obcc -> system.pc.evidence_collector: "[CE] Command read\nstatus log" { class: ce }
test_operator -> system.pc.evidence_collector: "[CE] Test control\nand verdict" { class: ce }

system.note_scope -> system.pc.evidence_collector { class: cstr }
system.note_valid_pass -> system.cansat.obcc_module.obcc_pcb.cansat_xiao.obcc { class: cstr }
system.note_valid_pass -> system.pc.evidence_collector { class: cstr }
system.note_fault_pass -> system.cansat.obcc_module.obcc_pcb.cansat_xiao.obcc { class: cstr }
system.note_fault_pass -> system.pc.evidence_collector { class: cstr }
system.note_statistics -> system.pc.evidence_collector { class: cstr }

# Layout-only edges to keep external test means left of the focused UUT.
test_operator -> command_test_transmitter { style: { opacity: 0 } }
command_test_transmitter -> obcc_debug_monitor { style: { opacity: 0 } }
obcc_debug_monitor -> system { style: { opacity: 0 } }
system.cansat -> system.pc { style: { opacity: 0 } }
