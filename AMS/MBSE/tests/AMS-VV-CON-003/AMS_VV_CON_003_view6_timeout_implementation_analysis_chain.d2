vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

# Functional chain: timeout implementation and environmental-read model-coverage analysis for AMS-VV-CON-003.

chain: "AMS-VV-CON-003 — Environmental I2C timeout implementation coverage analysis\nAnalysis; AMS v1.0 final acceptance; Refs: IVV, AMS-R2, AMS-R5\nTrace: constraint, AMS-FE-SensorBusFault, AMS-UC-MeasureAtmosphere" {
  class: chain
  direction: down

  generate_coverage_matrix: "[F] Generate coverage\nmatrix" { class: func }
  map_i2c_callsites: "[F] Map environmental\nI2C callsites" { class: func }
  read_pressure: "[F] Read\npressure" { class: func }
  read_temperature: "[F] Read\ntemperature" { class: func }
  inspect_timeout_config: "[F] Inspect timeout\nconfiguration" { class: func }
  compare_dynamic_evidence: "[F] Compare dynamic\nevidence" { class: func }
  record_anomalies: "[F] Record\nanomalies" { class: func }
  archive_evidence: "[F] Archive\nevidence" { class: func }

  note_scope: "[C] Scope confirmed for final acceptance:\nRead pressure and Read temperature only;\nperipheral-init, chip-ID, and hidden driver setup reads\nare out of scope unless reachable from these functions" { class: note; shape: page }
  note_analyzed_elements: "[C] Analyzed elements: [CE] I2C, [LC] AMS Processing,\nRead pressure, Read temperature, and implementation\ncall paths reachable from environmental measurement reads" { class: note; shape: page }
  note_coverage: "[C] Pass requires 100% environmental measurement I2C\nread functions mapped to implementation; no environmental\nAMS Processing I2C read path lacks a ≤ 5 ms timeout" { class: note; shape: page }
  note_wrapper: "[C] Retries, wrappers, bus-recovery attempts, or driver calls\nshall not make one environmental read exceed 5.000 ms\nfrom entry to returned status" { class: note; shape: page }
  note_recovery: "[C] Recovery without reset after released I2C fault is mandatory\nand shall be supported by static rationale and dynamic evidence" { class: note; shape: page }
  note_rationale: "[C] Analysis viewpoint: design/API consistency and fault hardening;\nrationale checked against timing-test evidence and code/API contracts" { class: note; shape: page }
}

chain.generate_coverage_matrix -> chain.map_i2c_callsites: "[FE] Environmental read\ninventory" { class: fe }
chain.map_i2c_callsites -> chain.read_pressure: "[FE] Pressure\ncallsite map" { class: fe }
chain.map_i2c_callsites -> chain.read_temperature: "[FE] Temperature\ncallsite map" { class: fe }
chain.read_pressure -> chain.inspect_timeout_config: "[FE] Timeout constants\nand call paths" { class: fe }
chain.read_temperature -> chain.inspect_timeout_config: "[FE] Timeout constants\nand call paths" { class: fe }
chain.inspect_timeout_config -> chain.compare_dynamic_evidence: "[FE] Static findings" { class: fe }
chain.compare_dynamic_evidence -> chain.record_anomalies: "[FE] Mismatch /\ngap list" { class: fe }
chain.compare_dynamic_evidence -> chain.archive_evidence: "[FE] Analysis result" { class: fe }

chain.note_scope -> chain.generate_coverage_matrix { class: cstr }
chain.note_analyzed_elements -> chain.map_i2c_callsites { class: cstr }
chain.note_coverage -> chain.generate_coverage_matrix { class: cstr }
chain.note_coverage -> chain.inspect_timeout_config { class: cstr }
chain.note_wrapper -> chain.compare_dynamic_evidence { class: cstr }
chain.note_recovery -> chain.compare_dynamic_evidence { class: cstr }
chain.note_rationale -> chain.archive_evidence { class: cstr }

# Layout-only edge to keep the two environmental read functions grouped before timeout inspection.
chain.read_temperature -> chain.inspect_timeout_config { style: { opacity: 0 } }
