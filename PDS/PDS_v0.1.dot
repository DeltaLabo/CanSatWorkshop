digraph PDS_v0_1 {
  graph [rankdir=TB, splines=polyline, nodesep=0.5, ranksep=0.85, pad=0.25, bgcolor="white", fontname="Helvetica", compound=true, forcelabels=true, newrank=true];
  node [shape=box, style="filled", fontname="Helvetica", fontsize=18, margin="0.18,0.12"];
  edge [fontname="Helvetica", fontsize=16, penwidth=2.5, arrowsize=0.8];

  subgraph cluster_user {
    label="User";
    style="filled,rounded";
    fillcolor="#BFEAF4";
    color="#5B65C9";
    penwidth=2;

    switch_on [label="Switch power\non", fillcolor="#BDFB9B", color="#166534"];
    switch_off [label="Switch power\noff", fillcolor="#BDFB9B", color="#166534"];
  }

  subgraph cluster_pds {
    label="PDS v0.1 Subsystem";
    style="filled,rounded";
    fillcolor="#D9D9D9";
    color="#888888";
    penwidth=2;

    subgraph cluster_board {
      label="PDS Circuitboard";
      style="filled";
      fillcolor="#FFF8BF";
      color="#D1B24A";
      penwidth=2;

      subgraph cluster_protection {
        label="Protection Circuit";
        style="filled";
        fillcolor="#FFF8BF";
        color="#D1B24A";
        penwidth=2;

        subgraph cluster_power_protection {
          label="Power Protection";
          style="filled,rounded";
          fillcolor="#A9C7E6";
          color="#5B65C9";
          penwidth=2;

          restore_power [label="Restore power", fillcolor="#BDFB9B", color="#166534"];
          cut_off_power [label="Cut off power", fillcolor="#BDFB9B", color="#166534"];
        }
      }

      connector_terminal [label="Connector\nTerminal", fillcolor="#FFF5B0", color="#D1B24A"];

      subgraph cluster_regulator_block {
        label="Regulator";
        style="filled";
        fillcolor="#FFF8BF";
        color="#D1B24A";
        penwidth=2;

        subgraph cluster_regulator {
          label="Regulator";
          style="filled,rounded";
          fillcolor="#A9C7E6";
          color="#5B65C9";
          penwidth=2;

          regulate_voltage [label="Regulate voltage", fillcolor="#BDFB9B", color="#166534"];
        }
      }
    }

    subgraph cluster_battpack {
      label="1s1P Li-Ion";
      style="filled";
      fillcolor="#FFF8BF";
      color="#D1B24A";
      penwidth=2;

      subgraph cluster_battery {
        label="Battery";
        style="filled,rounded";
        fillcolor="#A9C7E6";
        color="#5B65C9";
        penwidth=2;

        store_energy [label="Store energy", fillcolor="#BDFB9B", color="#166534"];
        provide_power [label="Provide power", fillcolor="#BDFB9B", color="#166534"];
      }
    }
  }

  screw_terminals [label="{c} Screw terminal or\ncrimped cables", fillcolor="#FFF5B0", color="#D1B24A"];

  switch_on -> switch_off [style=invis, weight=10];
  store_energy -> provide_power [style=invis, weight=10];
  restore_power -> cut_off_power [style=invis, weight=10];
  screw_terminals -> connector_terminal [style=dashed, color="#333333", constraint=false];

  { rank=same; switch_on; restore_power; store_energy; }
  { rank=same; switch_off; cut_off_power; provide_power; }
  { rank=same; regulate_voltage; screw_terminals; }
  restore_power -> store_energy [style=invis, weight=40];
  regulate_voltage -> screw_terminals [style=invis, weight=8];
  restore_power -> regulate_voltage [style=invis, weight=25];
  store_energy -> regulate_voltage [style=invis, weight=10];
  regulate_voltage -> connector_terminal [style=invis, weight=25];

  switch_on -> restore_power [color="#1F7A4D", fontcolor="#1F7A4D", constraint=false];
  switch_off -> cut_off_power [color="#1F7A4D", fontcolor="#1F7A4D", constraint=false];
  provide_power -> regulate_voltage [color="#1F7A4D", fontcolor="#1F7A4D", constraint=false];

  store_energy -> restore_power [xlabel="Battery Cable JST", color="#E11D28", fontcolor="#E11D28", ltail=cluster_battpack, lhead=cluster_protection, constraint=false];
  restore_power -> regulate_voltage [xlabel="PC Out / GND", color="#E11D28", fontcolor="#E11D28", ltail=cluster_protection, lhead=cluster_regulator_block, constraint=false];
  regulate_voltage -> connector_terminal [xlabel="5V / 3V3 / GND", color="#E11D28", fontcolor="#E11D28", constraint=false];
}
