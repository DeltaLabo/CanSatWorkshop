#include <TinyGPS++.h>
#include <HardwareSerial.h>

TinyGPSPlus gps;
HardwareSerial GPS_Serial(1);

// ─────────────────────────────────────────────
// Inicialización
// ─────────────────────────────────────────────
void setup() {
  // Init Serial0 con interrupts
  Serial.begin(115200);

  // Esperar al puerto USB CDC con timeout (crítico para XIAO ESP32 S3)
  unsigned long startTime = millis();
  while (!Serial && (millis() - startTime) < 3000);

  // Init Serial1 con interrupts — RX=GPIO3 (D2), TX=GPIO4 (D3)
  GPS_Serial.begin(38400, SERIAL_8N1, 3, 4, false, 5);

  Serial.println("GPS Module Test - XIAO ESP32 S3");
}

// ─────────────────────────────────────────────
// Loop de prueba — simula cómo el OBCC usaría
// los getters en producción a 5 Hz
// ─────────────────────────────────────────────
void loop() {
  // Medir tiempo de inicio de la iteración
  unsigned long iterationStart = millis();

  long latitude, longitude, speed;
  unsigned short result;

  result = getLatitude(&latitude);
  Serial.print("Latitud:   "); Serial.print(latitude);
  Serial.print("  |  código: "); Serial.println(result);

  result = getLongitude(&longitude);
  Serial.print("Longitud:  "); Serial.print(longitude);
  Serial.print("  |  código: "); Serial.println(result);

  result = getSpeed(&speed);
  Serial.print("Velocidad: "); Serial.print(speed);
  Serial.print("  |  código: "); Serial.println(result);

  // Diagnóstico de fix
  Serial.print("Satélites: "); Serial.println(gps.satellites.value());
  Serial.print("Fix válido: "); Serial.println(gps.location.isValid() ? "SÍ" : "NO");
  Serial.print("Tramas procesadas: "); Serial.println(gps.charsProcessed());

  if (millis() > 5000 && gps.charsProcessed() < 10) {
    Serial.println("⚠️  Sin datos del GPS — revisa el cableado y el baud rate");
  }

  // Tiempo que tomó esta iteración
  unsigned long iterationTime = millis() - iterationStart;
  Serial.print("Tiempo de iteración: "); Serial.print(iterationTime); Serial.println("ms");

  Serial.println();

  // Esperar el tiempo restante para completar 200ms (5 Hz)
  if (iterationTime < 200) {
    delay(200 - iterationTime);
  }
}

// ─────────────────────────────────────────────
// Adquisición de datos compartida
// Timeout máximo de 5ms sobre la lectura UART
// ─────────────────────────────────────────────
void acquireGPSData() {
  unsigned long startTime = millis();

  while (GPS_Serial.available() > 0) {
    if (millis() - startTime >= 4) {
      break; // Timeout de 5ms alcanzado
    }
    gps.encode(GPS_Serial.read());
  }
}

