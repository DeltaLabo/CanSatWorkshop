vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PV3 — PDS-VV-CON-001 functional allocation testbench.
# Capella PA PV3 only: System/PCs/LCs/Functions, EAs with Functions, and constraints.
# No PLs, CEs, or FEs. References: IVV, PDS-R2, PDS-R4, PDS-R5, PDS-R6, PDS-R7.
# Traceability: [C] At 4.2 V, 0.5 A; PDS-UC-ChargeESS; PDS-FE-LiIonUnsafeCondition;
# PDS-FE-OvercurrentOvervoltage; PDS-VV-FC-001; PDS-VV-SAFE-001.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

test_operator: "[EA] Test Operator" {
  class: ea
  direction: down
  grid-columns: 1
  read_definition: "[F] Read modeled\nverification definition" { class: func }
  inspect_liion_docs: "[F] Inspect Li-ion\nsafety documents and limits" { class: func }
  connect_approved_setup: "[F] Connect approved\ncharge setup" { class: func }
  command_charge_enable: "[F] Command charge\nenergize when approved" { class: func }
  record_deviation: "[F] Record deviation\nor anomaly" { class: func }
}

safety_observer: "[EA] Safety Observer /\nWitness" {
  class: ea
  direction: down
  grid-columns: 1
  verify_containment: "[F] Verify fire-safe\nLi-ion containment" { class: func }
  approve_energize: "[F] Approve energize\nwithin documented limits" { class: func }
  hold_abort_unsafe: "[F] Hold or abort\nunsafe setup" { class: func }
  witness_result: "[F] Witness charge\npass/fail classification" { class: func }
}

charger_emulator: "[EA] Certified current-limited\ncharger / emulator" {
  class: ea
  direction: down
  grid-columns: 1
  verify_certification: "[F] Verify charger\ncertification / suitability" { class: func }
  set_charge_voltage: "[F] Set 4.2 V\ncharge voltage limit" { class: func }
  set_charge_current: "[F] Set 0.5 A\ncharge current limit" { class: func }
  provide_power: "[F] Provide power" { class: func }
  report_charger_status: "[F] Report charger\nstatus and termination" { class: func }
}

battery_emulator: "[EA] Battery emulator /\ncurrent-limited source" {
  class: ea
  direction: down
  grid-columns: 1
  set_emulated_limits: "[F] Set emulated-cell\nvoltage/current limits" { class: func }
  dry_run_charge_path: "[F] Dry-run charge path\nwithout Li-ion cell" { class: func }
  remove_emulated_energy: "[F] Remove emulator\nenergy on hold" { class: func }
}

usb_meter: "[EA] USB power meter /\ncurrent-voltage logger" {
  class: ea
  direction: down
  grid-columns: 1
  log_usb_voltage_current: "[F] Log USB input\nvoltage and current" { class: func }
}

dmm_daq: "[EA] Calibrated DMM / DAQ" {
  class: ea
  direction: down
  grid-columns: 1
  measure_charge_voltage: "[F] Measure cell/protection\ncharge voltage" { class: func }
  measure_charge_current: "[F] Measure charge\ncurrent" { class: func }
  retain_raw_samples: "[F] Retain raw\nV-I samples" { class: func }
}

scope_logger: "[EA] Oscilloscope /\ncharge logger" {
  class: ea
  direction: down
  grid-columns: 1
  capture_charge_profile: "[F] Capture complete\ncharge profile if used" { class: func }
  capture_transients: "[F] Capture connection /\ntermination transients" { class: func }
}

thermal_instr: "[EA] Thermal camera /\nthermocouples" {
  class: ea
  direction: down
  grid-columns: 1
  measure_temperature: "[F] Measure battery,\nprotection, connector temperature" { class: func }
}

ambient_meter: "[EA] Ambient thermometer /\nhygrometer" {
  class: ea
  direction: down
  grid-columns: 1
  read_ambient: "[F] Read ambient\nbefore repetitions" { class: func }
}

fire_safety: "[EA] Fire-safe Li-ion containment /\nE-stop equipment" {
  class: ea
  direction: down
  grid-columns: 1
  contain_flight_pack: "[F] Contain flight pack\nfor normal non-abuse charge" { class: func }
  trip_emergency_stop: "[F] Trip emergency stop\non unsafe condition" { class: func }
}

evidence_repo: "[EA] Evidence repository /\nhost PC" {
  class: ea
  direction: down
  grid-columns: 1
  log_evidence: "[F] Log raw data,\nphotos, documents, holds" { class: func }
  analyze_uncertainty: "[F] Analyze measurement\nuncertainty and tolerance" { class: func }
  archive_package: "[F] Archive controlled\nPDS-VV-CON-001 package" { class: func }
}

system: "[System] PDS-VV-CON-001 functional allocation\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R2; PDS-R4; PDS-R5; PDS-R6; PDS-R7" {
  class: sys
  direction: down
  grid-columns: 2

  uut: "[PC] Integrated PDS & ESS\nv1.0 UUT" {
    class: pc
    direction: down

    ess_module: "[PC] ESS Module" {
      class: pc
      direction: down
      battery_pack: "[PC] 1S1P Li-Ion" {
        class: pc
        direction: down
        battery_lc: "[LC] Battery" {
          class: lc
          direction: down
          grid-columns: 1
          store_energy: "[F] Store energy" { class: func }
          provide_power: "[F] Provide power" { class: func }
          expose_cell_identity: "[F] Expose cell identity\nand safety limits" { class: func }
          remain_non_abuse: "[F] Remain within\nnormal non-abuse conditions" { class: func }
        }
      }
    }

    pds_module: "[PC] PDS Module" {
      class: pc
      direction: down

      pds_pcb: "[PC] PDS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        battery_connector: "[PC] Battery Connector" {
          class: pc
          charge_path_lc: "[LC] Cell/protection\ncharge-path interface" {
            class: lc
            direction: down
            grid-columns: 1
            receive_charge_path: "[F] Receive charger or\nemulator charge path" { class: func }
            expose_charge_voltage: "[F] Expose charge-path\nvoltage for test" { class: func }
            expose_charge_current: "[F] Expose charge-path\ncurrent for test" { class: func }
          }
        }

        protection: "[PC] Protection Circuit" {
          class: pc
          direction: down

          battery_charger: "[LC] Battery Charger" {
            class: lc
            direction: down
            grid-columns: 1
            regulate_voltage: "[F] Regulate voltage" { class: func }
            limit_charge_current: "[F] Limit charge current\nto nominal 0.5 A" { class: func }
            report_termination: "[F] Report actual\ncharge termination" { class: func }
          }

          charger_safety: "[LC] Charger safety\nhold interface" {
            class: lc
            direction: down
            grid-columns: 1
            reject_wrong_charger: "[F] Hold wrong or\nuncertified charger safe" { class: func }
            reject_reverse_ambiguous: "[F] Hold reverse or\nambiguous setup safe" { class: func }
            prevent_unsafe_energize: "[F] Prevent energize\nuntil approved" { class: func }
          }

          power_protection: "[LC] Power Protection" {
            class: lc
            direction: down
            grid-columns: 1
            detect_overcurrent: "[F] Detect overcurrent" { class: func }
            detect_overvoltage: "[F] Detect overvoltage" { class: func }
            cut_off_power: "[F] Cut off power" { class: func }
          }
        }

        ina219: "[PC] INA219" {
          class: pc
          battery_monitoring: "[LC] Battery monitoring" {
            class: lc
            direction: down
            grid-columns: 1
            measure_voltage: "[F] Measure voltage" { class: func }
            measure_current: "[F] Measure current" { class: func }
          }
        }
      }
    }
  }

  test_harness: "[PC] PDS-VV-CON-001\nnormal-charge verification harness" {
    class: pc
    direction: down
    grid-columns: 2

    setup_safety: "[LC] Setup, safety,\nand environment context" {
      class: lc
      direction: down
      grid-columns: 1
      verify_calibration_status: "[F] Verify calibration /\nstatus checks" { class: func }
      record_ambient: "[F] Record ambient T/RH\nbefore repetitions" { class: func }
      verify_safety_documents: "[F] Verify Li-ion safety\ndocuments and limits" { class: func }
      arm_safety_equipment: "[F] Arm containment,\nE-stop, and observer" { class: func }
    }

    charge_control: "[LC] Normal charge\ncontrol" {
      class: lc
      direction: down
      grid-columns: 1
      verify_charger_settings: "[F] Verify charger\nsettings before energize" { class: func }
      command_emulator_check: "[F] Command emulator /\nnon-cell path check" { class: func }
      command_apply_charger: "[F] Apply certified\ncharger to charge path" { class: func }
      stop_on_hold: "[F] Stop before energize\non hold condition" { class: func }
    }

    measurement_capture: "[LC] Charge measurement\nand observation" {
      class: lc
      direction: down
      grid-columns: 1
      sample_voltage_current: "[F] Sample charge voltage\nand current" { class: func }
      measure_pack_temperature: "[F] Measure battery/protection\ntemperature" { class: func }
      observe_no_unsafe_condition: "[F] Observe no swelling,\nsmoke, heating, anomaly" { class: func }
      log_charge_profile: "[F] Log charge data\nand charger termination" { class: func }
    }

    evidence_analysis: "[LC] Evidence analysis\nand trace closure" {
      class: lc
      direction: down
      grid-columns: 1
      compare_charge_constraint: "[F] Compare data to\n4.2 V / 0.5 A constraint" { class: func }
      apply_uncertainty: "[F] Apply tolerance and\nmeasurement uncertainty" { class: func }
      reference_fc001: "[F] Reference PDS-VV-FC-001\nnormal charge path" { class: func }
      reference_safe001: "[F] Reference PDS-VV-SAFE-001\nsafety-document evidence" { class: func }
      classify_no_liion_claim: "[F] Classify no final\nLi-ion claim if docs absent" { class: func }
      package_final_evidence: "[F] Package final\nacceptance evidence" { class: func }
    }
  }

  note_definition: "[C] PDS-VV-CON-001 definition\nConstraint-derived final flight acceptance verification for normal charge\nat modeled 4.2 V / 0.5 A. Trace: PDS-UC-ChargeESS;\nPDS-FE-LiIonUnsafeCondition; PDS-FE-OvercurrentOvervoltage;\nPDS-VV-FC-001; PDS-VV-SAFE-001." {
    class: note
    shape: page
  }

  note_pass: "[C] Pass/fail constraints\nCharge voltage at cell/protection path never exceeds modeled 4.2 V plus\ndeclared uncertainty/tolerance; current is limited to nominal 0.5 A;\nrecord actual termination if below 4.2 V. Any uncontrolled current,\novervoltage, reverse current, unexpected protection event, unsafe\ntemperature, smoke, swelling, or cell/connector anomaly is fail/hold." {
    class: note
    shape: page
  }

  note_safety: "[C] Safety prerequisites\nPowered Li-ion charge requires cell identity, datasheet/SDS or equivalent,\ncharge/discharge/storage limits, UN38.3/IEC62133 or equivalent evidence\nwhen available, current-limited charger, fire-safe enclosure, and Safety\nObserver approval. If absent, use emulator only and report no final Li-ion\ncharge acceptance." {
    class: note
    shape: page
  }

  note_stats_fault: "[C] Statistical and fault-hardening viewpoint\nUse ≥30 stable V/I/T samples per relevant condition or a complete logged\ncharge profile; retain raw data and uncertainty. Fault hardening covers\nwrong/uncertified charger, reverse or ambiguous setup, unsafe ambient,\ncalibration/status issue, overcurrent/overvoltage precursor, heating, and\nLi-ion unsafe-condition precursor. Destructive abuse is out of scope." {
    class: note
    shape: page
  }
}

system.note_definition -> system.uut.pds_module.pds_pcb.protection.battery_charger.regulate_voltage { class: cstr }
system.note_definition -> system.uut.ess_module.battery_pack.battery_lc.store_energy { class: cstr }
system.note_definition -> system.test_harness.evidence_analysis.reference_fc001 { class: cstr }
system.note_pass -> system.uut.pds_module.pds_pcb.battery_connector.charge_path_lc.expose_charge_voltage { class: cstr }
system.note_pass -> system.uut.pds_module.pds_pcb.battery_connector.charge_path_lc.expose_charge_current { class: cstr }
system.note_pass -> system.test_harness.evidence_analysis.compare_charge_constraint { class: cstr }
system.note_pass -> dmm_daq.measure_charge_voltage { class: cstr }
system.note_pass -> dmm_daq.measure_charge_current { class: cstr }
system.note_safety -> system.test_harness.setup_safety.verify_safety_documents { class: cstr }
system.note_safety -> safety_observer.approve_energize { class: cstr }
system.note_safety -> fire_safety.contain_flight_pack { class: cstr }
system.note_safety -> system.uut.ess_module.battery_pack.battery_lc.remain_non_abuse { class: cstr }
system.note_stats_fault -> system.test_harness.measurement_capture.sample_voltage_current { class: cstr }
system.note_stats_fault -> system.test_harness.evidence_analysis.apply_uncertainty { class: cstr }
system.note_stats_fault -> system.uut.pds_module.pds_pcb.protection.charger_safety.reject_wrong_charger { class: cstr }
system.note_stats_fault -> system.uut.pds_module.pds_pcb.protection.charger_safety.prevent_unsafe_energize { class: cstr }
system.note_stats_fault -> thermal_instr.measure_temperature { class: cstr }
system.note_stats_fault -> evidence_repo.archive_package { class: cstr }

# Layout-only rank hints to keep actors, UUT/harness, and constraints readable.
test_operator -> safety_observer { style: { opacity: 0 } }
safety_observer -> charger_emulator { style: { opacity: 0 } }
charger_emulator -> battery_emulator { style: { opacity: 0 } }
battery_emulator -> usb_meter { style: { opacity: 0 } }
usb_meter -> dmm_daq { style: { opacity: 0 } }
dmm_daq -> scope_logger { style: { opacity: 0 } }
scope_logger -> thermal_instr { style: { opacity: 0 } }
thermal_instr -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> fire_safety { style: { opacity: 0 } }
fire_safety -> evidence_repo { style: { opacity: 0 } }
evidence_repo -> system { style: { opacity: 0 } }
system.uut -> system.test_harness { style: { opacity: 0 } }
system.test_harness -> system.note_definition { style: { opacity: 0 } }
system.note_definition -> system.note_pass { style: { opacity: 0 } }
system.note_pass -> system.note_safety { style: { opacity: 0 } }
system.note_safety -> system.note_stats_fault { style: { opacity: 0 } }
