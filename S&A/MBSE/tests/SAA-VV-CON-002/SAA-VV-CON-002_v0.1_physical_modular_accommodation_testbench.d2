vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-CON-002 verification-only Physical Architecture PV1.
# v0.1 reusable structural module readiness testbench for modular-structure and 44 mm PCB accommodation constraints.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R3, SAA-R4, SAA-R5.
# This file is a test-definition view and does not modify the v0.1 baseline model.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
witness: "[EA] Safety / QA Witness" { class: ea }
fit_gauge_set: "[EA] 44 mm PCB Fit Gauge /\nDummy PCB Set\n44.00 mm × 44.00 mm" { class: ea }
caliper_feeler: "[EA] Calipers /\nFeeler Gauges\nC_min, U_C" { class: ea }
keepout_probe: "[EA] Keepout and\nRemoval-Path Probe" { class: ea }
cycle_counter: "[EA] Insert / Remove\nCycle Counter\nN ≥ 3 screen" { class: ea }
camera: "[EA] Photo / Video\nEvidence Camera" { class: ea }
ambient_meter: "[EA] Ambient Thermo-\nHygrometer" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-CON-002" { class: ea }

system: "[System] SAA-VV-CON-002 v0.1 Modular Structure and 44 mm PCB Accommodation Testbench\nRefs: IVV; SAA-R1; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down
  grid-columns: 1

  article: "[PC] v0.1 Reusable Module Article\ntransition-readiness UUT" {
    class: pc
    direction: right

    structural_envelope: "[PC] CanSat Structural\nEnvelope" {
      class: pc
      direction: right

      standard_stack: "[PC] Standard Carrier\nModule Stack\n(Type 1)" {
        class: pc
        direction: down
        grid-columns: 1

        ads_module: "[PC] ADS Module\nType 1 standard carrier" { class: pc }
        ams_module: "[PC] AMS Module\nType 1 standard carrier" { class: pc }
        obcc_module: "[PC] OBCC Module\nType 1 standard carrier" { class: pc }
        pds_module: "[PC] PDS Module\nType 1 standard carrier" { class: pc }
        ess_module: "[PC] ESS Module\nType 1 standard carrier" { class: pc }
      }

      backplane_volume: "[PC] Perpendicular\nBackplane Volume" { class: pc }
      parachute_module: "[PC] Parachute / Top\nModule\n(Type 2)" { class: pc }
    }
  }

  type_count_limit: "[C] v0.1 module-type pass/fail:\nOnly two module types may be present: Type 1 Standard Carrier Module\nand Type 2 Parachute / Top Module. ADS/AMS/OBCC/PDS/ESS are Type 1\ninstances. Any third structural module family, permanent adapter, shim\nor undocumented variant is hold/fail unless the baseline is updated." {
    class: note
    shape: page
  }

  accommodation_limit: "[C] v0.1 44 mm accommodation pass/fail:\nADS/AMS/OBCC/PDS standard-module accommodations accept a calibrated\n44.00 mm × 44.00 mm dummy PCB or fit gauge through the intended service\npath without forced fit, scraping, filing, board flex, temporary omission\nor unapproved hardware removal. ESS is counted as Type 1; any future ESS\nPCB-bay claim must use the same evidence or be documented as battery-only." {
    class: note
    shape: page
  }

  clearance_retention: "[C] Clearance/retention constraint:\nFor every mandatory accommodation, measured clearance after uncertainty\nis positive: C_min - U_C > 0 at edges, standoffs, keepouts and removal\npath. Retention features engage without warped-print contact, stripped\nbosses, loose board, rocking beyond intended clearance or stress marks." {
    class: note
    shape: page
  }

  keepout_interference: "[C] Keepout/removal-path constraint:\nBackplane volume, stack screws, adjacent modules and top module must not\nblock insertion or removal of the 44 mm gauge. No snag, scrape, forced\nrotation, blocked service path or post-fit damage is allowed." {
    class: note
    shape: page
  }

  evidence_conditions: "[C] Evidence/environment constraint:\nRecord baseline copy, article ID, gauge ID, calibration, ambient\ntemperature/humidity before cycles, raw clearances, uncertainty, N ≥ 3\ninsert/remove screen cycles per mandatory accommodation, photos/video,\nwitness decision and anomaly dispositions under results/SAA-VV-CON-002/." {
    class: note
    shape: page
  }

  viewpoints: "[C] Viewpoints:\nStatistical = 100% census of module instances and mandatory PCB accommodations;\ninsert/remove repetitions are screening only, no reliability claim. Fault\nhardening = wrong type count, tolerance stack, warped print, undersized gauge,\nforced fit, interference, blocked removal path or evidence-control escape." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability targets:\nModeled modular-structure constraint; SAA-UC-IntegratedAssembly;\nSAA-FE-EnvelopeNonCompliance; SAA-FE-StructuralLoosening." {
    class: note
    shape: page
  }
}

system.article.structural_envelope.standard_stack.ads_module -- system.article.structural_envelope.standard_stack.ams_module: "[PL] Stack screws" { class: pl }
system.article.structural_envelope.standard_stack.ams_module -- system.article.structural_envelope.standard_stack.obcc_module: "[PL] Stack screws" { class: pl }
system.article.structural_envelope.standard_stack.obcc_module -- system.article.structural_envelope.standard_stack.pds_module: "[PL] Stack screws" { class: pl }
system.article.structural_envelope.standard_stack.pds_module -- system.article.structural_envelope.standard_stack.ess_module: "[PL] Stack screws" { class: pl }
system.article.structural_envelope.standard_stack -- system.article.structural_envelope.parachute_module: "[PL] Stack screws" { class: pl }
system.article.structural_envelope.standard_stack -- system.article.structural_envelope.backplane_volume: "[PL] Perpendicular\nbackplane slot" { class: pl }
system.article.structural_envelope.parachute_module -- system.article.structural_envelope.backplane_volume: "[PL] Backplane\nclearance" { class: pl }

operator -- system.article: "[PL] Handling /\nmodule census" { class: pl }
witness -- system.article: "[PL] Witnessed\ninspection" { class: pl }
fit_gauge_set -- system.article.structural_envelope.standard_stack: "[PL] ADS/AMS/OBCC/PDS\n44 mm dummy insertion" { class: pl }
caliper_feeler -- system.article.structural_envelope.standard_stack: "[PL] Clearance probes" { class: pl }
keepout_probe -- system.article.structural_envelope.standard_stack: "[PL] Service path /\nkeepout probe" { class: pl }
keepout_probe -- system.article.structural_envelope.backplane_volume: "[PL] Backplane-volume\nkeepout probe" { class: pl }
cycle_counter -- fit_gauge_set: "[PL] Cycle log" { class: pl }
camera -- system.article: "[PL] Photos/video" { class: pl }
ambient_meter -- system.article: "[PL] Ambient record" { class: pl }
repo -- camera: "[PL] Evidence transfer" { class: pl }

system.type_count_limit -> system.article.structural_envelope.standard_stack { class: cstr }
system.type_count_limit -> system.article.structural_envelope.parachute_module { class: cstr }
system.accommodation_limit -> system.article.structural_envelope.standard_stack { class: cstr }
system.clearance_retention -> system.article.structural_envelope.standard_stack { class: cstr }
system.keepout_interference -> system.article.structural_envelope.backplane_volume { class: cstr }
system.evidence_conditions -> repo { class: cstr }
system.evidence_conditions -> ambient_meter { class: cstr }
system.viewpoints -> system.article { class: cstr }
system.traceability -> system.article.structural_envelope.standard_stack { class: cstr }

# Layout-only edges keep test equipment, UUT, repository, and notes in a stable reading order.
operator -> witness { style: { opacity: 0 } }
witness -> fit_gauge_set { style: { opacity: 0 } }
fit_gauge_set -> caliper_feeler { style: { opacity: 0 } }
caliper_feeler -> keepout_probe { style: { opacity: 0 } }
keepout_probe -> cycle_counter { style: { opacity: 0 } }
cycle_counter -> camera { style: { opacity: 0 } }
camera -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.article -> system.type_count_limit { style: { opacity: 0 } }
system.type_count_limit -> system.accommodation_limit { style: { opacity: 0 } }
system.accommodation_limit -> system.clearance_retention { style: { opacity: 0 } }
system.clearance_retention -> system.keepout_interference { style: { opacity: 0 } }
system.keepout_interference -> system.evidence_conditions { style: { opacity: 0 } }
system.evidence_conditions -> system.viewpoints { style: { opacity: 0 } }
system.viewpoints -> system.traceability { style: { opacity: 0 } }
