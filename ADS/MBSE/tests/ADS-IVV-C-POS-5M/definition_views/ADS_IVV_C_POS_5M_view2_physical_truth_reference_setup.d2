vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PV1 physical setup for GPS position accuracy testing.
# Only PCs, non-human EAs, PLs, and constraints are shown.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

gnss_truth: "[EA] GNSS simulator or\nsurveyed reference receiver" { class: ea }
gps_fault_source: "[EA] GNSS/UART\nfault source" { class: ea }
power_supply: "[EA] Current-limited\npower supply" { class: ea }

system: "[System] ADS-IVV-C-POS-5M physical truth/reference setup\nRefs: IVV, ADS MBSE plan, GPS/UBX, SW/statistics" {
  class: sys
  direction: right

  uut: "[PC] ADS UUT /\nversion selector" {
    class: pc
    direction: down
    grid-columns: 2

    v01: "[PC] v0.1 GPS prototype\napplicable" { class: pc }
    v02: "[PC] v0.2 GPS+IMU prototype\napplicable" { class: pc }
    v10: "[PC] v1.0 integrated ADS/OBCC\napplicable observation point" { class: pc }
    v03: "[PC] v0.3 PCB delivery\nN/A for behavior" { class: pc }
  }

  harness: "[PC] Verification harness /\nlogging adapter" {
    class: pc
    direction: down
    grid-columns: 1

    ads_log_port: "[PC] ADS log /\ntelemetry tap" { class: pc }
    truth_log_port: "[PC] Truth and\ntime correlation port" { class: pc }
    obcc_obs_port: "[PC] v1.0 ADS/OBCC\nobservation tap" { class: pc }
  }
}

pc_logger: "[EA] PC / OBCC logger" { class: ea }
timebase: "[EA] Common timebase\n(PPS, NTP, or clock sync)" { class: ea }
condition_station: "[EA] Ambient and sky\ncondition monitor" { class: ea }
analysis_host: "[EA] Statistical\nanalysis host" { class: ea }

c_truth: "[C] Select one truth method per campaign:\nGNSS simulator OR surveyed high-confidence\nreference receiver; record calibration and uncertainty" {
  class: note
  shape: page
}
c_samples: "[C] Collect n ≥ 30 matched valid\nADS/truth samples per campaign; preserve\nraw logs and timestamps" {
  class: note
  shape: page
}
c_guard: "[C] Pass if horizontal error plus\ntruth/measurement uncertainty guard band\nOR formal 95/95 bound is < 5 m" {
  class: note
  shape: page
}
c_faults: "[C] Invalid/no-fix/stale samples may\nbe excluded only when visibly flagged or\nhandled invalid by ADS/OBCC" {
  class: note
  shape: page
}
c_environment: "[C] Record sky visibility, multipath,\nantenna placement, ambient conditions,\nwarm-up, power, and selected ADS version" {
  class: note
  shape: page
}

gnss_truth -- system.uut: "[PL] RF / antenna /\nsurveyed-truth path" { class: pl }
gps_fault_source -- system.uut: "[PL] no-fix, stale,\nmalformed, silent stimulus" { class: pl }
power_supply -- system.uut: "[PL] USB or 3V3\npower feed" { class: pl }

system.uut -- system.harness.ads_log_port: "[PL] USB/UART\ntap" { class: pl }
system.uut.v10 -- system.harness.obcc_obs_port: "[PL] OBCC\ntap" { class: pl }
system.harness.truth_log_port -- gnss_truth: "[PL] truth\nlog" { class: pl }
pc_logger -- system.harness.ads_log_port: "[PL] ADS\nlog" { class: pl }
timebase -- system.harness.truth_log_port: "[PL] time\nref" { class: pl }
condition_station -- system.harness.truth_log_port: "[PL] condition\nrecord" { class: pl }
analysis_host -- system.harness.truth_log_port: "[PL] evidence\ntransfer" { class: pl }

c_truth -> gnss_truth { class: cstr }
c_samples -> system.harness { class: cstr }
c_guard -> analysis_host { class: cstr }
c_faults -> gps_fault_source { class: cstr }
c_faults -> system.uut { class: cstr }
c_environment -> condition_station { class: cstr }

# Layout-only edge to keep the equipment band ordered around the UUT.
gnss_truth -> system { style: { opacity: 0 } }
system -> pc_logger { style: { opacity: 0 } }
