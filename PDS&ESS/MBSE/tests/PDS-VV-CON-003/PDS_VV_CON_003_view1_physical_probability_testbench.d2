vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PV1 — PDS-VV-CON-003 physical probability testbench.
# Capella PA PV1 only: System, PCs, non-human EAs with PLs, Physical Links, constraints.
# References: IVV, PDS-R4, PDS-R5, PDS-R6, PDS-R7, PDS-R8, and PDS-R2 for CanSat safety context.
# Traceability: [C] Probability < 1%; PDS-VV-FC-001; PDS-FE-OvercurrentOvervoltage;
# PDS-FE-LiIonUnsafeCondition; PDS-FE-RailBrownout; PDS-UC-ProvideRegulatedPower.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

battery_emulator: "[EA] Battery emulator /\ncurrent-limited source" { class: ea }
overcurrent_harness: "[EA] Overcurrent / short-equivalent\ndemand harness" { class: ea }
overvoltage_source: "[EA] Current-limited\novervoltage source" { class: ea }
rail_loads: "[EA] Protected rail loads /\nrepresentative flight loads" { class: ea }
safety_controller: "[EA] Relay / interlock /\nsafety controller" { class: ea }
dmm_daq: "[EA] Calibrated DMM / DAQ" { class: ea }
scope_logger: "[EA] Oscilloscope /\nlogger" { class: ea }
thermal_instr: "[EA] Thermal camera /\nthermocouples" { class: ea }
ambient_meter: "[EA] Ambient thermometer /\nhygrometer" { class: ea }
fire_safety: "[EA] E-stop / fire-safe\nLi-ion containment" { class: ea }
evidence_repo: "[EA] Evidence repository /\nhost PC" { class: ea }

system: "[System] PDS-VV-CON-003 protection probability physical testbench\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R4; PDS-R5; PDS-R6; PDS-R7; PDS-R8; PDS-R2" {
  class: sys
  direction: down
  grid-columns: 1

  test_harness: "[PC] PDS-VV-CON-003\nprobability demand test harness" {
    class: pc
    direction: down
    grid-columns: 2

    battery_fixture: "[PC] Fault-safe battery-emulator\ninput fixture" { class: pc }
    protected_output_breakout: "[PC] Protected output /\nbackplane rail breakout" { class: pc }
    overcurrent_adapter: "[PC] Current-limited overcurrent /\nshort-equivalent adapter" { class: pc }
    overvoltage_adapter: "[PC] Current-limited\novervoltage adapter" { class: pc }
    rail_load_adapter: "[PC] Rail load adapter" { class: pc }
    interlock_panel: "[PC] Relay interlock /\nE-stop panel" { class: pc }
    measurement_breakout: "[PC] Cut-off, rail, current,\nand restore measurement breakout" { class: pc }
    thermal_fixture: "[PC] Thermal sensor mounts /\nIR sight lines" { class: pc }
    environment_station: "[PC] Ambient record station" { class: pc }
    log_export: "[PC] Trial log export /\ncontrolled media" { class: pc }
  }

  uut: "[PC] Integrated PDS & ESS\nv1.0 UUT" {
    class: pc
    direction: down

    ess_module: "[PC] ESS Module" {
      class: pc
      direction: down
      battery_pack: "[PC] 1S1P Li-Ion\nflight pack contained;\nno abuse during trials" { class: pc }
    }

    pds_module: "[PC] PDS Module" {
      class: pc
      direction: down

      pds_pcb: "[PC] PDS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        battery_connector: "[PC] Battery Connector" { class: pc }
        protection: "[PC] Protection Circuit\nprobability constraint item" { class: pc }
        ina219: "[PC] INA219" { class: pc }
        regulator: "[PC] Regulator" { class: pc }
        pds_backplane_connector: "[PC] Backplane Connector\nprotected output rails" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB\nprotected rail distribution" {
      class: pc
      direction: down
      pds_headers: "[PC] 2mm 2x6 PDS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }

    obcc_module: "[PC] OBCC Module\nreset / restart witness" {
      class: pc
      direction: down
      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        xiao: "[PC] XIAO ESP32-S3" { class: pc }
        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }
  }


  note_scope: "[C] PDS-VV-CON-003 scope and interpretation\nVerify modeled [C] Probability < 1% as missed demanded unsafe\nprotection action probability <1% for each mode: overcurrent /\nshort-equivalent and overvoltage. Trace to PDS-VV-FC-001 and\nPDS-FE-OvercurrentOvervoltage / LiIonUnsafeCondition / RailBrownout." {
    class: note
    shape: page
  }

  note_safety: "[C] Environmental and safety controls\nRead ambient before each trial set; verify instrument status;\nset current limits before energizing; Safety Observer approves.\nBattery emulator preferred for all demand trials. No flight-pack\nshort or overcharge abuse; destructive Li-ion abuse out of scope." {
    class: note
    shape: page
  }

  note_acceptance: "[C] Statistical pass/fail\nAny missed unsafe action is fail/hold/anomaly and cannot be waived\ninto a pass for the statistical claim. Formal <1% at 95% confidence:\n299 independent zero-missed demanded-protection trials per mode.\nFewer trials: report exact one-sided Clopper-Pearson upper bound only." {
    class: note
    shape: page
  }

  note_observability: "[C] Trial observability constraints\nDemand inside safe/current-limited envelope; detect function observable;\ncut-off before unsafe rail/cell/temperature limits; rails safe; restore\ninhibited until cleared; controlled restore returns nominal without reset\nor uncontrolled restart. Continuous data calibrated/raw; use PDS-VV-CON-004\nor collect ≥30 samples where continuous limits are claimed." {
    class: note
    shape: page
  }
}

# Baseline protected power path under probability test.
system.uut.ess_module.battery_pack -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] battery cable" { class: pl }
system.uut.pds_module.pds_pcb.battery_connector -- system.uut.pds_module.pds_pcb.protection: "[PL] Battery ± traces" { class: pl }
system.uut.pds_module.pds_pcb.protection -- system.uut.pds_module.pds_pcb.ina219: "[PL] Protection output trace" { class: pl }
system.uut.pds_module.pds_pcb.ina219 -- system.uut.pds_module.pds_pcb.regulator: "[PL] INA output trace" { class: pl }
system.uut.pds_module.pds_pcb.regulator -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] protected rails" { class: pl }
system.uut.pds_module.pds_pcb.pds_backplane_connector -- system.uut.backplane_pcb.pds_headers: "[PL] PDS parallel cable" { class: pl }
system.uut.backplane_pcb.pds_headers -- system.uut.backplane_pcb.spine: "[PL] backplane copper" { class: pl }
system.uut.backplane_pcb.spine -- system.uut.backplane_pcb.obcc_headers: "[PL] backplane copper" { class: pl }
system.uut.backplane_pcb.obcc_headers -- system.uut.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] OBCC parallel cable" { class: pl }
system.uut.obcc_module.obcc_pcb.obcc_backplane_connector -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] 3V3 / reset witness traces" { class: pl }

# Verification-only physical links.
battery_emulator -- system.test_harness.battery_fixture: "[PL] source leads" { class: pl }
system.test_harness.battery_fixture -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] battery input" { class: pl }
overcurrent_harness -- system.test_harness.overcurrent_adapter: "[PL] OC cable" { class: pl }
system.test_harness.overcurrent_adapter -- system.test_harness.protected_output_breakout: "[PL] OC injection" { class: pl }
system.test_harness.protected_output_breakout -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] rail access" { class: pl }
overvoltage_source -- system.test_harness.overvoltage_adapter: "[PL] OV leads" { class: pl }
system.test_harness.overvoltage_adapter -- system.test_harness.protected_output_breakout: "[PL] OV injection" { class: pl }
rail_loads -- system.test_harness.rail_load_adapter: "[PL] load cables" { class: pl }
system.test_harness.rail_load_adapter -- system.test_harness.protected_output_breakout: "[PL] rail loads" { class: pl }
safety_controller -- system.test_harness.interlock_panel: "[PL] interlock" { class: pl }
system.test_harness.interlock_panel -- system.test_harness.battery_fixture: "[PL] source cutoff" { class: pl }
system.test_harness.interlock_panel -- system.test_harness.overcurrent_adapter: "[PL] fault cutoff" { class: pl }
system.test_harness.interlock_panel -- system.test_harness.overvoltage_adapter: "[PL] OV cutoff" { class: pl }
dmm_daq -- system.test_harness.measurement_breakout: "[PL] DMM leads" { class: pl }
scope_logger -- system.test_harness.measurement_breakout: "[PL] scope probes" { class: pl }
system.test_harness.measurement_breakout -- system.test_harness.protected_output_breakout: "[PL] rail probes" { class: pl }
system.test_harness.measurement_breakout -- system.uut.pds_module.pds_pcb.protection: "[PL] protection probes" { class: pl }
thermal_instr -- system.test_harness.thermal_fixture: "[PL] thermal link" { class: pl }
system.test_harness.thermal_fixture -- system.uut.pds_module.pds_pcb.protection: "[PL] protection thermal" { class: pl }
system.test_harness.thermal_fixture -- system.uut.pds_module.pds_pcb.regulator: "[PL] regulator thermal" { class: pl }
system.test_harness.thermal_fixture -- system.uut.ess_module.battery_pack: "[PL] battery thermal" { class: pl }
ambient_meter -- system.test_harness.environment_station: "[PL] ambient" { class: pl }
system.test_harness.environment_station -- system.uut: "[PL] test-cell prox" { class: pl }
fire_safety -- system.uut.ess_module.battery_pack: "[PL] containment" { class: pl }
fire_safety -- system.test_harness.interlock_panel: "[PL] E-stop" { class: pl }
evidence_repo -- system.test_harness.log_export: "[PL] evidence link" { class: pl }
system.test_harness.log_export -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] reset log" { class: pl }

system.note_scope -> system.uut.pds_module.pds_pcb.protection { class: cstr }
system.note_scope -> system.test_harness.protected_output_breakout { class: cstr }
system.note_safety -> system.test_harness.battery_fixture { class: cstr }
system.note_safety -> system.test_harness.interlock_panel { class: cstr }
system.note_safety -> fire_safety { class: cstr }
system.note_acceptance -> system.test_harness.overcurrent_adapter { class: cstr }
system.note_acceptance -> system.test_harness.overvoltage_adapter { class: cstr }
system.note_acceptance -> system.test_harness.log_export { class: cstr }
system.note_observability -> system.uut.pds_module.pds_pcb.protection { class: cstr }
system.note_observability -> system.test_harness.measurement_breakout { class: cstr }
system.note_observability -> system.uut.backplane_pcb { class: cstr }

# Layout-only rank hints for equipment, UUT/harness, and constraint bands.
battery_emulator -> overcurrent_harness { style: { opacity: 0 } }
overcurrent_harness -> overvoltage_source { style: { opacity: 0 } }
overvoltage_source -> rail_loads { style: { opacity: 0 } }
rail_loads -> safety_controller { style: { opacity: 0 } }
safety_controller -> dmm_daq { style: { opacity: 0 } }
dmm_daq -> scope_logger { style: { opacity: 0 } }
scope_logger -> thermal_instr { style: { opacity: 0 } }
thermal_instr -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> fire_safety { style: { opacity: 0 } }
fire_safety -> evidence_repo { style: { opacity: 0 } }
evidence_repo -> system { style: { opacity: 0 } }
system.test_harness -> system.uut { style: { opacity: 0 } }
system.test_harness -> system.note_scope { style: { opacity: 0 } }
system.note_scope -> system.note_safety { style: { opacity: 0 } }
system.note_safety -> system.note_acceptance { style: { opacity: 0 } }
system.note_acceptance -> system.note_observability { style: { opacity: 0 } }
