vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Evidence and traceability interface view for ADS-IVV-C-NOBLOCK.
# Ensures reports bind evidence to model elements, constraints, capabilities, and feared event.
direction: right

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

ivv_authority: "[EA] IVV authority /\ntest reviewer" { class: ea }
source_package: "[EA] Copied ADS MBSE\nsource view package" { class: ea }
firmware_repo: "[EA] Firmware repository /\nconfiguration source" { class: ea }
equipment_archive: "[EA] Equipment and\ncalibration archive" { class: ea }
master_plan: "[EA] ADS-wide IVV plan\ncoverage update" { class: ea }

system: "[System] ADS-IVV-C-NOBLOCK\nEvidence and traceability interfaces\nRefs: IVV; ADS MBSE plan; SW/stats; GPS/UBX; IMU/I2C" {
  class: sys
  direction: down

  record: "[PC] No-blocking verification\nrecord package" {
    class: pc
    direction: down
    grid-columns: 2

    trace_matrix: "[LC] Traceability matrix" {
      class: lc
      direction: down
      map_constraint: "[F] Map no-blocking\nconstraint and linked timeouts" { class: func }
      map_model_elements: "[F] Map Loop / ADS Processing,\nUART/I2C reads, process/getters" { class: func }
      map_targets: "[F] Map ADS-FE-STUCK-LOOP,\nADS-CAP-INIT, ADS-CAP-DELIVERY" { class: func }
    }

    review_evidence: "[LC] Code/model\nreview evidence" {
      class: lc
      direction: down
      store_review: "[F] Store D2/source review\nchecklist" { class: func }
      store_callgraph: "[F] Store call graph and\nblocking-call inventory" { class: func }
      store_timeout_paths: "[F] Store UART/I2C timeout\nand error-path rationale" { class: func }
    }

    runtime_evidence: "[LC] Runtime supporting\ntest evidence" {
      class: lc
      direction: down
      store_heartbeat: "[F] Store heartbeat and\ncycle progress logs" { class: func }
      store_fault_logs: "[F] Store GPS/I2C fault\nmarkers and raw logs" { class: func }
      store_environment: "[F] Store power, ambient,\nlogger timebase conditions" { class: func }
    }

    analysis_record: "[LC] Analysis result\nrecord" {
      class: lc
      direction: down
      classify_waits: "[F] Store wait classification\nand hidden-wait disposition" { class: func }
      evaluate_timing: "[F] Store timing/timeout and\nstall analysis" { class: func }
      evaluate_faults: "[F] Store fault-hardening\nrecovery analysis" { class: func }
    }

    disposition: "[LC] Verdict and\ndisposition record" {
      class: lc
      direction: down
      store_verdict: "[F] Store pass/fail, blocked,\nor v0.3 N/A verdict" { class: func }
      store_limits: "[F] Store deviations, gaps,\nwaivers, limitations, retest" { class: func }
    }
  }
}

note_targets: "[C] Traceability targets\nConstraint: No blocking operations besides I2C or UART comms.\nFeared event: ADS-FE-STUCK-LOOP.\nCapabilities: ADS-CAP-INIT and ADS-CAP-DELIVERY.\nConstraint-derived evidence also supports runtime delivery confidence." { class: note; shape: page }
note_reports: "[C] Expected reports\n../results/ADS-IVV-C-NOBLOCK/v0.1/\n../results/ADS-IVV-C-NOBLOCK/v0.2/\n../results/ADS-IVV-C-NOBLOCK/v0.3/\n../results/ADS-IVV-C-NOBLOCK/v1.0/" { class: note; shape: page }
note_status: "[C] Status and limitations\nDefinition ready; execution pending. Pass requires firmware source\nor equivalent instrumentation access. v0.2 I2C timeout is a model gap;\nv0.3 is runtime N/A after source review." { class: note; shape: page }
note_coverage: "[C] Coverage rule\nReport shall name selected version/SSIV, source views, modeled elements,\nIADT method, statistics and fault-hardening viewpoints, pass/fail rationale,\nanomalies, waivers, and retest status." { class: note; shape: page }

source_package -> system.record.trace_matrix: "[CE] copied D2/PNG\nsource views" { class: ce }
firmware_repo -> system.record.review_evidence: "[CE] source commit,\nbuild map, symbols" { class: ce }
equipment_archive -> system.record.runtime_evidence: "[CE] equipment IDs,\ncalibration, settings" { class: ce }
system.record.review_evidence -> system.record.analysis_record: "[CE] review inputs" { class: ce }
system.record.runtime_evidence -> system.record.analysis_record: "[CE] runtime inputs" { class: ce }
system.record.trace_matrix -> system.record.disposition: "[CE] model trace" { class: ce }
system.record.analysis_record -> system.record.disposition: "[CE] pass/fail\nrationale" { class: ce }
ivv_authority -> system.record.disposition: "[CE] review and\napproval decision" { class: ce }
master_plan -> system.record.trace_matrix: "[CE] coverage row\nintegration target" { class: ce }

note_targets -> system.record.trace_matrix { class: cstr }
note_reports -> system.record.disposition { class: cstr }
note_status -> system.record.disposition { class: cstr }
note_coverage -> system.record.disposition { class: cstr }

# Layout-only ordering hints.
ivv_authority -> source_package { style: { opacity: 0 } }
source_package -> firmware_repo { style: { opacity: 0 } }
firmware_repo -> equipment_archive { style: { opacity: 0 } }
equipment_archive -> master_plan { style: { opacity: 0 } }
system -> note_targets { style: { opacity: 0 } }
note_targets -> note_reports { style: { opacity: 0 } }
note_reports -> note_status { style: { opacity: 0 } }
note_status -> note_coverage { style: { opacity: 0 } }
