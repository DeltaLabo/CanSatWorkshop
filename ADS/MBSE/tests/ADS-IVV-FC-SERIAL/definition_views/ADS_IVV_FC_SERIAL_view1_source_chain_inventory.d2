vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional-chain inventory view for ADS-IVV-FC-SERIAL.
# Covers Serial0 logging chains in v0.1 and v0.2; v0.3 and v1.0 are explicit N/A.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-FC-SERIAL\nSerial0 logging source-chain inventory\nRefs: IVV; NASA-SE; SW/stats; ESA-CANSAT; ADS MBSE plan" {
  class: sys
  direction: down

  versions: "[PC] Selected ADS source baselines" {
    class: pc
    direction: right
    grid-columns: 2

    v01: "[PC] v0.1 prototype\nsource_views/v0.1" {
      class: pc
      direction: down
      chain: "[LC] Serial logging chain\nview5_serial_logging_chain" {
        class: lc
        direction: down
        get_ubx: "[F] Get UBX-G7020-KT\ninit state" { class: func }
        collect_init: "[F] Collect peripheral\ninit states" { class: func }
        collect_meas: "[F] Collect\nmeasurements" { class: func }
        log_serial0: "[F] Log via Serial0" { class: func }
        monitor: "[F] Monitor serial port\n(PC EA support)" { class: func }
      }
      note_pf: "[C] v0.1 applicable\nUSB-C PC link and PC Monitor serial port are modeled.\nRecords must include UBX init state and GPS-derived\nmeasurement fields or explicit unavailable/stale markers.\nSerial0 schema is an execution prerequisite." { class: note; shape: page }
    }

    v02: "[PC] v0.2 prototype\nsource_views/v0.2" {
      class: pc
      direction: down
      chain: "[LC] Serial logging chain\nview8_serial_logging_chain" {
        class: lc
        direction: down
        get_ubx: "[F] Get UBX-G7020-KT\ninit state" { class: func }
        get_icm: "[F] Get ICM20948\ninit state" { class: func }
        collect_init: "[F] Collect peripheral\ninit states" { class: func }
        collect_meas: "[F] Collect\nmeasurements" { class: func }
        log_serial0: "[F] Log via Serial0" { class: func }
        monitor: "[F] Monitor serial port\n(PC EA support)" { class: func }
      }
      note_pf: "[C] v0.2 applicable\nUSB-C PC link and PC Monitor serial port are modeled.\nRecords must include UBX and ICM20948 init states plus\nGPS/IMU/attitude measurement fields or explicit unavailable/stale markers.\nSerial0 schema is an execution prerequisite." { class: note; shape: page }
    }

    v03: "[PC] v0.3 PCB delivery\nsource_views/v0.3" {
      class: pc
      direction: down
      note_na: "[C] N/A for Serial0 functional chain\nOnly PV1 PCB/trace delivery is modeled.\nNo PC actor, USB-C PL, LC allocation, CE,\nor Serial0 logging chain exists; physical traces are\nnot credited as runtime logging behavior." { class: note; shape: page }
    }

    v10: "[PC] v1.0 integrated CanSat\nsource_views/v1.0" {
      class: pc
      direction: down
      note_na: "[C] N/A for ADS Serial0 logging\nv1.0 has no ADS Serial0 chain or development PC consumer.\nADS delivery is modeled through ADS Processing to OBCC\nusing Pointers and Returns; verify with OBCC-delivery activity." { class: note; shape: page }
    }
  }

  note_trace: "[C] Traceability targets\nADS-CAP-DELIVERY to development PC;\nADS-FE-CORRUPT-MEASUREMENT; ADS-FE-STUCK-LOOP;\nfreshness and validity assumptions for logged records." { class: note; shape: page }
  note_scope: "[C] Source coverage\nAll D2/PNG views for v0.1, v0.2, v0.3, and v1.0\nare copied into this definition. Serial0 execution applies\nto v0.1/v0.2; v0.3 and v1.0 branches are explicit N/A." { class: note; shape: page }
}

system.versions.v01.note_pf -> system.versions.v01.chain.log_serial0 { class: cstr }
system.versions.v02.note_pf -> system.versions.v02.chain.log_serial0 { class: cstr }
system.note_trace -> system.versions { class: cstr }
system.note_scope -> system.versions { class: cstr }
