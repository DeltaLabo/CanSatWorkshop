vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Historical Capella functional-chain view reconstructed from PDM/PDM_v0.1_FC.png.
# Source label: "v0.1 fall test (3 reps)".
# The source shows a physical-actor icon for Human Tester; this D2 uses the repo's [EA] external-actor prefix.
# PDM README caption says the terminal-speed limit comes from the ESA CanSat guide.
# Current PDM v1.0 XML does not contain the v0.1-only fall-test actor/functions/exchanges:
# Human Tester, Record fall, Release dummy, Measure terminal speed from video, Test Ready,
# Manual release, Landing, or the visible notes/constraints copied below.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDM v0.1 — Fall test chain (3 reps)" {
  class: chain
  direction: right

  human_tester: "[EA] Human Tester" {
    class: ea
    direction: down

    record_fall: "[F] Record fall" { class: func }
    release_dummy: "[F] Release dummy" { class: func }
    measure_terminal_speed: "[F] Measure\nterminal speed\nfrom video" { class: func }
  }

  # Historical v0.1 image uses Dummy CanSat / Top module; current PDM v1.0 XML uses CanSat / Parachute Module.
  dummy_cansat: "[PC] Dummy CanSat" {
    class: pc
    direction: down

    top_module: "[PC] Top module" {
      class: pc
      direction: down

      parachute: "[PC] Parachute" {
        class: pc
        direction: down

        descent_speed_control: "[LC] Descent speed control" {
          class: lc
          direction: down

          limit_terminal_speed: "[F] Limit terminal speed" { class: func }
        }
      }
    }
  }

  note_with_parachute_open: "[C] With\nparachute open" { class: note; shape: page }
  note_same_weight: "[C] Same weight as\nfinal estimate" { class: note; shape: page }
  note_foldable: "[C] Foldable, but\ndeployed\nmanually" { class: note; shape: page }
  note_terminal_speed: "[C] 11 m/s max." { class: note; shape: page }
}

chain.human_tester.record_fall -> chain.human_tester.release_dummy: "[FE] Test Ready []" { class: fe }
chain.human_tester.release_dummy -> chain.dummy_cansat.top_module.parachute.descent_speed_control.limit_terminal_speed: "[FE] Manual release []" { class: fe }
chain.dummy_cansat.top_module.parachute.descent_speed_control.limit_terminal_speed -> chain.human_tester.measure_terminal_speed: "[FE] Landing []" { class: fe }

# Source dashed constraint targets the Manual release exchange area; modeled on the releasing function.
chain.note_with_parachute_open -> chain.human_tester.release_dummy { class: cstr }
chain.note_same_weight -> chain.dummy_cansat { class: cstr }
chain.note_foldable -> chain.dummy_cansat.top_module.parachute { class: cstr }
chain.note_terminal_speed -> chain.dummy_cansat.top_module.parachute.descent_speed_control.limit_terminal_speed { class: cstr }
