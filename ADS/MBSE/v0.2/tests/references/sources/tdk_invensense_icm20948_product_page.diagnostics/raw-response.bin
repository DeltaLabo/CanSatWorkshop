_descri\":\"\u003cp\u003eUltrasonic ToF 45° FoV sensor module for rapid prototyping and integration into product enclosures\u003c/p\u003e\",\"field_status\":null,\"field_sub_title\":null,\"field_target_markets\":[],\"field_target_markets_application\":null,\"field_weight\":null},{\"id\":\"5\",\"label\":\"DK-CH201\",\"slug\":\"/products/ultrasonic-time-flight/dk-ch201\",\"product_id\":\"5\",\"uuid\":\"63b7eedb-2793-4941-bafd-6068a09f4efe\",\"langcode\":\"en\",\"type\":{\"id\":\"ultrasonic\",\"label\":\"Ultrasonic\"},\"uid\":{\"id\":\"0\",\"label\":\"Anonymous\"},\"status\":\"1\",\"title\":\"DK-CH201\",\"variations\":[],\"default_variation\":null,\"path\":null,\"created\":\"1763716682\",\"metatag\":[null,null,null],\"field_add_other_product_specific\":[{\"id\":\"145\",\"label\":\"DK-CH201 \u003e Add extra product specifications\"}],\"field_applications\":[],\"field_buy_now_link\":{\"title\":\"Shop Now\",\"url\":\"http://dilp.netcomponents.com/tdkcorp_result.html?lang=en\u0026mode=1\u0026partnumber1=CH201\u0026partnumber2=DKCH201\u0026partnumber3=EV_MOD_CH201-00-01\u0026pq=Search\u0026ref=/cgi-bin/tdkcorp.asp\"},\"field_category\":{\"id\":\"26\",\"label\":\"Ultrasonic ToF\"},\"field_current_consumption\":null,\"field_description\":null,\"field_documentation_resource\":[],\"field_features\":null,\"field_features_and_benefits\":null,\"field_features_listing\":[],\"field_interface\":null,\"field_key_attribute\":null,\"field_learn_more\":{\"title\":\"Learn more\",\"url\":\"\"},\"field_meta_tags\":null,\"field_operation\":null,\"field_part_number\":\"DK-CH201\",\"field_product_image\":[{\"id\":\"825\",\"label\":\"product-img-dk-ch201.png\"}],\"field_product_key_features\":[{\"id\":\"32\",\"label\":\"DK-CH201 \u003e Product key features\"}],\"field_product_segment\":\"Development kit\",\"field_products_thumbnail_image\":{\"id\":\"826\",\"label\":\"thumbnail-dk-ch201.jpg\"},\"field_range\":null,\"field_related_products\":[],\"field_short_description\":\"\u003cp\u003eComprehensive development platform for CH201, with the ability to connect up to four additional CH201 modules.\u003c/p\u003e\",\"field_size_d\":null,\"field_size_l\":null,\"field_size_w\":null,\"field_software_downloads\":[{\"id\":\"8439\",\"label\":\"SmartSonic CH201 Static Target Rejection Example\"}],\"field_specification_short_descri\":\"\u003cp\u003eComprehensive development platform for CH201, with the ability to connect up to four additional CH201 modules.\u003c/p\u003e\",\"field_status\":null,\"field_sub_title\":null,\"field_target_markets\":[],\"field_target_markets_application\":null,\"field_weight\":null}],\"field_short_description\":\"\u003cp\u003eChirp’s MEMS based ultrasonic technology leverages a Time‑of‑Flight (ToF) range sensor with a power-efficient digital signal processor (DSP) ASIC in a 3.5\u0026nbsp;×\u0026nbsp;3.5\u0026nbsp;mm package. The sensor handles a variety of ultrasonic signal-processing functions and algorithms, enabling customers flexible industrial design options for a broad range of use-case scenarios, including range-finding, presence and proximity sensing, object-detection and avoidance, and position-tracking.\u003c/p\u003e\",\"field_size_d\":\"1.26\",\"field_size_l\":\"3.50\",\"field_size_w\":\"3.50\",\"field_software_downloads\":[{\"id\":\"8439\",\"label\":\"SmartSonic CH201 Static Target Rejection Example\",\"slug\":\"/smartsonic-ch201-static-target-rejection-example-0\",\"nid\":\"8439\",\"uuid\":\"8966eae4-28e5-4c32-9e08-6af69e95be80\",\"vid\":\"9681\",\"langcode\":\"en\",\"type\":{\"id\":\"software_download\",\"label\":\"Software Download\"},\"revision_timestamp\":\"1774848618\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"SmartSonic CH201 Static Target Rejection Example\",\"created\":\"1774848485\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_description\":null,\"field_download_file\":{\"id\":\"1070\",\"label\":\"SmartSonic CH201 Static Target Rejection Example v2.9.0.zip\"},\"field_download_size\":\"5 MB\",\"field_external_link\":null,\"field_looking_for_additional_sec\":{\"id\":\"1337\",\"label\":\"SmartSonic CH201 Static Target Rejection Example \u003e Looking for additional section\"},\"field_media_image\":null,\"field_requires_login\":\"1\",\"field_software_type\":null,\"field_version\":\"2.9.0\"}],\"field_specification_short_descri\":\"\u003cp\u003eChirp’s MEMS based ultrasonic technology leverages a Time‑of‑Flight (ToF) range sensor with a power-efficient digital signal processor (DSP) ASIC in a 3.5\u0026nbsp;×\u0026nbsp;3.5\u0026nbsp;mm package.\u003c/p\u003e\",\"field_status\":null,\"field_sub_title\":\"Long-Range Ultra-Low-Power Integrated MEMS Ultrasonic Time‑of‑Flight Range Sensor with Millimeter Accuracy\",\"field_target_markets\":[],\"field_target_markets_application\":null,\"field_weight\":null}],\"field_sub_category_grid_section\":[],\"field_sub_category_intro_paras\":[],\"field_sub_category_intro_title\":null,\"field_sub_category_section_subti\":null,\"field_sub_category_section_title\":null,\"field_video_alignment\":null},\"field_description\":null,\"field_documentation_resource\":[{\"id\":\"8453\",\"label\":\"DS-000189 – ICM-20948 Datasheet\",\"slug\":\"/ds-000189-icm-20948-datasheet\",\"nid\":\"8453\",\"uuid\":\"3d64faf9-a104-4358-9690-f946cb5317ba\",\"vid\":\"9705\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1774868182\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"DS-000189 – ICM-20948 Datasheet\",\"created\":\"1774868138\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"The ICM-20948 is the world’s lowest power 9-axis MotionTracking device that is ideally suited for Smartphones, Tablets, Wearable Sensors, and IoT applications.\",\"field_file\":{\"id\":\"1693\",\"filename\":\"ds-000189-icm-20948-datasheet.pdf\",\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-03/ds-000189-icm-20948-datasheet.pdf?VersionId=DDZ6UQd2jbFGUCqi1PY4w_nR5jWpqKVN\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"25\",\"label\":\"Datasheet\",\"slug\":\"/datasheet\",\"tid\":\"25\",\"uuid\":\"cad0e6b0-8b3d-4707-9835-32d222f110ac\",\"langcode\":\"en\",\"vid\":{\"id\":\"resource_types\",\"label\":\"Resource Types\"},\"status\":\"1\",\"name\":\"Datasheet\",\"description\":null,\"weight\":\"0\",\"parent\":[],\"metatag\":[null,null,null],\"path\":null,\"content_translation_created\":\"1761059476\"},\"field_updated_date\":\"2024-03-12\",\"field_version\":\"1.6\"}],\"field_embedded_processor_s\":null,\"field_features\":null,\"field_features_and_benefits\":\"\u003cp\u003eDMP based 6 \u0026amp; 9-axis Cal/Fusion, Android M features : Pedometer, Significant Motion, Bring to See, Basic Activity Classfication, Pick Up\u003c/p\u003e\",\"field_features_listings\":[],\"field_key_attribute\":\"\u003cp\u003eLowest power 9-axis IMU with 3rd GEN embedded motion processor\u003c/p\u003e\",\"field_learn_more\":null,\"field_meta_tags\":null,\"field_part_number\":\"ICM-20948\",\"field_pins\":null,\"field_product_image\":[{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-03/product-img-icm-20948_0.png?VersionId=T7uM1MRLbWAh6T3Y_txQs_Gtz7JScfCe\",\"alt\":\"Microchip with TDK logo and \\\"ICM-20948\\\" etched onto its surface\"}],\"field_product_key_features\":[{\"id\":\"273\",\"label\":\"ICM-20948 \u003e Product key features\",\"uuid\":\"41d6b74c-b62a-4103-a719-5d7065d8a572\",\"langcode\":\"en\",\"type\":{\"id\":\"key_highlights_grid\",\"label\":\"Key highlights grid\"},\"status\":\"1\",\"created\":\"1767680815\",\"parent_id\":\"15\",\"parent_type\":\"commerce_product\",\"parent_f