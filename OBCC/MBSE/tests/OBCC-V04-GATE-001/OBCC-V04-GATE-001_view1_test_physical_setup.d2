vars: {
  d2-config: {
    layout-engine: elk
  }
}

# OBCC-V04-GATE-001 PV1: v0.4 wireless command/state verification physical setup.
# v0.4 Capella source views are absent; v1.0 views are copied as target-behavior context.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 24 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

command_station: "[EA] Command transmitter /\nDPS ground-station emulator" { class: ea }
rf_link_monitor: "[EA] RF link monitor /\nLoRa sniffer" { class: ea }
telemetry_observer: "[EA] Telemetry observer /\nDPS dashboard logger" { class: ea }
bench_pc: "[EA] USB programming PC\n(bench aid only)" { class: ea }
deployment_monitor: "[EA] Deployment side-effect\nlogic probe / safe load" { class: ea }
ambient_thermometer: "[EA] Ambient thermometer\n(calibrated; model TBD)" { class: ea }

system: "[System] OBCC-V04-GATE-001 — v0.4 wireless command/state physical setup\nRefs: IVV, PM&SE/IVV, OBCC README, LoRa_Frame, v1.0 PV1/PV2/PV3/Command chain" {
  class: sys
  direction: down

  uut: "[PC] v0.4 OBCC command/state UUT\n(source baseline absent;\nv1.0 target context)" {
    class: pc
    direction: down
    grid-columns: 1

    obcc_pcb: "[PC] OBCC PCB or breadboard\ncommand-state article" {
      class: pc
      direction: right
      grid-columns: 3

      xiao: "[PC] XIAO ESP32-S3" { class: pc }
      rfm95w: "[PC] RFM95W LoRa" { class: pc }
      usb_port: "[PC] USB-C port\nfor flashing only" { class: pc }
      deployment_test_point: "[PC] Deployment output\ntest point / safe load" { class: pc }
      status_indicator: "[PC] State/status\ntelemetry indicator" { class: pc }
    }

    note_presence: "[C] Inspection pass:\nRFM95W, XIAO, antenna path,\nstate/status observation path, and\nsafe deployment-output monitor are\npresent and identified." {
      class: note
      shape: page
    }

    note_no_serial: "[C] Flight-operation constraint:\nvalid On/Stand-by commands and state\nobservability shall not depend on a\nserial-console operator path. USB is\nbench aid only if documented." {
      class: note
      shape: page
    }

    note_source_gap: "[C] Source baseline gap:\nno v0.4 Capella/D2 views exist\nin the repository; copied v1.0\nviews provide target behavior." {
      class: note
      shape: page
    }
  }
}

command_station -- system.uut.obcc_pcb.rfm95w: "[PL] RF command uplink\nLoRa separation" { class: pl }
system.uut.obcc_pcb.rfm95w -- telemetry_observer: "[PL] RF telemetry downlink\nLoRa separation" { class: pl }
system.uut.obcc_pcb.rfm95w -- rf_link_monitor: "[PL] Monitor antenna\nRF observation" { class: pl }
bench_pc -- system.uut.obcc_pcb.usb_port: "[PL] USB-C flash/setup\nnot flight command" { class: pl }
deployment_monitor -- system.uut.obcc_pcb.deployment_test_point: "[PL] Logic probe /\nsafe load" { class: pl }
ambient_thermometer -- system.uut: "[PL] Bench ambient\nobservation" { class: pl }

system.uut.obcc_pcb.xiao -- system.uut.obcc_pcb.rfm95w: "[PL] SPI + power\nradio link" { class: pl }
system.uut.obcc_pcb.xiao -- system.uut.obcc_pcb.usb_port: "[PL] USB pads" { class: pl }
system.uut.obcc_pcb.xiao -- system.uut.obcc_pcb.deployment_test_point: "[PL] GPIO/PWM path\nmonitored only" { class: pl }
system.uut.obcc_pcb.xiao -- system.uut.obcc_pcb.status_indicator: "[PL] Internal status\ntelemetry path" { class: pl }

system.uut.note_presence -> system.uut.obcc_pcb { class: cstr }
system.uut.note_no_serial -> system.uut.obcc_pcb.usb_port { class: cstr }
system.uut.note_source_gap -> system { class: cstr }

# Layout-only edges keep test equipment above the UUT and notes below it.
command_station -> rf_link_monitor { style: { opacity: 0 } }
rf_link_monitor -> telemetry_observer { style: { opacity: 0 } }
telemetry_observer -> bench_pc { style: { opacity: 0 } }
bench_pc -> deployment_monitor { style: { opacity: 0 } }
deployment_monitor -> ambient_thermometer { style: { opacity: 0 } }
system.uut.obcc_pcb -> system.uut.note_presence { style: { opacity: 0 } }
system.uut.note_presence -> system.uut.note_no_serial { style: { opacity: 0 } }
system.uut.note_no_serial -> system.uut.note_source_gap { style: { opacity: 0 } }
