vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional Chain — PDS-VV-CON-003 binomial and independence analysis.
# Only functions, FEs, and constraints are inside the chain container.
# References: IVV, PDS-R4, PDS-R5, PDS-R6, PDS-R7, PDS-R8, PDS-R2.
# Traceability: [C] Probability < 1%; PDS-VV-FC-001; PDS-FE-OvercurrentOvervoltage;
# PDS-FE-LiIonUnsafeCondition; PDS-FE-RailBrownout; PDS-UC-ProvideRegulatedPower.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDS-VV-CON-003 — binomial / independence analysis chain\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R4; PDS-R5; PDS-R6; PDS-R7; PDS-R8; PDS-R2" {
  class: chain
  direction: down
  grid-columns: 1

  import_overcurrent_logs: "[F] Import overcurrent /\nshort-equivalent trial logs" { class: func }
  import_overvoltage_logs: "[F] Import overvoltage\ntrial logs" { class: func }
  verify_activity_baseline: "[F] Verify activity ID,\nSSIV, baseline, article ID" { class: func }
  validate_trial_records: "[F] Validate raw records,\ncalibration, ambient, limits" { class: func }
  partition_by_mode: "[F] Partition valid demanded\ntrials by protection mode" { class: func }
  count_trials_and_misses: "[F] Count valid trials\nand missed unsafe actions" { class: func }
  apply_miss_policy: "[F] Apply miss policy:\nany miss is fail/hold/anomaly" { class: func }
  check_overcurrent_independence: "[F] Check overcurrent-mode\nindependence assumptions" { class: func }
  check_overvoltage_independence: "[F] Check overvoltage-mode\nindependence assumptions" { class: func }
  compute_oc_cp_bound: "[F] Compute exact one-sided\nCP upper bound for overcurrent" { class: func }
  compute_ov_cp_bound: "[F] Compute exact one-sided\nCP upper bound for overvoltage" { class: func }
  compare_to_probability_limit: "[F] Compare bounds to\n<1% missed-demand limit" { class: func }
  classify_overcurrent_mode: "[F] Classify overcurrent mode:\nverified or screening" { class: func }
  classify_overvoltage_mode: "[F] Classify overvoltage mode:\nverified or screening" { class: func }
  classify_activity_result: "[F] Classify PDS-VV-CON-003\nfinal result" { class: func }
  link_to_fc001: "[F] Link result to\nPDS-VV-FC-001 coverage" { class: func }
  write_report: "[F] Write report-by-reference\nwith assumptions and caveats" { class: func }
  archive_analysis: "[F] Archive analysis, trial logs,\nand evidence package" { class: func }

  note_interpretation: "[C] Source-constraint interpretation\nThe source [C] Probability < 1% is treated as missed demanded unsafe protection\naction probability <1% for each mode: overcurrent/short-equivalent and overvoltage.\nIf the intended meaning differs, update the source model and this test." {
    class: note
    shape: page
  }
  note_acceptance_math: "[C] Statistical acceptance math\nFor zero missed unsafe actions, the exact one-sided 95% upper bound is\n1 - 0.05^(1/n). At n = 299, the bound is below 1%. Therefore formal acceptance\nrequires 299/299 zero misses per demanded mode unless project-approved allocation\nstates otherwise." {
    class: note
    shape: page
  }
  note_fewer_trials: "[C] Fewer-trial classification\nIf fewer than 299 independent trials are valid for either mode, report the exact\none-sided Clopper-Pearson upper bound and classify that mode as screening /\ncharacterization, not verification of <1%." {
    class: note
    shape: page
  }
  note_miss_policy: "[C] Miss and anomaly policy\nAny missed unsafe action, ambiguous unobservable detect/cut-off response, unsafe\nrestore, unsafe rail/cell/temperature event, or uncontrolled restart prevents a\nstatistical pass. No waiver can convert a miss into a pass for this claim." {
    class: note
    shape: page
  }
  note_independence: "[C] Independence assumptions\nDemand sequence is randomized or procedure-selected; source/load limits and ambient\nare recorded; instrumentation is calibrated/status-checked; article reset/cooldown\nor recovery state is controlled; common-cause anomalies are held out until disposition.\nIf independence is not defensible, classify as screening only." {
    class: note
    shape: page
  }
  note_fault_evidence: "[C] Fault-hardening and evidence viewpoint\nAnalysis checks that trials covered overcurrent, short-equivalent, overvoltage,\ncut-off failure susceptibility, unsafe restore prevention, brownout/reset,\noverheating, and Li-ion unsafe precursors. Evidence path: ../results/PDS-VV-CON-003/." {
    class: note
    shape: page
  }
}

chain.import_overcurrent_logs -> chain.import_overvoltage_logs: "[FE] Overcurrent trial set" { class: fe }
chain.import_overvoltage_logs -> chain.verify_activity_baseline: "[FE] Overvoltage trial set" { class: fe }
chain.verify_activity_baseline -> chain.validate_trial_records: "[FE] Baseline and article match" { class: fe }
chain.validate_trial_records -> chain.partition_by_mode: "[FE] Validated evidence records" { class: fe }
chain.partition_by_mode -> chain.count_trials_and_misses: "[FE] Mode-specific trial sets" { class: fe }
chain.count_trials_and_misses -> chain.apply_miss_policy: "[FE] n, misses, holds, anomalies" { class: fe }
chain.apply_miss_policy -> chain.check_overcurrent_independence: "[FE] Zero-miss or fail/hold status" { class: fe }
chain.check_overcurrent_independence -> chain.check_overvoltage_independence: "[FE] Overcurrent independence rationale" { class: fe }
chain.check_overvoltage_independence -> chain.compute_oc_cp_bound: "[FE] Overvoltage independence rationale" { class: fe }
chain.compute_oc_cp_bound -> chain.compute_ov_cp_bound: "[FE] Overcurrent CP bound" { class: fe }
chain.compute_ov_cp_bound -> chain.compare_to_probability_limit: "[FE] Overvoltage CP bound" { class: fe }
chain.compare_to_probability_limit -> chain.classify_overcurrent_mode: "[FE] Bound comparison" { class: fe }
chain.classify_overcurrent_mode -> chain.classify_overvoltage_mode: "[FE] Overcurrent classification" { class: fe }
chain.classify_overvoltage_mode -> chain.classify_activity_result: "[FE] Overvoltage classification" { class: fe }
chain.classify_activity_result -> chain.link_to_fc001: "[FE] PDS-VV-CON-003 result" { class: fe }
chain.link_to_fc001 -> chain.write_report: "[FE] Functional-chain trace" { class: fe }
chain.write_report -> chain.archive_analysis: "[FE] Report and calculation package" { class: fe }
