vars: {
  d2-config: {
    layout-engine: elk
  }
}

# OBCC-V10-FLIGHT-001 functional chain: final flight-readiness review and closure demonstration.
# References cited in the chain title: OBCC/MBSE/v1.0, OBCC/MBSE/tests/README.md, PM&SE/IVV.md.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "OBCC-V10-FLIGHT-001 — final flight-readiness review closure chain\nRefs: OBCC/MBSE/v1.0; tests/README; PM&SE/IVV" {
  class: chain
  direction: down

  convene_review: "[F] Convene final\nreadiness review" { class: func }
  record_environment: "[F] Record review\nenvironment and clocks" { class: func }
  lock_v1_baseline: "[F] Lock v1.0 model,\nfirmware, and config baseline" { class: func }
  identify_as_built: "[F] Identify final\nas-built configuration" { class: func }
  enumerate_candidate_rows: "[F] Enumerate all\nv1.0 candidate rows" { class: func }
  index_modeled_definitions: "[F] Index modeled\nverification definitions" { class: func }
  verify_results_paths: "[F] Verify expected\nresults and evidence paths" { class: func }
  inspect_pc_pl_evidence: "[F] Inspect PC/PL\npresence evidence" { class: func }
  analyze_ce_closure: "[F] Analyze component\nexchange closure" { class: func }
  analyze_allocation_closure: "[F] Analyze functional\nallocation closure" { class: func }
  review_functional_chain_reports: "[F] Review functional-chain\nand scenario reports" { class: func }
  verify_constraint_assignment: "[F] Verify constraint\nassignment closure" { class: func }
  evaluate_statistics_claims: "[F] Evaluate statistical\nclaim basis" { class: func }
  review_fault_hardening: "[F] Review fault-hardening\nand safety gaps" { class: func }
  disposition_deviations: "[F] Disposition as-built\ndeviations and waivers" { class: func }
  update_residual_risk_log: "[F] Update residual-risk\nlog" { class: func }
  demonstrate_readiness_walkthrough: "[F] Demonstrate readiness\nwalkthrough to board" { class: func }
  issue_go_no_go: "[F] Issue flight-readiness\ngo/no-go decision" { class: func }
  archive_closure_record: "[F] Archive closure report\nand evidence index" { class: func }

  note_all_rows: "[C] Every row OBCC-VV-PC-001,\nPL-001, CE-001..003, ALLOC-001..003,\nFC-001..006, and CON-001..005 is\ncovered, deferred with rationale, or N/A." {
    class: note
    shape: page
  }

  note_as_built: "[C] Final hardware/software/radio/config\nmatches OBCC v1.0 model or each\ndeviation has an accepted disposition." {
    class: note
    shape: page
  }

  note_evidence: "[C] Required evidence exists or is planned\nunder tests/results/<activity-id>/ for\ninspection, analysis, demonstration,\ntesting, and constraint closure." {
    class: note
    shape: page
  }

  note_stats: "[C] Statistical claims use project IVV policy:\nexact-binomial PDR, n=59 timing for\n95/95 limits, and 29/29 only for\nR90/C95 screening where applicable." {
    class: note
    shape: page
  }

  note_fault: "[C] No unclosed safety-critical command,\ndeployment, telemetry/range, runtime\nfault, or scheduler-blocking issue may\nremain open at go/no-go." {
    class: note
    shape: page
  }
}

chain.convene_review -> chain.record_environment: "[FE] Review opened\n[attendees + time]" { class: fe }
chain.record_environment -> chain.lock_v1_baseline: "[FE] Environment\nand clock record" { class: fe }
chain.lock_v1_baseline -> chain.identify_as_built: "[FE] Locked baseline\n[v1.0 refs]" { class: fe }
chain.identify_as_built -> chain.enumerate_candidate_rows: "[FE] As-built IDs\nand deviations" { class: fe }
chain.enumerate_candidate_rows -> chain.index_modeled_definitions: "[FE] Candidate set\n[all rows]" { class: fe }
chain.index_modeled_definitions -> chain.verify_results_paths: "[FE] Definition index\n[ready / missing]" { class: fe }
chain.verify_results_paths -> chain.inspect_pc_pl_evidence: "[FE] Evidence index\n[paths + status]" { class: fe }
chain.inspect_pc_pl_evidence -> chain.analyze_ce_closure: "[FE] PC/PL closure\n[inspection status]" { class: fe }
chain.analyze_ce_closure -> chain.analyze_allocation_closure: "[FE] CE closure\n[analysis status]" { class: fe }
chain.analyze_allocation_closure -> chain.review_functional_chain_reports: "[FE] Allocation closure\n[analysis status]" { class: fe }
chain.review_functional_chain_reports -> chain.verify_constraint_assignment: "[FE] FC/scenario closure\n[report status]" { class: fe }
chain.verify_constraint_assignment -> chain.evaluate_statistics_claims: "[FE] Constraint closure\n[pass/defer/N/A]" { class: fe }
chain.evaluate_statistics_claims -> chain.review_fault_hardening: "[FE] Statistics basis\n[claim limits]" { class: fe }
chain.review_fault_hardening -> chain.disposition_deviations: "[FE] Fault-hardening\nfindings" { class: fe }
chain.disposition_deviations -> chain.update_residual_risk_log: "[FE] Accepted deviations\nand waivers" { class: fe }
chain.update_residual_risk_log -> chain.demonstrate_readiness_walkthrough: "[FE] Residual-risk\nstate" { class: fe }
chain.demonstrate_readiness_walkthrough -> chain.issue_go_no_go: "[FE] Board review\nrecord" { class: fe }
chain.issue_go_no_go -> chain.archive_closure_record: "[FE] Go/no-go decision\n[accept / hold]" { class: fe }

chain.note_all_rows -> chain.enumerate_candidate_rows { class: cstr }
chain.note_all_rows -> chain.index_modeled_definitions { class: cstr }
chain.note_as_built -> chain.identify_as_built { class: cstr }
chain.note_evidence -> chain.verify_results_paths { class: cstr }
chain.note_stats -> chain.evaluate_statistics_claims { class: cstr }
chain.note_fault -> chain.review_fault_hardening { class: cstr }
chain.note_fault -> chain.issue_go_no_go { class: cstr }
