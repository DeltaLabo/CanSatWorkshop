vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Evidence and traceability view for ADS-IVV-C-RATE-5HZ.
# Ensures reports reference modeled source constraints, verification means, and pass/fail/blocked rationale.
direction: right

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

ivv_reviewer: "[EA] IVV reviewer /\nconfiguration authority" { class: ea }
reference_corpus: "[EA] Reference corpus\nIVV; SW/stats; ADS MBSE plan" { class: ea }
firmware_repo: "[EA] Firmware repository /\nbuild configuration source" { class: ea }
calibration_records: "[EA] Equipment and\ncalibration records" { class: ea }

system: "[System] ADS-IVV-C-RATE-5HZ\nEvidence and traceability record\nRefs: IVV; SW/stats; ADS MBSE plan; source_views" {
  class: sys
  direction: down

  record_package: "[PC] 5 Hz constraint\nverification record package" {
    class: pc
    direction: down
    grid-columns: 2

    trace_matrix: "[LC] Traceability matrix" {
      class: lc
      direction: down
      source_views: "[F] Map source views\nv0.1/v0.2/v0.3/v1.0" { class: func }
      source_constraint: "[F] Map At 5 Hz\nconstraint to Collect measurements" { class: func }
      trace_targets: "[F] Map ADS-CAP-GPS,\nADS-CAP-DELIVERY, ADS-FE-STUCK-LOOP" { class: func }
    }

    evidence_record: "[LC] Raw evidence record" {
      class: lc
      direction: down
      raw_logs: "[F] Store raw Serial0 /\nUUT timestamp logs" { class: func }
      timebase_logs: "[F] Store reference-clock\nand host timestamp logs" { class: func }
      env_logs: "[F] Store power and\nambient monitor logs" { class: func }
      config_logs: "[F] Store firmware,\nlogger, and hook configuration" { class: func }
    }

    analysis_record: "[LC] Analysis record" {
      class: lc
      direction: down
      period_stats: "[F] Store period series,\nmean rate, jitter" { class: func }
      gap_stats: "[F] Store worst gap,\ndropped/duplicate count" { class: func }
      stale_stats: "[F] Store stale-value and\nvalidity-marker results" { class: func }
      tolerance_basis: "[F] Store chosen tolerance\nand n = 59 basis if claimed" { class: func }
    }

    disposition_record: "[LC] Result and disposition" {
      class: lc
      direction: down
      verdicts: "[F] Store v0.1/v0.2\npass, fail, blocked, or limited verdict" { class: func }
      na_rationale: "[F] Store v0.3/v1.0\nN/A rationale" { class: func }
      deviations: "[F] Store deviations,\nanomalies, waivers, retest status" { class: func }
    }
  }
}

note_targets: "[C] Traceability targets\nConstraint 5 Hz; model element Collect measurements;\nGPS/collection/logging timestamps; loop timing context;\nADS-CAP-GPS; ADS-CAP-DELIVERY; ADS-FE-STUCK-LOOP." { class: note; shape: page }
note_report_rule: "[C] Report rule\nReports reference this modeled definition and record exact\nversion, source baseline, hardware revision, firmware commit,\nas-executed equipment, raw evidence, analysis settings, actual\nconditions, deviations, limitations, and retest status." { class: note; shape: page }
note_blocked: "[C] Blocked/limited rule\nIf jitter and worst-gap tolerance are not selected before\nexecution, the report may characterize observed timing but\nshall not issue an unqualified pass/fail verdict." { class: note; shape: page }
note_reports: "[C] Expected report locations\n../results/ADS-IVV-C-RATE-5HZ/v0.1/\n../results/ADS-IVV-C-RATE-5HZ/v0.2/\n../results/ADS-IVV-C-RATE-5HZ/v0.3/\n../results/ADS-IVV-C-RATE-5HZ/v1.0/" { class: note; shape: page }

ivv_reviewer -> system.record_package.disposition_record: "[CE] verdict review\nand approval" { class: ce }
reference_corpus -> system.record_package.trace_matrix: "[CE] reference and\nplanning basis" { class: ce }
firmware_repo -> system.record_package.evidence_record: "[CE] firmware commit,\nbuild flags, hook config" { class: ce }
calibration_records -> system.record_package.evidence_record: "[CE] equipment IDs\nand calibration status" { class: ce }
system.record_package.trace_matrix -> system.record_package.disposition_record: "[CE] model trace" { class: ce }
system.record_package.evidence_record -> system.record_package.analysis_record: "[CE] analysis inputs" { class: ce }
system.record_package.analysis_record -> system.record_package.disposition_record: "[CE] pass/fail and\nblocked rationale" { class: ce }

note_targets -> system.record_package.trace_matrix { class: cstr }
note_report_rule -> system.record_package.disposition_record { class: cstr }
note_blocked -> system.record_package.analysis_record.tolerance_basis { class: cstr }
note_blocked -> system.record_package.disposition_record.verdicts { class: cstr }
note_reports -> system.record_package.disposition_record { class: cstr }
