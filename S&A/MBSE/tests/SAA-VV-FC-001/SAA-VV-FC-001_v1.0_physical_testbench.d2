vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-001 verification-only Physical Architecture PV1.
# v1.0 integrated assembly fit, mass, envelope, and module accommodation demonstration/inspection.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R3, SAA-R4, SAA-R5.
# This file is a test-definition view and does not modify the v1.0 baseline model.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
witness: "[EA] QA Witness" { class: ea }
envelope_gauge: "[EA] 355 ml Envelope /\nCan Gauge\nØ66.0 mm × H122.0 mm" { class: ea }
caliper_height: "[EA] Calibrated Caliper /\nHeight Gauge" { class: ea }
scale: "[EA] Calibrated Scale\n≤0.1 g resolution target" { class: ea }
pcb_fit_gauges: "[EA] 44 mm × 44 mm PCB\nFit Gauges / Dummy PCBs" { class: ea }
camera: "[EA] Calibrated Camera /\nEvidence Light Box" { class: ea }
ambient_meter: "[EA] Ambient Thermo-\nHygrometer" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-FC-001" { class: ea }

system: "[System] SAA-VV-FC-001 v1.0 Integrated Fit/Mass/Envelope Testbench\nRefs: IVV; SAA-R1; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  cansat: "[PC] v1.0 CanSat Assembly\nUUT, as-flown configuration" {
    class: pc
    direction: right

    standard_stack: "[PC] Standard Carrier\nModule Stack\n(Type 1)" {
      class: pc
      direction: down

      ads_module: "[PC] ADS Module" {
        class: pc
        direction: right
        ads_pcb: "[PC] ADS PCB\n44 mm × 44 mm" { class: pc }
      }

      ams_module: "[PC] AMS Module" {
        class: pc
        direction: right
        ams_pcb: "[PC] AMS PCB\n44 mm × 44 mm" { class: pc }
      }

      obcc_module: "[PC] OBCC Module" {
        class: pc
        direction: right
        obcc_pcb: "[PC] OBCC PCB\n44 mm × 44 mm" { class: pc }
      }

      pds_module: "[PC] PDS Module" {
        class: pc
        direction: right
        pds_pcb: "[PC] PDS PCB\n44 mm × 44 mm" { class: pc }
      }

      ess_module: "[PC] ESS Module" {
        class: pc
        direction: right
        battery_pack: "[PC] ESS Battery Pack" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB\n100 mm × 28 mm\n2-layer stackup" {
      class: pc
      direction: down
      grid-columns: 1

      ads_headers: "[PC] 2 mm 2×6\nADS Headers" { class: pc }
      ams_headers: "[PC] 2 mm 2×6\nAMS Headers" { class: pc }
      obcc_headers: "[PC] 2 mm 2×6\nOBCC Headers" { class: pc }
      pds_headers: "[PC] 2 mm 2×6\nPDS Headers" { class: pc }
      pdm_servo_header: "[PC] PDM Servo\nConnector" { class: pc }
      spine: "[PC] Backplane Spine" { class: pc }
    }

    parachute_module: "[PC] Parachute / Top\nModule\n(Type 2)" {
      class: pc
      direction: down

      cap: "[PC] Cap" { class: pc }
      parachute: "[PC] Parachute" { class: pc }
      servo: "[PC] Servo" { class: pc }
    }
  }

  envelope_mass_guardbands: "[C] Envelope/mass pass-fail:\nMeasure the final as-flown article.\nPass only if max diameter + U_D ≤ 66.0 mm\nand height + U_H ≤ 122.0 mm.\n122.0 mm is the modeled height limit;\nany stricter competition limit supersedes.\nMass requirement is interpreted as\nactual total mass < 350.0 g with a\nmeasurement guard band: measured mass\n+ U_M < 350.0 g. If U_M = 0.1 g,\nindicated mass must be < 349.9 g." {
    class: note
    shape: page
  }

  accommodation_constraint: "[C] Fit/accommodation pass-fail:\nAll Type 1 standard modules have\n44 mm × 44 mm PCB accommodation\nverified by installed PCBs, dummy gauges,\nor build-recorded pre-closure ESS gauge;\nno forced fit, PCB bending, blocked\nstandoffs, or stress is allowed.\nBackplane PCB remains within its\n100 mm × 28 mm allocation, headers mate,\nand cap/parachute/servo/battery/backplane\ncoexist with no integrated interference." {
    class: note
    shape: page
  }

  evidence_constraint: "[C] Evidence constraint:\nRecord article/build ID, baseline copy,\ninstrument IDs/calibration status,\nambient record, raw measurements,\nuncertainty values, photos/video,\nwitness review, and anomaly dispositions\nunder results/SAA-VV-FC-001/." {
    class: note
    shape: page
  }

  viewpoints: "[C] Viewpoints:\nStatistical significance = 100% final\narticle measurement; continuous\nmeasurement uncertainty; no population\nreliability claim.\nFault hardening = full as-flown\nconfiguration only: battery, parachute,\ncap, servo, backplane, headers and PCBs\npresent; no temporary omissions or\nexternal fit exceptions." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental / equipment conditions:\nUse calibrated or controlled gauges.\nAmbient thermo-hygrometer records\nworkshop conditions before repetitions.\nHold if condensation, handling state,\nor conditions outside instrument/article\noperating range can affect readings." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability targets:\nSAA-UC-IntegratedAssembly;\nSAA-UC-BackplaneIntegration;\nSAA-UC-ParachuteClearance;\nSAA-FE-EnvelopeNonCompliance;\nSAA-FE-MassNonCompliance;\nSAA-FE-BackplaneMisMate;\nmodeled envelope, mass, module,\nbackplane and assembly constraints." {
    class: note
    shape: page
  }
}

system.cansat.standard_stack.ads_module -- system.cansat.standard_stack.ams_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.ams_module -- system.cansat.standard_stack.obcc_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.obcc_module -- system.cansat.standard_stack.pds_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack.pds_module -- system.cansat.standard_stack.ess_module: "[PL] Stack screws" { class: pl }
system.cansat.standard_stack -- system.cansat.parachute_module: "[PL] Stack screws" { class: pl }

system.cansat.standard_stack -- system.cansat.backplane_pcb: "[PL] Perpendicular fixture\n+ header mating" { class: pl }
system.cansat.parachute_module -- system.cansat.backplane_pcb: "[PL] Backplane fixture\n+ servo connector" { class: pl }

system.cansat.standard_stack.ads_module.ads_pcb -- system.cansat.standard_stack.ads_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.ams_module.ams_pcb -- system.cansat.standard_stack.ams_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.obcc_module.obcc_pcb -- system.cansat.standard_stack.obcc_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.pds_module.pds_pcb -- system.cansat.standard_stack.pds_module: "[PL] PCB standoffs\n/ screws" { class: pl }
system.cansat.standard_stack.ess_module.battery_pack -- system.cansat.standard_stack.ess_module: "[PL] Battery fixture" { class: pl }

operator -- system.cansat: "[PL] Manual handling /\nconfiguration control" { class: pl }
witness -- system.cansat: "[PL] Direct witness\nline of sight" { class: pl }
envelope_gauge -- system.cansat: "[PL] Free-fit can gauge\nclearance check" { class: pl }
caliper_height -- system.cansat: "[PL] Diameter / height\ncontact probes" { class: pl }
scale -- system.cansat: "[PL] Scale pan support" { class: pl }
pcb_fit_gauges -- system.cansat.standard_stack: "[PL] 44 mm PCB dummy\ninsertion / seating path" { class: pl }
camera -- system.cansat: "[PL] Optical evidence\nfield of view" { class: pl }
ambient_meter -- system.cansat: "[PL] Shared ambient\nmeasurement field" { class: pl }
repo -- camera: "[PL] USB / SD media\ntransfer path" { class: pl }

system.envelope_mass_guardbands -> system.cansat { class: cstr }
system.envelope_mass_guardbands -> envelope_gauge { class: cstr }
system.envelope_mass_guardbands -> caliper_height { class: cstr }
system.envelope_mass_guardbands -> scale { class: cstr }
system.accommodation_constraint -> system.cansat.standard_stack { class: cstr }
system.accommodation_constraint -> system.cansat.backplane_pcb { class: cstr }
system.accommodation_constraint -> system.cansat.parachute_module { class: cstr }
system.evidence_constraint -> camera { class: cstr }
system.evidence_constraint -> repo { class: cstr }
system.viewpoints -> system.cansat { class: cstr }
system.conditions -> ambient_meter { class: cstr }
system.traceability -> system.cansat { class: cstr }

# Layout-only edges keep the test equipment, UUT, and constraints in a stable reading order.
operator -> witness { style: { opacity: 0 } }
witness -> envelope_gauge { style: { opacity: 0 } }
envelope_gauge -> caliper_height { style: { opacity: 0 } }
caliper_height -> scale { style: { opacity: 0 } }
scale -> pcb_fit_gauges { style: { opacity: 0 } }
pcb_fit_gauges -> camera { style: { opacity: 0 } }
camera -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.cansat -> system.envelope_mass_guardbands { style: { opacity: 0 } }
system.envelope_mass_guardbands -> system.accommodation_constraint { style: { opacity: 0 } }
system.accommodation_constraint -> system.evidence_constraint { style: { opacity: 0 } }
system.evidence_constraint -> system.viewpoints { style: { opacity: 0 } }
system.viewpoints -> system.conditions { style: { opacity: 0 } }
system.conditions -> system.traceability { style: { opacity: 0 } }
