vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical test setup view for ADS-IVV-FC-ATT.
# Defines UUT, orientation/magnetic truth means, logging means, temporary PLs/CEs, and environment constraints.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-FC-ATT\nPhysical attitude demonstration setup\nRefs: IVV; NASA-SE; IMU/I2C; ESA-CANSAT; SW/stats" {
  class: sys
  direction: down

  uut: "[PC] Selected ADS UUT\n(one version per execution)" {
    class: pc
    direction: right
    grid-columns: 2
    v01: "[PC] v0.1 GPS + XIAO\nN/A: no attitude chain" { class: pc }
    v02: "[PC] v0.2 GPS + IMU + XIAO\nprototype" { class: pc }
    v03: "[PC] v0.3 ADS PCB\nN/A behavior article" { class: pc }
    v10: "[PC] v1.0 integrated\nCanSat / ADS / OBCC" { class: pc }
  }
}

test_conductor: "[EA] IVV attitude\ndemonstration conductor" { class: ea }
orientation_fixture: "[EA] Non-magnetic orientation\nfixture / 6-face jig" { class: ea }
mag_reference: "[EA] Magnetic reference\ncompass / field survey\nor controlled field source" { class: ea }
imu_fault_injector: "[EA] I2C / IMU /\nmagnetic disturbance injector" { class: ea }
data_logger: "[EA] Data-acquisition PC\nserial/I2C/debug logger\nand timestamp source" { class: ea }
obcc_logger: "[EA] OBCC log capture\n(v1.0 delivery evidence)" { class: ea }
power_supply: "[EA] Current-limited\nbench supply / battery simulator" { class: ea }

note_pass: "[C] Attitude pass condition\nNo formal attitude accuracy requirement is modeled.\nPass if PRY and acceleration outputs are finite, within\nthe selected angle convention/range, repeatable enough\nfor the stated demonstration objective, plausible for known\nstatic orientations/yaw changes, and delivered to collector." { class: note; shape: page }
note_environment: "[C] Environment constraints\nRecord fixture orientation, axis/sign convention, leveling,\nmagnetic cleanliness, local field survey, nearby ferrous/electrical\ndisturbers, vibration, temperature, warm-up, timebase, power mode,\nfirmware commit, and calibration status. Do not execute if axis\nconvention or magnetic disturbance status is unknown." { class: note; shape: page }
note_faults: "[C] Fault-hardening conditions\nInject or simulate I2C NACK/stuck/wrong address/partial read,\ninvalid acceleration, magnetic disturbance, stale data, and recovery.\nFail if invalid/stale/disturbed data are accepted as valid without\nstatus, PRY becomes non-finite, or loop/OBCC progress blocks." { class: note; shape: page }
note_timing: "[C] Timing and constraint viewpoint\nProcess/Calculate functions shall remain <5 ms where instrumented.\nv1.0 I2C reads shall return data or timeout/error <=5 ms.\nv0.2 I2C timeout remains a modeling gap to record." { class: note; shape: page }

# Temporary physical links used by the verification setup.
orientation_fixture -- system.uut: "[PL] mechanical\norientation fixture" { class: pl }
mag_reference -- system.uut: "[PL] magnetic field\nreference/context" { class: pl }
imu_fault_injector -- system.uut: "[PL] I2C/magnetic\nfault harness" { class: pl }
data_logger -- system.uut: "[PL] USB/UART/debug\nlog cable" { class: pl }
obcc_logger -- system.uut: "[PL] OBCC debug\nlog interface" { class: pl }
power_supply -- system.uut: "[PL] power leads" { class: pl }

# Verification component exchanges / records.
test_conductor -> system.uut: "[CE] demo run sheet\nand version selection" { class: ce }
orientation_fixture -> data_logger: "[CE] reference orientation\nand timestamps" { class: ce }
mag_reference -> data_logger: "[CE] magnetic context\nand disturbance markers" { class: ce }
system.uut -> data_logger: "[CE] ADS accel/mag/PRY\nsamples/status/time" { class: ce }
system.uut -> obcc_logger: "[CE] v1.0 OBCC\ncollected attitude record" { class: ce }
imu_fault_injector -> data_logger: "[CE] injected fault\nmarkers" { class: ce }

note_pass -> data_logger { class: cstr }
note_environment -> system { class: cstr }
note_faults -> imu_fault_injector { class: cstr }
note_faults -> obcc_logger { class: cstr }
note_timing -> data_logger { class: cstr }

# Layout-only rank hints.
test_conductor -> orientation_fixture { style: { opacity: 0 } }
orientation_fixture -> mag_reference { style: { opacity: 0 } }
mag_reference -> imu_fault_injector { style: { opacity: 0 } }
imu_fault_injector -> data_logger { style: { opacity: 0 } }
data_logger -> obcc_logger { style: { opacity: 0 } }
obcc_logger -> power_supply { style: { opacity: 0 } }
system -> note_pass { style: { opacity: 0 } }
note_pass -> note_environment { style: { opacity: 0 } }
note_environment -> note_faults { style: { opacity: 0 } }
note_faults -> note_timing { style: { opacity: 0 } }
