vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-PL-001 verification-only Physical Architecture PV1.
# v0.1 transition-readiness physical-link presence/retention/alignment inspection.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# This file is a test-definition view and does not modify the v0.1 baseline model.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

fixture: "[EA] Assembly Fixture /\nESD Support" { class: ea }
camera: "[EA] Calibrated Camera /\nMicroscope" { class: ea }
torque_pull: "[EA] Torque Tool /\nPull Gauge" { class: ea }
alignment_aids: "[EA] Slot / Clearance\nAlignment Aids" { class: ea }

system: "[System] SAA-VV-PL-001 v0.1 Physical Link Inspection Testbench\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  cansat: "[PC] v0.1 CanSat Structural\nEnvelope under PL inspection" {
    class: pc
    direction: right

    standard_stack: "[PC] Standard Carrier\nModule Stack\n(Type 1)" {
      class: pc
      direction: down
      grid-columns: 1

      ads_module: "[PC] ADS Module" { class: pc }
      ams_module: "[PC] AMS Module" { class: pc }
      obcc_module: "[PC] OBCC Module" { class: pc }
      pds_module: "[PC] PDS Module" { class: pc }
      ess_module: "[PC] ESS Module" { class: pc }
    }

    backplane_volume: "[PC] Perpendicular\nBackplane Volume" { class: pc }

    parachute_module: "[PC] Parachute / Top\nModule\n(Type 2)" { class: pc }
  }

  v01_link_census: "[C] v0.1 100% PL census target:\n5 stack-screw interfaces between\nADS-AMS-OBCC-PDS-ESS and top module;\n1 perpendicular backplane slot;\n1 backplane clearance interface.\nEach modeled PL receives an inspection row." {
    class: note
    shape: page
  }

  pass_fail: "[C] v0.1 pass/fail constraint:\nPass only if every modeled PL is present,\ncorrectly endpointed, routed/mated where\napplicable, retained/aligned, and free of\nlooseness, interference, damage, stripped\nbosses, or unapproved bypass.\nAny missing/extra/ambiguous link, wrong\nendpoint, blocked slot, insufficient\nclearance, damaged fastener/boss, or\nmissing evidence = fail/hold." {
    class: note
    shape: page
  }

  inspection_conditions: "[C] Inspection conditions:\nUse stable assembly fixture, adequate\nlighting, calibrated camera/microscope,\nand current torque/retention or pull-gauge\ncalibration where retention is checked.\nRecord any handling or ambient deviation\nthat affects inspection evidence." {
    class: note
    shape: page
  }

  stats_faults: "[C] Viewpoints:\nStatistical significance = 100% census of\nevery modeled v0.1 PL on each inspected\narticle; no sampling or reliability claim.\nFault hardening = screens loose/missing\nstack screws, stripped bosses, wrong\nmodule endpoints, blocked backplane slot,\nclearance interference, and evidence gaps." {
    class: note
    shape: page
  }

  trace: "[C] Traceability target:\nSAA-UC-IntegratedAssembly;\nSAA-UC-BackplaneIntegration;\nSAA-FE-BackplaneMisMate;\nSAA-FE-StructuralLoosening;\nmodeled v0.1 stack/backplane/assembly\nconstraints and IVV physical-link coverage." {
    class: note
    shape: page
  }
}

system.cansat.standard_stack.ads_module -- system.cansat.standard_stack.ams_module: "[PL] Stack screws\nPL-01" { class: pl }
system.cansat.standard_stack.ams_module -- system.cansat.standard_stack.obcc_module: "[PL] Stack screws\nPL-02" { class: pl }
system.cansat.standard_stack.obcc_module -- system.cansat.standard_stack.pds_module: "[PL] Stack screws\nPL-03" { class: pl }
system.cansat.standard_stack.pds_module -- system.cansat.standard_stack.ess_module: "[PL] Stack screws\nPL-04" { class: pl }
system.cansat.standard_stack -- system.cansat.parachute_module: "[PL] Stack screws\nPL-05" { class: pl }

system.cansat.standard_stack -- system.cansat.backplane_volume: "[PL] Perpendicular\nbackplane slot\nPL-06" { class: pl }
system.cansat.parachute_module -- system.cansat.backplane_volume: "[PL] Backplane\nclearance\nPL-07" { class: pl }

fixture -- system.cansat: "[PL] UUT restraint\nand ESD-safe support" { class: pl }
camera -- system.cansat: "[PL] Optical evidence path\nand scale reference" { class: pl }
torque_pull -- system.cansat.standard_stack: "[PL] Screw-head / boss\nretention contact" { class: pl }
alignment_aids -- system.cansat.backplane_volume: "[PL] Slot gauge and\nclearance reference contact" { class: pl }

system.v01_link_census -> system.cansat { class: cstr }
system.pass_fail -> system.cansat.standard_stack { class: cstr }
system.pass_fail -> system.cansat.backplane_volume { class: cstr }
system.pass_fail -> system.cansat.parachute_module { class: cstr }
system.inspection_conditions -> fixture { class: cstr }
system.inspection_conditions -> camera { class: cstr }
system.inspection_conditions -> torque_pull { class: cstr }
system.inspection_conditions -> alignment_aids { class: cstr }
system.stats_faults -> system.cansat { class: cstr }
system.trace -> system.cansat { class: cstr }

# Layout-only edges keep equipment above the v0.1 article and notes below it.
fixture -> camera { style: { opacity: 0 } }
camera -> torque_pull { style: { opacity: 0 } }
torque_pull -> alignment_aids { style: { opacity: 0 } }
alignment_aids -> system { style: { opacity: 0 } }
system.cansat -> system.v01_link_census { style: { opacity: 0 } }
system.v01_link_census -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.inspection_conditions { style: { opacity: 0 } }
system.inspection_conditions -> system.stats_faults { style: { opacity: 0 } }
system.stats_faults -> system.trace { style: { opacity: 0 } }
