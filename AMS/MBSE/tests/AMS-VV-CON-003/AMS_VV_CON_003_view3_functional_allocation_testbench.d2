vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional allocation view — AMS-VV-CON-003 I2C read timeout testbench
# Verification references: IVV, AMS-R2 (I2C), AMS-R5 (statistics).
# Final acceptance scope: environmental measurement I2C reads only.
# Traceability: constraint; AMS-FE-SensorBusFault; AMS-UC-MeasureAtmosphere.
# Show the full PA allocation stack without exchanges.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-CON-003 I2C timeout\nFinal acceptance; Refs: IVV, AMS-R2, AMS-R5" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: down
    grid-columns: 1

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        bme280: "[PC] BME280" {
          class: pc
          direction: down

          ams_sensing: "[LC] AMS Sensing" {
            class: lc
            direction: down
            grid-columns: 3

            measure_pressure: "[F] Measure\npressure" { class: func }
            measure_temperature: "[F] Measure\ntemp." { class: func }
            respond_i2c_requests: "[F] Respond to I2C\nRequests" { class: func }
          }

          note_accuracy_pressure: "[C] Accuracy\n< 1 hPa" {
            class: note
            shape: page
          }
          note_accuracy_temperature: "[C] Accuracy < 0.5 Celsius,\n10-40 °C range" {
            class: note
            shape: page
          }
        }

        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        grid-columns: 2

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down

          ams_processing: "[LC] AMS Processing" {
            class: lc
            direction: down
            grid-columns: 4

            get_bme280_init_state: "[F] Get BME280\ninit state" { class: func }
            read_pressure: "[F] Read\npressure" { class: func }
            read_temperature: "[F] Read\ntemperature" { class: func }
            calculate_altitude: "[F] Calculate\naltitude" { class: func }
            process_temperature: "[F] Process\ntemperature" { class: func }

            note_resolution: "[C] Resolution\n< 10m" {
              class: note
              shape: page
            }
          }

          obcc: "[LC] OBCC" {
            class: lc
            direction: down
            grid-columns: 1

            collect_peripheral_init_states: "[F] Collect peripheral\ninit states" { class: func }
            collect_measurements: "[F] Collect\nmeasurements" { class: func }
          }

          timeout_test_instrumentation: "[LC] AMS Timeout\nTest Instrumentation\n(VV-only)" {
            class: lc
            direction: down
            grid-columns: 2

            trigger_timed_pressure_read: "[F] Trigger timed\npressure read" { class: func }
            trigger_timed_temperature_read: "[F] Trigger timed\ntemperature read" { class: func }
            timestamp_read_entry_return: "[F] Timestamp read\nentry/return" { class: func }
            emit_result_record: "[F] Emit result\nrecord" { class: func }
            monitor_scheduler_alive: "[F] Monitor scheduler\nalive" { class: func }
            map_i2c_callsites: "[F] Map environmental\nI2C callsites" { class: func }
            inspect_timeout_config: "[F] Inspect timeout\nconfiguration" { class: func }
          }
        }

        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }

        note_variable_getter: "[C] Implement each\n(Read X, Process X) or\n(Read X, Calculate Y)\npair as a Variable\nGetter template" {
          class: note
          shape: page
        }
        note_i2c_timeout: "[C] All I2C read\nfunctions must have\na timeout ≤ 5 ms" {
          class: note
          shape: page
        }
        note_process_time: "[C] All Process or\nCalculate functions\nmust take < 5 ms" {
          class: note
          shape: page
        }
        note_no_blocking: "[C] No blocking\noperations besides\nI2C or UART comms" {
          class: note
          shape: page
        }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      grid-columns: 1

      ams_headers: "[PC] 2mm 2x6 AMS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }
  }
}

test_operator: "[EA] AMS-VV\nTest Operator" {
  class: ea
  direction: down
  grid-columns: 2

  configure_test_case: "[F] Configure\ntest case" { class: func }
  authorize_fault_injection: "[F] Authorize fault\ninjection" { class: func }
  record_anomalies: "[F] Record\nanomalies" { class: func }
  archive_evidence: "[F] Archive\nevidence" { class: func }
  record_ambient_conditions: "[F] Record ambient\nconditions" { class: func }
}

host_pc: "[EA] Host PC /\nTest Controller" {
  class: ea
  direction: down
  grid-columns: 2

  command_timed_read_batch: "[F] Command timed\nread batch" { class: func }
  receive_timestamped_log: "[F] Receive timestamped\nsample log" { class: func }
  compute_timing_statistics: "[F] Compute timing\nstatistics" { class: func }
  generate_coverage_matrix: "[F] Generate coverage\nmatrix" { class: func }
}

logic_analyzer: "[EA] Logic Analyzer /\nTimer" {
  class: ea
  direction: down
  grid-columns: 1

  capture_sda_scl_timing: "[F] Capture SDA/SCL\ntiming" { class: func }
  export_trace_evidence: "[F] Export trace\nevidence" { class: func }
}

fault_harness: "[EA] I2C Fault\nInjection Harness" {
  class: ea
  direction: down
  grid-columns: 1

  pass_nominal_i2c: "[F] Pass through\nnominal I2C" { class: func }
  force_nack_absent_sensor: "[F] Force NACK /\nabsent sensor" { class: func }
  hold_sda_low: "[F] Hold SDA\nlow" { class: func }
  hold_scl_low: "[F] Hold SCL\nlow" { class: func }
  release_fault: "[F] Release\nfault" { class: func }
}

bench_supply: "[EA] Bench Power\nSupply" {
  class: ea
  direction: down
  grid-columns: 1

  supply_stable_power: "[F] Supply stable\n3V3 power" { class: func }
  record_voltage_current: "[F] Record voltage /\ncurrent" { class: func }
}

ambient_thermometer: "[EA] Ambient Thermometer\nTraceable Logger" {
  class: ea
  direction: down
  grid-columns: 1

  read_ambient_temperature: "[F] Read ambient\ntemperature" { class: func }
}

note_timing_boundary: "[C] Timing boundary: read-function entry\nto returned success/error status;\ninstrumentation overhead recorded" {
  class: note
  shape: page
}
note_nominal_samples: "[C] 59/59 nominal samples per environmental\nI2C read function for a 95/95\ntiming claim" {
  class: note
  shape: page
}
note_fault_trials: "[C] Fault modes per environmental read function: NACK/absent\nsensor, held SDA, held SCL, and timeout/no-response; classify\npass/fail with low-level cause codes; recovery without reset is mandatory" {
  class: note
  shape: page
}
note_status_mapping: "[C] Shared status mapping: timeout/no-response -> TIMEOUT;\nruntime sensor/bus/value fault -> SENSOR_FAULT or applicable\nnon-VALID; init/no-data -> INIT_FAIL or NO_DATA.\nNo stale/old sample as VALID; record sequence/sample IDs,\ntimestamps/age where freshness is claimed, overhead, deviations." {
  class: note
  shape: page
}
note_environment: "[C] Bench environment: ambient 20-30 °C\nrecorded; stable 3V3/common ground;\nharness pullups/capacitance recorded" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb.bme280.note_accuracy_pressure -> system.cansat.ams_module.ams_pcb.bme280.ams_sensing.measure_pressure { class: cstr }
system.cansat.ams_module.ams_pcb.bme280.note_accuracy_temperature -> system.cansat.ams_module.ams_pcb.bme280.ams_sensing.measure_temperature { class: cstr }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing.note_resolution -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing.calculate_altitude { class: cstr }

system.cansat.obcc_module.obcc_pcb.note_variable_getter -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_i2c_timeout -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_process_time -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_no_blocking -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }


note_timing_boundary -> system.cansat.obcc_module.obcc_pcb.xiao.timeout_test_instrumentation.timestamp_read_entry_return { class: cstr }
note_timing_boundary -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing.read_pressure { class: cstr }
note_timing_boundary -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing.read_temperature { class: cstr }
note_nominal_samples -> host_pc.compute_timing_statistics { class: cstr }
note_fault_trials -> fault_harness.force_nack_absent_sensor { class: cstr }
note_fault_trials -> fault_harness.hold_sda_low { class: cstr }
note_fault_trials -> fault_harness.hold_scl_low { class: cstr }
note_fault_trials -> system.cansat.obcc_module.obcc_pcb.xiao.timeout_test_instrumentation.monitor_scheduler_alive { class: cstr }
note_status_mapping -> system.cansat.obcc_module.obcc_pcb.xiao.timeout_test_instrumentation.emit_result_record { class: cstr }
note_status_mapping -> host_pc.receive_timestamped_log { class: cstr }
note_environment -> bench_supply.supply_stable_power { class: cstr }
note_environment -> ambient_thermometer.read_ambient_temperature { class: cstr }
note_environment -> test_operator.record_ambient_conditions { class: cstr }

# Layout-only edges to stack the VV actors and constraint notes below the UUT allocation.
system -> test_operator { style: { opacity: 0 } }
test_operator -> host_pc { style: { opacity: 0 } }
host_pc -> logic_analyzer { style: { opacity: 0 } }
logic_analyzer -> fault_harness { style: { opacity: 0 } }
fault_harness -> bench_supply { style: { opacity: 0 } }
bench_supply -> ambient_thermometer { style: { opacity: 0 } }
ambient_thermometer -> note_timing_boundary { style: { opacity: 0 } }
note_timing_boundary -> note_nominal_samples { style: { opacity: 0 } }
note_nominal_samples -> note_fault_trials { style: { opacity: 0 } }
note_fault_trials -> note_status_mapping { style: { opacity: 0 } }
note_status_mapping -> note_environment { style: { opacity: 0 } }
