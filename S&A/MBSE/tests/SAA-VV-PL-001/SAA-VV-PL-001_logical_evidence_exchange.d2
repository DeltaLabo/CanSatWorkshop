vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-PL-001 verification-only Physical Architecture PV2.
# Logical/evidence component exchanges between test actors, tools, and PL inspection records.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# These CEs define the verification means only; they are not baseline S&A design exchanges.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] Inspection Operator" { class: ea }
camera: "[EA] Calibrated Camera /\nMicroscope" { class: ea }
torque_pull: "[EA] Torque Tool /\nPull Gauge" { class: ea }
continuity_alignment: "[EA] Continuity /\nAlignment Aids" { class: ea }

system: "[System] SAA-VV-PL-001 Logical Evidence Exchange View\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  evidence_boundary: "[PC] Verification Evidence\nControl Boundary" {
    class: pc
    direction: down
    intake_lc: "[LC] Tool / Operator Evidence Intake\nverification-only" { class: lc }
  }

  v01_article: "[PC] v0.1 S&A Article\nPL inspection record boundary" {
    class: pc
    direction: right
    v01_census_lc: "[LC] v0.1 Baseline PL Census\nverification-only" { class: lc }
    v01_record_lc: "[LC] v0.1 Link Inspection Evidence Record\nverification-only" { class: lc }
  }

  v10_article: "[PC] v1.0 S&A Article\nPL inspection record boundary" {
    class: pc
    direction: right
    v10_census_lc: "[LC] v1.0 Baseline PL Census\nverification-only" { class: lc }
    v10_record_lc: "[LC] v1.0 Link Inspection Evidence Record\nverification-only" { class: lc }
  }

  verification_only: "[C] Verification-only CEs:\nmodel test evidence/control flows for\nphysical-link inspection only. They do not\nclaim or replace missing baseline S&A\ncomponent exchanges for power, signals,\nor subsystem behavior." {
    class: note
    shape: page
  }

  evidence_integrity: "[C] Evidence integrity constraint:\nEach modeled PL row records article ID,\nversion, PL identifier, modeled endpoints,\nobserved endpoints/routing/mating,\nretention/alignment status, open/short\nor bent-pin evidence when applicable,\nphoto/tool evidence IDs, anomaly\nstatus, and QA witness disposition." {
    class: note
    shape: page
  }

  gate_logic: "[C] Gate constraint:\nA version readiness gate cannot close\nuntil its evidence record has one\nnon-ambiguous pass/fail/hold disposition\nfor every modeled PL in that baseline,\nincluding all stack-screw, backplane,\nPCB-standoff, battery-fixture, and\nconnector/servo links applicable to the version." {
    class: note
    shape: page
  }

  calibration: "[C] Calibration / suitability constraint:\nCamera/microscope, torque or pull gauge,\nand continuity/alignment aids must be\nidentified and in current calibration or\napproved workshop check status before\nmeasurements are used as evidence." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nSAA-UC-IntegratedAssembly;\nSAA-UC-BackplaneIntegration;\nSAA-UC-ParachuteClearance;\nSAA-FE-BackplaneMisMate;\nSAA-FE-StructuralLoosening;\nSAA-FE-LandingDamage;\nmodeled physical-link constraints." {
    class: note
    shape: page
  }
}

witness: "[EA] QA Witness" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-PL-001" { class: ea }

operator -> system.evidence_boundary.intake_lc: "[CE] Baseline selection,\nobservations, anomalies" { class: ce }
camera -> system.evidence_boundary.intake_lc: "[CE] Link photo /\nmicroscope evidence" { class: ce }
torque_pull -> system.evidence_boundary.intake_lc: "[CE] Retention, torque,\nor pull observations" { class: ce }
continuity_alignment -> system.evidence_boundary.intake_lc: "[CE] Alignment, mating,\nopen/short evidence" { class: ce }

system.evidence_boundary.intake_lc -> system.v01_article.v01_record_lc: "[CE] v0.1 evidence rows\nfor PL-01 through PL-07" { class: ce }
system.v01_article.v01_census_lc -> system.v01_article.v01_record_lc: "[CE] v0.1 modeled PL list\nand pass/fail fields" { class: ce }
system.v01_article.v01_record_lc -> witness: "[CE] v0.1 review package\napproval / hold" { class: ce }
system.v01_article.v01_record_lc -> repo: "[CE] v0.1 released\nevidence package" { class: ce }

system.evidence_boundary.intake_lc -> system.v10_article.v10_record_lc: "[CE] v1.0 evidence rows\nfor PL-01 through PL-12" { class: ce }
system.v10_article.v10_census_lc -> system.v10_article.v10_record_lc: "[CE] v1.0 modeled PL list\nand pass/fail fields" { class: ce }
system.v10_article.v10_record_lc -> witness: "[CE] v1.0 review package\napproval / hold" { class: ce }
system.v10_article.v10_record_lc -> repo: "[CE] v1.0 released\nevidence package" { class: ce }

system.verification_only -> system.evidence_boundary.intake_lc { class: cstr }
system.evidence_integrity -> system.v01_article.v01_record_lc { class: cstr }
system.evidence_integrity -> system.v10_article.v10_record_lc { class: cstr }
system.gate_logic -> system.v01_article.v01_record_lc { class: cstr }
system.gate_logic -> system.v10_article.v10_record_lc { class: cstr }
system.calibration -> system.evidence_boundary.intake_lc { class: cstr }
system.traceability -> system.v01_article { class: cstr }
system.traceability -> system.v10_article { class: cstr }

# Layout-only edges keep actors, system, and repository in a stable reading order.
operator -> camera { style: { opacity: 0 } }
camera -> torque_pull { style: { opacity: 0 } }
torque_pull -> continuity_alignment { style: { opacity: 0 } }
continuity_alignment -> system { style: { opacity: 0 } }
system -> witness { style: { opacity: 0 } }
witness -> repo { style: { opacity: 0 } }
system.evidence_boundary -> system.v01_article { style: { opacity: 0 } }
system.v01_article -> system.v10_article { style: { opacity: 0 } }
system.v10_article -> system.verification_only { style: { opacity: 0 } }
system.verification_only -> system.evidence_integrity { style: { opacity: 0 } }
system.evidence_integrity -> system.gate_logic { style: { opacity: 0 } }
system.gate_logic -> system.calibration { style: { opacity: 0 } }
system.calibration -> system.traceability { style: { opacity: 0 } }
