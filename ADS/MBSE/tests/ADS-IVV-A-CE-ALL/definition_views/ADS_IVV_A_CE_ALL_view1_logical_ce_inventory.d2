vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Logical view: all-version component-exchange inventory and analysis constraints for ADS-IVV-A-CE-ALL.
# References: IVV CE analysis rule; NASA-SE; GPS/UBX; IMU/I2C; SW/stats; Workmanship; ADS MBSE plan.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-A-CE-ALL\nComponent exchange analysis inventory\nRefs: IVV; NASA-SE; GPS/UBX; IMU/I2C; SW/stats; Workmanship" {
  class: sys
  direction: down
  grid-columns: 1

  v01: "[PC] ADS v0.1 CE inventory" {
    class: pc
    direction: right
    gps: "[PC] UBX-G7020-KT GPS" {
      class: pc
      gps_sensing: "[LC] ADS GPS Sensing" { class: lc }
    }
    xiao: "[PC] XIAO ESP32" {
      class: pc
      loop: "[LC] Loop" { class: lc }
    }
  }

  v02: "[PC] ADS v0.2 CE inventory" {
    class: pc
    direction: right
    gps: "[PC] UBX-G7020-KT GPS" {
      class: pc
      gps_sensing: "[LC] ADS GPS Sensing" { class: lc }
    }
    imu: "[PC] ICM20948 IMU" {
      class: pc
      kinematic_sensing: "[LC] ADS Kinematic Sensing" { class: lc }
    }
    xiao: "[PC] XIAO ESP32" {
      class: pc
      loop: "[LC] Loop" { class: lc }
    }
  }

  v03: "[PC] ADS v0.3 PCB delivery\nCE inventory = none" {
    class: pc
    note_v03_na: "[C] v0.3 CE N/A rationale\nOnly PV1 physical PCB delivery is modeled.\nNo LCs, no PV2, and no Component Exchanges.\nUART/I2C are physical traces only here." { class: note; shape: page }
  }

  v10: "[PC] ADS v1.0 CE inventory" {
    class: pc
    direction: right
    ads_pcb: "[PC] ADS PCB" {
      class: pc
      direction: down
      gps: "[PC] UBX-G7020-KT GPS" {
        class: pc
        gps_sensing: "[LC] ADS GPS Sensing" { class: lc }
      }
      imu: "[PC] ICM20948 IMU" {
        class: pc
        kinematic_sensing: "[LC] ADS Kinematic Sensing" { class: lc }
      }
    }
    obcc_pcb: "[PC] OBCC PCB / XIAO ESP32-S3" {
      class: pc
      direction: down
      ads_processing: "[LC] ADS Processing" { class: lc }
      obcc: "[LC] OBCC" { class: lc }
    }
  }
}

note_coverage: "[C] Coverage constraint\nAnalyze 100% of modeled CEs in the selected version.\nv0.1: 1/1 UART. v0.2: 2/2 UART/I2C.\nv0.3: explicit 0/0 N/A after 1/1 view reviewed.\nv1.0: 4/4 UART/I2C/Pointers/Returns." { class: note; shape: page }
note_consistency: "[C] CE consistency constraint\nPass only if implemented endpoints, protocol or interface type,\nrequest/response semantics, timeout/no-blocking behavior,\nand data validity/freshness semantics match model intent." { class: note; shape: page }
note_faults: "[C] Fault-hardening viewpoint\nUART: silent/no-fix/malformed GPS, wrong baud, swapped TX/RX.\nI2C: NACK, stuck bus, wrong address, swapped SDA/SCL.\nPointers/Returns: stale/null/dangling pointer, invalid return,\nOBCC consuming corrupt ADS data." { class: note; shape: page }
note_trace: "[C] Traceability targets\nADS-CAP-GPS, ADS-CAP-IMU, ADS-CAP-ATT, ADS-CAP-INIT,\nADS-CAP-DELIVERY, ADS-CAP-PCB for v0.3 N/A,\nADS-FE-STUCK-LOOP, ADS-FE-SILENT-SENSOR-FAIL,\nADS-FE-CORRUPT-MEASUREMENT." { class: note; shape: page }

system.v01.gps.gps_sensing -> system.v01.xiao.loop: "[CE] UART" { class: ce }
system.v02.gps.gps_sensing -> system.v02.xiao.loop: "[CE] UART" { class: ce }
system.v02.imu.kinematic_sensing -> system.v02.xiao.loop: "[CE] I2C" { class: ce }
system.v10.ads_pcb.gps.gps_sensing -> system.v10.obcc_pcb.ads_processing: "[CE] UART" { class: ce }
system.v10.ads_pcb.imu.kinematic_sensing -> system.v10.obcc_pcb.ads_processing: "[CE] I2C" { class: ce }
system.v10.obcc_pcb.ads_processing -> system.v10.obcc_pcb.obcc: "[CE] Pointers" { class: ce }
system.v10.obcc_pcb.ads_processing -> system.v10.obcc_pcb.obcc: "[CE] Returns" { class: ce }

note_coverage -> system { class: cstr }
note_consistency -> system { class: cstr }
note_faults -> system { class: cstr }
note_trace -> system { class: cstr }

# Layout-only rank hints for readable notes.
system -> note_coverage { style: { opacity: 0 } }
note_coverage -> note_consistency { style: { opacity: 0 } }
note_consistency -> note_faults { style: { opacity: 0 } }
note_faults -> note_trace { style: { opacity: 0 } }
