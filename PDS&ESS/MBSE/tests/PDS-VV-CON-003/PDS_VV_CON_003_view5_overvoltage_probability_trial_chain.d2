vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional Chain — PDS-VV-CON-003 overvoltage probability trials.
# Only functions, FEs, and constraints are inside the chain container.
# References: IVV, PDS-R4, PDS-R5, PDS-R6, PDS-R7, PDS-R8, PDS-R2.
# Traceability: [C] Probability < 1%; PDS-VV-FC-001; PDS-FE-OvercurrentOvervoltage;
# PDS-FE-LiIonUnsafeCondition; PDS-FE-RailBrownout; PDS-UC-ProvideRegulatedPower.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDS-VV-CON-003 — overvoltage probability trial chain\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R4; PDS-R5; PDS-R6; PDS-R7; PDS-R8; PDS-R2" {
  class: chain
  direction: down
  grid-columns: 1

  read_ambient: "[F] Read ambient\nbefore trial set" { class: func }
  verify_calibration_status: "[F] Verify source/load,\ninstrument, interlock status" { class: func }
  configure_battery_emulator: "[F] Configure battery emulator\nor current-limited source" { class: func }
  configure_overvoltage_source: "[F] Configure current-limited\novervoltage source" { class: func }
  set_overvoltage_limits: "[F] Set overvoltage and\ncurrent limits" { class: func }
  safety_approval: "[F] Obtain Safety Observer\napproval for trial set" { class: func }
  arm_logging_interlock: "[F] Arm logging, thermal,\nand E-stop interlock" { class: func }
  select_trial_variant: "[F] Randomize/procedure-select\novervoltage trial" { class: func }
  switch_power_on: "[F] Switch power on" { class: func }
  restore_power_initial: "[F] Restore power" { class: func }
  regulate_nominal_rails: "[F] Regulate nominal\n5 V / 3V3 rails" { class: func }
  verify_pre_fault_nominal: "[F] Verify pre-fault\nnominal state" { class: func }
  command_overvoltage_demand: "[F] Command current-limited\novervoltage demand" { class: func }
  inject_overvoltage: "[F] Inject current-limited\novervoltage demand" { class: func }
  detect_overvoltage: "[F] Detect overvoltage" { class: func }
  verify_detect_observable: "[F] Verify detect function\ninvoked / observable" { class: func }
  cut_off_power: "[F] Cut off power" { class: func }
  verify_cutoff_before_limits: "[F] Verify cut-off before\nunsafe rail/cell/temp limits" { class: func }
  verify_safe_state: "[F] Verify safe state:\nrails off or current-limited" { class: func }
  monitor_temperature_cell: "[F] Monitor no unsafe\ntemperature or cell behavior" { class: func }
  record_cutoff_evidence: "[F] Record cut-off\nwaveforms and status" { class: func }
  attempt_restore_with_fault: "[F] Attempt restore while\novervoltage remains" { class: func }
  verify_restore_inhibited: "[F] Verify restore inhibited\nuntil overvoltage removed" { class: func }
  remove_overvoltage_demand: "[F] Remove overvoltage\ndemand" { class: func }
  command_controlled_restore: "[F] Command controlled\nrestore" { class: func }
  restore_power_after_clear: "[F] Restore power" { class: func }
  verify_nominal_recovery: "[F] Verify nominal recovery\nwithout reset / restart" { class: func }
  classify_trial: "[F] Classify trial:\npass, miss, hold, anomaly" { class: func }
  stop_on_miss_or_update_count: "[F] Stop on miss or update\nzero-miss trial count" { class: func }
  log_evidence: "[F] Log raw evidence\nand trial metadata" { class: func }
  repeat_until_acceptance: "[F] Repeat independent trials\nuntil 299 zero misses or stop" { class: func }
  archive_evidence: "[F] Archive overvoltage-mode\nevidence package" { class: func }

  note_scope: "[C] PDS-VV-CON-003 overvoltage-mode scope\nConservative interpretation of [C] Probability < 1%: missed demanded unsafe\nprotection action probability <1% for current-limited overvoltage demands.\nTrace: PDS-VV-FC-001; PDS-FE-OvercurrentOvervoltage; LiIonUnsafeCondition;\nRailBrownout; PDS-UC-ProvideRegulatedPower." {
    class: note
    shape: page
  }
  note_trial_pass: "[C] Per-trial pass/fail\nDemand applied by a preconfigured current-limited overvoltage source; Detect\novervoltage invoked and observable; Cut off power before unsafe rail/cell/\ntemperature limits; rails safe; restore inhibited until overvoltage removed;\ncontrolled restore returns nominal without brownout, reset, or uncontrolled restart." {
    class: note
    shape: page
  }
  note_no_miss: "[C] Miss policy\nAny missed unsafe action is fail/hold/anomaly. No waiver can turn a miss into a\npass for the <1% statistical claim. Ambiguous detect or cut-off evidence is held,\nnot passed." {
    class: note
    shape: page
  }
  note_statistical: "[C] Statistical significance\nFormal <1% missed-demand probability at 95% confidence requires 299 independent\novervoltage demanded-protection trials with zero misses. Fewer trials require\nexact one-sided Clopper-Pearson upper bound and screening classification only." {
    class: note
    shape: page
  }
  note_safety: "[C] Environmental and safety constraints\nRead ambient before the trial set; verify calibrated/status-checked instruments;\nset voltage/current limits before energizing; Safety Observer approves; battery\nemulator preferred; no flight-pack overcharge abuse or destructive Li-ion abuse." {
    class: note
    shape: page
  }
  note_fault_hardening: "[C] Fault-hardening and continuous data\nCovers overvoltage, wrong/reverse source setup hold, cut-off failure, unsafe\nrestore, rail brownout/reset, overheating, and Li-ion unsafe precursors.\nContinuous rail/current/thermal limits reference PDS-VV-CON-004 or collect ≥30\nraw samples." {
    class: note
    shape: page
  }
}

chain.read_ambient -> chain.verify_calibration_status: "[FE] Ambient record" { class: fe }
chain.verify_calibration_status -> chain.configure_battery_emulator: "[FE] Verified equipment" { class: fe }
chain.configure_battery_emulator -> chain.configure_overvoltage_source: "[FE] Safe source baseline" { class: fe }
chain.configure_overvoltage_source -> chain.set_overvoltage_limits: "[FE] Overvoltage source configured" { class: fe }
chain.set_overvoltage_limits -> chain.safety_approval: "[FE] Safe voltage/current limits" { class: fe }
chain.safety_approval -> chain.arm_logging_interlock: "[FE] Witness approval" { class: fe }
chain.arm_logging_interlock -> chain.select_trial_variant: "[FE] Trigger-ready setup" { class: fe }
chain.select_trial_variant -> chain.switch_power_on: "[FE] Trial variant selected" { class: fe }
chain.switch_power_on -> chain.restore_power_initial: "[FE] Power-on command" { class: fe }
chain.restore_power_initial -> chain.regulate_nominal_rails: "[FE] Protected power restored" { class: fe }
chain.regulate_nominal_rails -> chain.verify_pre_fault_nominal: "[FE] Nominal rails" { class: fe }
chain.verify_pre_fault_nominal -> chain.command_overvoltage_demand: "[FE] Pre-fault state accepted" { class: fe }
chain.command_overvoltage_demand -> chain.inject_overvoltage: "[FE] Demand command" { class: fe }
chain.inject_overvoltage -> chain.detect_overvoltage: "[FE] Current-limited overvoltage" { class: fe }
chain.detect_overvoltage -> chain.verify_detect_observable: "[FE] Detect response" { class: fe }
chain.verify_detect_observable -> chain.cut_off_power: "[FE] Detect observable" { class: fe }
chain.cut_off_power -> chain.verify_cutoff_before_limits: "[FE] Cut-off state" { class: fe }
chain.verify_cutoff_before_limits -> chain.verify_safe_state: "[FE] Limit-safe cut-off" { class: fe }
chain.verify_safe_state -> chain.monitor_temperature_cell: "[FE] Rails/current safe" { class: fe }
chain.monitor_temperature_cell -> chain.record_cutoff_evidence: "[FE] Thermal/cell safe" { class: fe }
chain.record_cutoff_evidence -> chain.attempt_restore_with_fault: "[FE] Cut-off evidence recorded" { class: fe }
chain.attempt_restore_with_fault -> chain.verify_restore_inhibited: "[FE] Restore attempt with OV" { class: fe }
chain.verify_restore_inhibited -> chain.remove_overvoltage_demand: "[FE] Inhibition evidence" { class: fe }
chain.remove_overvoltage_demand -> chain.command_controlled_restore: "[FE] Overvoltage removed" { class: fe }
chain.command_controlled_restore -> chain.restore_power_after_clear: "[FE] Controlled restore command" { class: fe }
chain.restore_power_after_clear -> chain.verify_nominal_recovery: "[FE] Recovered protected power" { class: fe }
chain.verify_nominal_recovery -> chain.classify_trial: "[FE] Recovery/no-reset evidence" { class: fe }
chain.classify_trial -> chain.stop_on_miss_or_update_count: "[FE] Trial classification" { class: fe }
chain.stop_on_miss_or_update_count -> chain.log_evidence: "[FE] Count updated or stop invoked" { class: fe }
chain.log_evidence -> chain.repeat_until_acceptance: "[FE] Controlled evidence" { class: fe }
chain.repeat_until_acceptance -> chain.archive_evidence: "[FE] 299 zero misses or screening stop" { class: fe }
