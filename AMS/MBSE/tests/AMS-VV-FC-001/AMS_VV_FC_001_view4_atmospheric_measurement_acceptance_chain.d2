vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

# Functional chain: v1.0 atmospheric measurement chain extended through reference measurement,
# AMS processing, OBCC collection, comparison, stale-data checks, and evidence logging.

chain: "AMS-VV-FC-001 — Atmospheric measurement final-acceptance chain\nTesting/Demonstration; AMS v1.0 final acceptance; Refs: IVV, AMS-R1, AMS-R3/R4/R5/R7\nTrace: AMS-UC-MeasureAtmosphere, AMS-FE-BadExposure, AMS-FE-StaleMeasurement, pressure/temp/altitude constraints" {
  class: chain
  direction: down

  configure_test_case: "[F] Configure final\nacceptance operating point" { class: func }
  record_instrument_ids: "[F] Record instrument\nIDs/calibration" { class: func }
  read_ambient_temperature: "[F] Read ambient\ntemperature" { class: func }
  set_stable_thermal_point: "[F] Set stable\nthermal point" { class: func }
  measure_reference_temperature: "[F] Measure reference\ntemperature" { class: func }
  set_pressure_operating_point: "[F] Set pressure\noperating point" { class: func }
  measure_reference_pressure: "[F] Measure reference\npressure" { class: func }
  record_reference_conditions: "[F] Record reference\nconditions" { class: func }
  supply_stable_power: "[F] Supply stable\n3V3 power" { class: func }
  record_voltage_current: "[F] Record voltage /\ncurrent" { class: func }
  start_sample_batch: "[F] Start n ≥ 30\nsample batch" { class: func }
  tag_sample_sequence: "[F] Tag sample\nsequence ID" { class: func }
  timestamp_measurement_steps: "[F] Timestamp read /\nprocess / collect steps" { class: func }

  measure_pressure: "[F] Measure\npressure" { class: func }
  measure_temperature: "[F] Measure\ntemp." { class: func }
  respond_i2c_requests: "[F] Respond to I2C\nRequests" { class: func }
  read_pressure: "[F] Read\npressure" { class: func }
  read_temperature: "[F] Read\ntemperature" { class: func }
  calculate_altitude: "[F] Calculate\naltitude" { class: func }
  process_temperature: "[F] Process\ntemperature" { class: func }
  collect_measurements: "[F] Collect\nmeasurements" { class: func }
  emit_current_measurement_record: "[F] Emit status/age\nmeasurement record" { class: func }

  capture_obcc_results: "[F] Capture OBCC\nresult log" { class: func }
  parse_result_order_units: "[F] Parse result\norder / units" { class: func }
  check_current_not_stale: "[F] Check VALID and\nage_ms <= 400 ms" { class: func }
  pair_samples_with_references: "[F] Pair samples\nwith references" { class: func }
  compare_pressure_to_reference: "[F] Compare pressure\nto reference" { class: func }
  compare_temperature_to_reference: "[F] Compare temperature\nto reference" { class: func }
  compute_bias_u95: "[F] Compute bias\nand U95" { class: func }
  archive_evidence: "[F] Archive raw data\nand pass/fail" { class: func }

  note_n30: "[C] Pass condition: collect n ≥ 30 paired\npressure and temperature samples per operating point\nbefore computing final acceptance statistics" { class: note; shape: page }
  note_pressure: "[C] Pressure passes iff abs(bias) + U95 ≤ 1 hPa\nfor AMS pressure paired with the reference pressure" { class: note; shape: page }
  note_temperature: "[C] Temperature passes iff abs(bias) + U95 ≤ 0.5 °C\nfor tested point(s) inside 10-40 °C" { class: note; shape: page }
  note_obcc_current: "[C] Fresh/current oracle at AMS→OBCC: collect altitude\nand temperature in modeled order; current only when\nstatus == VALID and age_ms <= 400 ms. Non-VALID\n(STALE, NO_DATA, TIMEOUT, SENSOR_FAULT, INIT_FAIL)\nshall not be treated as current." { class: note; shape: page }
  note_altitude: "[C] Altitude calculation participates in this chain;\n10 m-equivalent pressure-step resolution pass/fail is\nmodeled in AMS_VV_FC_001_view5" { class: note; shape: page }
  note_i2c_dependency: "[C] Detailed I2C ≤5 ms timeout proof is a dependency\non AMS-VV-CON-003 and is not duplicated here; any TIMEOUT,\nSENSOR_FAULT, stale-valid, or currentness anomaly fails" { class: note; shape: page }
  note_evidence: "[C] Evidence required: timestamp, sequence/sample-ID, age_ms,\nstatus, raw AMS pressure/temperature/altitude values, reference\nvalues, uncertainty inputs, order evidence, deviations/anomalies" { class: note; shape: page }
  note_response_phase2: "[C] Temperature response <=60 s is phase-2 only unless\nthis folder is explicitly extended with declared temperature step,\nreference data, synchronized/correlated timestamps, exposure state,\nand response calculation; not closed here." { class: note; shape: page }
  note_environment: "[C] Environment: ambient thermometer is read before\nrepetitions; pressure and temperature references are\nco-located with BME280; stable 3V3/common ground and\nsunlight-blocking/airflow configuration are recorded" { class: note; shape: page }
  note_fault: "[C] Fault-hardening viewpoint: BadExposure, non-VALID or stale\nmeasurement, swapped pressure/temperature branches, unexplained\noutliers, evidence gaps, or old/default values marked VALID fail\nor require anomaly/waiver in the report" { class: note; shape: page }
}

chain.configure_test_case -> chain.record_instrument_ids: "[FE] Test setup" { class: fe }
chain.record_instrument_ids -> chain.read_ambient_temperature: "[FE] Ambient\nthermometer ID" { class: fe }
chain.record_instrument_ids -> chain.measure_reference_temperature: "[FE] Temp. ref.\nID/U" { class: fe }
chain.record_instrument_ids -> chain.measure_reference_pressure: "[FE] Pressure ref.\nID/U" { class: fe }
chain.read_ambient_temperature -> chain.record_reference_conditions: "[FE] Ambient\nreading" { class: fe }
chain.configure_test_case -> chain.set_stable_thermal_point: "[FE] Thermal\nsetpoint" { class: fe }
chain.set_stable_thermal_point -> chain.measure_reference_temperature: "[FE] Stable\nthermal point" { class: fe }
chain.configure_test_case -> chain.set_pressure_operating_point: "[FE] Pressure\nsetpoint" { class: fe }
chain.set_pressure_operating_point -> chain.measure_reference_pressure: "[FE] Stable\npressure point" { class: fe }
chain.measure_reference_temperature -> chain.record_reference_conditions: "[FE] T_ref + U" { class: fe }
chain.measure_reference_pressure -> chain.record_reference_conditions: "[FE] P_ref + U" { class: fe }
chain.configure_test_case -> chain.supply_stable_power: "[FE] Power setup" { class: fe }
chain.supply_stable_power -> chain.record_voltage_current: "[FE] Voltage/current" { class: fe }
chain.record_reference_conditions -> chain.start_sample_batch: "[FE] Reference conditions\n+ n ≥ 30 plan" { class: fe }
chain.record_voltage_current -> chain.start_sample_batch: "[FE] Power context\nready" { class: fe }
chain.start_sample_batch -> chain.tag_sample_sequence: "[FE] Sample schedule" { class: fe }
chain.tag_sample_sequence -> chain.timestamp_measurement_steps: "[FE] Sample ID" { class: fe }

chain.measure_pressure -> chain.respond_i2c_requests: "[FE] Pressure\nsignal" { class: fe }
chain.measure_temperature -> chain.respond_i2c_requests: "[FE] Temperature\nsignal" { class: fe }
chain.timestamp_measurement_steps -> chain.read_pressure: "[FE] Timed pressure\nread request" { class: fe }
chain.timestamp_measurement_steps -> chain.read_temperature: "[FE] Timed temperature\nread request" { class: fe }
chain.read_pressure -> chain.respond_i2c_requests: "[FE] Pressure\nI2C Req" { class: fe }
chain.read_temperature -> chain.respond_i2c_requests: "[FE] Temp.\nI2C Req" { class: fe }
chain.respond_i2c_requests -> chain.read_pressure: "[FE] Pressure\n+ status" { class: fe }
chain.respond_i2c_requests -> chain.read_temperature: "[FE] Temperature\n+ status" { class: fe }
chain.read_pressure -> chain.calculate_altitude: "[FE] Pressure\n+ status" { class: fe }
chain.read_temperature -> chain.process_temperature: "[FE] Temperature\n+ status" { class: fe }
chain.calculate_altitude -> chain.collect_measurements: "[FE] Result\n[Altitude]\nstatus+age" { class: fe }
chain.process_temperature -> chain.collect_measurements: "[FE] Result\n[Temperature]\nstatus+age" { class: fe }
chain.tag_sample_sequence -> chain.collect_measurements: "[FE] Sample ID /\ncurrentness tag" { class: fe }
chain.read_pressure -> chain.emit_current_measurement_record: "[FE] Pressure status,\nage, sample ID" { class: fe }
chain.read_temperature -> chain.emit_current_measurement_record: "[FE] Temperature status,\nage, sample ID" { class: fe }
chain.calculate_altitude -> chain.emit_current_measurement_record: "[FE] Altitude status,\nage, sample ID" { class: fe }
chain.collect_measurements -> chain.capture_obcc_results: "[FE] OBCC results in\nmodeled order + status/age" { class: fe }
chain.emit_current_measurement_record -> chain.capture_obcc_results: "[FE] VV measurement\nrecord" { class: fe }
chain.capture_obcc_results -> chain.parse_result_order_units: "[FE] Raw OBCC log" { class: fe }
chain.parse_result_order_units -> chain.check_current_not_stale: "[FE] Parsed values,\nstatus, age, sample ID" { class: fe }
chain.check_current_not_stale -> chain.pair_samples_with_references: "[FE] Current sample\nonly" { class: fe }
chain.record_reference_conditions -> chain.pair_samples_with_references: "[FE] Reference\nconditions" { class: fe }
chain.pair_samples_with_references -> chain.compare_pressure_to_reference: "[FE] Pressure pairs" { class: fe }
chain.pair_samples_with_references -> chain.compare_temperature_to_reference: "[FE] Temperature pairs" { class: fe }
chain.compare_pressure_to_reference -> chain.compute_bias_u95: "[FE] Pressure bias" { class: fe }
chain.compare_temperature_to_reference -> chain.compute_bias_u95: "[FE] Temperature bias" { class: fe }
chain.compute_bias_u95 -> chain.archive_evidence: "[FE] Accuracy\npass/fail" { class: fe }
chain.check_current_not_stale -> chain.archive_evidence: "[FE] Staleness / order\npass/fail" { class: fe }
chain.record_voltage_current -> chain.archive_evidence: "[FE] Power context" { class: fe }

chain.note_n30 -> chain.start_sample_batch { class: cstr }
chain.note_n30 -> chain.compute_bias_u95 { class: cstr }
chain.note_pressure -> chain.compare_pressure_to_reference { class: cstr }
chain.note_pressure -> chain.compute_bias_u95 { class: cstr }
chain.note_temperature -> chain.compare_temperature_to_reference { class: cstr }
chain.note_temperature -> chain.compute_bias_u95 { class: cstr }
chain.note_obcc_current -> chain.collect_measurements { class: cstr }
chain.note_obcc_current -> chain.check_current_not_stale { class: cstr }
chain.note_altitude -> chain.calculate_altitude { class: cstr }
chain.note_altitude -> chain.collect_measurements { class: cstr }
chain.note_i2c_dependency -> chain.read_pressure { class: cstr }
chain.note_i2c_dependency -> chain.read_temperature { class: cstr }
chain.note_evidence -> chain.emit_current_measurement_record { class: cstr }
chain.note_evidence -> chain.capture_obcc_results { class: cstr }
chain.note_response_phase2 -> chain.set_stable_thermal_point { class: cstr }
chain.note_response_phase2 -> chain.archive_evidence { class: cstr }
chain.note_environment -> chain.read_ambient_temperature { class: cstr }
chain.note_environment -> chain.record_reference_conditions { class: cstr }
chain.note_environment -> chain.record_voltage_current { class: cstr }
chain.note_fault -> chain.check_current_not_stale { class: cstr }
chain.note_fault -> chain.archive_evidence { class: cstr }

# Layout-only edges to keep setup, UUT flow, and evidence/constraint flow readable.
chain.read_temperature -> chain.calculate_altitude { style: { opacity: 0 } }
chain.process_temperature -> chain.emit_current_measurement_record { style: { opacity: 0 } }
chain.archive_evidence -> chain.note_n30 { style: { opacity: 0 } }
chain.note_n30 -> chain.note_pressure { style: { opacity: 0 } }
chain.note_pressure -> chain.note_temperature { style: { opacity: 0 } }
chain.note_temperature -> chain.note_obcc_current { style: { opacity: 0 } }
chain.note_obcc_current -> chain.note_altitude { style: { opacity: 0 } }
chain.note_altitude -> chain.note_i2c_dependency { style: { opacity: 0 } }
chain.note_i2c_dependency -> chain.note_evidence { style: { opacity: 0 } }
chain.note_evidence -> chain.note_response_phase2 { style: { opacity: 0 } }
chain.note_response_phase2 -> chain.note_environment { style: { opacity: 0 } }
chain.note_environment -> chain.note_fault { style: { opacity: 0 } }
