vars: {
  d2-config: {
    layout-engine: elk
  }
}

# DPS-V10-T-002 logical test context.
# Verification additions: Test Operator, Command RF Monitor, UI Automation Driver, and verification-only evidence collector LC.
# The unmodified full DPS v1.0 PV2 is retained in ./baseline/.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 20 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

test_operator: "[EA] Test Operator" { class: ea }
ui_automation_driver: "[EA] UI Automation Driver" { class: ea }
command_rf_monitor: "[EA] Command RF Monitor\nRFM95W/SX1276" { class: ea }

system: "[System] DPS v1.0\nDPS-V10-T-002 PV2 logical test context\nIADT: Testing; Refs: P0,R1-R5,R8-R13; Trace: FC02,C07" {
  class: sys
  direction: down
  grid-columns: 1

  ground_station_pcb: "[PC] Ground Station PCB" {
    class: pc
    direction: right

    ground_xiao: "[PC] XIAO ESP32" {
      class: pc
      direction: down
      ground_forwarder: "[LC] LoRa Forwarder" { class: lc }
    }

    ground_rfm: "[PC] RFM95W LoRa" {
      class: pc
      direction: down
      ground_lora: "[LC] LoRa Transceiver" { class: lc }
    }
  }

  pc: "[PC] PC" {
    class: pc
    direction: right
    grid-columns: 4
    grid-gap: 80

    dashboard: "[LC] Dashboard" { class: lc }
    decoder: "[LC] Decoder" { class: lc }
    evidence_collector: "[LC] Command Test Evidence Collector\n(verification-only)" { class: lc }
  }

  note_scope: "[C] Focused test context: FC02 dashboard command/uplink and C07 cooldown.\nFull v1.0 baseline architecture remains copied in ./baseline/." {
    class: note
    shape: page
  }

  note_valid_pass: "[C] Valid-command pass: at least 60 accepted toggles outside cooldown;\neach produces exactly one RF command frame with the expected state, no wrong state,\nno duplicate command and no missing RF capture in the observation window." {
    class: note
    shape: page
  }

  note_cooldown_pass: "[C] Cooldown pass: for at least 30 rapid-toggle bursts, only the first\ntoggle enqueues/transmits; suppressed toggles during cooldown produce zero extra\nCommand CEs/RF frames; UI re-enables at 5.0 s ±0.5 s." {
    class: note
    shape: page
  }

  note_statistics_fault: "[C] Statistics/fault viewpoint: 60/60 valid commands is exact-binomial\nscreening for command success; burst trials screen duplicate/stale command hardening,\nqueue bypass, UI disable failure and UART/SPI/radio not-ready logging." {
    class: note
    shape: page
  }

  note_uart_direction: "[C] Model discrepancy watch: source PV2 models CE-03 as\nForwarder→Decoder UART, while FC02 uses command bytes from Decoder back to\nForwarder over the same serial/USB path. This test records the reverse-use\nevidence and requires disposition in the report." {
    class: note
    shape: page
  }
}

ui_automation_driver -> system.pc.dashboard: "[CE] Browser UI\ntoggle actions" { class: ce }
test_operator -> system.pc.evidence_collector: "[CE] Test control\nand verdict" { class: ce }
system.pc.dashboard -> system.pc.decoder: "[CE-06] Command" { class: ce }
system.pc.decoder -> system.ground_station_pcb.ground_xiao.ground_forwarder: "[CE-03] UART command\n(FC02 reverse use)" { class: ce }
system.ground_station_pcb.ground_xiao.ground_forwarder -> system.ground_station_pcb.ground_rfm.ground_lora: "[CE-02] SPI" { class: ce }
system.ground_station_pcb.ground_rfm.ground_lora -> command_rf_monitor: "[CE] LoRa RF\ncommand frames" { class: ce }

ui_automation_driver -> system.pc.evidence_collector: "[CE] UI event log" { class: ce }
system.pc.dashboard -> system.pc.evidence_collector: "[CE] Dashboard log" { class: ce }
system.pc.decoder -> system.pc.evidence_collector: "[CE] Command queue log" { class: ce }
system.ground_station_pcb.ground_xiao.ground_forwarder -> system.pc.evidence_collector: "[CE] Forwarder log" { class: ce }
command_rf_monitor -> system.pc.evidence_collector: "[CE] RF capture log" { class: ce }

system.note_scope -> system.pc.evidence_collector { class: cstr }
system.note_valid_pass -> system.pc.evidence_collector { class: cstr }
system.note_valid_pass -> system.ground_station_pcb.ground_rfm.ground_lora { class: cstr }
system.note_cooldown_pass -> system.pc.dashboard { class: cstr }
system.note_cooldown_pass -> system.pc.evidence_collector { class: cstr }
system.note_statistics_fault -> system.pc.evidence_collector { class: cstr }
system.note_uart_direction -> system.pc.evidence_collector { class: cstr }
system.note_uart_direction -> system.ground_station_pcb.ground_xiao.ground_forwarder { class: cstr }
system.note_uart_direction -> system.pc.decoder { class: cstr }

# Layout-only edges to keep external test means left of the UUT and preserve ground-to-PC reading order.
test_operator -> ui_automation_driver { style: { opacity: 0 } }
ui_automation_driver -> command_rf_monitor { style: { opacity: 0 } }
command_rf_monitor -> system { style: { opacity: 0 } }
system.pc.dashboard -> system.pc.decoder { style: { opacity: 0 } }
system.ground_station_pcb -> system.pc { style: { opacity: 0 } }
