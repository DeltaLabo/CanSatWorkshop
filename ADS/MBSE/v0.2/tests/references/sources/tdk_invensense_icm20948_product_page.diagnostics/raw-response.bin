hnologies for industrial automation\",\"field_app_section_paragraphs\":[{\"id\":\"47\",\"label\":\"Industrial \u003e Applications section paragraphs\"},{\"id\":\"423\",\"label\":\"Industrial \u003e Applications section paragraphs\"},{\"id\":\"1221\",\"label\":\"Industrial \u003e Applications section paragraphs\"},{\"id\":\"1223\",\"label\":\"Industrial \u003e Applications section paragraphs\"}],\"field_app_section_sub_title\":\"Explore our precision sensing solutions enabling automation, robotics, heavy equipment, and connected industrial platforms\",\"field_apps_related_to_category\":[],\"field_category_header_image\":{\"id\":\"346\",\"label\":\"industrial-hero.jpg\"},\"field_category_image\":{\"id\":\"469\",\"label\":\"bento-industrial.jpg\"},\"field_category_short_description\":null,\"field_category_thumbnail_image\":{\"id\":\"213\",\"label\":\"aboutUs.png\"},\"field_category_title\":\"Industrial applications \",\"field_dedicated_bundled_software\":null,\"field_dedicated_softwares\":[],\"field_dedicate_software_subtitle\":null,\"field_description\":\"\u003cp\u003eTDK’s MEMS motion sensors deliver industrial-grade precision, robustness, and long-term stability, enabling smarter automation, safer equipment, and more efficient operations.\u0026nbsp;\u003c/p\u003e\u003cp\u003eFrom factory floors to mobile industrial equipment, our solutions are built to withstand vibration, shock, temperature extremes, and continuous operation.\u0026nbsp;\u003c/p\u003e\",\"field_development_hardware_title\":null,\"field_development_products\":[],\"field_dev_hardware_subtitle\":null,\"field_explore_more_apps\":{\"title\":\"Explore more applications\",\"url\":\"#Applications\"},\"field_external_url\":null,\"field_featured_news_section\":[],\"field_featured_products\":[],\"field_featured_section_sub_title\":null,\"field_featured_section_title\":null,\"field_featured_video_section\":null,\"field_features_and_benefits_grid\":[],\"field_features_and_benefit_subti\":null,\"field_features_an