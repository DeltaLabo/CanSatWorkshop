vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PV1 — PDS-VV-FC-001 physical power/protection final-acceptance testbench.
# Capella PA PV1 only: System, PCs, non-human EAs with PLs, Physical Links, constraints.
# References: IVV, PDS-R2, PDS-R4, PDS-R5, PDS-R6, PDS-R7, PDS-R8.
# Traceability: PDS-UC-ChargeESS; PDS-UC-ProvideRegulatedPower;
# PDS-FE-OvercurrentOvervoltage; PDS-FE-RailBrownout; PDS-FE-LiIonUnsafeCondition.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

charger_emulator: "[EA] Certified current-limited\ncharger / charger emulator" { class: ea }
battery_emulator: "[EA] Battery emulator /\ncurrent-limited source" { class: ea }
load_bank: "[EA] 5 V / 3V3 programmable\nloads or representative flight loads" { class: ea }
overcurrent_harness: "[EA] Overcurrent demand harness /\ncurrent-limited electronic load" { class: ea }
overvoltage_source: "[EA] Current-limited\novervoltage demand source" { class: ea }
dmm_daq: "[EA] Calibrated DMM / DAQ" { class: ea }
scope_logger: "[EA] Oscilloscope /\nlogger" { class: ea }
thermal_instr: "[EA] Thermal camera /\nthermocouples" { class: ea }
ambient_meter: "[EA] Ambient thermometer /\nhygrometer" { class: ea }
fire_safety: "[EA] Fire-safe Li-ion container /\nE-stop safety equipment" { class: ea }
evidence_repo: "[EA] Evidence repository /\nhost PC" { class: ea }

system: "[System] PDS-VV-FC-001 full power/protection physical testbench\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R2; PDS-R4; PDS-R5; PDS-R6; PDS-R7; PDS-R8" {
  class: sys
  direction: down
  grid-columns: 2

  uut: "[PC] Integrated PDS & ESS\nv1.0 flight-acceptance article" {
    class: pc
    direction: down

    ess_module: "[PC] ESS Module" {
      class: pc
      direction: down
      battery_pack: "[PC] 1S1P Li-Ion\nflight pack\n(normal non-abuse only)" { class: pc }
    }

    pds_module: "[PC] PDS Module" {
      class: pc
      direction: down

      pds_pcb: "[PC] PDS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        battery_connector: "[PC] Battery Connector" { class: pc }
        protection: "[PC] Protection Circuit" { class: pc }
        ina219: "[PC] INA219" { class: pc }
        regulator: "[PC] Regulator" { class: pc }
        pds_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module\nreset/uncontrolled-restart witness" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        xiao: "[PC] XIAO ESP32-S3" { class: pc }
        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      pds_headers: "[PC] 2mm 2x6 PDS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }
  }

  test_harness: "[PC] PDS-VV-FC-001\nflight-acceptance test harness" {
    class: pc
    direction: down
    charger_breakout: "[PC] Current-limited\ncharger breakout" { class: pc }
    battery_fixture: "[PC] Battery-emulator /\nLi-ion-safe fixture" { class: pc }
    rail_load_adapter: "[PC] 5 V / 3V3\nload adapter" { class: pc }
    overcurrent_adapter: "[PC] Overcurrent /\nshort-equivalent adapter" { class: pc }
    overvoltage_adapter: "[PC] Overvoltage\ninjection adapter" { class: pc }
    measurement_breakout: "[PC] Rail, current, and\nprotection measurement breakout" { class: pc }
    thermal_fixture: "[PC] Thermal sensor\nmounts / sight lines" { class: pc }
    environment_station: "[PC] Ambient record\nstation" { class: pc }
    log_export: "[PC] Log export /\ncontrolled media" { class: pc }
  }

  note_scope: "[C] PDS-VV-FC-001 scope\nFinal flight acceptance functional-chain test for charge,\nnominal power, overcurrent cut-off/restore, overvoltage\ncut-off/restore, and commanded power-off safe state.\nEarlier versions are protoflight/out of scope." {
    class: note
    shape: page
  }

  note_safety: "[C] Environmental and safety constraints\nRead ambient before repetitions; use calibrated/status-checked instruments;\nset current limits before energizing; use ESD/fire-safe Li-ion handling.\nBattery emulator is preferred for fault injection; destructive Li-ion abuse\nshall come only from certified documentation or accredited lab evidence." {
    class: note
    shape: page
  }

  note_pass: "[C] Pass/fail constraints\nNominal chain completes; charge path respects 4.2 V / 0.5 A when exercised;\n5 V and 3V3 rails meet model or reference PDS-VV-CON-004;\nno brownout/reset/uncontrolled restart; every demanded protection event\ncuts off safely and restores only after cleared." {
    class: note
    shape: page
  }

  note_stats_fault: "[C] Statistical / fault-hardening viewpoint\nContinuous rail/thermal data: ≥30 samples per condition or PDS-VV-CON-004.\nBinary protection trials: exact one-sided binomial; 299 zero-missed demands\nneeded for <1% failure probability at 95% confidence.\nCover overcurrent, short-equivalent, overvoltage, wrong/reverse charger hold,\nunsafe restore, loose/high-resistance path, brownout, overheating, Li-ion unsafe condition." {
    class: note
    shape: page
  }
}

# Baseline physical power/protection path.
charger_emulator -- system.test_harness.charger_breakout: "[PL] Certified charger\nUSB-C / power cable" { class: pl }
system.test_harness.charger_breakout -- system.uut.pds_module.pds_pcb.protection: "[PL] Current-limited\ncharge input leads" { class: pl }
system.uut.ess_module.battery_pack -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] Battery cable" { class: pl }
system.uut.pds_module.pds_pcb.battery_connector -- system.uut.pds_module.pds_pcb.protection: "[PL] Battery ± traces" { class: pl }
system.uut.pds_module.pds_pcb.protection -- system.uut.pds_module.pds_pcb.ina219: "[PL] Protection output trace" { class: pl }
system.uut.pds_module.pds_pcb.ina219 -- system.uut.pds_module.pds_pcb.regulator: "[PL] INA output trace" { class: pl }
system.uut.pds_module.pds_pcb.regulator -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] 5 V / 3V3 regulator\nbackplane traces" { class: pl }
system.uut.pds_module.pds_pcb.pds_backplane_connector -- system.uut.backplane_pcb.pds_headers: "[PL] PDS parallel cable" { class: pl }
system.uut.backplane_pcb.pds_headers -- system.uut.backplane_pcb.spine: "[PL] backplane copper" { class: pl }
system.uut.backplane_pcb.spine -- system.uut.backplane_pcb.obcc_headers: "[PL] backplane copper" { class: pl }
system.uut.backplane_pcb.obcc_headers -- system.uut.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] OBCC parallel cable" { class: pl }
system.uut.obcc_module.obcc_pcb.obcc_backplane_connector -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] 3V3 / reset witness traces" { class: pl }

# Verification-only physical links.
battery_emulator -- system.test_harness.battery_fixture: "[PL] Current-limited\nemulated battery leads" { class: pl }
system.test_harness.battery_fixture -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] Fault-safe battery\ninput leads" { class: pl }
load_bank -- system.test_harness.rail_load_adapter: "[PL] Load bank cables" { class: pl }
system.test_harness.rail_load_adapter -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] 5 V / 3V3\nload leads" { class: pl }
overcurrent_harness -- system.test_harness.overcurrent_adapter: "[PL] Current-limited\noverload / short cable" { class: pl }
system.test_harness.overcurrent_adapter -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] Demand injection\nat protected output" { class: pl }
overvoltage_source -- system.test_harness.overvoltage_adapter: "[PL] Current-limited\novervoltage source leads" { class: pl }
system.test_harness.overvoltage_adapter -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] Overvoltage\ndemand injection leads" { class: pl }
dmm_daq -- system.test_harness.measurement_breakout: "[PL] Kelvin / shunt\nmeasurement leads" { class: pl }
scope_logger -- system.test_harness.measurement_breakout: "[PL] High-impedance\nrail/protection probes" { class: pl }
system.test_harness.measurement_breakout -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] Rail probe breakout" { class: pl }
system.test_harness.measurement_breakout -- system.uut.pds_module.pds_pcb.protection: "[PL] Protection-state\nprobe breakout" { class: pl }
thermal_instr -- system.test_harness.thermal_fixture: "[PL] Thermocouple /\nIR sight line" { class: pl }
system.test_harness.thermal_fixture -- system.uut.pds_module.pds_pcb.regulator: "[PL] Regulator thermal\ncontact / sight line" { class: pl }
system.test_harness.thermal_fixture -- system.uut.pds_module.pds_pcb.protection: "[PL] Protection thermal\ncontact / sight line" { class: pl }
system.test_harness.thermal_fixture -- system.uut.ess_module.battery_pack: "[PL] Battery surface\ntemperature contact" { class: pl }
ambient_meter -- system.test_harness.environment_station: "[PL] Ambient meter\nbench placement" { class: pl }
system.test_harness.environment_station -- system.uut: "[PL] Test-cell proximity" { class: pl }
fire_safety -- system.uut.ess_module.battery_pack: "[PL] Fire-safe enclosure /\nE-stop access" { class: pl }
evidence_repo -- system.test_harness.log_export: "[PL] Network / removable\nevidence transfer" { class: pl }
system.test_harness.log_export -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] Reset/status log\nexport cable if used" { class: pl }

system.note_scope -> system.uut { class: cstr }
system.note_safety -> system.test_harness.battery_fixture { class: cstr }
system.note_safety -> fire_safety { class: cstr }
system.note_safety -> ambient_meter { class: cstr }
system.note_pass -> system.uut.pds_module.pds_pcb.protection { class: cstr }
system.note_pass -> system.uut.pds_module.pds_pcb.regulator { class: cstr }
system.note_pass -> system.uut.backplane_pcb { class: cstr }
system.note_stats_fault -> system.test_harness.overcurrent_adapter { class: cstr }
system.note_stats_fault -> system.test_harness.overvoltage_adapter { class: cstr }
system.note_stats_fault -> system.test_harness.measurement_breakout { class: cstr }

# Layout-only rank hints for equipment, UUT, and constraint bands.
charger_emulator -> battery_emulator { style: { opacity: 0 } }
battery_emulator -> load_bank { style: { opacity: 0 } }
load_bank -> overcurrent_harness { style: { opacity: 0 } }
overcurrent_harness -> overvoltage_source { style: { opacity: 0 } }
overvoltage_source -> dmm_daq { style: { opacity: 0 } }
dmm_daq -> scope_logger { style: { opacity: 0 } }
scope_logger -> thermal_instr { style: { opacity: 0 } }
thermal_instr -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> fire_safety { style: { opacity: 0 } }
fire_safety -> evidence_repo { style: { opacity: 0 } }
evidence_repo -> system { style: { opacity: 0 } }
system.uut -> system.test_harness { style: { opacity: 0 } }
system.test_harness -> system.note_scope { style: { opacity: 0 } }
system.note_scope -> system.note_safety { style: { opacity: 0 } }
system.note_safety -> system.note_pass { style: { opacity: 0 } }
system.note_pass -> system.note_stats_fault { style: { opacity: 0 } }
