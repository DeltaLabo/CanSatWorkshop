vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Logical view — AMS-VV-FC-001 atmospheric measurement chain acceptance testbench
# Verification references: IVV, AMS-R1 (BME280), AMS-R3/R4 (environment/standard atmosphere), AMS-R5 (statistics), AMS-R7 (low-cost altitude context).
# IADT: Testing / Demonstration. SSIV: AMS v1.0 final acceptance / flight readiness.
# Traceability: AMS-UC-MeasureAtmosphere; AMS-FE-BadExposure; AMS-FE-StaleMeasurement; pressure/temperature/altitude constraints.
# Logical view contains physical containment, logical components, component exchanges, EAs, and constraints.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-FC-001 atmospheric chain acceptance\nAMS v1.0 final; Refs: IVV, AMS-R1, AMS-R3/R4/R5/R7" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: down
    grid-columns: 1

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        bme280: "[PC] BME280" {
          class: pc
          direction: down

          ams_sensing: "[LC] AMS Sensing" { class: lc }
        }

        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        grid-columns: 2

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down

          ams_processing: "[LC] AMS Processing" { class: lc }
          obcc: "[LC] OBCC" { class: lc }
          fc_acceptance_instrumentation: "[LC] Atmospheric Chain\nAcceptance Instrumentation\n(VV-only)" { class: lc }
        }

        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
        vv_usb_log_port: "[PC] VV USB / Logger\nAccess Port (VV-only)" {
          class: pc
          direction: down

          vv_log_interface: "[LC] Measurement Evidence\nInterface (VV-only)" { class: lc }
        }

        note_variable_getter: "[C] Implement each\n(Read X, Process X) or\n(Read X, Calculate Y)\npair as a Variable\nGetter template" {
          class: note
          shape: page
        }
        note_i2c_timeout: "[C] All I2C read\nfunctions must have\na timeout ≤ 5 ms" {
          class: note
          shape: page
        }
        note_process_time: "[C] All Process or\nCalculate functions\nmust take < 5 ms" {
          class: note
          shape: page
        }
        note_no_blocking: "[C] No blocking\noperations besides\nI2C or UART comms" {
          class: note
          shape: page
        }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" { class: pc }
  }
}

test_operator: "[EA] Test Operator" { class: ea }
host_pc_logger: "[EA] Host PC /\nData Logger" { class: ea }
pressure_reference: "[EA] Reference Barometer /\nPressure Calibrator" { class: ea }
thermal_reference: "[EA] Reference Thermometer /\nStable Thermal Source" { class: ea }
ambient_thermometer: "[EA] Ambient Thermometer\nTraceable Logger" { class: ea }
bench_supply: "[EA] Bench Power\nSupply" { class: ea }
evidence_repo: "[EA] Evidence Repository /\nReport Workspace" { class: ea }

note_scope: "[C] Scope: v1.0 atmospheric measurement chain\nfinal acceptance, covering pressure, temperature,\naltitude calculation, processing, and OBCC collection" {
  class: note
  shape: page
}
note_stat: "[C] Statistical viewpoint: n ≥ 30 paired\npressure and temperature samples per operating point;\nreport bias and expanded uncertainty U95" {
  class: note
  shape: page
}
note_fault: "[C] Fault-hardening viewpoint: BadExposure and\nStaleMeasurement are explicit trace targets; swapped\nbranches, stale/currentness errors, and outlier handling\nare pass/fail concerns" {
  class: note
  shape: page
}
note_dependency: "[C] Detailed I2C ≤5 ms timeout proof is not\nduplicated here; acceptance credits AMS-VV-CON-003\nfor bounded environmental I2C read timing" {
  class: note
  shape: page
}
note_report: "[C] Report by reference: AMS/MBSE/tests/results/\nAMS-VV-FC-001/report.md records as-run article,\ninstruments, raw data, deviations, and anomalies" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb.bme280.ams_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] I2C" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Pointers" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Returns" { class: ce }

test_operator -> system.cansat.obcc_module.obcc_pcb.xiao.fc_acceptance_instrumentation: "[CE] procedure,\noperating points, anomalies" { class: ce }
host_pc_logger -> system.cansat.obcc_module.obcc_pcb.vv_usb_log_port.vv_log_interface: "[CE] command /\nresult capture" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.fc_acceptance_instrumentation -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] sample IDs /\nVV timestamps" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.obcc -> system.cansat.obcc_module.obcc_pcb.vv_usb_log_port.vv_log_interface: "[CE] current OBCC\nmeasurement records" { class: ce }
system.cansat.obcc_module.obcc_pcb.vv_usb_log_port.vv_log_interface -> evidence_repo: "[CE] AMS result logs /\nmetadata archive" { class: ce }
pressure_reference -> evidence_repo: "[CE] reference pressure /\npressure-step records" { class: ce }
thermal_reference -> evidence_repo: "[CE] reference temperature\nrecords" { class: ce }
ambient_thermometer -> evidence_repo: "[CE] ambient records" { class: ce }
bench_supply -> evidence_repo: "[CE] voltage/current\nrecords" { class: ce }
host_pc_logger -> evidence_repo: "[CE] computed statistics /\nreport inputs" { class: ce }

system.cansat.obcc_module.obcc_pcb.note_variable_getter -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_i2c_timeout -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_process_time -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_no_blocking -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }

note_scope -> system.cansat.obcc_module.obcc_pcb.xiao.fc_acceptance_instrumentation { class: cstr }
note_scope -> system.cansat.obcc_module.obcc_pcb.xiao.obcc { class: cstr }
note_stat -> host_pc_logger { class: cstr }
note_stat -> evidence_repo { class: cstr }
note_fault -> system.cansat.obcc_module.obcc_pcb.xiao.obcc { class: cstr }
note_fault -> system.cansat.ams_module.ams_pcb.bme280.ams_sensing { class: cstr }
note_dependency -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
note_dependency -> system.cansat.obcc_module.obcc_pcb.xiao.fc_acceptance_instrumentation { class: cstr }
note_report -> evidence_repo { class: cstr }

# Layout-only edges to keep EAs and constraint notes in readable bands.
system -> test_operator { style: { opacity: 0 } }
test_operator -> host_pc_logger { style: { opacity: 0 } }
host_pc_logger -> pressure_reference { style: { opacity: 0 } }
pressure_reference -> thermal_reference { style: { opacity: 0 } }
thermal_reference -> ambient_thermometer { style: { opacity: 0 } }
ambient_thermometer -> bench_supply { style: { opacity: 0 } }
bench_supply -> evidence_repo { style: { opacity: 0 } }
evidence_repo -> note_scope { style: { opacity: 0 } }
note_scope -> note_stat { style: { opacity: 0 } }
note_stat -> note_fault { style: { opacity: 0 } }
note_fault -> note_dependency { style: { opacity: 0 } }
note_dependency -> note_report { style: { opacity: 0 } }
