vars: {
  d2-config: {
    layout-engine: elk
  }
}

# DPS-V10-T-002B functional chain: cooldown and duplicate/stale command hardening test sequence.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 32 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 28 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 34
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 26 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 24 } }
}

chain: "DPS-V10-T-002B — Cooldown/duplicate command hardening test\nIADT: Testing; Refs: P0,R1-R5,R8-R13; Trace: FC02,C07, feared command spam; Report: tests/results/DPS-V10-T-002/" {
  class: chain
  direction: down

  op_confirm_baseline: "[F] Operator confirms\nDPS v1.0 baseline" { class: func }
  open_dashboard: "[F] Open dashboard\nin browser" { class: func }
  configure_clock_and_rf: "[F] Configure monotonic\nclock and RF monitor" { class: func }
  start_cooldown_logging: "[F] Start UI, queue,\nforwarder and RF logs" { class: func }
  issue_rapid_bursts: "[F] Issue 30 rapid-toggle\nbursts" { class: func }
  timestamp_burst_events: "[F] Timestamp burst\nUI events" { class: func }

  catch_first_toggle: "[F] Catch first State\ntoggle in burst" { class: func }
  push_first_command: "[F] Push first command\nto command queue" { class: func }
  disable_toggle: "[F] Disable\ntoggle" { class: func }
  cooldown: "[F] Cooldown" { class: func }
  suppress_extra_toggles: "[F] Suppress toggles\nduring cooldown" { class: func }
  enable_toggle: "[F] Enable\ntoggle" { class: func }

  consume_first_command: "[F] Consume first\ncommand queue entry" { class: func }
  forward_first_command: "[F] Forward first command\nto transceiver" { class: func }
  store_incoming_uart_data: "[F] Store incoming\nUART data" { class: func }
  read_command: "[F] Read command" { class: func }
  generate_frame: "[F] Generate frame" { class: func }
  write_to_lora_radio: "[F] Write to\nLoRa Radio" { class: func }
  transmit_outgoing_data: "[F] Transmit\noutgoing data" { class: func }
  capture_single_rf_frame: "[F] Capture single RF\ncommand frame" { class: func }

  issue_followup_after_cooldown: "[F] Issue post-cooldown\nvalid toggle" { class: func }
  capture_followup_rf_frame: "[F] Capture follow-up\nRF command frame" { class: func }

  capture_ui_log: "[F] Capture UI disable/\nenable timing log" { class: func }
  capture_decoder_log: "[F] Capture command queue\nand decoder log" { class: func }
  capture_forwarder_log: "[F] Capture forwarder\nand serial log" { class: func }
  compare_burst_evidence: "[F] Compare burst events\nto queue/RF evidence" { class: func }
  compute_cooldown_verdict: "[F] Compute cooldown\nand duplicate verdict" { class: func }
  archive_evidence: "[F] Archive evidence\nin results folder" { class: func }

  note_trace: "[C] Traceability target: C07 5 s toggle cooldown and feared event\n'command spam, duplicate or stale command is transmitted'. Source model is\nFC02 dashboard command/uplink debounce branch." {
    class: note
    shape: page
  }

  note_environment: "[C] Environment/setup constraint: same dashboard, serial, radio and RF monitor\nconfiguration as the valid-command sequence; monotonic timebase resolution and\nclock source are recorded before burst trials." {
    class: note
    shape: page
  }

  note_stimulus: "[C] Fault stimulus constraint: at least 30 bursts. Each burst starts with one\nvalid toggle followed by at least three rapid repeated/stale toggle attempts during\nthe cooldown interval, then one post-cooldown valid toggle for recovery." {
    class: note
    shape: page
  }

  note_pass: "[C] Pass constraints: exactly one command queue entry and one RF command frame\nare produced by the first toggle in each burst; rapid toggles during cooldown\nproduce zero additional queue entries or RF frames; post-cooldown toggle is accepted once." {
    class: note
    shape: page
  }

  note_timing_pass: "[C] C07 timing pass: UI disabled state persists during cooldown and\nre-enables at 5.0 s ±0.5 s using the monotonic test timebase; any early enable,\nlate enable or missing enable is a failure or limitation." {
    class: note
    shape: page
  }

  note_statistics: "[C] Statistical viewpoint: burst trials are binary duplicate-suppression\nscreening evidence. Report k/n for clean bursts, timing distribution min/median/max,\nand any anomaly or waiver by burst ID." {
    class: note
    shape: page
  }
}

chain.op_confirm_baseline -> chain.open_dashboard: "[FE] Baseline OK\n[Test condition]" { class: fe }
chain.open_dashboard -> chain.configure_clock_and_rf: "[FE] UI reachable\n[Test condition]" { class: fe }
chain.configure_clock_and_rf -> chain.start_cooldown_logging: "[FE] Time/RF ready\n[Test condition]" { class: fe }
chain.start_cooldown_logging -> chain.issue_rapid_bursts: "[FE] Start trigger\n[Test control]" { class: fe }
chain.issue_rapid_bursts -> chain.timestamp_burst_events: "[FE] Burst event times\n[Evidence]" { class: fe }
chain.issue_rapid_bursts -> chain.catch_first_toggle: "[FE] First toggle\n[State]" { class: fe }

chain.catch_first_toggle -> chain.push_first_command: "[FE] New State\n[State]" { class: fe }
chain.catch_first_toggle -> chain.disable_toggle: "[FE] Toggled []" { class: fe }
chain.disable_toggle -> chain.cooldown: "[FE] Toggle disabled []" { class: fe }
chain.cooldown -> chain.suppress_extra_toggles: "[FE] Cooldown active\n[Disabled UI]" { class: fe }
chain.suppress_extra_toggles -> chain.capture_ui_log: "[FE] Suppressed attempts\n[UI log]" { class: fe }
chain.cooldown -> chain.enable_toggle: "[FE] Cooldown finished []" { class: fe }
chain.enable_toggle -> chain.issue_followup_after_cooldown: "[FE] Re-enabled UI\n[Test control]" { class: fe }

chain.push_first_command -> chain.consume_first_command: "[FE] Command\n[State]" { class: fe }
chain.consume_first_command -> chain.forward_first_command: "[FE] Command\n[State]" { class: fe }
chain.forward_first_command -> chain.store_incoming_uart_data: "[FE] Command\n[State]" { class: fe }
chain.store_incoming_uart_data -> chain.read_command: "[FE] UART Data []" { class: fe }
chain.read_command -> chain.generate_frame: "[FE] Command\n[State]" { class: fe }
chain.generate_frame -> chain.write_to_lora_radio: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.write_to_lora_radio -> chain.transmit_outgoing_data: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.transmit_outgoing_data -> chain.capture_single_rf_frame: "[FE] RF command frame\n[LoRa Frame]" { class: fe }

chain.issue_followup_after_cooldown -> chain.capture_followup_rf_frame: "[FE] Follow-up command\n[Recovery evidence]" { class: fe }

chain.timestamp_burst_events -> chain.capture_ui_log: "[FE] Burst event times\n[Evidence]" { class: fe }
chain.push_first_command -> chain.capture_decoder_log: "[FE] First queue entry\n[Evidence]" { class: fe }
chain.forward_first_command -> chain.capture_decoder_log: "[FE] Forwarded command\n[Evidence]" { class: fe }
chain.generate_frame -> chain.capture_forwarder_log: "[FE] Generated frame\n[Evidence]" { class: fe }
chain.capture_single_rf_frame -> chain.compare_burst_evidence: "[FE] First RF frame\n[Evidence]" { class: fe }
chain.capture_followup_rf_frame -> chain.compare_burst_evidence: "[FE] Follow-up RF frame\n[Evidence]" { class: fe }
chain.capture_ui_log -> chain.compare_burst_evidence: "[FE] UI events and timing\n[Evidence]" { class: fe }
chain.capture_decoder_log -> chain.compare_burst_evidence: "[FE] Queue counts\n[Evidence]" { class: fe }
chain.capture_forwarder_log -> chain.compute_cooldown_verdict: "[FE] Forwarder counts\n[Evidence]" { class: fe }
chain.compare_burst_evidence -> chain.compute_cooldown_verdict: "[FE] Clean burst count\n[k/N]" { class: fe }
chain.compute_cooldown_verdict -> chain.archive_evidence: "[FE] Verdict and evidence\n[Test report input]" { class: fe }

chain.note_environment -> chain.configure_clock_and_rf { class: cstr }
chain.note_stimulus -> chain.issue_rapid_bursts { class: cstr }
chain.note_pass -> chain.compare_burst_evidence { class: cstr }
chain.note_timing_pass -> chain.capture_ui_log { class: cstr }
chain.note_timing_pass -> chain.compute_cooldown_verdict { class: cstr }
chain.note_statistics -> chain.compute_cooldown_verdict { class: cstr }

# Layout-only edge: keep traceability near pass constraints without adding verification semantics.
chain.note_trace -> chain.note_pass { style: { opacity: 0 } }
