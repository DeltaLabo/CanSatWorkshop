",\"label\":\"DS-000383 – T5838 Datasheet\"},{\"id\":\"281\",\"label\":\"AN-100 – MEMS Microphone Handling and Assembly Guide\"},{\"id\":\"285\",\"label\":\"AN-1003 – Recommendations for Mounting and Connecting InvenSense MEMS Microphones\"},{\"id\":\"292\",\"label\":\"AN-1112 – Microphone Specifications Explained\"},{\"id\":\"283\",\"label\":\"AN-1124 – Recommendations for Sealing InvenSense Bottom-Port MEMS Microphones from Dust and Liquid Ingress\"},{\"id\":\"284\",\"label\":\"AN-1140 – Microphone Array Beamforming\"},{\"id\":\"251\",\"label\":\"AN-0078 – High-Performance Digital MEMS Microphone Simple Interface to SigmaDSP Audio Codec\"},{\"id\":\"252\",\"label\":\"AN-000048 – PDM Digital Output MEMS Microphone Flex Evaluation Board User Guide\"},{\"id\":\"254\",\"label\":\"AN-000278 – T5838 Flex EVB User Guide\"},{\"id\":\"8655\",\"label\":\"AN-000298 – TDK T58xx Series MEMS Microphone Acoustic Activity Detect User Guide\"},{\"id\":\"288\",\"label\":\"Understanding Microphone Sensitivity\"}],\"field_embedded_processor_s\":null,\"field_features\":\"\u003cul\u003e\u003cli data-list-item-id=\\\"ecafa01c4f0efa92f62f0533e5b57717b\\\"\u003eIndustry standard High Quality Mode sensitivity of -37 dBFS and Low-Power Mode sensitivity of -21 dBFS\u003c/li\u003e\u003cli data-list-item-id=\\\"e4043f5de84eb7a8261410dd095fe405a\\\"\u003eLow power consumption in all modes; ~50 – 70% lower than competitors\u003c/li\u003e\u003cli data-list-item-id=\\\"e9161f5206f842085c75db3e1d8e3b174\\\"\u003eHigh SNR and AOP in all operational modes\u003c/li\u003e\u003cli data-list-item-id=\\\"e1413cae3b9f2b842a58bf7d4cbdb543c\\\"\u003eAcoustic Activity Detect w/ programmable thresholds \u0026amp; filters with power consumption\u0026nbsp;as low as 20 uA\u003c/li\u003e\u003c/ul\u003e\",\"field_features_and_benefits\":null,\"field_features_listing\":[],\"field_high_quality_mode_current\":null,\"field_interface_microphone\":null,\"field_key_attribute\":\"\u003cp\u003eUltra-Low Power, High SNR, Multi-Mode PDM Microphone with AAD\u003c/p\u003e\",\"field_learn_more\":{\"title\":\"Learn more\",\"url\":\"/products/t5838\"},\"field_lf_cutoff\":\"28\",\"field_low_power_mode_current\":null,\"field_meta_tags\":null,\"field_output_type\":\"PDM\",\"field_part_number\":\"T5828\",\"field_port_location\":\"Bottom\",\"field_power_modes\":null,\"field_product_image\":[{\"id\":\"713\",\"label\":\"product-img-t5838.png\"}],\"field_product_key_features\":[{\"id\":\"96\",\"label\":\"T5838 \u003e Product key features\"}],\"field_product_segment\":\"Normal Product(ex: Ics)\",\"field_products_thumbnail_image\":{\"id\":\"520\",\"label\":\"thumbnail-t5838.jpg\"},\"field_related_products\":[{\"id\":\"3\",\"label\":\"EV_T5838-FX2\"}],\"field_sensitivity_1_khz_94_db_sp\":null,\"field_sensitivity_db_fs_1_db\":\"-41.00\",\"field_short_description\":\"\u003cp\u003eThe T5838\u0026nbsp;is a low noise, high AOP digital Pulse\u0026nbsp;Density\u0026nbsp;Modulation (PDM) microphone using a fifth-order Σ‑Δ modulator. It also features Acoustic\u0026nbsp;Activity\u0026nbsp;Detect (AAD), a new ultra-low power edge processing feature consuming as low as 20\u0026nbsp;µA.\u003c/p\u003e\",\"field_size_d\":\"0.98\",\"field_size_l\":\"3.50\",\"field_size_w\":\"2.65\",\"field_snr\":\"68.00\",\"field_software_downloads\":[],\"field_specification_short_descri\":null,\"field_status\":\"Production\",\"field_sub_title\":\"Bottom Port PDM Digital Output Multi‑Mode Microphone\",\"field_supply_voltage_vdd\":\"1.8\",\"field_support_and_resources\":[],\"field_target_markets\":[],\"field_target_markets_application\":\"\u003cp\u003eSmartphones, Smart Speakers, Headsets, TV Remotes, Smart TV, Set-top Box, Wearables\u003c/p\u003e\",\"field_temperature\":null,\"field_weight\":null}]},{\"id\":\"468\",\"label\":\"Wearables \u003e Applications section paragraphs\",\"uuid\":\"6d864b3e-8169-4a74-a3bf-425d94e3a53b\",\"langcode\":\"en\",\"type\":{\"id\":\"about_section_with_image_left\",\"label\":\"Paragraph section with image\"},\"status\":\"1\",\"created\":\"1769814431\",\"parent_id\":\"39\",\"parent_type\":\"taxonomy_term\",\"parent_field_name\":\"field_app_section_paragraphs\",\"content_translation_changed\":null,\"field_custom_tags\":[],\"field_image_alignment\":\"Left\",\"field_left_side_image\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-02/paragraph-product-smartsonic.jpg?VersionId=I8disGIPU6p1oURmN3ZoFoUJHWNp7EyO\",\"alt\":\"Two small TDK microchips next to a series of three classic ultrasonic sensors\"},\"field_paragraph_sub_title\":\"Spatial awareness and proximity sensing for wearable systems\",\"field_read_more_link\":{\"title\":\"Learn More\",\"url\":\"/ultrasonic-time-flight\"},\"field_section_description\":\"\u003cp\u003eSmartSonic ultrasonic Time-of-Flight (ToF) sensors add environmental awareness and spatial interaction to wearable platforms, enabling devices to detect presence, distance, and surrounding objects.\u003c/p\u003e\u003cul\u003e\u003cli data-list-item-id=\\\"e3cc07a89dc9134d4225ba8db3e716a43\\\"\u003eEnable presence detection, proximity sensing, and range finding for responsive behavior\u003c/li\u003e\u003cli data-list-item-id=\\\"e27956afcbeb4a49a03cdc5e67e400c14\\\"\u003eSupport gesture interaction, object detection, and 3D positioning\u003c/li\u003e\u003cli data-list-item-id=\\\"e0e28373145ad20e6a2c3ff31ab579b87\\\"\u003eEnable spatial awareness for AR/VR and smart glasses experiences\u003c/li\u003e\u003c/ul\u003e\",\"field_section_title\":\"SmartSonic™ \",\"field_select_product\":[{\"id\":\"4\",\"label\":\"ICU-10201\",\"slug\":\"/products/ultrasonic-time-flight/icu-10201\",\"product_id\":\"4\",\"uuid\":\"38692f0b-2702-44bf-b511-89141620d941\",\"langcode\":\"en\",\"type\":{\"id\":\"ultrasonic\",\"label\":\"Ultrasonic\"},\"uid\":{\"id\":\"0\",\"label\":\"Anonymous\"},\"status\":\"1\",\"title\":\"ICU-10201\",\"variations\":[],\"default_variation\":null,\"path\":null,\"created\":\"1764666395\",\"metatag\":[null,null,null],\"field_add_other_product_specific\":[{\"id\":\"103\",\"label\":\"ICU-10201 \u003e Add extra product specifications\"}],\"field_applications\":[{\"id\":\"89\",\"label\":\"Drones\"},{\"id\":\"55\",\"label\":\"Gaming\"},{\"id\":\"79\",\"label\":\"Mobile Devices \u0026 Computers\"},{\"id\":\"97\",\"label\":\"Smart Glasses \u0026 AR/VR\"}],\"field_buy_now_link\":{\"title\":\"Shop Now\",\"url\":\"https://dilp.netcomponents.com/tdkcorp_result.html?mode=1\u0026partnumber1=icu-10201\u0026pq=Search\u0026ref=/cgi-bin/tdkcorp.asp\"},\"field_category\":{\"id\":\"26\",\"label\":\"Ultrasonic ToF\"},\"field_current_consumption\":\"17.00\",\"field_description\":\"\u003cp\u003eThe ICU-10201 extends battery life via its ultra-low power consumption (17µA – 320µA depending on the number of samples per second), and is highly flexible thanks to a large amount of embedded program and data memory.\u003c/p\u003e\",\"field_documentation_resource\":[{\"id\":\"162\",\"label\":\"DS-000480 – ICU-10201 Datasheet\"},{\"id\":\"169\",\"label\":\"ICU-x0201 EVK for DK-x0201 Board\"}],\"field_features\":\"$2a\",\"field_features_and_benefits\":null,\"field_features_listing\":[],\"field_interface\":\"SPI 13 MHz\",\"field_key_attribute\":null,\"field_learn_more\":{\"title\":\"Learn more\",\"url\":\"/products/ICU-10201\"},\"field_meta_tags\":null,\"field_operation\":\"Pulse-Echo\",\"field_part_number\":\"ICU-10201\",\"field_product_image\":[{\"id\":\"535\",\"label\":\"product-img-icu-10201.png\"}],\"field_product_key_features\":[{\"id\":\"57\",\"label\":\"ICU-10201 \u003e Product key features\"}],\"field_product_segment\":\"Normal Product(ex: Ics)\",\"field_products_thumbnail_image\":{\"id\":\"536\",\"label\":\"thumbnail-icu-10201.jpg\"},\"field_range\":\"0 – 1.2\",\"field_related_products\":[{\"id\":\"13\",\"label\":\"DK-x0201\"}],\"field_short_description\":\"\u003cp\u003eThe ICU-10201 is a high-performance ultrasonic Time-of-Flight sensor that is ideal for measuring the range of objects between 10cm and 1.2m, and offers a customizable field-of-view of up to 180º. It has a sample rate of 250 samples per second at 0.3 meters, and 130 samples per second at 1 meter. It comes in a 3.5\u0026nbsp;×\u0026nbsp;3.5\u0026nbsp;×\u0026nbsp;1.26\u0026nbsp;mm LGA package, and includes an integrated DSP for signal processing.\u003c/p\u003e\",\"field_size_d\":\"1.26\",\"field_size_l\":\"3.50\",\"field_size_w\":\"3.50\",\"field_software_downloads\":[{\"id\":\"8424\",\"label\":\"ICU-x0201 EVK 3.3.1 for DK-x0201 Board\"},{\"id\":\"8339\",\"label\":\"ICU-x0201 Hello Chirp Example for SmartSonic\"}],\"field_specification_short_descri\":null,\"field_status\":null,\"field_sub_title\":\"High-Performance Ultrasonic Time‑of‑Flight Sensor\",\"field_target_markets\":[],\"field_target_markets_application\":null,\"field_weight\":null}]},{\"id\":\"469\",\"label\":\"Wearables \u003e Applications section paragraphs\",\"uuid\":\"d1e9001f-8a74-48ea-a75b-e061ad62d1a2\",\"langcode\":\"en\",\"type\":{\"id\":\"about_section_with_image_left\",\"label\":\"Paragraph section with image\"},\"status\":\"1\",\"created\":\"1769814493\",\"parent_id\":\"39\",\"parent_type\":\"taxonomy_term\",\"parent_field_name\":\"field_app_section_paragraphs\",\"content_translation_changed\":null,\"field_custom_tags\":[{\"id\":\"1275\",\"label\":\"Wearables \u003e Applications section paragraphs \u003e Custom tags\",\"uuid\":\"81f89bdf-4596-44e6-9acf-fa2344764793\",\"langcode\":\"en\",\"type\":{\"id\":\"custom_tags\",\"label\":\"Custom tags\"},\"status\":\"1\",\"created\":\"1773773907\",\"parent_id\":\"469\",\"parent_type\":\"paragraph\",\"parent_field_name\":\"field_custom_tags\",\"content_translation_changed\":\"1773773907\",\"field_paragraph_custom_tag\":{\"title\":\"TMR\",\"url\":\"/tmr\"}},{\"id\":\"1276\",\"label\":\"Wearables \u003e Applications section paragraphs \u003e Custom tags\",\"uuid\":\"96a4a8dd-cf4c-4837-847d-3dfb8645f2b8\",\"langcode\":\"en\",\"type\":{\"id\":\"custom_tags\",\"label\":\"Custom tags\"},\"status\":\"1\",\"created\":\"1773773914\",\"parent_id\":\"469\",\"parent_type\":\"paragraph\",\"parent_field_name\":\"field_custom_tags\",\"content_translation_changed\":\"1773773914\",\"field_paragraph_custom_tag\":{\"title\":\"Hall sensors\",\"url\":\"/hall-sensors\"}}],\"field_image_alignment\":\"Right\",\"field_left_side_image\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-02/paragraph-product-magnetic.jpg?VersionId=7rL1Bp6aFZMWlhJwVSDgyMpGGEqRJU0K\",\"alt\":\"Microchip next to two small magnets\"},\"field_paragraph_sub_title\":\"Magnetic sensing for control, positioning, and interaction\",\"field_read_more_link\":{\"title\":\"Learn more \",\"url\":\"/magnetics-0\"},\"field_section_description\":\"\u003cp\u003eSmartMagnetics Hall and TMR sensors enable intuitive control and precise positioning across wearable devices, including smartwatches, smart rings, and AR/VR systems.\u003c/p\u003e\u003cul\u003e\u003cli data-list-item-id=\\\"e9aac1ced849380c1c919565d5c3dd560\\\"\u003eEnable intuitive controls such as digital crowns, buttons, dials, and rotational inputs\u003c/li\u003e\u003cli data-list-item-id=\\\"ed81037e5c49824aff97bccd6742d9fd2\\\"\u003eDeliver ultra-low-power magnetic sensing for precise positioning\u003c/li\u003e\u003cli data-list-item-id=\\\"ed495bd8d1e8f40847bec3debe7a8bf23\\\"\u003eSupport always-on operation with long battery life and reliable performance\u003c/li\u003e\u003c/ul\u003e\",\"field_section_title\":\"SmartMagnetics \",\"field_select_product\":[]}],\"field_app_section_sub_title\":\"Advanced motion, magnetic, audio, and time-of-flight sensing for fitness, health, and immersive applications \",\"field_apps_related_to_category\":[],\"field_category_header_image\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-03/hero-wearables-2.jpg?VersionId=ICuzNcj6XNB5n5gBkROiCqQzPQaDHrf5\",\"alt\":\"Close-up of a person wearing a smart watch on their wrist with overlaid graphics that suggest data \"},\"field_category_image\":{\"url\