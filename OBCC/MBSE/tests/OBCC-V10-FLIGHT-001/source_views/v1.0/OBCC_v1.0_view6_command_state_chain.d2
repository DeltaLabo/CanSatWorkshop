vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional chain: DPS wireless command generation and OBCC operational state update.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "OBCC v1.0 — Command and state chain" {
  class: chain
  direction: down

  catch_state_toggle: "[F] Catch state\ntoggle" { class: func }
  push_to_command_queue: "[F] Push to\ncommand queue" { class: func }
  store_incoming_uart_data: "[F] Store incoming\nUART data" { class: func }
  generate_command_frame: "[F] Generate command\nframe" { class: func }
  write_to_lora_radio: "[F] Write to\nLoRa radio" { class: func }
  transmit_outgoing_data: "[F] Transmit\noutgoing data" { class: func }
  receive_incoming_data: "[F] Receive\nincoming data" { class: func }
  receive_lora_rx_interrupt: "[F] Receive LoRa\nRX interrupt" { class: func }
  read_command: "[F] Read\ncommand" { class: func }
  validate_command: "[F] Validate\ncommand" { class: func }
  handle_command: "[F] Handle\ncommand" { class: func }
  set_on_state: "[F] Set On\nstate" { class: func }
  set_standby_state: "[F] Set Stand-by\nstate" { class: func }
  coordinate_operational_state: "[F] Coordinate\noperational state" { class: func }
  publish_state_metadata: "[F] Publish state\nmetadata" { class: func }
  log_invalid_command: "[F] Log invalid\ncommand" { class: func }

  note_modes: "[C] Accepted commands are On and Stand-by.\nStand-by keeps telemetry alive and\ninhibits parachute deployment." {
    class: note
    shape: page
  }

  note_invalid: "[C] Invalid commands do not change\noperational state; they are recorded\nin health/status metadata." {
    class: note
    shape: page
  }
}

chain.catch_state_toggle -> chain.push_to_command_queue: "[FE] New state\n[State]" { class: fe }
chain.push_to_command_queue -> chain.store_incoming_uart_data: "[FE] Command\n[State]" { class: fe }
chain.store_incoming_uart_data -> chain.generate_command_frame: "[FE] UART command\n[State]" { class: fe }
chain.generate_command_frame -> chain.write_to_lora_radio: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.write_to_lora_radio -> chain.transmit_outgoing_data: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.transmit_outgoing_data -> chain.receive_incoming_data: "[FE] Radio signal\n[LoRa Frame]" { class: fe }
chain.receive_incoming_data -> chain.receive_lora_rx_interrupt: "[FE] Interrupt []" { class: fe }
chain.receive_incoming_data -> chain.read_command: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.receive_lora_rx_interrupt -> chain.read_command: "[FE] Flag []" { class: fe }
chain.read_command -> chain.validate_command: "[FE] Command\n[State]" { class: fe }
chain.validate_command -> chain.handle_command: "[FE] Valid command\n[State]" { class: fe }
chain.validate_command -> chain.log_invalid_command: "[FE] Invalid command []" { class: fe }
chain.handle_command -> chain.set_on_state: "[FE] On command []" { class: fe }
chain.handle_command -> chain.set_standby_state: "[FE] Stand-by\ncommand []" { class: fe }
chain.set_on_state -> chain.coordinate_operational_state: "[FE] On state []" { class: fe }
chain.set_standby_state -> chain.coordinate_operational_state: "[FE] Stand-by\nstate []" { class: fe }
chain.coordinate_operational_state -> chain.publish_state_metadata: "[FE] State update []" { class: fe }
chain.log_invalid_command -> chain.publish_state_metadata: "[FE] Command error []" { class: fe }

chain.note_modes -> chain.handle_command { class: cstr }
chain.note_invalid -> chain.log_invalid_command { class: cstr }
