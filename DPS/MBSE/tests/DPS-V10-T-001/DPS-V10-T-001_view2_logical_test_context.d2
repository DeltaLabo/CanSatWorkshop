vars: {
  d2-config: {
    layout-engine: elk
  }
}

# DPS-V10-T-001 logical test context.
# Verification additions: LoRa test transmitter EA, test operator EA, and verification-only evidence collector LC.
# The unmodified full DPS v1.0 PV2 is retained in ./baseline/; this focused view shows the LCs/CEs used by this test.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 20 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

test_operator: "[EA] Test Operator" { class: ea }

lora_test_transmitter: "[EA] LoRa Test Transmitter\nRFM95W/SX1276" { class: ea }

system: "[System] DPS v1.0\nDPS-V10-T-001 PV2 logical test context\nIADT: Testing; Refs: P0,R1-R5,R8-R15; Trace: FC01,C05" {
  class: sys
  direction: down
  grid-columns: 1

  ground_station_pcb: "[PC] Ground Station PCB" {
    class: pc
    direction: right

    ground_rfm: "[PC] RFM95W LoRa" {
      class: pc
      direction: down
      ground_lora: "[LC] LoRa Transceiver" { class: lc }
    }

    ground_xiao: "[PC] XIAO ESP32" {
      class: pc
      direction: down
      ground_forwarder: "[LC] LoRa Forwarder" { class: lc }
    }
  }

  pc: "[PC] PC" {
    class: pc
    direction: down
    grid-columns: 1

    evidence_collector: "[LC] Test Evidence Collector\n(verification-only)" { class: lc }
    decoder: "[LC] Decoder" { class: lc }
    csv_writer: "[LC] CSV Writer" { class: lc }

    note_verification_only: "[C] Test Evidence Collector is verification-only;\ncollects logs, compares CSV to TX log,\nand computes PDR/latency verdict" {
      class: note
      shape: page
    }

    note_pass: "[C] Pass constraints: N≥300 valid frames at 2s cadence;\n95% exact PDR lower bound ≥0.90; p95 latency <1s;\nCSV rows equal accepted decoded frames; unique CSV name" {
      class: note
      shape: page
    }

    note_fault: "[C] Fault hardening: corrupt, short or wrong-type frames\nare rejected/logged and never appended to CSV;\nno stale payload is queued after rejection" {
      class: note
      shape: page
    }
  }

  note_scope: "[C] Focused test context: LoRa Test Transmitter replaces\nthe flight CanSat/OBCC as a controlled frame source.\nFull v1.0 baseline architecture remains copied in ./baseline/." {
    class: note
    shape: page
  }
}

lora_test_transmitter -> system.ground_station_pcb.ground_rfm.ground_lora: "[CE] LoRa PHY\nframes" { class: ce }
system.ground_station_pcb.ground_xiao.ground_forwarder -> system.ground_station_pcb.ground_rfm.ground_lora: "[CE] SPI" { class: ce }
system.ground_station_pcb.ground_xiao.ground_forwarder -> system.pc.decoder: "[CE] UART" { class: ce }
system.pc.decoder -> system.pc.csv_writer: "[CE] Payload" { class: ce }

lora_test_transmitter -> system.pc.evidence_collector: "[CE] TX log" { class: ce }
system.pc.decoder -> system.pc.evidence_collector: "[CE] Decode log" { class: ce }
system.pc.csv_writer -> system.pc.evidence_collector: "[CE] CSV" { class: ce }
test_operator -> system.pc.evidence_collector: "[CE] Test control\nand verdict" { class: ce }

system.pc.note_verification_only -> system.pc.evidence_collector { class: cstr }
system.pc.note_pass -> system.pc.evidence_collector { class: cstr }
system.pc.note_pass -> system.pc.decoder { class: cstr }
system.pc.note_pass -> system.pc.csv_writer { class: cstr }
system.pc.note_fault -> system.pc.evidence_collector { class: cstr }
system.pc.note_fault -> system.pc.decoder { class: cstr }

# Layout-only edges to keep external actors left of the focused UUT.
test_operator -> lora_test_transmitter { style: { opacity: 0 } }
lora_test_transmitter -> system { style: { opacity: 0 } }
