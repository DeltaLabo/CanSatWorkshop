26 Resources\"},\"revision_timestamp\":\"1767794561\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-0078 – High-Performance Digital MEMS Microphone Simple Interface to SigmaDSP Audio Codec\",\"created\":\"1767794561\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"686\",\"label\":\"AN-0078 – High-Performance Digital MEMS Microphone Simple Interface to SigmaDSP Audio Codec.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2014-02-22\",\"field_version\":\"1.0\"},{\"id\":\"252\",\"label\":\"AN-000048 – PDM Digital Output MEMS Microphone Flex Evaluation Board User Guide\",\"slug\":\"/000048-pdm-digital-output-mems-microphone-flex-evaluation-board-user-guide\",\"nid\":\"252\",\"uuid\":\"a0798ee8-e949-4fd7-bd6c-9583a884a163\",\"vid\":\"612\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1767796015\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000048 – PDM Digital Output MEMS Microphone Flex Evaluation Board User Guide\",\"created\":\"1767796015\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"677\",\"label\":\"AN-000048 – PDM Digital Output MEMS Microphone Flex Evaluation Board User Guide.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2020-06-01\",\"field_version\":\"1.2\"},{\"id\":\"254\",\"label\":\"AN-000278 – T5838 Flex EVB User Guide\",\"slug\":\"/000278-t5838-flex-evb-user-guide\",\"nid\":\"254\",\"uuid\":\"1f185fc7-aaa2-4b7e-a0f8-4d788043852c\",\"vid\":\"614\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1767796156\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000278 – T5838 Flex EVB User Guide\",\"created\":\"1767796156\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"632\",\"label\":\"AN-000278-T5838-Flex-EVB-User-Guide-v1.2.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2022-08-02\",\"field_version\":\"1.2\\t\"},{\"id\":\"8655\",\"label\":\"AN-000298 – TDK T58xx Series MEMS Microphone Acoustic Activity Detect User Guide\",\"slug\":\"/000298-tdk-t58xx-series-mems-microphone-acoustic-activity-detect-user-guide\",\"nid\":\"8655\",\"uuid\":\"e1f64581-08f6-46ef-acda-4c5660b2e81c\",\"vid\":\"10016\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1778281381\",\"revision_uid\":{\"id\":\"123783\",\"label\":\"robertvargas\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"123783\",\"label\":\"robertvargas\"},\"title\":\"AN-000298 – TDK T58xx Series MEMS Microphone Acoustic Activity Detect User Guide\",\"created\":\"1778281349\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"The T5838 and T5848 microphones introduce new Acoustic Activity Detect (AAD) modes to TDK’s latest generation of PDM and I2S microphones, respectively. The AAD modes operate in parallel to the existing Sleep and Low Power modes as shown in the diagram below. The AAD modes use combination of the MEMS acoustic signal along with dedicated ASIC processing to determine if acoustic activity has occurred or not.\",\"field_file\":{\"id\":\"1210\",\"label\":\"an-000298-t58xx-mems-microphone-acoustic-activity-detect-user-guide.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2026-01-16\",\"field_version\":\"1.0\"},{\"id\":\"288\",\"label\":\"Understanding Microphone Sensitivity\",\"slug\":\"/understanding-microphone-sensitivity\",\"nid\":\"288\",\"uuid\":\"67e7a936-5e25-4638-bc77-92394dd2650d\",\"vid\":\"648\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1767877610\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"Understanding Microphone Sensitivity\",\"created\":\"1767877610\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"666\",\"label\":\"Understanding-Microphone-Sensitivity.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":null,\"field_version\":\"1.0\"}],\"field_embedded_processor_s\":null,\"field_features\":\"\u003cul\u003e\u003cli data-list-item-id=\\\"ecafa01c4f0efa92f62f0533e5b57717b\\\"\u003eIndustry standard High Quality Mode sensitivity of -37 dBFS and Low-Power Mode sensitivity of -21 dBFS\u003c/li\u003e\u003cli data-list-item-id=\\\"e4043f5de84eb7a8261410dd095fe405a\\\"\u003eLow power consumption in all modes; ~50 – 70% lower than competitors\u003c/li\u003e\u003cli data-list-item-id=\\\"e9161f5206f842085c75db3e1d8e3b174\\\"\u003eHigh SNR and AOP in all operational modes\u003c/li\u003e\u003cli data-list-item-id=\\\"e1413cae3b9f2b842a58bf7d4cbdb543c\\\"\u003eAcoustic Activity Detect w/ programmable thresholds \u0026amp; filters with power consumption\u0026nbsp;as low as 20 uA\u003c/li\u003e\u003c/ul\u003e\",\"field_features_and_benefits\":null,\"field_features_listing\":[],\"field_high_quality_mode_current\":null,\"field_interface_microphone\":null,\"field_key_attribute\":\"\u003cp\u003eUltra-Low Power, High SNR, Multi-Mode PDM Microphone with AAD\u003c/p\u003e\",\"field_learn_more\":{\"title\":\"Learn more\",\"url\":\"/products/t5838\"},\"field_lf_cutoff\":\"28\",\"field_low_power_mode_current\":null,\"field_meta_tags\":null,\"field_output_type\":\"PDM\",\"field_part_number\":\"T5828\",\"field_port_location\":\"Bottom\",\"field_power_modes\":null,\"field_product_image\":[{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-03/product-img-t5838.png?VersionId=NRnEIRW9C.KjkmuDEtmAP4neR3q_HjWG\",\"alt\":\"Illustration of T5838, TDK MEMS microphone\"}],\"field_product_key_features\":[{\"id\":\"96\",\"label\":\"T5838 \u003e Product key features\",\"uuid\":\"7bd7ec5c-610b-42ab-86aa-b2189448bec5\",\"langcode\":\"en\",\"type\":{\"id\":\"key_highlights_grid\",\"label\":\"Key highlights grid\"},\"status\":\"1\",\"created\":\"1764344215\",\"parent_id\":\"11\",\"parent_type\":\"commerce_product\",\"parent_field_name\":\"field_product_key_features\",\"content_translation_changed\":null,\"field_image_for_key_highlight\":null,\"field_key_highlight_grid_title\":null,\"field_key_highlight_short_desc\":null}],\"field_product_segment\":\"Normal Product(ex: Ics)\",\"field_products_thumbnail_image\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-02/thumbnail-t5838.jpg?VersionId=kw46J9Gp3WLucfzkN9lKXSDSEcuj..Ag\",\"alt\":\"TDK microchip with T5838 etched onto its surface\"},\"field_related_products\":[{\"id\":\"3\",\"label\":\"EV_T5838-FX2\",\"slug\":\"/products/microphone/evt5838-fx2\",\"product_id\":\"3\",\"uuid\":\"0cf031f3-9c6c-4f9c-b7b7-9474fc0d99f0\",\"langcode\":\"en\",\"type\":{\"id\":\"microphone\",\"label\":\"Microphone\"},\"uid\":{\"id\":\"0\",\"label\":\"Anonymous\"},\"status\":\"1\",\"title\":\"EV_T5838-FX2\",\"variations\":[],\"default_variation\":null,\"path\":null,\"created\":\"1764344712\",\"metatag\":[null,null,null],\"field_a_d\":\"Analog\",\"field_additional_help_section\":[],\"field_add_other_product_specific\":[{\"id\":\"162\",\"label\":\"EV_T5838-FX2 \u003e Add extra product specifications\"}],\"field_aop\":null,\"field_applications_listing\":[{\"id\":\"39\",\"label\":\"Wearables\"}],\"field_buy_now_link\":{\"title\":\"Shop Now\",\"url\":\"https://dilp.netcomponents.com/tdkcorp_result.html?lang=en\u0026mode=1\u0026partnumber1=MMICT5838\u0026partnumber2=EV_T5838-FX2\"},\"field_category\":{\"id\":\"19\",\"label\":\"Microphone\"},\"field_description\":null,\"field_documentation_resource\":[],\"field_embedded_processor_s\":null,\"field_features\":null,\"field_features_and_benefits\":null,\"field_features_listing\":[],\"field_high_quality_mode_current\":null,\"field_interface_microphone\":null,\"field_key_attribute\":null,\"field_learn_more\":null,\"field_lf_cutoff\":null,\"field_low_power_mode_current\":null,\"field_meta_tags\":null,\"field_output_type\":null,\"field_part_number\":\"EV_T5838-FX2\",\"field_port_location\":null,\"field_power_modes\":null,\"field_product_image\":[{\"id\":\"734\",\"label\":\"thumbnail-ev_t5838-fx2.jpg\"}],\"field_product_key_features\":[{\"id\":\"73\",\"label\":\"EV_T5838-FX2 \u003e Product key features\"}],\"field_product_segment\":\"Normal Product(ex: Ics)\",\"field_products_thumbnail_image\":{\"id\":\"735\",\"label\":\"thumbnail-ev_t5838-fx2.jpg\"},\"field_related_products\":[],\"field_sensitivity_1_khz_94_db_sp\":null,\"field_sensitivity_db_fs_1_db\":null,\"field_short_description\":\"\u003cp\u003eFlexible PCB Evaluation Module for T5838\u003c/p\u003e\",\"field_size_d\":null,\"field_size_l\":null,\"field_size_w\":null,\"field_snr\":null,\"field_software_downloads\":[],\"field_specification_short_descri\":null