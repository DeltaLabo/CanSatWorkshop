vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Logical view — AMS-V01-FC-001 breadboard functional-chain testbench
# Verification references: IVV, AMS-R1 (BME280), AMS-R3/R4 (metrology/atmosphere), AMS-R5 (statistics), AMS-R6 (CanSat bench context).
# IADT: Testing / Demonstration. SSIV: AMS v0.1 readiness gate to v0.2 PCB delivery.
# Traceability: AMS-v0.1-to-v0.2-readiness; AMS-UC-MeasureAtmosphere; AMS-UC-InitializePeripheral; AMS-UC-LogSerialTelemetry; AMS-FE-SensorBusFault.
# Logical view contains physical containment, logical components, component exchanges, EAs, and constraints.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-V01-FC-001 breadboard chain test\nAMS v0.1 → v0.2 readiness; Refs: IVV, AMS-R1, AMS-R3/R4/R5/R6" {
  class: sys
  direction: right

  bme280: "[PC] BME280\n(v0.1 breadboard)" {
    class: pc
    direction: down

    ams_sensing: "[LC] AMS Sensing" { class: lc }
  }

  xiao: "[PC] XIAO ESP32\n(v0.1 breadboard)" {
    class: pc
    direction: down
    grid-columns: 1

    ams_processing: "[LC] AMS Processing" { class: lc }
    fc_test_instrumentation: "[LC] AMS v0.1 FC\nTest Instrumentation\n(VV-only)" { class: lc }
  }

  probe_points: "[PC] Breadboard Serial/I2C\nProbe Points (VV-only)" {
    class: pc
    direction: down

    probe_interface: "[LC] Probe Interface\n(VV-only)" { class: lc }
  }
}

bench_operator: "[EA] Bench Operator" { class: ea }
host_pc: "[EA] Host PC Serial\nTerminal / Data Logger" { class: ea }
reference_thermometer: "[EA] Reference Thermometer\n(traceable logger)" { class: ea }
pressure_reference: "[EA] Reference Barometer /\nPressure Reference" { class: ea }
bench_power: "[EA] Bench Power /\nUSB Current Monitor" { class: ea }
logic_analyzer: "[EA] Logic Analyzer /\nTimer (optional)" { class: ea }
evidence_store: "[EA] Evidence Repository /\nReport Workspace" { class: ea }

note_scope: "[C] Scope: v0.1 breadboard execution behavior of\natmospheric measurement, BME280 init-state, and\nSerial0 logging chains; Issue 001 inspection/analysis\ncoverage is not duplicated" {
  class: note
  shape: page
}
note_stat: "[C] Statistical viewpoint: n ≥ 30 paired pressure/\ntemperature samples for the breadboard characterization\npoint; smoke-chain repetitions are readiness screening" {
  class: note
  shape: page
}
note_fault: "[C] Fault-hardening viewpoint: stale data, swapped fields,\nmissing init state, sensor-bus non-response, and\nunbounded blocking are treated as readiness failures or\nexplicit dependencies for later I2C fault tests" {
  class: note
  shape: page
}
note_report: "[C] Report by reference: AMS/MBSE/tests/results/\nAMS-V01-FC-001/report.md records as-run IDs,\nraw logs, uncertainty, deviations, and anomalies" {
  class: note
  shape: page
}

system.bme280.ams_sensing -> system.xiao.ams_processing: "[CE] I2C\nTARGET behavior" { class: ce }
system.xiao.ams_processing -> host_pc: "[CE] Serial0 / USB\npayload log" { class: ce }
bench_operator -> system.xiao.fc_test_instrumentation: "[CE] procedure, sample tags,\nanomalies" { class: ce }
host_pc -> system.xiao.fc_test_instrumentation: "[CE] capture control ↔\nparsed evidence" { class: ce }
reference_thermometer -> evidence_store: "[CE] reference temp.\nrecords" { class: ce }
pressure_reference -> evidence_store: "[CE] reference pressure /\ndelta records" { class: ce }
bench_power -> evidence_store: "[CE] voltage/current\nrecords" { class: ce }
logic_analyzer -> system.probe_points.probe_interface: "[CE] timing traces\n(optional)" { class: ce }
system.probe_points.probe_interface -> evidence_store: "[CE] probe metadata /\ntiming trace archive" { class: ce }
system.xiao.fc_test_instrumentation -> system.xiao.ams_processing: "[CE] VV timestamps /\nsample sequence IDs" { class: ce }
system.xiao.fc_test_instrumentation -> evidence_store: "[CE] archived raw data,\ncoverage, report inputs" { class: ce }

note_scope -> system.xiao.fc_test_instrumentation { class: cstr }
note_scope -> system.xiao.ams_processing { class: cstr }
note_stat -> system.xiao.fc_test_instrumentation { class: cstr }
note_stat -> evidence_store { class: cstr }
note_fault -> system.xiao.ams_processing { class: cstr }
note_fault -> system.bme280.ams_sensing { class: cstr }
note_report -> evidence_store { class: cstr }

# Layout-only edges to keep EAs and constraints in readable bands.
system -> bench_operator { style: { opacity: 0 } }
bench_operator -> host_pc { style: { opacity: 0 } }
host_pc -> reference_thermometer { style: { opacity: 0 } }
reference_thermometer -> pressure_reference { style: { opacity: 0 } }
pressure_reference -> bench_power { style: { opacity: 0 } }
bench_power -> logic_analyzer { style: { opacity: 0 } }
logic_analyzer -> evidence_store { style: { opacity: 0 } }
evidence_store -> note_scope { style: { opacity: 0 } }
note_scope -> note_stat { style: { opacity: 0 } }
note_stat -> note_fault { style: { opacity: 0 } }
note_fault -> note_report { style: { opacity: 0 } }
