vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-003 verification-only Physical Architecture PV2.
# Logical/interface view for parachute deployment command, observation, clearance, retention, and evidence exchanges.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# These logical components and exchanges define the verification means only; they are not baseline S&A design exchanges.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
witness: "[EA] Safety / QA Witness" { class: ea }
pack_fixture: "[EA] Parachute Pack /\nReset Fixture" { class: ea }
servo_interface: "[EA] Servo Command Interface /\nManual Actuation Tool" { class: ea }
camera: "[EA] High-speed / Video Camera" { class: ea }
clearance_gauge: "[EA] Clearance Gauge /\nSnag Witness Markers" { class: ea }
inspection_kit: "[EA] Pre/Post PC-PL\nInspection Kit" { class: ea }
env_screen_record: "[EA] Vibration / Drop\nScreen Record" { class: ea }
ambient_meter: "[EA] Ambient Thermo-\nHygrometer" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-FC-003" { class: ea }

system: "[System] SAA-VV-FC-003 Logical Deployment Command / Observation / Evidence Exchange\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  uut: "[PC] v1.0 S&A Top-Module\nDeployment Clearance Boundary" {
    class: pc
    direction: down

    config_record: "[LC] Article / Baseline\nand Test Configuration\nverification-only" { class: lc }
    pack_state: "[LC] Parachute Pack /\nReset State Record\nverification-only" { class: lc }
    command_record: "[LC] Servo Command /\nManual Actuation Record\nverification-only" { class: lc }
    motion_observation: "[LC] Cap and Servo\nMotion Observation\nverification-only" { class: lc }
    extraction_record: "[LC] Parachute Extraction\nand Snag Result\nverification-only" { class: lc }
    clearance_record: "[LC] Structure / Backplane /\nServo-Connector Clearance Record\nverification-only" { class: lc }
    retention_record: "[LC] Pre/Post Physical\nComponent and Link Retention Record\nverification-only" { class: lc }
    serviceability_record: "[LC] Reset / Serviceability\nRecord\nverification-only" { class: lc }
    trial_log: "[LC] Repetition and Statistical\nTrial Log\nverification-only" { class: lc }
    anomaly_record: "[LC] Snag / Interference /\nMovement Anomaly Record\nverification-only" { class: lc }
    evidence_package: "[LC] Video / Photo /\nMeasurement Evidence Package\nverification-only" { class: lc }
    acceptance_gate: "[LC] Deployment Clearance\nAcceptance Gate\nverification-only" { class: lc }
  }

  verification_scope: "[C] Verification-only CEs: These exchanges carry setup,\ncommand, observation, inspection, statistical and\nevidence information for SAA-VV-FC-003 only. They do not\ncreate or close baseline S&A component exchanges." {
    class: note
    shape: page
  }

  pass_fail: "[C] Pass/fail data required: Cap and servo motion clear\nthe top-module structure, standard stack, backplane\nspine and PDM servo connector; parachute extracts\nwithout snagging or hand assistance; reset is\nserviceable; no connector, backplane, module, fixture or\nscrew movement is introduced; pre/post PC-PL checks and\nevidence are complete." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint: Record 10/10\nzero-snag deployments for the workshop screen. Record\n29/29 representative independent zero-snag trials only\nif claiming R90/C95. The trial log records pack/reset\nstate, command method, result and any failure or hold\nfor every deployment." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint: Records explicitly screen\ncap rub, servo travel limit, packed-parachute\nvariability, backplane or PDM servo connector\ninterference, and post-vibration/drop looseness. Open\nanomaly or ambiguous video blocks acceptance." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target: SAA-UC-ParachuteClearance;\nSAA-FE-StructuralLoosening; SAA-FE-LandingDamage; v1.0\ntop-module/backplane physical links and modeled\nlanding-impact / assembly constraints." {
    class: note
    shape: page
  }
}

operator -> system.uut.config_record: "[CE] Article ID, v1.0\nbaseline, operator steps" { class: ce }
operator -> system.uut.pack_state: "[CE] Pack/reset action\nand serviceability note" { class: ce }
operator -> system.uut.anomaly_record: "[CE] Observed snag,\nmovement, hold, or rework note" { class: ce }
witness -> system.uut.acceptance_gate: "[CE] Witness review,\nsafety status, pass/hold/fail decision" { class: ce }
pack_fixture -> system.uut.pack_state: "[CE] Fold/reset fixture\nsetting and repeatability status" { class: ce }
servo_interface -> system.uut.command_record: "[CE] Open command,\nmanual actuation method, timestamp" { class: ce }
camera -> system.uut.motion_observation: "[CE] Video of cap and\nservo motion" { class: ce }
camera -> system.uut.evidence_package: "[CE] Trial video/photos,\nframe rate, FOV and lighting" { class: ce }
clearance_gauge -> system.uut.clearance_record: "[CE] Clearance, rub,\nwitness-marker and snag status" { class: ce }
inspection_kit -> system.uut.retention_record: "[CE] Pre/post stack,\ntop-module, backplane and connector checks" { class: ce }
env_screen_record -> system.uut.retention_record: "[CE] Pre/post vibration\nor drop screen condition" { class: ce }
ambient_meter -> system.uut.evidence_package: "[CE] Ambient temperature,\nhumidity, condition flag" { class: ce }

system.uut.config_record -> system.uut.pack_state: "[CE] Accepted UUT\nconfiguration" { class: ce }
system.uut.pack_state -> system.uut.command_record: "[CE] Packed and closed\nstate ready for command" { class: ce }
system.uut.command_record -> system.uut.motion_observation: "[CE] Actuation event\nand timestamp" { class: ce }
system.uut.motion_observation -> system.uut.clearance_record: "[CE] Cap/servo path\nobservation" { class: ce }
system.uut.motion_observation -> system.uut.extraction_record: "[CE] Deployment motion\nand parachute path" { class: ce }
system.uut.extraction_record -> system.uut.serviceability_record: "[CE] Extracted state\nand reset need" { class: ce }
system.uut.serviceability_record -> system.uut.trial_log: "[CE] Reset/serviceability\nresult for next trial" { class: ce }
system.uut.clearance_record -> system.uut.acceptance_gate: "[CE] Clearance / no-rub\nstatus" { class: ce }
system.uut.extraction_record -> system.uut.acceptance_gate: "[CE] Zero-snag extraction\nstatus" { class: ce }
system.uut.retention_record -> system.uut.acceptance_gate: "[CE] No movement /\nretention status" { class: ce }
system.uut.trial_log -> system.uut.acceptance_gate: "[CE] 10/10 screen or\n29/29 R90/C95 trial count" { class: ce }
system.uut.anomaly_record -> system.uut.acceptance_gate: "[CE] Open or closed\nanomaly disposition" { class: ce }
system.uut.evidence_package -> system.uut.acceptance_gate: "[CE] Evidence\ncompleteness status" { class: ce }
system.uut.acceptance_gate -> repo: "[CE] Released report-by-reference\npackage" { class: ce }
system.uut.anomaly_record -> repo: "[CE] Snag/interference,\nrework, waiver, re-run evidence" { class: ce }

system.verification_scope -> system.uut.config_record { class: cstr }
system.pass_fail -> system.uut.acceptance_gate { class: cstr }
system.pass_fail -> system.uut.clearance_record { class: cstr }
system.pass_fail -> system.uut.extraction_record { class: cstr }
system.pass_fail -> system.uut.retention_record { class: cstr }
system.statistical -> system.uut.trial_log { class: cstr }
system.fault_hardening -> system.uut.anomaly_record { class: cstr }
system.fault_hardening -> system.uut.retention_record { class: cstr }
system.traceability -> system.uut.acceptance_gate { class: cstr }

# Layout-only edges keep actors, UUT records, repository, and notes in a readable order.
operator -> witness { style: { opacity: 0 } }
witness -> pack_fixture { style: { opacity: 0 } }
pack_fixture -> servo_interface { style: { opacity: 0 } }
servo_interface -> camera { style: { opacity: 0 } }
camera -> clearance_gauge { style: { opacity: 0 } }
clearance_gauge -> inspection_kit { style: { opacity: 0 } }
inspection_kit -> env_screen_record { style: { opacity: 0 } }
env_screen_record -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.uut.config_record -> system.uut.pack_state { style: { opacity: 0 } }
system.uut.pack_state -> system.uut.command_record { style: { opacity: 0 } }
system.uut.command_record -> system.uut.motion_observation { style: { opacity: 0 } }
system.uut.motion_observation -> system.uut.extraction_record { style: { opacity: 0 } }
system.uut.extraction_record -> system.uut.clearance_record { style: { opacity: 0 } }
system.uut.clearance_record -> system.uut.retention_record { style: { opacity: 0 } }
system.uut.retention_record -> system.uut.serviceability_record { style: { opacity: 0 } }
system.uut.serviceability_record -> system.uut.trial_log { style: { opacity: 0 } }
system.uut.trial_log -> system.uut.anomaly_record { style: { opacity: 0 } }
system.uut.anomaly_record -> system.uut.evidence_package { style: { opacity: 0 } }
system.uut.evidence_package -> system.uut.acceptance_gate { style: { opacity: 0 } }
system.uut -> system.verification_scope { style: { opacity: 0 } }
system.verification_scope -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.traceability { style: { opacity: 0 } }
