#include <HardwareSerial.h>

HardwareSerial mySerial(1);

long voltage, current, power, battery;

void setup() {
  Serial.begin(115200);
  mySerial.begin(9600, SERIAL_8N1, 22, 23);
  mySerial.setTimeout(1000);
  Serial.println("=== RECEPTOR LISTO ===");
}

void loop() {
  // Sin while ni available() — espera activamente el \n
  String data = mySerial.readStringUntil('\n');
  data.trim();

  if (data.length() == 0) return;

  Serial.print("Raw: ");
  Serial.println(data);

  int result = sscanf(data.c_str(), "%ld,%ld,%ld,%ld",
                      &voltage, &current, &power, &battery);

  if (result == 4) {
    Serial.print("Voltaje: ");   Serial.print(voltage / 100.0);  Serial.print(" V | ");
    Serial.print("Corriente: "); Serial.print(current / 100.0);  Serial.print(" mA | ");
    Serial.print("Potencia: ");  Serial.print(power / 100.0);    Serial.print(" mW | ");
    Serial.print("Batería: ");   Serial.print(battery);          Serial.println(" %");
  } else {
    Serial.print("Error al parsear, campos: ");
    Serial.println(result);
  }

  Serial.println("----------------------");
}
