vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PV1 — PDS-VV-CON-001 physical normal-charge testbench.
# Capella PA PV1 only: System, PCs, non-human EAs with PLs, Physical Links, constraints.
# References: IVV, PDS-R2, PDS-R4, PDS-R5, PDS-R6, PDS-R7.
# Traceability: [C] At 4.2 V, 0.5 A; PDS-UC-ChargeESS; PDS-FE-LiIonUnsafeCondition;
# PDS-FE-OvercurrentOvervoltage; PDS-VV-FC-001; PDS-VV-SAFE-001.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

charger_emulator: "[EA] Certified current-limited\ncharger / charger emulator" { class: ea }
battery_emulator: "[EA] Battery emulator /\ncurrent-limited source" { class: ea }
usb_meter: "[EA] USB power meter /\ncurrent-voltage logger" { class: ea }
dmm_daq: "[EA] Calibrated DMM / DAQ" { class: ea }
scope_logger: "[EA] Oscilloscope /\ncharge logger" { class: ea }
thermal_instr: "[EA] Thermal camera /\nthermocouples" { class: ea }
ambient_meter: "[EA] Ambient thermometer /\nhygrometer" { class: ea }
fire_safety: "[EA] Fire-safe Li-ion containment /\nE-stop safety equipment" { class: ea }
evidence_repo: "[EA] Evidence repository /\nhost PC" { class: ea }

system: "[System] PDS-VV-CON-001 normal-charge physical testbench\nPDS & ESS v1.0 final flight acceptance — refs: IVV; PDS-R2; PDS-R4; PDS-R5; PDS-R6; PDS-R7" {
  class: sys
  direction: down
  grid-columns: 1

  test_harness: "[PC] PDS-VV-CON-001\nnormal-charge test harness" {
    class: pc
    direction: down
    grid-columns: 2

    charger_breakout: "[PC] Certified charger\nUSB-C charge breakout" { class: pc }
    dry_run_fixture: "[PC] Battery-emulator /\nnon-cell path-check fixture" { class: pc }
    cell_charge_fixture: "[PC] Flight-pack\nnon-abuse charge fixture" { class: pc }
    measurement_breakout: "[PC] Cell/protection V-I\nmeasurement breakout" { class: pc }
    usb_meter_adapter: "[PC] USB power-meter\nadapter" { class: pc }
    thermal_fixture: "[PC] Battery/protection\nthermal sensor mounts" { class: pc }
    environment_station: "[PC] Ambient record\nstation" { class: pc }
    safety_panel: "[PC] E-stop / containment\ninterlock panel" { class: pc }
    log_export: "[PC] Charge-profile log\nexport / controlled media" { class: pc }
  }

  uut: "[PC] Integrated PDS & ESS\nv1.0 UUT" {
    class: pc
    direction: down

    ess_module: "[PC] ESS Module" {
      class: pc
      direction: down
      battery_pack: "[PC] 1S1P Li-Ion\nflight pack\n(normal non-abuse only)" { class: pc }
    }

    pds_module: "[PC] PDS Module" {
      class: pc
      direction: down

      pds_pcb: "[PC] PDS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        battery_connector: "[PC] Battery Connector\ncell/protection charge path" { class: pc }
        protection: "[PC] Protection Circuit\nUSB-C charge input" { class: pc }
        ina219: "[PC] INA219\ncharge current witness" { class: pc }
        regulator: "[PC] Regulator" { class: pc }
        pds_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module\nstatus/reset witness" {
      class: pc
      direction: down
      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        xiao: "[PC] XIAO ESP32-S3" { class: pc }
        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      pds_headers: "[PC] 2mm 2x6 PDS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }
  }

  note_scope: "[C] PDS-VV-CON-001 scope\nVerify normal charge constraint [C] At 4.2 V, 0.5 A\nfor PDS & ESS v1.0 final flight acceptance. Covers USB-C charge\npath through Protection Circuit, Battery Charger, Battery Connector,\nand 1S1P Li-Ion only under supervised non-abuse conditions.\nTrace: PDS-UC-ChargeESS; PDS-VV-FC-001; PDS-VV-SAFE-001." {
    class: note
    shape: page
  }

  note_safety: "[C] Environmental and safety conditions\nRead ambient before repetitions; verify instrument status; check\ncell identity, datasheet/SDS, UN38.3/IEC62133 or equivalent evidence\nand charge/discharge/storage limits before powered Li-ion charge.\nUse fire-safe containment, E-stop, and Safety Observer approval." {
    class: note
    shape: page
  }

  note_pass: "[C] Charge pass/fail\nCell/protection charge-path voltage never exceeds modeled 4.2 V plus\ndeclared measurement uncertainty/tolerance. Charge current is limited\nto nominal 0.5 A with uncertainty considered. Record actual termination\nif below 4.2 V. No overvoltage, uncontrolled current, reverse current,\nsmoke, swelling, unsafe temperature, or connector/PCB heating." {
    class: note
    shape: page
  }

  note_hold: "[C] Hold / abort constraints\nWrong or uncertified charger, reverse polarity, ambiguous setup,\nunsafe ambient, missing safety documents or limits, unresolved\ncalibration/status issue, unsafe cell condition, or Safety Observer\nhold prevents energizing. If safety evidence is absent, use only\nsupervised emulator/non-cell path checks and make no final Li-ion\ncharge acceptance claim." {
    class: note
    shape: page
  }

  note_stats_fault: "[C] Statistical and fault-hardening viewpoint\nContinuous voltage/current/temperature evidence uses ≥30 stable\nsamples per relevant condition or a complete logged charge profile;\nretain raw data and uncertainty. Fault-hardening focus: wrong charger,\nreverse/ambiguous setup, overcurrent/overvoltage precursor, unsafe\nheating, and Li-ion unsafe-condition precursor. Destructive abuse and\naccredited safety certification are out of scope." {
    class: note
    shape: page
  }
}

# Baseline charge and power path.
charger_emulator -- system.test_harness.charger_breakout: "[PL] Certified charger\nUSB-C / power cable" { class: pl }
system.test_harness.charger_breakout -- system.uut.pds_module.pds_pcb.protection: "[PL] USB-C charge\ninput path" { class: pl }
system.uut.pds_module.pds_pcb.protection -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] charge-path /\nbattery ± traces" { class: pl }
system.uut.ess_module.battery_pack -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] Battery cable" { class: pl }
system.uut.pds_module.pds_pcb.protection -- system.uut.pds_module.pds_pcb.ina219: "[PL] Protection output trace" { class: pl }
system.uut.pds_module.pds_pcb.ina219 -- system.uut.pds_module.pds_pcb.regulator: "[PL] INA output trace" { class: pl }
system.uut.pds_module.pds_pcb.regulator -- system.uut.pds_module.pds_pcb.pds_backplane_connector: "[PL] 5 V / 3V3 traces" { class: pl }
system.uut.pds_module.pds_pcb.pds_backplane_connector -- system.uut.backplane_pcb.pds_headers: "[PL] PDS parallel cable" { class: pl }
system.uut.backplane_pcb.pds_headers -- system.uut.backplane_pcb.spine: "[PL] backplane copper" { class: pl }
system.uut.backplane_pcb.spine -- system.uut.backplane_pcb.obcc_headers: "[PL] backplane copper" { class: pl }
system.uut.backplane_pcb.obcc_headers -- system.uut.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] OBCC parallel cable" { class: pl }
system.uut.obcc_module.obcc_pcb.obcc_backplane_connector -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] 3V3 / reset\nwitness traces" { class: pl }

# Verification-only physical links.
battery_emulator -- system.test_harness.dry_run_fixture: "[PL] Current-limited\nemulated cell leads" { class: pl }
system.test_harness.dry_run_fixture -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] non-cell path-check\nbattery connector leads" { class: pl }
system.test_harness.cell_charge_fixture -- system.uut.ess_module.battery_pack: "[PL] fire-safe pack\nfixture contact" { class: pl }
usb_meter -- system.test_harness.usb_meter_adapter: "[PL] USB meter cable" { class: pl }
system.test_harness.usb_meter_adapter -- system.test_harness.charger_breakout: "[PL] charge input\nV-I tap" { class: pl }
dmm_daq -- system.test_harness.measurement_breakout: "[PL] Kelvin / shunt\nmeasurement leads" { class: pl }
scope_logger -- system.test_harness.measurement_breakout: "[PL] high-impedance\ntransient probes" { class: pl }
system.test_harness.measurement_breakout -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] cell/protection\ncharge-path probes" { class: pl }
system.test_harness.measurement_breakout -- system.uut.pds_module.pds_pcb.protection: "[PL] charger/protection\nstate probes" { class: pl }
system.test_harness.measurement_breakout -- system.uut.pds_module.pds_pcb.ina219: "[PL] current witness\nprobe breakout" { class: pl }
thermal_instr -- system.test_harness.thermal_fixture: "[PL] thermocouple /\nIR sight line" { class: pl }
system.test_harness.thermal_fixture -- system.uut.ess_module.battery_pack: "[PL] battery surface\ntemperature contact" { class: pl }
system.test_harness.thermal_fixture -- system.uut.pds_module.pds_pcb.protection: "[PL] protection thermal\ncontact / sight line" { class: pl }
system.test_harness.thermal_fixture -- system.uut.pds_module.pds_pcb.battery_connector: "[PL] connector thermal\ncontact / sight line" { class: pl }
ambient_meter -- system.test_harness.environment_station: "[PL] ambient meter\nbench placement" { class: pl }
system.test_harness.environment_station -- system.uut: "[PL] test-cell proximity" { class: pl }
fire_safety -- system.uut.ess_module.battery_pack: "[PL] fire-safe enclosure /\nE-stop access" { class: pl }
fire_safety -- system.test_harness.safety_panel: "[PL] interlock /\nE-stop cable" { class: pl }
system.test_harness.safety_panel -- system.test_harness.charger_breakout: "[PL] charger enable\ninterlock" { class: pl }
evidence_repo -- system.test_harness.log_export: "[PL] network / removable\nevidence transfer" { class: pl }
system.test_harness.log_export -- system.test_harness.measurement_breakout: "[PL] raw charge logs" { class: pl }
system.test_harness.log_export -- system.uut.obcc_module.obcc_pcb.xiao: "[PL] status/reset log\nexport if used" { class: pl }

system.note_scope -> system.uut.pds_module.pds_pcb.protection { class: cstr }
system.note_scope -> system.uut.ess_module.battery_pack { class: cstr }
system.note_safety -> system.test_harness.safety_panel { class: cstr }
system.note_safety -> fire_safety { class: cstr }
system.note_safety -> ambient_meter { class: cstr }
system.note_pass -> system.test_harness.measurement_breakout { class: cstr }
system.note_pass -> system.uut.pds_module.pds_pcb.battery_connector { class: cstr }
system.note_pass -> system.uut.pds_module.pds_pcb.protection { class: cstr }
system.note_hold -> system.test_harness.charger_breakout { class: cstr }
system.note_hold -> system.test_harness.dry_run_fixture { class: cstr }
system.note_hold -> system.test_harness.safety_panel { class: cstr }
system.note_stats_fault -> system.test_harness.log_export { class: cstr }
system.note_stats_fault -> system.test_harness.measurement_breakout { class: cstr }
system.note_stats_fault -> system.uut.ess_module.battery_pack { class: cstr }

# Layout-only rank hints for equipment, UUT/harness, and constraints.
charger_emulator -> battery_emulator { style: { opacity: 0 } }
battery_emulator -> usb_meter { style: { opacity: 0 } }
usb_meter -> dmm_daq { style: { opacity: 0 } }
dmm_daq -> scope_logger { style: { opacity: 0 } }
scope_logger -> thermal_instr { style: { opacity: 0 } }
thermal_instr -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> fire_safety { style: { opacity: 0 } }
fire_safety -> evidence_repo { style: { opacity: 0 } }
evidence_repo -> system { style: { opacity: 0 } }
system.test_harness -> system.uut { style: { opacity: 0 } }
system.uut -> system.note_scope { style: { opacity: 0 } }
system.note_scope -> system.note_safety { style: { opacity: 0 } }
system.note_safety -> system.note_pass { style: { opacity: 0 } }
system.note_pass -> system.note_hold { style: { opacity: 0 } }
system.note_hold -> system.note_stats_fault { style: { opacity: 0 } }
