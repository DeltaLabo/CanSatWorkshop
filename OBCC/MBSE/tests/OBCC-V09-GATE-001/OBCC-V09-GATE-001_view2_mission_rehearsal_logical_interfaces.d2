vars: {
  d2-config: {
    layout-engine: elk
  }
}

# OBCC-V09-GATE-001 PV2: logical/component-exchange setup for the
# end-to-end mission-window rehearsal. No functions or physical links are used.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 23 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] OBCC mission-window rehearsal logical interface view\nRefs: IVV, PM&SE/IVV, OBCC README, LoRa_Frame, Variable Getter Template, v1.0 PV2; trace: FC-001..FC-005 -> FC-006" {
  class: sys
  direction: down

  cansat: "[PC] Integrated CanSat\nunder test" {
    class: pc
    direction: right

    source_modules: "[PC] ADS / AMS / PDS\nsource modules" {
      class: pc
      direction: down
      grid-columns: 1

      ads: "[PC] ADS Module" {
        class: pc
        direction: right
        ads_gps_sensing: "[LC] ADS GPS Sensing" { class: lc }
        ads_kinematic_sensing: "[LC] ADS Kinematic Sensing" { class: lc }
      }

      ams: "[PC] AMS Module" {
        class: pc
        ams_sensing: "[LC] AMS Sensing" { class: lc }
      }

      pds: "[PC] PDS Module" {
        class: pc
        battery_monitoring: "[LC] Battery Monitoring" { class: lc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: right

        rfm95w: "[PC] RFM95W LoRa" {
          class: pc
          cansat_lora: "[LC] LoRa Transceiver" { class: lc }
        }

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down
          grid-columns: 3

          free_rtos: "[LC] FreeRTOS Kernel" { class: lc }
          obcc_supervisor: "[LC] OBCC Supervisor" { class: lc }
          health_monitor: "[LC] Health Monitor" { class: lc }
          telemetry_collector: "[LC] Telemetry Collector" { class: lc }
          telemetry_encoder: "[LC] Telemetry Encoder" { class: lc }
          command_handler: "[LC] Command Handler" { class: lc }
          pdm_processing: "[LC] PDM Processing" { class: lc }
          ads_processing: "[LC] ADS Processing" { class: lc }
          ams_processing: "[LC] AMS Processing" { class: lc }
          ess_processing: "[LC] ESS Processing" { class: lc }
        }
      }
    }

    parachute_module: "[PC] Parachute Module" {
      class: pc
      servo: "[PC] Servo" {
        class: pc
        trigger: "[LC] Trigger" { class: lc }
      }
    }
  }

  ground_station_pcb: "[PC] Ground Station PCB" {
    class: pc
    direction: right

    ground_rfm95w: "[PC] RFM95W LoRa" {
      class: pc
      ground_lora: "[LC] LoRa Transceiver" { class: lc }
    }

    ground_xiao: "[PC] XIAO ESP32" {
      class: pc
      lora_forwarder: "[LC] LoRa Forwarder" { class: lc }
    }
  }

  ground_pc: "[PC] Ground PC" {
    class: pc
    direction: right
    decoder: "[LC] Decoder" { class: lc }
    dashboard: "[LC] Dashboard" { class: lc }
    csv_writer: "[LC] CSV Writer" { class: lc }
  }

  test_workstation: "[PC] Test Evidence Workstation\n(verification-only)" {
    class: pc
    direction: right
    evidence_orchestrator: "[LC] Evidence Orchestrator" { class: lc }
    timing_logger: "[LC] Timing Logger" { class: lc }
    config_manifest: "[LC] As-tested Config Manifest" { class: lc }
    fault_injection_controller: "[LC] Safe Fault Injection Controller" { class: lc }
    deployment_fixture_controller: "[LC] Deployment Fixture Controller" { class: lc }
  }

  note_analysis: "[C] Analysis hook: every modeled rehearsal CE\nshall be implemented consistently with v1.0 intent\n(I2C, UART, SPI, PWM, LoRa, Payload, Command,\nGetters, Queue, State, Mode gate, IMU/alt, evidence)." {
    class: note
    shape: page
  }

  note_no_reliability_overclaim: "[C] Statistical viewpoint: the integrated\nmission rehearsal is integration evidence. Reliability,\nPDR, or deadline claims require independent counts and\nexact confidence/tolerance calculations in the report." {
    class: note
    shape: page
  }
}

integrated_test_operator: "[EA] Integrated test operator" { class: ea }
range_ground_operator: "[EA] Range / ground operator" { class: ea }
rf_monitor: "[EA] RF monitor" { class: ea }
ambient_weather_recorder: "[EA] Ambient/weather recorder" { class: ea }
deployment_safety_observer: "[EA] Deployment-safety observer" { class: ea }
evidence_data_manager: "[EA] Evidence/data manager" { class: ea }
as_tested_config_recorder: "[EA] As-tested configuration recorder" { class: ea }

system.cansat.source_modules.ads.ads_gps_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ads_processing: "[CE] UART" { class: ce }
system.cansat.source_modules.ads.ads_kinematic_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ads_processing: "[CE] I2C" { class: ce }
system.cansat.source_modules.ams.ams_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] I2C" { class: ce }
system.cansat.source_modules.pds.battery_monitoring -> system.cansat.obcc_module.obcc_pcb.xiao.ess_processing: "[CE] I2C" { class: ce }

system.cansat.obcc_module.obcc_pcb.xiao.obcc_supervisor -> system.cansat.obcc_module.obcc_pcb.xiao.health_monitor: "[CE] Startup health" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.health_monitor -> system.cansat.obcc_module.obcc_pcb.xiao.telemetry_collector: "[CE] Health flags" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.telemetry_collector -> system.cansat.obcc_module.obcc_pcb.xiao.telemetry_encoder: "[CE] Queue" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.telemetry_collector -> system.cansat.obcc_module.obcc_pcb.xiao.pdm_processing: "[CE] IMU/alt" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.pdm_processing -> system.cansat.parachute_module.servo.trigger: "[CE] PWM" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.command_handler -> system.cansat.obcc_module.obcc_pcb.xiao.obcc_supervisor: "[CE] State" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.obcc_supervisor -> system.cansat.obcc_module.obcc_pcb.xiao.pdm_processing: "[CE] Mode gate" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.free_rtos -> system.cansat.obcc_module.obcc_pcb.xiao.telemetry_collector: "[CE] Timer / task release" { class: ce }

system.cansat.obcc_module.obcc_pcb.xiao.telemetry_encoder -> system.cansat.obcc_module.obcc_pcb.rfm95w.cansat_lora: "[CE] SPI" { class: ce }
system.cansat.obcc_module.obcc_pcb.rfm95w.cansat_lora -> system.cansat.obcc_module.obcc_pcb.xiao.command_handler: "[CE] SPI" { class: ce }
system.cansat.obcc_module.obcc_pcb.rfm95w.cansat_lora -> system.ground_station_pcb.ground_rfm95w.ground_lora: "[CE] LoRa" { class: ce }
system.ground_station_pcb.ground_rfm95w.ground_lora -> system.ground_station_pcb.ground_xiao.lora_forwarder: "[CE] SPI" { class: ce }
system.ground_station_pcb.ground_xiao.lora_forwarder -> system.ground_station_pcb.ground_rfm95w.ground_lora: "[CE] SPI command" { class: ce }
system.ground_station_pcb.ground_xiao.lora_forwarder -> system.ground_pc.decoder: "[CE] UART payload" { class: ce }
system.ground_pc.decoder -> system.ground_pc.csv_writer: "[CE] Payload" { class: ce }
system.ground_pc.decoder -> system.ground_pc.dashboard: "[CE] Payload" { class: ce }
system.ground_pc.dashboard -> system.ground_pc.decoder: "[CE] Command" { class: ce }

system.ground_pc.csv_writer -> system.test_workstation.evidence_orchestrator: "[CE] CSV + logs" { class: ce }
system.ground_pc.dashboard -> system.test_workstation.timing_logger: "[CE] State/telemetry timestamps" { class: ce }
system.test_workstation.fault_injection_controller -> system.cansat.obcc_module.obcc_pcb.xiao.health_monitor: "[CE] Safe fault stimuli" { class: ce }
system.test_workstation.fault_injection_controller -> system.cansat.obcc_module.obcc_pcb.xiao.telemetry_collector: "[CE] Getter fault profile" { class: ce }
system.test_workstation.deployment_fixture_controller -> system.cansat.obcc_module.obcc_pcb.xiao.pdm_processing: "[CE] Safe trigger / no-trigger profile" { class: ce }
system.cansat.parachute_module.servo.trigger -> system.test_workstation.deployment_fixture_controller: "[CE] Travel / inhibit evidence" { class: ce }
system.test_workstation.config_manifest -> system.test_workstation.evidence_orchestrator: "[CE] As-tested IDs" { class: ce }
system.test_workstation.timing_logger -> system.test_workstation.evidence_orchestrator: "[CE] Timing trace" { class: ce }

integrated_test_operator -> system.test_workstation.evidence_orchestrator: "[CE] Step authorization / gate decision" { class: ce }
range_ground_operator -> system.ground_pc.dashboard: "[CE] On / Stand-by commands" { class: ce }
rf_monitor -> system.test_workstation.evidence_orchestrator: "[CE] RSSI/SNR/PDR log" { class: ce }
ambient_weather_recorder -> system.test_workstation.evidence_orchestrator: "[CE] Ambient/weather log" { class: ce }
deployment_safety_observer -> system.test_workstation.deployment_fixture_controller: "[CE] Safe/unsafe fixture status" { class: ce }
evidence_data_manager -> system.test_workstation.evidence_orchestrator: "[CE] Evidence export manifest" { class: ce }
as_tested_config_recorder -> system.test_workstation.config_manifest: "[CE] UUT/equipment/source IDs" { class: ce }

system.note_analysis -> system.cansat.obcc_module.obcc_pcb.xiao.telemetry_collector { class: cstr }
system.note_analysis -> system.test_workstation.evidence_orchestrator { class: cstr }
system.note_no_reliability_overclaim -> system.test_workstation.timing_logger { class: cstr }

# Layout-only edges preserve the flight-to-ground-to-evidence reading order.
system.cansat -> system.ground_station_pcb { style: { opacity: 0 } }
system.ground_station_pcb -> system.ground_pc { style: { opacity: 0 } }
system.ground_pc -> system.test_workstation { style: { opacity: 0 } }
system.test_workstation -> system.note_analysis { style: { opacity: 0 } }
system.note_analysis -> system.note_no_reliability_overclaim { style: { opacity: 0 } }
integrated_test_operator -> range_ground_operator { style: { opacity: 0 } }
range_ground_operator -> rf_monitor { style: { opacity: 0 } }
rf_monitor -> ambient_weather_recorder { style: { opacity: 0 } }
ambient_weather_recorder -> deployment_safety_observer { style: { opacity: 0 } }
deployment_safety_observer -> evidence_data_manager { style: { opacity: 0 } }
evidence_data_manager -> as_tested_config_recorder { style: { opacity: 0 } }
