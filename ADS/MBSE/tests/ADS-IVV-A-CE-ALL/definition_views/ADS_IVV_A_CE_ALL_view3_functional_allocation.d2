vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional allocation view: verification-only functions for ADS-IVV-A-CE-ALL.
# References: IVV CE analysis rule; ADS MBSE all-version source views.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-A-CE-ALL\nVerification-only functional allocation\nRefs: IVV; NASA-SE; GPS/UBX; IMU/I2C; SW/stats" {
  class: sys
  direction: down

  selected_version: "[PC] Selected ADS version\n(analysis interface)" {
    class: pc
    direction: down

    ce_analysis_interface: "[LC] CE analysis interface" {
      class: lc
      direction: down
      grid-columns: 2

      expose_model_views: "[F] Expose copied\nD2 source views" { class: func }
      expose_ce_inventory: "[F] Expose modeled\nCE inventory" { class: func }
      expose_constraints: "[F] Expose linked\nconstraints and chains" { class: func }
      hold_ce_deviation: "[F] Hold CE deviation\nmarkers until disposition" { class: func }
    }
  }
}

analyst: "[EA] IVV CE analyst" {
  class: ea
  direction: down
  grid-columns: 2

  select_baseline: "[F] Select ADS version\nand source baseline" { class: func }
  enumerate_ces: "[F] Enumerate modeled\nCEs and endpoints" { class: func }
  map_endpoints: "[F] Map CEs to\nimplementation endpoints" { class: func }
  compare_protocols: "[F] Compare protocol\nor interface type" { class: func }
  analyze_direction: "[F] Analyze direction\nand request/response\nsemantics" { class: func }
  record_ce_result: "[F] Record CE pass/fail,\nN/A rationale, anomalies" { class: func }
}

firmware_repo: "[EA] Firmware repository /\nstatic analysis tool" {
  class: ea
  direction: down
  grid-columns: 2

  inspect_uart_code: "[F] Inspect UART\nconfiguration and parser" { class: func }
  inspect_i2c_code: "[F] Inspect I2C\naddressing and register access" { class: func }
  inspect_pointer_returns: "[F] Inspect Pointers /\nReturns contract" { class: func }
  inspect_timeout_logic: "[F] Inspect timeout,\nno-blocking, error handling" { class: func }
}

capture_tools: "[EA] Runtime evidence tools\n(serial, I2C, logs)" {
  class: ea
  direction: down
  grid-columns: 2

  decode_uart_capture: "[F] Decode UART\nGPS transactions" { class: func }
  decode_i2c_capture: "[F] Decode I2C\nIMU transactions" { class: func }
  collect_integration_logs: "[F] Collect integration\nlogs and traces" { class: func }
  flag_fault_observations: "[F] Flag fault\nobservations" { class: func }
}

reference_corpus: "[EA] Reference corpus" {
  class: ea
  direction: down
  grid-columns: 2

  provide_ubx_reference: "[F] Provide GPS/UBX\nprotocol references" { class: func }
  provide_i2c_reference: "[F] Provide ICM20948\nand I2C references" { class: func }
  provide_sw_reference: "[F] Provide SW/statistics\nanalysis references" { class: func }
}

quality_authority: "[EA] Quality / configuration\nauthority" {
  class: ea
  review_disposition: "[F] Review deviations,\nwaivers, retest status" { class: func }
}

note_coverage: "[C] CE coverage\nEvery modeled CE in the selected version\nshall be analyzed. v0.3 is pass/N/A only\nif all source views are reviewed and no\nCEs or LC endpoints are present." { class: note; shape: page }
note_pass_fail: "[C] CE pass/fail\nPass if endpoint LCs, protocol/interface,\ndirection/request-response behavior,\ntimeout/no-blocking constraints, and\nvalidity/freshness/error semantics match\nmodel intent." { class: note; shape: page }
note_faults: "[C] Fault hardening\nAnalyze silent/malformed GPS UART, I2C\nNACK/stuck/wrong address, stale/corrupt\ndata, and unsafe v1.0 pointer/return\ncontract behavior." { class: note; shape: page }
note_stats: "[C] Statistical viewpoint\nCE presence/consistency is complete\nenumeration, not sampling. Runtime\ntransaction counts are supporting evidence\nonly unless a separate chain/constraint\ntest claims statistical performance." { class: note; shape: page }

note_coverage -> analyst.enumerate_ces { class: cstr }
note_pass_fail -> analyst.compare_protocols { class: cstr }
note_pass_fail -> analyst.record_ce_result { class: cstr }
note_faults -> firmware_repo.inspect_timeout_logic { class: cstr }
note_faults -> capture_tools.flag_fault_observations { class: cstr }
note_stats -> analyst.record_ce_result { class: cstr }

# Layout-only edge to keep equipment below the selected version interface.
system -> analyst { style: { opacity: 0 } }
analyst -> firmware_repo { style: { opacity: 0 } }
firmware_repo -> capture_tools { style: { opacity: 0 } }
capture_tools -> reference_corpus { style: { opacity: 0 } }
reference_corpus -> quality_authority { style: { opacity: 0 } }
