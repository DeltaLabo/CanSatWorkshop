vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view — AMS-VV-FC-001 atmospheric measurement chain acceptance testbench
# Verification references: IVV, AMS-R1 (BME280), AMS-R3/R4 (environment/standard atmosphere), AMS-R5 (statistics), AMS-R7 (low-cost altitude context).
# IADT: Testing / Demonstration. SSIV: AMS v1.0 final acceptance / flight readiness.
# Traceability: AMS-UC-MeasureAtmosphere; AMS-FE-BadExposure; AMS-FE-StaleMeasurement; pressure/temperature/altitude constraints.
# Physical view contains only physical components, external actors/equipment, physical links, and constraints.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-FC-001 atmospheric chain acceptance\nAMS v1.0 final; Refs: IVV, AMS-R1, AMS-R3/R4/R5/R7" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: right

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down

        bme280: "[PC] BME280" { class: pc }
        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      grid-columns: 1

      ams_headers: "[PC] 2mm 2x6 AMS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down

        xiao: "[PC] XIAO ESP32-S3" { class: pc }
        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
        vv_usb_log_port: "[PC] VV USB / Logger\nAccess Port (VV-only)" { class: pc }
      }
    }
  }
}

test_operator: "[EA] Test Operator" { class: ea }
host_pc_logger: "[EA] Host PC /\nData Logger" { class: ea }
pressure_reference: "[EA] Reference Barometer /\nPressure Calibrator" { class: ea }
thermal_reference: "[EA] Reference Thermometer /\nStable Thermal Source" { class: ea }
ambient_thermometer: "[EA] Ambient Thermometer\nTraceable Logger" { class: ea }
bench_supply: "[EA] Bench Power\nSupply" { class: ea }
evidence_repo: "[EA] Evidence Repository /\nReport Workspace" { class: ea }

note_airflow: "[C] Test article remains in final acceptance\nexposure configuration: block direct sunlight\nwhile preserving airflow to the AMS module" {
  class: note
  shape: page
}
note_testbench: "[C] VV-only pressure/thermal/logging connections\nshall not bypass the modeled BME280→AMS Processing→OBCC\nmeasurement path or alter the backplane I2C/3V3 path" {
  class: note
  shape: page
}
note_environment: "[C] Environmental conditions are formalized by\nreference pressure, reference temperature, ambient\nthermometer, and bench supply equipment; record IDs,\ncalibration status, and readings before repetitions" {
  class: note
  shape: page
}
note_report: "[C] Evidence is archived for\nAMS/MBSE/tests/results/AMS-VV-FC-001/report.md" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb -- system.cansat.ams_module: "[PL] Screws" { class: pl }
system.cansat.obcc_module.obcc_pcb -- system.cansat.obcc_module: "[PL] Screws" { class: pl }

system.cansat.ams_module -- system.cansat.backplane_pcb: "[PL] Backplane\nFixture" { class: pl }
system.cansat.obcc_module -- system.cansat.backplane_pcb: "[PL] Backplane\nFixture" { class: pl }

system.cansat.ams_module.ams_pcb.bme280 -- system.cansat.ams_module.ams_pcb: "[PL] BME280\nFootprint" { class: pl }
system.cansat.ams_module.ams_pcb.ams_backplane_connector -- system.cansat.ams_module.ams_pcb: "[PL] Connector\nfootprint" { class: pl }
system.cansat.ams_module.ams_pcb.bme280 -- system.cansat.ams_module.ams_pcb.ams_backplane_connector: "[PL] I2C + 3V3\ntraces" { class: pl }
system.cansat.ams_module.ams_pcb.ams_backplane_connector -- system.cansat.backplane_pcb.ams_headers: "[PL] Parallel\nConnector" { class: pl }

system.cansat.obcc_module.obcc_pcb.xiao -- system.cansat.obcc_module.obcc_pcb: "[PL] XIAO\nFootprint" { class: pl }
system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector -- system.cansat.obcc_module.obcc_pcb: "[PL] Connector\nfootprint" { class: pl }
system.cansat.obcc_module.obcc_pcb.xiao -- system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] I2C + 3V3\ntraces" { class: pl }
system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector -- system.cansat.backplane_pcb.obcc_headers: "[PL] Parallel\nCable" { class: pl }
system.cansat.obcc_module.obcc_pcb.xiao -- system.cansat.obcc_module.obcc_pcb.vv_usb_log_port: "[PL] USB/UART\nlogger access" { class: pl }

system.cansat.backplane_pcb.ams_headers -- system.cansat.backplane_pcb.spine: "[PL] Footprint" { class: pl }
system.cansat.backplane_pcb.obcc_headers -- system.cansat.backplane_pcb.spine: "[PL] Footprint" { class: pl }

host_pc_logger -- system.cansat.obcc_module.obcc_pcb.vv_usb_log_port: "[PL] USB log /\ncommand cable" { class: pl }
pressure_reference -- system.cansat.ams_module.ams_pcb.bme280: "[PL] Shared pressure\nvolume / port" { class: pl }
thermal_reference -- system.cansat.ams_module.ams_pcb.bme280: "[PL] Co-located thermal\nreference / source" { class: pl }
ambient_thermometer -- system.cansat.ams_module: "[PL] Ambient probe\nnear AMS" { class: pl }
bench_supply -- system.cansat.backplane_pcb: "[PL] 3V3/GND\nbench feed" { class: pl }
test_operator -- system.cansat.obcc_module.obcc_pcb.vv_usb_log_port: "[PL] Launch/reset\naccess" { class: pl }
host_pc_logger -- evidence_repo: "[PL] File sync /\nreport archive" { class: pl }

note_airflow -> system.cansat.ams_module { class: cstr }
note_testbench -> system.cansat.obcc_module.obcc_pcb.vv_usb_log_port { class: cstr }
note_testbench -> pressure_reference { class: cstr }
note_testbench -> thermal_reference { class: cstr }
note_environment -> ambient_thermometer { class: cstr }
note_environment -> pressure_reference { class: cstr }
note_environment -> thermal_reference { class: cstr }
note_environment -> bench_supply { class: cstr }
note_report -> evidence_repo { class: cstr }
note_report -> host_pc_logger { class: cstr }

# Layout-only edges to keep UUT, equipment, and constraints in readable bands.
system -> test_operator { style: { opacity: 0 } }
test_operator -> host_pc_logger { style: { opacity: 0 } }
host_pc_logger -> pressure_reference { style: { opacity: 0 } }
pressure_reference -> thermal_reference { style: { opacity: 0 } }
thermal_reference -> ambient_thermometer { style: { opacity: 0 } }
ambient_thermometer -> bench_supply { style: { opacity: 0 } }
bench_supply -> evidence_repo { style: { opacity: 0 } }
evidence_repo -> note_airflow { style: { opacity: 0 } }
note_airflow -> note_testbench { style: { opacity: 0 } }
note_testbench -> note_environment { style: { opacity: 0 } }
note_environment -> note_report { style: { opacity: 0 } }
