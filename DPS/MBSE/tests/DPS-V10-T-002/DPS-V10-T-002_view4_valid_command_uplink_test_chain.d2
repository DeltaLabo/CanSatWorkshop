vars: {
  d2-config: {
    layout-engine: elk
  }
}

# DPS-V10-T-002A functional chain: valid dashboard command/uplink test sequence.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 32 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 28 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 34
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 26 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 24 } }
}

chain: "DPS-V10-T-002A — Valid command/uplink test\nIADT: Testing; Refs: P0,R1-R5,R8-R13; Trace: FC02 command/uplink; Report: tests/results/DPS-V10-T-002/" {
  class: chain
  direction: down

  op_confirm_baseline: "[F] Operator confirms\nDPS v1.0 baseline" { class: func }
  open_dashboard: "[F] Open dashboard\nin browser" { class: func }
  configure_rf_capture: "[F] Configure RF command\nmonitor" { class: func }
  start_command_logging: "[F] Start UI, decoder,\nforwarder and RF logs" { class: func }
  issue_valid_toggles: "[F] Issue 60 valid\nstate toggles" { class: func }
  timestamp_ui_events: "[F] Timestamp UI\nevents and expected state" { class: func }

  catch_state_toggle: "[F] Catch State\ntoggle" { class: func }
  push_to_command_queue: "[F] Push to\ncommand queue" { class: func }
  consume_command_queue: "[F] Consume\ncommand queue" { class: func }
  forward_to_transceiver: "[F] Forward to\ntransceiver" { class: func }
  store_incoming_uart_data: "[F] Store incoming\nUART data" { class: func }
  receive_serial0_rx_interrupt: "[F] Receive Serial0\nRX Interrupt" { class: func }
  read_command: "[F] Read command" { class: func }
  generate_frame: "[F] Generate frame" { class: func }
  write_to_lora_radio: "[F] Write to\nLoRa Radio" { class: func }
  transmit_outgoing_data: "[F] Transmit\noutgoing data" { class: func }

  capture_command_frames: "[F] Capture RF command\nframes" { class: func }
  decode_command_state: "[F] Decode commanded\nstate from frame" { class: func }
  capture_ui_log: "[F] Capture UI event\nlog" { class: func }
  capture_decoder_log: "[F] Capture command queue\nand decoder log" { class: func }
  capture_forwarder_log: "[F] Capture forwarder\nand serial log" { class: func }
  compare_command_sequence: "[F] Compare RF commands\nto expected toggle sequence" { class: func }
  compute_success_stats: "[F] Compute command success\nand pass/fail verdict" { class: func }
  archive_evidence: "[F] Archive evidence\nin results folder" { class: func }

  note_trace: "[C] Traceability target: inferred use case 'wireless state command';\nsource model FC02 dashboard command/uplink chain. Formal mission/capability\nIDs remain TBD." {
    class: note
    shape: page
  }

  note_environment: "[C] Environment/setup constraint: dashboard URL/browser, serial port,\nground radio settings, RF monitor settings, antennas/attenuator, time source,\nsoftware revisions and evidence directories are recorded before the run." {
    class: note
    shape: page
  }

  note_stimulus: "[C] Stimulus constraint: at least 60 valid state toggles outside cooldown;\ntoggles alternate the expected command state and are separated enough that\nC07 cooldown from a previous toggle cannot suppress the next valid trial." {
    class: note
    shape: page
  }

  note_pass: "[C] Pass constraints: every accepted toggle produces exactly one RF\ncommand frame matching the expected state; zero wrong states, zero duplicates,\nzero missing commands and no direct Dashboard-to-radio bypass." {
    class: note
    shape: page
  }

  note_statistics: "[C] Statistical viewpoint: 60/60 correct single command transmissions\nprovides a one-sided 95% exact-binomial lower bound of about 0.95 for\ncommand-transmit success in this controlled setup; record k/n if N differs." {
    class: note
    shape: page
  }

  note_fault_watch: "[C] Fault-hardening watch items: stale command, duplicate queue entry,\nUART write failure, SPI/radio not-ready, missing RF capture or hidden command\nbypass is a failure or report limitation/anomaly." {
    class: note
    shape: page
  }
}

chain.op_confirm_baseline -> chain.open_dashboard: "[FE] Baseline OK\n[Test condition]" { class: fe }
chain.open_dashboard -> chain.configure_rf_capture: "[FE] UI reachable\n[Test condition]" { class: fe }
chain.configure_rf_capture -> chain.start_command_logging: "[FE] RF capture ready\n[Test condition]" { class: fe }
chain.start_command_logging -> chain.issue_valid_toggles: "[FE] Start trigger\n[Test control]" { class: fe }
chain.issue_valid_toggles -> chain.timestamp_ui_events: "[FE] Expected command\n[State sequence]" { class: fe }
chain.issue_valid_toggles -> chain.catch_state_toggle: "[FE] User toggle\n[State]" { class: fe }

chain.catch_state_toggle -> chain.push_to_command_queue: "[FE] New State\n[State]" { class: fe }
chain.push_to_command_queue -> chain.consume_command_queue: "[FE] Command\n[State]" { class: fe }
chain.consume_command_queue -> chain.forward_to_transceiver: "[FE] Command\n[State]" { class: fe }
chain.forward_to_transceiver -> chain.store_incoming_uart_data: "[FE] Command\n[State]" { class: fe }
chain.store_incoming_uart_data -> chain.receive_serial0_rx_interrupt: "[FE] Interrupt []" { class: fe }
chain.store_incoming_uart_data -> chain.read_command: "[FE] UART Data []" { class: fe }
chain.receive_serial0_rx_interrupt -> chain.read_command: "[FE] Flag []" { class: fe }
chain.read_command -> chain.generate_frame: "[FE] Command\n[State]" { class: fe }
chain.generate_frame -> chain.write_to_lora_radio: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.write_to_lora_radio -> chain.transmit_outgoing_data: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.transmit_outgoing_data -> chain.capture_command_frames: "[FE] RF command frame\n[LoRa Frame]" { class: fe }
chain.capture_command_frames -> chain.decode_command_state: "[FE] Captured frame\n[Command evidence]" { class: fe }

chain.timestamp_ui_events -> chain.capture_ui_log: "[FE] UI expected sequence\n[Evidence]" { class: fe }
chain.push_to_command_queue -> chain.capture_decoder_log: "[FE] Queued command\n[Evidence]" { class: fe }
chain.forward_to_transceiver -> chain.capture_decoder_log: "[FE] Forwarded command\n[Evidence]" { class: fe }
chain.generate_frame -> chain.capture_forwarder_log: "[FE] Generated frame\n[Evidence]" { class: fe }
chain.decode_command_state -> chain.compare_command_sequence: "[FE] Decoded RF commands\n[Evidence]" { class: fe }
chain.capture_ui_log -> chain.compare_command_sequence: "[FE] Expected sequence\n[Evidence]" { class: fe }
chain.capture_decoder_log -> chain.compute_success_stats: "[FE] Queue/forward counts\n[Evidence]" { class: fe }
chain.capture_forwarder_log -> chain.compute_success_stats: "[FE] Serial/frame counts\n[Evidence]" { class: fe }
chain.compare_command_sequence -> chain.compute_success_stats: "[FE] Matched commands\n[k/N]" { class: fe }
chain.compute_success_stats -> chain.archive_evidence: "[FE] Verdict and evidence\n[Test report input]" { class: fe }

chain.note_environment -> chain.configure_rf_capture { class: cstr }
chain.note_stimulus -> chain.issue_valid_toggles { class: cstr }
chain.note_pass -> chain.compare_command_sequence { class: cstr }
chain.note_statistics -> chain.compute_success_stats { class: cstr }
chain.note_fault_watch -> chain.capture_decoder_log { class: cstr }
chain.note_fault_watch -> chain.capture_forwarder_log { class: cstr }
chain.note_fault_watch -> chain.capture_command_frames { class: cstr }

# Layout-only edge: keep traceability near pass constraints without adding verification semantics.
chain.note_trace -> chain.note_pass { style: { opacity: 0 } }
