vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-PL-001 verification-only Physical Architecture PV1.
# v1.0 flight-readiness physical-link presence/retention/alignment inspection.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# This file is a test-definition view and does not modify the v1.0 baseline model.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

fixture: "[EA] Assembly Fixture /\nESD Support" { class: ea }
camera: "[EA] Calibrated Camera /\nMicroscope" { class: ea }
torque_pull: "[EA] Torque Tool /\nPull Gauge" { class: ea }
continuity_alignment: "[EA] Continuity /\nHeader Alignment Aids" { class: ea }

system: "[System] SAA-VV-PL-001 v1.0 Physical Link Inspection Testbench\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  cansat: "[PC] v1.0 CanSat Assembly\nunder PL inspection" {
    class: pc
    direction: right

    standard_stack: "[PC] Standard Carrier\nModule Stack\n(Type 1)" {
      class: pc
      direction: down

      ads_module: "[PC] ADS Module" {
        class: pc
        direction: right
        ads_pcb: "[PC] ADS PCB\n44 mm × 44 mm" { class: pc }
      }

      ams_module: "[PC] AMS Module" {
        class: pc
        direction: right
        ams_pcb: "[PC] AMS PCB\n44 mm × 44 mm" { class: pc }
      }

      obcc_module: "[PC] OBCC Module" {
        class: pc
        direction: right
        obcc_pcb: "[PC] OBCC PCB\n44 mm × 44 mm" { class: pc }
      }

      pds_module: "[PC] PDS Module" {
        class: pc
        direction: right
        pds_pcb: "[PC] PDS PCB\n44 mm × 44 mm" { class: pc }
      }

      ess_module: "[PC] ESS Module" {
        class: pc
        direction: right
        battery_pack: "[PC] ESS Battery Pack" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB\n100 mm × 28 mm\n2-layer stackup" {
      class: pc
      direction: down
      grid-columns: 1

      ads_headers: "[PC] 2 mm 2×6\nADS Headers" { class: pc }
      ams_headers: "[PC] 2 mm 2×6\nAMS Headers" { class: pc }
      obcc_headers: "[PC] 2 mm 2×6\nOBCC Headers" { class: pc }
      pds_headers: "[PC] 2 mm 2×6\nPDS Headers" { class: pc }
      pdm_servo_header: "[PC] PDM Servo\nConnector" { class: pc }
      spine: "[PC] Backplane Spine" { class: pc }
    }

    parachute_module: "[PC] Parachute / Top\nModule\n(Type 2)" {
      class: pc
      direction: down

      cap: "[PC] Cap" { class: pc }
      parachute: "[PC] Parachute" { class: pc }
      servo: "[PC] Servo" { class: pc }
    }
  }

  v10_link_census: "[C] v1.0 100% PL census target:\n5 stack-screw interfaces; 4 PCB\nstandoff/screw interfaces; 1 battery\nfixture; 1 perpendicular fixture +\nheader mating link; 1 backplane fixture\n+ servo connector link.\nEach modeled PL receives an inspection row." {
    class: note
    shape: page
  }

  pass_fail: "[C] v1.0 pass/fail constraint:\nPass only if every modeled PL is present,\ncorrectly endpointed, routed/mated, retained,\naligned, and free of looseness, interference,\ndamage, stripped bosses, bent pins, open/short\nevidence where applicable, or unapproved bypass.\nAny missing/extra/ambiguous link, wrong endpoint,\nloose fixture/screw, mis-mated header/connector,\nbattery slip, backplane/servo interference,\ndamaged pin/boss, open/short evidence, or\nmissing evidence = fail/hold." {
    class: note
    shape: page
  }

  inspection_conditions: "[C] Inspection conditions:\nUse stable assembly fixture, ESD handling,\nadequate lighting, calibrated camera/microscope,\ncurrent torque/retention or pull-gauge status,\nand continuity/alignment aids for electrical\nor mating links. Record handling or ambient\ndeviations that affect evidence quality." {
    class: note
    shape: page
  }

  stats_faults: "[C] Viewpoints:\nStatistical significance = 100% census of\nevery modeled v1.0 PL on each flight-readiness\narticle; no sampling or reliability claim.\nFault hardening = screens loose stack screws,\nPCB standoff/screw failures, battery fixture slip,\nheader/backplane misalignment, bent pins,\nservo connector unseat, open/short indications,\nand evidence-control escapes." {
    class: note
    shape: page
  }

  trace: "[C] Traceability target:\nSAA-UC-IntegratedAssembly;\nSAA-UC-BackplaneIntegration;\nSAA-UC-ParachuteClearance;\nSAA-FE-BackplaneMisMate;\nSAA-FE-StructuralLoosening;\nSAA-FE-LandingDamage;\nmodeled v1.0 physical-link and backplane\nretention/mating constraints." {
    class: note
    shape: page
  }
}

system.cansat.standard_stack.ads_module -- system.cansat.standard_stack.ams_module: "[PL] Stack screws\nPL-01" { class: pl }
system.cansat.standard_stack.ams_module -- system.cansat.standard_stack.obcc_module: "[PL] Stack screws\nPL-02" { class: pl }
system.cansat.standard_stack.obcc_module -- system.cansat.standard_stack.pds_module: "[PL] Stack screws\nPL-03" { class: pl }
system.cansat.standard_stack.pds_module -- system.cansat.standard_stack.ess_module: "[PL] Stack screws\nPL-04" { class: pl }
system.cansat.standard_stack -- system.cansat.parachute_module: "[PL] Stack screws\nPL-05" { class: pl }

system.cansat.standard_stack -- system.cansat.backplane_pcb: "[PL] Perpendicular fixture\n+ header mating\nPL-06" { class: pl }
system.cansat.parachute_module -- system.cansat.backplane_pcb: "[PL] Backplane fixture\n+ servo connector\nPL-07" { class: pl }

system.cansat.standard_stack.ads_module.ads_pcb -- system.cansat.standard_stack.ads_module: "[PL] PCB standoffs\n/ screws\nPL-08" { class: pl }
system.cansat.standard_stack.ams_module.ams_pcb -- system.cansat.standard_stack.ams_module: "[PL] PCB standoffs\n/ screws\nPL-09" { class: pl }
system.cansat.standard_stack.obcc_module.obcc_pcb -- system.cansat.standard_stack.obcc_module: "[PL] PCB standoffs\n/ screws\nPL-10" { class: pl }
system.cansat.standard_stack.pds_module.pds_pcb -- system.cansat.standard_stack.pds_module: "[PL] PCB standoffs\n/ screws\nPL-11" { class: pl }
system.cansat.standard_stack.ess_module.battery_pack -- system.cansat.standard_stack.ess_module: "[PL] Battery fixture\nPL-12" { class: pl }

fixture -- system.cansat: "[PL] UUT restraint\nand ESD-safe support" { class: pl }
camera -- system.cansat: "[PL] Optical evidence path\nand scale reference" { class: pl }
torque_pull -- system.cansat.standard_stack: "[PL] Stack / PCB / battery\nretention contact" { class: pl }
continuity_alignment -- system.cansat.backplane_pcb: "[PL] Header/connector alignment\nand continuity probe contact" { class: pl }

system.v10_link_census -> system.cansat { class: cstr }
system.pass_fail -> system.cansat.standard_stack { class: cstr }
system.pass_fail -> system.cansat.backplane_pcb { class: cstr }
system.pass_fail -> system.cansat.parachute_module { class: cstr }
system.inspection_conditions -> fixture { class: cstr }
system.inspection_conditions -> camera { class: cstr }
system.inspection_conditions -> torque_pull { class: cstr }
system.inspection_conditions -> continuity_alignment { class: cstr }
system.stats_faults -> system.cansat { class: cstr }
system.trace -> system.cansat { class: cstr }

# Layout-only edges keep equipment above the v1.0 article and notes below it.
fixture -> camera { style: { opacity: 0 } }
camera -> torque_pull { style: { opacity: 0 } }
torque_pull -> continuity_alignment { style: { opacity: 0 } }
continuity_alignment -> system { style: { opacity: 0 } }
system.cansat -> system.v10_link_census { style: { opacity: 0 } }
system.v10_link_census -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.inspection_conditions { style: { opacity: 0 } }
system.inspection_conditions -> system.stats_faults { style: { opacity: 0 } }
system.stats_faults -> system.trace { style: { opacity: 0 } }
