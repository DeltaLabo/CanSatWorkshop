ld_link\":null,\"field_meta_tags\":null,\"field_product_spotlight_sub_titl\":\"Innovate with our family of motion products with our latest offerings and state of the art MEMS designs\",\"field_product_spotlight_title\":\"Product Spotlight\",\"field_published_date\":null,\"field_short_description\":null,\"field_spotlight_products\":[{\"id\":\"55\",\"label\":\"ICM-45686\"},{\"id\":\"2\",\"label\":\"ICM-45605\"},{\"id\":\"57\",\"label\":\"ICM-42688-P\"},{\"id\":\"56\",\"label\":\" ICM-42670-P\"},{\"id\":\"26\",\"label\":\"ICM-42370-P\"},{\"id\":\"27\",\"label\":\"ICM-42686-P\"},{\"id\":\"63\",\"label\":\"ICM-40609-D\"},{\"id\":\"62\",\"label\":\"ICM-42605\"}],\"field_sub_category_grid_section\":[{\"id\":\"1099\",\"label\":\"Consumer \u003e Category grids\"},{\"id\":\"1104\",\"label\":\"Consumer \u003e Category grids\"},{\"id\":\"1105\",\"label\":\"Consumer \u003e Category grids\"},{\"id\":\"1106\",\"label\":\"Consumer \u003e Category grids\"},{\"id\":\"1107\",\"label\":\"Consumer \u003e Category grids\"},{\"id\":\"1108\",\"label\":\"Consumer \u003e Category grids\"},{\"id\":\"1152\",\"label\":\"Consumer \u003e Category grids\"},{\"id\":\"1153\",\"label\":\"Consumer \u003e Category grids\"}],\"field_sub_category_intro_paras\":[],\"field_sub_category_intro_title\":null,\"field_sub_category_section_subti\":\"From wearables to robotics, enable responsive, efficient, and immersive consumer experiences\",\"field_sub_category_section_title\":\"Enabling the next generation of Physical AI applications\",\"field_video_alignment\":null},\"field_description\":\"$25\",\"field_documentation_resource\":[{\"id\":\"2128\",\"label\":\"DS-000347 – ICM-42688-P Datasheet\",\"slug\":\"/ds-000347-icm-42688-p-datasheet\",\"nid\":\"2128\",\"uuid\":\"b0f28ec9-e538-47d9-8061-49ab400d1116\",\"vid\":\"10160\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1780332798\",\"revision_uid\":{\"id\":\"124658\",\"label\":\"jimlin\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"DS-000347 – ICM-42688-P Datasheet\",\"created\":\"1771474696\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"1224\",\"label\":\"DS-000347 ICM-42688-P v1.9.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"25\",\"label\":\"Datasheet\"},\"field_updated_date\":\"2026-06-01\",\"field_version\":\"1.9\"},{\"id\":\"2129\",\"label\":\"AN-000173 – ICM-426xx APEX Motion Functions: Description and Usage\",\"slug\":\"/000173-icm-426xx-apex-motion-functions-description-and-usage\",\"nid\":\"2129\",\"uuid\":\"3798390f-4aad-476a-905b-6b035a2fae90\",\"vid\":\"9528\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1774295020\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000173 – ICM-426xx APEX Motion Functions: Description and Usage\",\"created\":\"1771474779\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"1014\",\"label\":\"an-000173-icm-426xx-apex-motion-functions-description-and-usage.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2021-08-18\",\"field_version\":\"1.1\"},{\"id\":\"8356\",\"label\":\"HW-000097 – Ver-G SmartMotion Hardware User Guide\",\"slug\":\"/hw-000097-ver-g-smartmotion-hardware-user-guide\",\"nid\":\"8356\",\"uuid\":\"da7a7699-131b-4c4f-8955-a7ab5327c208\",\"vid\":\"9529\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1774295201\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"HW-000097 – Ver-G SmartMotion Hardware User Guide\",\"created\":\"1774295164\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"The DK-42688-P TDK SmartMotion Platform is a comprehensive development system for TDK InvenSense Motion Sensor devices. The platform designed around the Microchip SAMG55 MCU can be used by customers for rapid evaluation and development of InvenSense sensor-based solutions. The platform integrates an on-board Embedded Debugger so external tools are not required to program or debug with the SAMG55 MCU. Each InvenSense motion sensor has its own unique development kit.\",\"field_file\":{\"id\":\"1015\",\"label\":\"hw-000097-ver-g-smartmotion-hardware-user-guide.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2020-04-22\",\"field_version\":\"1.0\"},{\"id\":\"2141\",\"label\":\"AN-000300 – SmartMotion Platform User Guide\",\"slug\":\"/000300-smartmotion-platform-user-guide-2\",\"nid\":\"2141\",\"uuid\":\"edcf5035-5def-444e-a149-14c1c14241e4\",\"vid\":\"2914\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1771478065\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000300 – SmartMotion Platform User Guide\",\"created\":\"1771478065\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":null,\"field_file\":{\"id\":\"329\",\"label\":\"AN-000300-SmartMotion-Development-Platform-Ver.-G-Hardware-User-Guide-v1.2 (2).pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2024-02-16\",\"field_version\":\"1.2\"},{\"id\":\"8400\",\"label\":\"UG-ICM-42688-P – Software User Guide for ICM-42688-P\",\"slug\":\"/ug-icm-42688-p-software-user-guide-icm-42688-p\",\"nid\":\"8400\",\"uuid\":\"0710ce92-510a-4291-a041-47ea3d45f3c3\",\"vid\":\"9609\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1774516845\",\"revision_uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"UG-ICM-42688-P – Software User Guide for ICM-42688-P\",\"created\":\"1774516740\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"The purpose of this document is to give an overview of the ICM-426xx SmartMotion Development Kit that will allow users to run a predefined application based on motion sensors. This document may also serve as a quick start guide for the ICM-426xx package and its elements, including setup and how to use the sample applications provided.\",\"field_file\":{\"id\":\"1043\",\"label\":\"ug-icm-42688-p-software-user-guide-for-icm-42688-p.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2020-03-03\",\"field_version\":\"2.0\"},{\"id\":\"2169\",\"label\":\"AN-000393 – IMU PCB Design and MEMS Assembly Guidelines\",\"slug\":\"/000393-imu-pcb-design-and-mems-assembly-guidelines\",\"nid\":\"2169\",\"uuid\":\"8c9f57db-7a66-437e-9db2-6984494fbf32\",\"vid\":\"10161\",\"langcode\":\"en\",\"type\":{\"id\":\"documentation_resource\",\"label\":\"Documentation \u0026 Resources\"},\"revision_timestamp\":\"1780333281\",\"revision_uid\":{\"id\":\"124658\",\"label\":\"jimlin\"},\"revision_log\":null,\"status\":\"1\",\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"title\":\"AN-000393 – IMU PCB Design and MEMS Assembly Guidelines\",\"created\":\"1771635625\",\"promote\":\"1\",\"sticky\":\"0\",\"metatag\":[null,null,null],\"path\":null,\"menu_link\":null,\"field_dp_short_description\":\"This document provides high-level PCB design, sensor mounting, and handling guidelines for TDK IMU Products, which incorporate a combination of gyroscopes and accelerometers. Each sensor has specific requirements to ensure the highest performance in a finished product. For a layout assessment of your design, including placement and estimated temperature disturbances, please contact TDK.\",\"field_file\":{\"id\":\"1225\",\"label\":\"AN-000393 TDK InvenSense IMU PCB Design and MEMS Assembly Guidelines v2.4.pdf\"},\"field_learn_more\":null,\"field_type\":{\"id\":\"12\",\"label\":\"App Notes \u0026 User Guides\"},\"field_updated_date\":\"2026-06-01\",\"field_version\":\"2.4\"}],\"field_embedded_processor_s\":\"\u003cp\u003eAdvanced Pedometer and Event Detection (APEX)\u003c/p\u003e\",\"field_features\":\"\u003cp\u003ePedometer, Tilt Detection, Tap Detection, Wake on Motion, Raise – Wake/Sleep, Significant Motion Detection, Real Time Clock (RTC) input, 19/18 bit data format in FIFO for Gyro/Accel\u003c/p\u003e\",\"field_features_and_benefits\":\"$26\",\"field_features_listings\":[],\"field_key_attribute\":\"\u003cp\u003eHighest Performance 6-axis IMU with advanced motion features and events\u003c/p\u003e\",\"field_learn_more\":null,\"field_meta_tags\":null,\"field_part_number\":\"ICM-42688-P\",\"field_pins\":\"LGA 14-leads\",\"field_product_image\":[{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-03/product-img-icm-42688-p.png?VersionId=bdjTxuwjT_P.kZefGC3KMV8HTbcOHOU7\",\"alt\":\"Microchip with TDK logo and \\\"ICM-42688-P\\\" etched onto its surface\"}],\"field_product_key_features\":[{\"id\":\"855\",\"label\":\"ICM-42688-P \u003e Product key features\",\"uuid\":\"947aa6ee-3fa1-4b49-935b-e0