vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional allocation view
# Reconstruct the full allocation hierarchy while keeping the three main deployment bands readable.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] Physical System" {
  class: sys
  direction: down
  grid-columns: 1

  cansat: "[PC] CanSat" {
    class: pc
    direction: down

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: right

        cansat_rfm: "[PC] RFM95W LoRa" {
          class: pc
          direction: down

          cansat_lora: "[LC] LoRa Transceiver" {
            class: lc
            direction: down
            cansat_receive_incoming_data: "[F] Receive incoming data" { class: func }
            cansat_transmit_outgoing_data: "[F] Transmit outgoing data" { class: func }
          }
        }

        cansat_xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down
          grid-columns: 2

          obcc: "[LC] OBCC" {
            class: lc
            direction: down
            cansat_receive_lora_rx_interrupt: "[F] Receive LoRa\nRX Interrupt" { class: func }
            send_lora_packet: "[F] Send LoRa packet" { class: func }
            obcc_read_command: "[F] Read command" { class: func }
          }

          ess_processing: "[LC] ESS Processing" { class: lc }
          ads_processing: "[LC] ADS Processing" { class: lc }
          pdm_processing: "[LC] PDM Processing" { class: lc }
          ams_processing: "[LC] AMS Processing" { class: lc }
        }

        cansat_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }
  }

  ground_station_pcb: "[PC] Ground Station PCB" {
    class: pc
    direction: right

    ground_rfm: "[PC] RFM95W LoRa" {
      class: pc
      direction: down

      ground_lora: "[LC] LoRa Transceiver" {
        class: lc
        direction: down
        ground_store_incoming_data: "[F] Store incoming data" { class: func }
        ground_transmit_outgoing_data: "[F] Transmit outgoing data" { class: func }
      }
    }

    ground_xiao: "[PC] XIAO ESP32" {
      class: pc
      direction: down

      ground_forwarder: "[LC] LoRa Forwarder" {
        class: lc
        direction: down
        grid-columns: 3

        init_serial0_with_interrupts: "[F] Init Serial0 with\ninterrupts" { class: func }
        init_spi_with_interrupts: "[F] Init SPI with\ninterrupts" { class: func }
        log_error: "[F] Log error" { class: func }
        ground_receive_lora_rx_interrupt: "[F] Receive LoRa\nRX Interrupt" { class: func }
        read_payload: "[F] Read payload" { class: func }
        forward_to_pc: "[F] Forward to PC" { class: func }
        store_incoming_uart_data: "[F] Store incoming\nUART data" { class: func }
        receive_serial0_rx_interrupt: "[F] Receive Serial0\nRX Interrupt" { class: func }
        forwarder_read_command: "[F] Read command" { class: func }
        generate_frame: "[F] Generate frame" { class: func }
        write_to_lora_radio: "[F] Write to\nLoRa Radio" { class: func }
      }
    }
  }

  pc: "[PC] PC" {
    class: pc
    direction: down
    grid-columns: 2

    decoder: "[LC] Decoder" {
      class: lc
      direction: down
      grid-columns: 3

      check_if_data_is_available: "[F] Check if data\nis available" { class: func }
      read_and_decode_frame: "[F] Read and\ndecode frame" { class: func }
      push_to_payload_queue: "[F] Push to\npayload queue" { class: func }
      get_rx_timestamp: "[F] Get RX\ntimestamp" { class: func }
      calculate_latency: "[F] Calculate\nlatency" { class: func }
      forward_to_transceiver: "[F] Forward to\ntransceiver" { class: func }
      consume_command_queue: "[F] Consume\ncommand queue" { class: func }
    }

    csv_writer: "[LC] CSV Writer" {
      class: lc
      direction: down

      csv_consume_payload_queue: "[F] Consume\npayload queue" { class: func }
      append_to_csv: "[F] Append to CSV" { class: func }

      note_csv_name: "[C] Give each CSV a\nunique name based\non the initial\ntimestamp" {
        class: note
        shape: page
      }
    }

    dashboard: "[LC] Dashboard" {
      class: lc
      direction: down
      grid-columns: 2

      dashboard_consume_payload_queue: "[F] Consume\npayload queue" { class: func }
      update_orientation_3d_plot: "[F] Update orientation\n3D plot" { class: func }
      update_rel_humidity_2d_plot: "[F] Update rel.\nhumidity 2D plot" { class: func }
      push_to_command_queue: "[F] Push to\ncommand queue" { class: func }
      update_temperature_2d_plot: "[F] Update temperature\n2D plot" { class: func }
      update_altitude_2d_plot: "[F] Update altitude\n2D plot" { class: func }
      catch_state_toggle: "[F] Catch State\ntoggle" { class: func }
      update_latency_alert: "[F] Update latency\nalert" { class: func }
      disable_toggle: "[F] Disable\ntoggle" { class: func }
      enable_toggle: "[F] Enable\ntoggle" { class: func }
      cooldown: "[F] Cooldown" { class: func }
      create_plots: "[F] Create plots" { class: func }
    }

    note_alert: "[C] Show text alert at\nthe top of the\ndashboard when\nLatency > 1s" {
      class: note
      shape: page
    }

    note_cooldown: "[C] 5 seconds" {
      class: note
      shape: page
    }

    note_plots: "[C] A 4x4 matrix of\nplots, 3D on top left" {
      class: note
      shape: page
    }

    usb_port: "[PC] USB Port" {
      class: pc
      direction: down

      usb_power: "[LC] USB Power" {
        class: lc
        direction: down
        provide_power: "[F] Provide power" { class: func }
      }
    }

    note_concurrent: "[C] Concurrent\nexecution" {
      class: note
      shape: page
    }

    note_browser: "[C] Accesible via\na web browser" {
      class: note
      shape: page
    }
  }
}

note_separation: "[C] Max. separation of 500m\nbetween CanSat and DPS" {
  class: note
  shape: page
}

system.pc.csv_writer.note_csv_name -> system.pc.csv_writer.append_to_csv { class: cstr }
system.pc.note_alert -> system.pc.dashboard.update_latency_alert { class: cstr }
system.pc.note_cooldown -> system.pc.dashboard.cooldown { class: cstr }
system.pc.note_plots -> system.pc.dashboard.create_plots { class: cstr }
system.pc.note_concurrent -> system.pc.decoder { class: cstr }
system.pc.note_concurrent -> system.pc.csv_writer { class: cstr }
system.pc.note_concurrent -> system.pc.dashboard { class: cstr }
system.pc.note_browser -> system.pc.dashboard { class: cstr }
note_separation -> system.cansat { class: cstr }
note_separation -> system.ground_station_pcb { class: cstr }

# Layout-only edges to preserve the original banding.
system.cansat -> system.ground_station_pcb { style: { opacity: 0 } }
system.ground_station_pcb -> system.pc { style: { opacity: 0 } }
