vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PDM-V01-FC-FALL source inventory and IVV coverage/gap view.
# Functional-allocation style view: PCs, LCs, functions, EAs, and constraints only.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] PDM v0.1 source inventory\nPDM-V01-FC-FALL coverage/gap view\nRefs: PDM_v0.1 views 1-4; PM&SE/IVV.md; CON-003 PDM-BLK-007" {
  class: sys
  direction: down

  dummy_cansat: "[PC] Dummy CanSat" {
    class: pc
    direction: down

    top_module: "[PC] Top module" {
      class: pc
      direction: down

      parachute: "[PC] Parachute" {
        class: pc
        direction: down

        descent_speed_control: "[LC] Descent speed control" {
          class: lc
          direction: down

          limit_terminal_speed: "[F] Limit terminal speed" { class: func }
        }
      }
    }
  }
}

source_human_tester: "[EA] Human Tester\n(source actor)" {
  class: ea
  direction: down
  grid-columns: 1

  record_fall: "[F] Record fall" { class: func }
  release_dummy: "[F] Release dummy" { class: func }
  measure_terminal_speed: "[F] Measure terminal\nspeed from video" { class: func }
}

same_weight: "[C] Same weight as\nfinal estimate" { class: note; shape: page }
foldable_deployed_manually: "[C] Foldable, but\ndeployed manually" { class: note; shape: page }
with_parachute_open: "[C] With\nparachute open" { class: note; shape: page }
terminal_speed_max: "[C] 11 m/s max." { class: note; shape: page }

activity_scope: "[C] PDM-V01-FC-FALL models the\nv0.1 fall-test chain, all relevant v0.1 constraints,\nand linked PC/allocation evidence." { class: note; shape: page }
no_source_pl: "[C] Source v0.1 has no modeled\nphysical links; do not invent\nsource PL coverage." { class: note; shape: page }
no_source_ce: "[C] Source v0.1 has no modeled\ncomponent exchanges; record CE\ncoverage as a v0.1 gap/N/A." { class: note; shape: page }
allocation_scope: "[C] Allocation target:\n[LC] Descent speed control is\nallocated to [PC] Parachute and\ncontains [F] Limit terminal speed." { class: note; shape: page }
pdm_blk_criteria: "[C] PDM-BLK-007 strict interpretation\ncriteria: mass/config `+/-5%` or `+/-10 g` (tighter),\nscale resolution `<= 1 g` or equivalent uncertainty,\nretained video/timebase `>=30 fps` unless calibrated equivalent,\ndistance calibration uncertainty `<=5%`, accepted segment\nafter open/stable and before ground-effect/landing disturbance,\nterminal speed + uncertainty `<= 11 m/s`,\nwind `<= 3 m/s` or justified indoor/still-air equivalent,\npredeclared anomaly/exclusion rules, and\n3 repetitions as development screening only." { class: note; shape: page }

same_weight -> system.dummy_cansat { class: cstr }
foldable_deployed_manually -> system.dummy_cansat.top_module.parachute { class: cstr }
with_parachute_open -> source_human_tester.release_dummy { class: cstr }
terminal_speed_max -> system.dummy_cansat.top_module.parachute.descent_speed_control.limit_terminal_speed { class: cstr }
activity_scope -> system { class: cstr }
no_source_pl -> system.dummy_cansat { class: cstr }
no_source_ce -> system.dummy_cansat.top_module.parachute.descent_speed_control { class: cstr }
allocation_scope -> system.dummy_cansat.top_module.parachute.descent_speed_control { class: cstr }
pdm_blk_criteria -> system.dummy_cansat { class: cstr }
