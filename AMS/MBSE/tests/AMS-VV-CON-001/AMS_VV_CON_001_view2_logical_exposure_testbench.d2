vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Logical view — AMS-VV-CON-001 exposure verification interfaces
# Verification references: IVV, AMS-R3 (thermal/meteorological exposure), AMS-R6 (CanSat environmental context), AMS-R5 (paired-sample statistics if used).
# Traceability: [C] Block sunlight, allow airflow; AMS-FE-BadExposure; AMS-UC-MeasureAtmosphere; temperature-accuracy constraint context.
# IADT: Inspection / Demonstration for AMS v1.0 final acceptance.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-CON-001 exposure verification\nAMS v1.0 final acceptance\nRefs: IVV, AMS-R3, AMS-R6, AMS-R5" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: right

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down

        bme280: "[PC] BME280" {
          class: pc
          direction: down

          ams_sensing: "[LC] AMS Sensing" { class: lc }
        }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down
          grid-columns: 1

          ams_processing: "[LC] AMS Processing" { class: lc }
          exposure_vv_instrumentation: "[LC] Exposure Verification\nInstrumentation\n(VV-only)" {
            class: lc

            note_no_accuracy_credit: "[C] Optional paired temperature-bias\nevidence hardens exposure assessment;\nit does not replace AMS-VV-FC-001\nmeasurement accuracy verification" {
              class: note
              shape: page
            }
          }
        }
      }
    }
  }
}

inspector_operator: "[EA] Inspector /\nTest Operator" {
  class: ea
  direction: down
  grid-columns: 1

  note_iadt: "[C] IADT: Inspection / Demonstration;\nreport by reference to this model definition;\nexecution evidence goes to results/AMS-VV-CON-001" {
    class: note
    shape: page
  }
}

exposure_equipment: "[EA] Exposure and\nMeasurement Equipment" {
  class: ea
  direction: down
  grid-columns: 1

  note_fault_hardening: "[C] Fault-hardening targets: direct radiation,\nblocked ventilation, heat-soak bias, fixture/wire\nobstruction, and unmodeled temporary shielding" {
    class: note
    shape: page
  }
}

evidence_repository: "[EA] Evidence\nRepository" { class: ea }

note_scope: "[C] AMS-VV-CON-001 verifies the\nphysical/environmental exposure constraint:\nblock sunlight while preserving airflow" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb.bme280.ams_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] I2C" { class: ce }
inspector_operator -> system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation: "[CE] Procedure ↔\nstatus/results" { class: ce }
exposure_equipment -> system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation: "[CE] Ambient/exposure\nreadings" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] Temp.\n↔" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation -> evidence_repository: "[CE] Evidence record /\nraw paired samples" { class: ce }

system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation.note_no_accuracy_credit -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
inspector_operator.note_iadt -> system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation { class: cstr }
exposure_equipment.note_fault_hardening -> system.cansat.ams_module.ams_pcb.bme280.ams_sensing { class: cstr }
exposure_equipment.note_fault_hardening -> system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation { class: cstr }
note_scope -> system.cansat.ams_module.ams_pcb.bme280.ams_sensing { class: cstr }
note_scope -> system.cansat.obcc_module.obcc_pcb.xiao.exposure_vv_instrumentation { class: cstr }

# Layout-only edges to keep logical UUT, operator, equipment, and repository in readable bands.
system -> inspector_operator { style: { opacity: 0 } }
inspector_operator -> exposure_equipment { style: { opacity: 0 } }
exposure_equipment -> evidence_repository { style: { opacity: 0 } }
