vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PDS-VV-CON-004 functional chain: transient and fault-hardening rail checks.
# References: IVV, PDS-R2, PDS-R6, PDS-R8.
# Traceability: [C] Supply both 5±0.1 V and 3.3±0.1 V, 1 A;
# PDS-UC-ProvideRegulatedPower; PDS-FE-RailBrownout.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "PDS-VV-CON-004 — transient / fault-hardening chain\n(IVV, PDS-R2, PDS-R6, PDS-R8)" {
  class: chain
  direction: down

  read_ambient: "[F] Read ambient\nbefore transient trials" { class: func }
  set_limits: "[F] Set battery emulator\ncurrent and thermal limits" { class: func }
  arm_logging: "[F] Arm oscilloscope, DAQ,\nand reset logging" { class: func }
  apply_input: "[F] Apply emulated\nbattery input" { class: func }
  command_switch_on: "[F] Press / command\nswitch on" { class: func }
  regulate_voltage: "[F] Regulate voltage" { class: func }
  capture_startup: "[F] Capture startup\novershoot and ripple" { class: func }
  sample_startup_settled: "[F] Collect post-startup\nsettled rail samples" { class: func }
  observe_startup_brownout: "[F] Observe no startup\nbrownout / reset" { class: func }

  command_5v_step: "[F] Command 5 V load step\nno-load ↔ nominal ↔ 1 A" { class: func }
  capture_5v_recovery: "[F] Capture 5 V\ntransient recovery" { class: func }
  command_3v3_step: "[F] Command 3V3 load step\nno-load ↔ nominal ↔ 1 A" { class: func }
  capture_3v3_recovery: "[F] Capture 3V3\ntransient recovery" { class: func }
  observe_step_brownout: "[F] Observe no load-step\nbrownout / reset" { class: func }
  monitor_current_temperature: "[F] Monitor current and\nregulator temperature" { class: func }
  command_switch_off: "[F] Press / command\nswitch off" { class: func }
  compare_fault_constraints: "[F] Compare transient and\nfault-hardening constraints" { class: func }
  store_evidence: "[F] Store waveforms, logs,\nand pass/fail result" { class: func }

  note_transient: "[C] Startup / transient pass:\nafter campaign-configurable settling\n(placeholder: ≤100 ms startup,\n≤50 ms load step), 5 V is in [4.9, 5.1] V\nand 3.3 V is in [3.2, 3.4] V." {
    class: note
    shape: page
  }

  note_fault: "[C] Fault-hardening viewpoint:\nno brownout/reset, uncontrolled current,\nunsafe temperature, latch-up, smoke,\nor unexpected protection cut-off during\nstartup or load-step trials." {
    class: note
    shape: page
  }

  note_stats: "[C] Statistical significance viewpoint:\nclassify each startup/load-step trial pass/fail;\nretain waveforms and post-settling samples.\nReliability claims require binomial confidence\nplanning beyond workshop screening." {
    class: note
    shape: page
  }

  note_safety: "[C] Safety scope:\nuse current-limited battery emulator;\nreal Li-ion destructive abuse, short-circuit\nabuse, and transport certification tests\nare outside PDS-VV-CON-004." {
    class: note
    shape: page
  }

  note_trace: "[C] Trace / references:\nConstraint PDS-VV-CON-004;\nPDS-UC-ProvideRegulatedPower;\nPDS-FE-RailBrownout;\nIVV, PDS-R2, PDS-R6, PDS-R8." {
    class: note
    shape: page
  }
}

chain.read_ambient -> chain.set_limits: "[FE] ambient precheck" { class: fe }
chain.set_limits -> chain.arm_logging: "[FE] safe trial limits" { class: fe }
chain.arm_logging -> chain.apply_input: "[FE] trigger-ready setup" { class: fe }
chain.apply_input -> chain.command_switch_on: "[FE] emulated battery power" { class: fe }
chain.command_switch_on -> chain.regulate_voltage: "[FE] power-on command" { class: fe }
chain.regulate_voltage -> chain.capture_startup: "[FE] startup rails" { class: fe }
chain.capture_startup -> chain.sample_startup_settled: "[FE] startup waveform" { class: fe }
chain.sample_startup_settled -> chain.observe_startup_brownout: "[FE] post-startup rail data" { class: fe }
chain.observe_startup_brownout -> chain.command_5v_step: "[FE] no reset observed" { class: fe }
chain.command_5v_step -> chain.capture_5v_recovery: "[FE] 5 V load transient" { class: fe }
chain.capture_5v_recovery -> chain.command_3v3_step: "[FE] 5 V recovery data" { class: fe }
chain.command_3v3_step -> chain.capture_3v3_recovery: "[FE] 3V3 load transient" { class: fe }
chain.capture_3v3_recovery -> chain.observe_step_brownout: "[FE] 3V3 recovery data" { class: fe }
chain.observe_step_brownout -> chain.monitor_current_temperature: "[FE] reset status" { class: fe }
chain.monitor_current_temperature -> chain.command_switch_off: "[FE] safe thermal/current state" { class: fe }
chain.command_switch_off -> chain.compare_fault_constraints: "[FE] completed trial" { class: fe }
chain.compare_fault_constraints -> chain.store_evidence: "[FE] pass/fail decision" { class: fe }

chain.note_transient -> chain.capture_startup { class: cstr }
chain.note_transient -> chain.capture_5v_recovery { class: cstr }
chain.note_transient -> chain.capture_3v3_recovery { class: cstr }
chain.note_fault -> chain.observe_startup_brownout { class: cstr }
chain.note_fault -> chain.observe_step_brownout { class: cstr }
chain.note_fault -> chain.monitor_current_temperature { class: cstr }
chain.note_stats -> chain.compare_fault_constraints { class: cstr }
chain.note_trace -> chain.store_evidence { class: cstr }
