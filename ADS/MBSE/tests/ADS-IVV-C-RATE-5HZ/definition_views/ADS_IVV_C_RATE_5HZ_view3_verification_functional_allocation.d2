vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Verification-only functional allocation for ADS-IVV-C-RATE-5HZ.
# Allocates human, equipment, firmware, and analysis functions for the 5 Hz constraint verification.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-C-RATE-5HZ\nVerification-only functional allocation\nRefs: IVV; SW/stats; ADS MBSE plan" {
  class: sys
  direction: down

  selected_uut: "[PC] Selected ADS UUT\nv0.1 or v0.2 for execution" {
    class: pc
    direction: down
    timing_interface: "[LC] Loop timing observation\ninterface" {
      class: lc
      direction: down
      grid-columns: 2
      expose_collect: "[F] Expose Collect\nmeasurements execution" { class: func }
      emit_internal_ts: "[F] Emit firmware\ncollection timestamp" { class: func }
      emit_sample_id: "[F] Emit monotonically\nincreasing sample ID" { class: func }
      emit_status: "[F] Emit stale/drop/\nvalidity markers" { class: func }
      expose_loop_progress: "[F] Expose loop progress\nand stall marker" { class: func }
      constrain_probe: "[F] Bound timestamp\ninstrumentation overhead" { class: func }
    }
  }
}

conductor: "[EA] IVV rate test conductor" {
  class: ea
  direction: down
  grid-columns: 2
  select_baseline: "[F] Select version, source\nview copy, firmware commit" { class: func }
  select_tolerance: "[F] Select jitter and\nworst-gap tolerance before run" { class: func }
  start_stop: "[F] Start/stop run and\nmark repetitions" { class: func }
  review_environment: "[F] Read power/ambient\nconditions and calibration state" { class: func }
  record_deviations: "[F] Record anomalies,\nwaivers, limitations, retest" { class: func }
}

serial_logger: "[EA] PC serial logger /\nhost timestamping tool" {
  class: ea
  direction: down
  grid-columns: 2
  capture_serial: "[F] Capture Serial0\nrecords and raw bytes" { class: func }
  timestamp_lines: "[F] Timestamp received\nrecords against timebase" { class: func }
  detect_missing: "[F] Detect missing,\nduplicate, stale records" { class: func }
  preserve_logs: "[F] Preserve immutable\nraw log files" { class: func }
}

firmware_tool: "[EA] Firmware instrumentation\nand build tool" {
  class: ea
  direction: down
  grid-columns: 2
  add_hooks: "[F] Add optional timestamp\nhooks around collection" { class: func }
  build_flash: "[F] Build and flash\ninstrumented firmware" { class: func }
  measure_overhead: "[F] Estimate hook\noverhead and clock resolution" { class: func }
  preserve_config: "[F] Preserve build flags\nand instrumentation config" { class: func }
}

reference_clock: "[EA] Reference clock /\ntimebase" {
  class: ea
  direction: down
  grid-columns: 2
  provide_timebase: "[F] Provide reference\ntimebase to logger" { class: func }
  verify_drift: "[F] Verify logger clock\ndrift/wrap before and after" { class: func }
}

analysis_tool: "[EA] Rate analysis script" {
  class: ea
  direction: down
  grid-columns: 2
  parse_records: "[F] Parse timestamped\ncollection records" { class: func }
  compute_periods: "[F] Compute periods,\nmean rate, and jitter" { class: func }
  compute_worst_gap: "[F] Compute worst gap\nand dropped-sample count" { class: func }
  check_stale: "[F] Check stale values\nand validity markers" { class: func }
  apply_n59: "[F] Apply n = 59 rule\nfor formal tolerance claim" { class: func }
  produce_verdict: "[F] Produce pass/fail,\nblocked, or limited verdict" { class: func }
}

power_ambient: "[EA] Power and ambient\nmonitor" {
  class: ea
  direction: down
  grid-columns: 2
  log_voltage: "[F] Log supply voltage\nand current" { class: func }
  log_ambient: "[F] Read ambient temperature\nand humidity" { class: func }
}

quality: "[EA] IVV reviewer /\nconfiguration authority" {
  class: ea
  direction: down
  grid-columns: 1
  review_trace: "[F] Review traceability\nand model baseline" { class: func }
  approve_result: "[F] Approve verdict or\nblocked/limited rationale" { class: func }
}

note_pass: "[C] Pass/fail constraint\nNominal period is 200 ms. Pass only if selected\npre-execution mean-rate, per-sample period, worst-gap,\nstale-value, and dropped-value criteria are all met." { class: note; shape: page }
note_gate: "[C] Blocking constraint\nIf allowed jitter/worst-gap tolerance is not fixed before\nexecution, final rate verdict is blocked/limited even if\nmeasurements were collected." { class: note; shape: page }
note_stats: "[C] Statistical viewpoint\nUse complete campaign records. For a formal deadline/\ntolerance claim, use n = 59 representative samples and\nrequire every sample inside the chosen limit." { class: note; shape: page }
note_faults: "[C] Fault-hardening viewpoint\nEvaluate loop stalls, serial backpressure, timestamp loss,\nclock drift/wrap, stale values, and dropped/duplicated records." { class: note; shape: page }
note_na: "[C] N/A versions\nv0.3 has no behavior model. v1.0 has no explicit ADS 5 Hz\nconstraint in the current model; report observed rate only\nas information unless a new constraint is added." { class: note; shape: page }

note_pass -> analysis_tool.compute_periods { class: cstr }
note_pass -> analysis_tool.compute_worst_gap { class: cstr }
note_pass -> analysis_tool.check_stale { class: cstr }
note_gate -> conductor.select_tolerance { class: cstr }
note_gate -> analysis_tool.produce_verdict { class: cstr }
note_stats -> analysis_tool.apply_n59 { class: cstr }
note_faults -> system.selected_uut.timing_interface.expose_loop_progress { class: cstr }
note_faults -> serial_logger.detect_missing { class: cstr }
note_na -> quality.review_trace { class: cstr }

# Layout-only edge to stack verification means under the UUT.
system -> conductor { style: { opacity: 0 } }
conductor -> serial_logger { style: { opacity: 0 } }
serial_logger -> firmware_tool { style: { opacity: 0 } }
firmware_tool -> reference_clock { style: { opacity: 0 } }
reference_clock -> analysis_tool { style: { opacity: 0 } }
analysis_tool -> power_ambient { style: { opacity: 0 } }
power_ambient -> quality { style: { opacity: 0 } }
quality -> note_pass { style: { opacity: 0 } }
note_pass -> note_gate { style: { opacity: 0 } }
note_gate -> note_stats { style: { opacity: 0 } }
note_stats -> note_faults { style: { opacity: 0 } }
note_faults -> note_na { style: { opacity: 0 } }
