vars: {
  d2-config: {
    layout-engine: elk
  }
}

# DPS-V10-T-003A functional chain: valid CanSat command receive test sequence.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 32 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 28 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 34
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 26 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 24 } }
}

chain: "DPS-V10-T-003A — Valid CanSat command receive test\nIADT: Testing; Refs: P0,R1-R5,R8-R13; Trace: FC03 CanSat receive path; Report: tests/results/DPS-V10-T-003/" {
  class: chain
  direction: down

  op_confirm_baseline: "[F] Operator confirms\nDPS v1.0 baseline" { class: func }
  configure_lora_settings: "[F] Configure LoRa\ncommand transmitter" { class: func }
  arm_obcc_debug_capture: "[F] Arm OBCC debug\nand interrupt capture" { class: func }
  start_valid_sequence: "[F] Start valid-command\nsequence" { class: func }
  generate_valid_commands: "[F] Generate 60 valid\ncommand frames" { class: func }
  log_command_sequence: "[F] Log command sequence\nand TX timestamps" { class: func }

  receive_incoming_data: "[F] Receive incoming data" { class: func }
  receive_lora_rx_interrupt: "[F] Receive LoRa\nRX Interrupt" { class: func }
  read_command: "[F] Read command" { class: func }
  capture_rx_interrupts: "[F] Capture LoRa RX\ninterrupt evidence" { class: func }
  capture_command_reads: "[F] Capture OBCC command\nread results" { class: func }
  capture_tx_log: "[F] Capture transmitter\ncommand log" { class: func }
  compare_acceptance: "[F] Compare accepted\ncommands to TX log" { class: func }
  compute_success_stats: "[F] Compute command-receive\nsuccess verdict" { class: func }
  archive_evidence: "[F] Archive evidence\nin results folder" { class: func }

  note_trace: "[C] Traceability target: inferred use case 'OBCC receives wireless state command'.\nSource model FC03 CanSat receive path. Formal mission/capability IDs remain TBD." {
    class: note
    shape: page
  }

  note_environment: "[C] Environment/setup constraint: RF geometry/attenuator, LoRa settings,\nantenna state, OBCC debug monitor connection, timebase, software revisions and\nevidence directory are recorded before the run." {
    class: note
    shape: page
  }

  note_stimulus: "[C] Stimulus constraint: N≥60 valid command frames, known state/sequence,\nknown payload framing/CRC, and no intentional corruption in this sequence." {
    class: note
    shape: page
  }

  note_pass: "[C] Pass constraints: every valid command frame is observed by OBCC read\nexactly once with the expected state/sequence; zero missing, wrong-state,\nduplicate or stale command acceptances." {
    class: note
    shape: page
  }

  note_statistics: "[C] Statistical viewpoint: 60/60 valid command accepts gives a one-sided\n95% exact-binomial lower bound of about 0.95 for controlled command-receive\nsuccess; record k/N if N differs." {
    class: note
    shape: page
  }

  note_fault_watch: "[C] Fault-hardening watch items: missing RX interrupt, old-buffer reuse,\nduplicate read, stale previous command, debug-probe reset, or missing evidence\nis a failure or report anomaly/limitation." {
    class: note
    shape: page
  }
}

chain.op_confirm_baseline -> chain.configure_lora_settings: "[FE] Baseline OK\n[Test condition]" { class: fe }
chain.configure_lora_settings -> chain.arm_obcc_debug_capture: "[FE] RF settings ready\n[Test condition]" { class: fe }
chain.arm_obcc_debug_capture -> chain.start_valid_sequence: "[FE] Capture ready\n[Test condition]" { class: fe }
chain.start_valid_sequence -> chain.generate_valid_commands: "[FE] Start trigger\n[Test control]" { class: fe }
chain.generate_valid_commands -> chain.receive_incoming_data: "[FE] Valid command frame\n[LoRa Frame]" { class: fe }
chain.generate_valid_commands -> chain.log_command_sequence: "[FE] TX command sequence\n[Reference log]" { class: fe }

chain.receive_incoming_data -> chain.receive_lora_rx_interrupt: "[FE] Interrupt []" { class: fe }
chain.receive_incoming_data -> chain.read_command: "[FE] Frame\n[LoRa Frame]" { class: fe }
chain.receive_lora_rx_interrupt -> chain.read_command: "[FE] Flag []" { class: fe }
chain.receive_lora_rx_interrupt -> chain.capture_rx_interrupts: "[FE] Interrupt event\n[Evidence]" { class: fe }
chain.read_command -> chain.capture_command_reads: "[FE] Command read\n[State/sequence]" { class: fe }

chain.log_command_sequence -> chain.capture_tx_log: "[FE] TX reference\n[Evidence]" { class: fe }
chain.capture_command_reads -> chain.compare_acceptance: "[FE] Accepted commands\n[Evidence]" { class: fe }
chain.capture_tx_log -> chain.compare_acceptance: "[FE] Expected commands\n[Evidence]" { class: fe }
chain.capture_rx_interrupts -> chain.compute_success_stats: "[FE] Interrupt counts\n[Evidence]" { class: fe }
chain.compare_acceptance -> chain.compute_success_stats: "[FE] Matched accepts\n[k/N]" { class: fe }
chain.compute_success_stats -> chain.archive_evidence: "[FE] Verdict and evidence\n[Test report input]" { class: fe }

chain.note_environment -> chain.configure_lora_settings { class: cstr }
chain.note_environment -> chain.arm_obcc_debug_capture { class: cstr }
chain.note_stimulus -> chain.generate_valid_commands { class: cstr }
chain.note_pass -> chain.compare_acceptance { class: cstr }
chain.note_statistics -> chain.compute_success_stats { class: cstr }
chain.note_fault_watch -> chain.capture_command_reads { class: cstr }
chain.note_fault_watch -> chain.capture_rx_interrupts { class: cstr }

# Layout-only edge: keep traceability near pass constraints without adding verification semantics.
chain.note_trace -> chain.note_pass { style: { opacity: 0 } }
