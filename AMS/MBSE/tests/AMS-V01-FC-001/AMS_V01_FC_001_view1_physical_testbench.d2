vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view — AMS-V01-FC-001 breadboard functional-chain testbench
# Verification references: IVV, AMS-R1 (BME280), AMS-R3/R4 (metrology/atmosphere), AMS-R5 (statistics), AMS-R6 (CanSat bench context).
# IADT: Testing / Demonstration. SSIV: AMS v0.1 readiness gate to v0.2 PCB delivery.
# Traceability: AMS-v0.1-to-v0.2-readiness; AMS-UC-MeasureAtmosphere; AMS-UC-InitializePeripheral; AMS-UC-LogSerialTelemetry; AMS-FE-SensorBusFault.
# Physical view contains only physical components, external actors/equipment, physical links, and constraints.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-V01-FC-001 breadboard chain test\nAMS v0.1 → v0.2 readiness; Refs: IVV, AMS-R1, AMS-R3/R4/R5/R6" {
  class: sys
  direction: right

  bme280: "[PC] BME280\n(v0.1 breadboard)" { class: pc }
  xiao: "[PC] XIAO ESP32\n(v0.1 breadboard)" { class: pc }
  probe_points: "[PC] Breadboard Serial/I2C\nProbe Points (VV-only)" { class: pc }
}

bench_operator: "[EA] Bench Operator" { class: ea }
host_pc: "[EA] Host PC Serial\nTerminal / Data Logger" { class: ea }
reference_thermometer: "[EA] Reference Thermometer\n(traceable logger)" { class: ea }
pressure_reference: "[EA] Reference Barometer /\nPressure Reference" { class: ea }
bench_power: "[EA] Bench Power /\nUSB Current Monitor" { class: ea }
logic_analyzer: "[EA] Logic Analyzer /\nTimer (optional)" { class: ea }

note_scope: "[C] v0.1 breadboard FC test; VV equipment\nshall not bypass or replace the modeled BME280↔XIAO\nI2C, 3V3, GND, and USB serial links" {
  class: note
  shape: page
}
note_environment: "[C] Record ambient before repetitions: reference\nthermometer colocated with BME280 and pressure\nreference sharing the same bench pressure volume" {
  class: note
  shape: page
}
note_power: "[C] Stable bench power required; record voltage/current\nbefore and after measurement and smoke sequences" {
  class: note
  shape: page
}
note_probe: "[C] Logic-analyzer probes, if used, shall be high impedance\nand shall not alter I2C timing enough to invalidate the breadboard run" {
  class: note
  shape: page
}

system.bme280 -- system.xiao: "[PL] I2C Cables" { class: pl }
system.bme280 -- system.xiao: "[PL] 3V3" { class: pl }
system.bme280 -- system.xiao: "[PL] GND" { class: pl }
system.xiao -- host_pc: "[PL] USB-C Serial0\nlog cable" { class: pl }
bench_power -- system.xiao: "[PL] USB power /\ncurrent monitor" { class: pl }
bench_power -- system.bme280: "[PL] 3V3/GND\nmonitor" { class: pl }
reference_thermometer -- system.bme280: "[PL] Co-located\nambient probe" { class: pl }
pressure_reference -- system.bme280: "[PL] Shared pressure\nvolume / port" { class: pl }
system.bme280 -- system.probe_points: "[PL] SDA/SCL\nprobe clips" { class: pl }
system.xiao -- system.probe_points: "[PL] Serial0/I2C\nprobe clips" { class: pl }
logic_analyzer -- system.probe_points: "[PL] High-Z timing\ntest leads" { class: pl }
bench_operator -- system.xiao: "[PL] Manual reset /\nlaunch access" { class: pl }

note_scope -> system { class: cstr }
note_environment -> reference_thermometer { class: cstr }
note_environment -> pressure_reference { class: cstr }
note_environment -> system.bme280 { class: cstr }
note_power -> bench_power { class: cstr }
note_power -> system.xiao { class: cstr }
note_probe -> logic_analyzer { class: cstr }
note_probe -> system.probe_points { class: cstr }

# Layout-only edges to keep human/equipment actors and constraints in readable bands.
system -> bench_operator { style: { opacity: 0 } }
bench_operator -> host_pc { style: { opacity: 0 } }
host_pc -> reference_thermometer { style: { opacity: 0 } }
reference_thermometer -> pressure_reference { style: { opacity: 0 } }
pressure_reference -> bench_power { style: { opacity: 0 } }
bench_power -> logic_analyzer { style: { opacity: 0 } }
logic_analyzer -> note_scope { style: { opacity: 0 } }
note_scope -> note_environment { style: { opacity: 0 } }
note_environment -> note_power { style: { opacity: 0 } }
note_power -> note_probe { style: { opacity: 0 } }
