vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Logical view — AMS-VV-FC-002 peripheral initialisation testbench
# Verification references: IVV, AMS-R1 (BME280), AMS-R2 (I2C), AMS-R5 (statistics).
# IADT: Testing / Demonstration. Traceability: AMS-UC-InitializePeripheral,
# AMS-FE-SensorBusFault, AMS-FE-StartupFault, variable-getter/I2C-timeout/no-blocking constraints.
# Show deployed logical components and VV-only logical exchanges while preserving PA containment.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-FC-002 Peripheral initialisation\nFinal acceptance; Refs: IVV, AMS-R1, AMS-R2, AMS-R5" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: down
    grid-columns: 1

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        bme280: "[PC] BME280" {
          class: pc
          direction: down

          ams_sensing: "[LC] AMS Sensing" { class: lc }
        }

        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        grid-columns: 2

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down

          ams_processing: "[LC] AMS Processing" { class: lc }
          obcc: "[LC] OBCC" { class: lc }
          init_test_instrumentation: "[LC] Init-State Test\nInstrumentation\n(VV-only)" { class: lc }
        }

        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }

        note_variable_getter: "[C] Init-state getter shall use shared status:\nVALID, STALE, NO_DATA, TIMEOUT, SENSOR_FAULT, INIT_FAIL.\nCurrent/fresh only VALID with age_ms <= 400 ms;\nno stale/default/previous OK as VALID" {
          class: note
          shape: page
        }
        note_i2c_timeout: "[C] Startup I2C access has bounded failure/status behavior:\ninit failure -> INIT_FAIL or applicable non-VALID; timeout -> TIMEOUT;\nruntime bus/sensor fault -> SENSOR_FAULT. Detailed environmental-read\n≤ 5 ms proof is AMS-VV-CON-003 context" {
          class: note
          shape: page
        }
        note_no_blocking: "[C] No unbounded blocking during boot/init;\ncritical startup fault shall be observable" {
          class: note
          shape: page
        }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" { class: pc }
  }
}

test_operator: "[EA] AMS-VV\nTest Operator" { class: ea }
host_pc_logger: "[EA] Host PC /\nBoot Logger" { class: ea }
power_cycle_fixture: "[EA] Bench Power /\nPower-Cycle Fixture" { class: ea }
fault_fixture: "[EA] I2C Fault /\nBME280 Disconnect Fixture" { class: ea }
ambient_thermometer: "[EA] Ambient Thermometer\n/ Logger" { class: ea }
evidence_repository: "[EA] Evidence Repository\nControlled Storage" { class: ea }

note_iadt: "[C] Final acceptance IADT: Testing / Demonstration;\nreport by reference to this model definition at\nAMS/MBSE/tests/results/AMS-VV-FC-002/report.md" {
  class: note
  shape: page
}
note_scope: "[C] Scope: BME280 init-state request/response, OBCC collection,\nnominal VALID init with timestamp/sample-ID/age evidence, and\nstartup-fault behavior for absent/NACK BME280 or held SDA/SCL" {
  class: note
  shape: page
}
note_con003_dep: "[C] Dependency: AMS-VV-CON-003 owns detailed environmental\nRead pressure/Read temperature timeout/fault evidence and recovery;\nthis test records boot IDs, power cycles, fixture config, 3V3/GND,\ntimestamps/age where applicable, and shared status values" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb.bme280.ams_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] I2C" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Pointers" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Returns" { class: ce }

test_operator -> host_pc_logger: "[CE] Procedure ↔\nobservations" { class: ce }
host_pc_logger -> system.cansat.obcc_module.obcc_pcb.xiao.init_test_instrumentation: "[CE] Boot commands ↔\ninit evidence" { class: ce }
power_cycle_fixture -> system.cansat.obcc_module.obcc_pcb.xiao.init_test_instrumentation: "[CE] Power-cycle\ntrigger/status" { class: ce }
fault_fixture -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] Faulted I2C\ncondition ↔ status" { class: ce }
ambient_thermometer -> host_pc_logger: "[CE] Ambient\nreading" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.init_test_instrumentation -> evidence_repository: "[CE] Evidence\nrecord path" { class: ce }
host_pc_logger -> evidence_repository: "[CE] Raw logs +\nreport artifacts" { class: ce }

system.cansat.obcc_module.obcc_pcb.note_variable_getter -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_variable_getter -> system.cansat.obcc_module.obcc_pcb.xiao.obcc { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_i2c_timeout -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_no_blocking -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_no_blocking -> system.cansat.obcc_module.obcc_pcb.xiao.obcc { class: cstr }

note_iadt -> test_operator { class: cstr }
note_scope -> system.cansat.obcc_module.obcc_pcb.xiao.init_test_instrumentation { class: cstr }
note_scope -> fault_fixture { class: cstr }
note_con003_dep -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
note_con003_dep -> evidence_repository { class: cstr }
