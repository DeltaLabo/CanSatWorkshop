vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

# Functional chain: power-up, BME280 init-state collection, nominal measurement logging, and evidence capture.

chain: "AMS-V01-FC-001 — Serial/init smoke chain\nTesting/Demonstration; AMS v0.1 → v0.2 readiness; Refs: IVV, AMS-R1, AMS-R2, AMS-R5/R6\nTrace: AMS-v0.1-to-v0.2-readiness, AMS-UC-InitializePeripheral, AMS-UC-LogSerialTelemetry, AMS-FE-SensorBusFault" {
  class: chain
  direction: down

  configure_smoke_test: "[F] Configure serial/init\nsmoke test" { class: func }
  record_instrument_ids: "[F] Record instrument\nIDs/calibration" { class: func }
  supply_stable_power: "[F] Supply stable\npower" { class: func }
  record_voltage_current: "[F] Record voltage /\ncurrent" { class: func }
  open_serial_terminal: "[F] Open serial\nterminal" { class: func }
  press_reset_launch: "[F] Press reset /\nlaunch button" { class: func }

  init_serial0_serial1: "[F] Init Serial0 and\nSerial1 with interrupts" { class: func }
  get_bme280_init_state: "[F] Get BME280\ninit state" { class: func }
  respond_i2c_requests: "[F] Respond to I2C\nRequests" { class: func }
  collect_peripheral_init_states: "[F] Collect peripheral\ninit states" { class: func }
  measure_pressure: "[F] Measure\npressure" { class: func }
  measure_temperature: "[F] Measure\ntemperature" { class: func }
  read_pressure: "[F] Read\npressure" { class: func }
  read_temperature: "[F] Read\ntemperature" { class: func }
  calculate_altitude: "[F] Calculate\naltitude" { class: func }
  process_temperature: "[F] Process\ntemperature" { class: func }
  collect_measurements: "[F] Collect\nmeasurements" { class: func }
  tag_sample_sequence: "[F] Tag sample\nsequence ID" { class: func }
  log_serial0: "[F] Log via\nSerial0" { class: func }

  capture_serial0_log: "[F] Capture Serial0\nlog" { class: func }
  parse_init_payload: "[F] Parse init-state\npayload" { class: func }
  parse_measurement_payload: "[F] Parse measurement\npayload" { class: func }
  check_field_order_units: "[F] Check field\norder / units" { class: func }
  check_current_sample: "[F] Check current\nsample not stale" { class: func }
  monitor_serial_responsiveness: "[F] Monitor serial\nresponsiveness" { class: func }
  annotate_anomalies: "[F] Annotate\nanomalies" { class: func }
  archive_evidence: "[F] Archive smoke\nevidence" { class: func }

  note_repetitions: "[C] Smoke pass condition: execute ≥5 nominal power-up/\nserial-log repetitions for v0.1→v0.2 readiness; this\nis screening, not a statistical reliability claim" { class: note; shape: page }
  note_init_state: "[C] Serial output shall contain a BME280 init state\nfield after power-up; missing, ambiguous, or contradictory\ninit-state evidence fails the smoke activity" { class: note; shape: page }
  note_serial_fields: "[C] Payload shall contain init state and measurement\nfields in expected v0.1 order/units, including pressure,\ntemperature, and altitude when measurement fields are emitted" { class: note; shape: page }
  note_no_stale: "[C] No stale measurement may be logged as current: sample ID\nand timestamp/order must advance consistently with collection" { class: note; shape: page }
  note_timing: "[C] Read/process/calculate functions shall meet modeled\nconstraints; detailed I2C fault-timeout proof may be a\ndependency on later fault-hardening tests" { class: note; shape: page }
  note_no_blocking: "[C] No unbounded blocking during nominal serial logging;\nonly modeled I2C/UART waits are allowed, and terminal\nresponsiveness shall be preserved during the smoke window" { class: note; shape: page }
  note_environment: "[C] Record power, serial-port settings, instrument IDs,\noperator actions, raw logs, deviations, and anomalies\nfor the report-by-reference evidence package" { class: note; shape: page }
}

chain.configure_smoke_test -> chain.record_instrument_ids: "[FE] Smoke setup" { class: fe }
chain.record_instrument_ids -> chain.supply_stable_power: "[FE] Power setup" { class: fe }
chain.supply_stable_power -> chain.record_voltage_current: "[FE] Voltage/current" { class: fe }
chain.configure_smoke_test -> chain.open_serial_terminal: "[FE] Serial0 settings" { class: fe }
chain.open_serial_terminal -> chain.press_reset_launch: "[FE] Ready to\ncapture boot log" { class: fe }
chain.press_reset_launch -> chain.init_serial0_serial1: "[FE] Power-up / reset" { class: fe }

chain.init_serial0_serial1 -> chain.get_bme280_init_state: "[FE] Serial ready" { class: fe }
chain.get_bme280_init_state -> chain.respond_i2c_requests: "[FE] Init-state\nI2C Req" { class: fe }
chain.respond_i2c_requests -> chain.get_bme280_init_state: "[FE] State info" { class: fe }
chain.get_bme280_init_state -> chain.collect_peripheral_init_states: "[FE] Result\n[Init state]" { class: fe }

chain.measure_pressure -> chain.respond_i2c_requests: "[FE] Pressure\nsignal" { class: fe }
chain.measure_temperature -> chain.respond_i2c_requests: "[FE] Temperature\nsignal" { class: fe }
chain.read_pressure -> chain.respond_i2c_requests: "[FE] Pressure\nI2C Req" { class: fe }
chain.read_temperature -> chain.respond_i2c_requests: "[FE] Temperature\nI2C Req" { class: fe }
chain.respond_i2c_requests -> chain.read_pressure: "[FE] Pressure" { class: fe }
chain.respond_i2c_requests -> chain.read_temperature: "[FE] Temperature" { class: fe }
chain.read_pressure -> chain.calculate_altitude: "[FE] Pressure" { class: fe }
chain.read_temperature -> chain.process_temperature: "[FE] Temperature" { class: fe }
chain.calculate_altitude -> chain.collect_measurements: "[FE] Result\n[Altitude]" { class: fe }
chain.process_temperature -> chain.collect_measurements: "[FE] Result\n[Temperature]" { class: fe }
chain.tag_sample_sequence -> chain.collect_measurements: "[FE] Sample ID" { class: fe }

chain.collect_peripheral_init_states -> chain.log_serial0: "[FE] Init states" { class: fe }
chain.collect_measurements -> chain.log_serial0: "[FE] Measurements" { class: fe }
chain.log_serial0 -> chain.capture_serial0_log: "[FE] Serial0 payload" { class: fe }
chain.capture_serial0_log -> chain.parse_init_payload: "[FE] Boot/init lines" { class: fe }
chain.capture_serial0_log -> chain.parse_measurement_payload: "[FE] Measurement lines" { class: fe }
chain.parse_init_payload -> chain.check_field_order_units: "[FE] Init state\nfield" { class: fe }
chain.parse_measurement_payload -> chain.check_field_order_units: "[FE] Measurement\nfields" { class: fe }
chain.parse_measurement_payload -> chain.check_current_sample: "[FE] Sample ID /\ntimestamp" { class: fe }
chain.check_field_order_units -> chain.monitor_serial_responsiveness: "[FE] Parser pass/fail" { class: fe }
chain.check_current_sample -> chain.monitor_serial_responsiveness: "[FE] Staleness pass/fail" { class: fe }
chain.record_voltage_current -> chain.monitor_serial_responsiveness: "[FE] Power context" { class: fe }
chain.monitor_serial_responsiveness -> chain.annotate_anomalies: "[FE] Exceptions" { class: fe }
chain.monitor_serial_responsiveness -> chain.archive_evidence: "[FE] Smoke pass/fail" { class: fe }
chain.annotate_anomalies -> chain.archive_evidence: "[FE] Deviations" { class: fe }

chain.note_repetitions -> chain.press_reset_launch { class: cstr }
chain.note_repetitions -> chain.archive_evidence { class: cstr }
chain.note_init_state -> chain.collect_peripheral_init_states { class: cstr }
chain.note_init_state -> chain.parse_init_payload { class: cstr }
chain.note_serial_fields -> chain.check_field_order_units { class: cstr }
chain.note_serial_fields -> chain.log_serial0 { class: cstr }
chain.note_no_stale -> chain.check_current_sample { class: cstr }
chain.note_no_stale -> chain.tag_sample_sequence { class: cstr }
chain.note_timing -> chain.get_bme280_init_state { class: cstr }
chain.note_timing -> chain.calculate_altitude { class: cstr }
chain.note_timing -> chain.process_temperature { class: cstr }
chain.note_no_blocking -> chain.monitor_serial_responsiveness { class: cstr }
chain.note_no_blocking -> chain.log_serial0 { class: cstr }
chain.note_environment -> chain.record_instrument_ids { class: cstr }
chain.note_environment -> chain.record_voltage_current { class: cstr }
chain.note_environment -> chain.archive_evidence { class: cstr }

# Layout-only edges to keep setup, UUT smoke execution, and evidence capture readable.
chain.record_voltage_current -> chain.open_serial_terminal { style: { opacity: 0 } }
chain.collect_peripheral_init_states -> chain.measure_pressure { style: { opacity: 0 } }
chain.process_temperature -> chain.log_serial0 { style: { opacity: 0 } }
chain.archive_evidence -> chain.note_repetitions { style: { opacity: 0 } }
chain.note_repetitions -> chain.note_init_state { style: { opacity: 0 } }
chain.note_init_state -> chain.note_serial_fields { style: { opacity: 0 } }
chain.note_serial_fields -> chain.note_no_stale { style: { opacity: 0 } }
chain.note_no_stale -> chain.note_timing { style: { opacity: 0 } }
chain.note_timing -> chain.note_no_blocking { style: { opacity: 0 } }
chain.note_no_blocking -> chain.note_environment { style: { opacity: 0 } }
