digraph PDS_v0_3 {
  graph [
    rankdir=TB,
    splines=polyline,
    nodesep=0.42,
    ranksep=0.9,
    pad=0.28,
    bgcolor="white",
    fontname="Helvetica",
    compound=true,
    forcelabels=true,
    newrank=true
  ];

  node [shape=box, style="filled", fontname="Helvetica", fontsize=18, margin="0.18,0.12"];
  edge [fontname="Helvetica", fontsize=15, penwidth=2.2, arrowsize=0.8];

  // Left exterior lane
  note_energy [label="Enough for 6 hours\nof continuous\noperation in On\nmode", fillcolor="#FFF5B0", color="#D1B24A"];

  subgraph cluster_charger {
    label="Charger";
    style="filled,rounded";
    fillcolor="#BFEAF4";
    color="#5B65C9";
    penwidth=2;

    charger_usb   [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
    charger_power [label="Provide power", fillcolor="#BDFB9B", color="#166534"];
  }

  subgraph cluster_user {
    label="User";
    style="filled,rounded";
    fillcolor="#BFEAF4";
    color="#5B65C9";
    penwidth=2;

    user_on  [label="Switch power on",  fillcolor="#BDFB9B", color="#166534"];
    user_off [label="Switch power off", fillcolor="#BDFB9B", color="#166534"];
  }

  note_prob [label="{c} Probability< 1%", fillcolor="#FFF5B0", color="#D1B24A"];

  // Main subsystem
  subgraph cluster_pds {
    label="PDS v0.2-0.3 Subsystem";
    style="filled,rounded";
    fillcolor="#D9D9D9";
    color="#888888";
    penwidth=2;

    subgraph cluster_battpack {
      label="1S1P Li-Ion";
      style="filled";
      fillcolor="#FFF8BF";
      color="#D1B24A";
      penwidth=2;

      battpack_jst [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];

      subgraph cluster_battery {
        label="Battery";
        style="filled,rounded";
        fillcolor="#A9C7E6";
        color="#5B65C9";
        penwidth=2;

        battery_jst  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        batt_store   [label="Store energy",  fillcolor="#BDFB9B", color="#166534"];
        batt_provide [label="Provide power", fillcolor="#BDFB9B", color="#166534"];
      }
    }

    subgraph cluster_board {
      label="PDS Circuitboard";
      style="filled";
      fillcolor="#FFF8BF";
      color="#D1B24A";
      penwidth=2;

      subgraph cluster_protection {
        label="Protection Circuit";
        style="filled";
        fillcolor="#FFF8BF";
        color="#D1B24A";
        penwidth=2;

        protection_usb_anchor  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        protection_batt_anchor [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        protection_phys_out    [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];

        subgraph cluster_batt_charger {
          label="Battery Charger";
          style="filled,rounded";
          fillcolor="#A9C7E6";
          color="#5B65C9";
          penwidth=2;

          battchg_usb_in  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          battchg_batt_in [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          charger_reg [label="Regulate voltage", fillcolor="#BDFB9B", color="#166534"];

          battchg_usb_in -> battchg_batt_in [style=invis, weight=10];
          battchg_usb_in -> charger_reg [style=invis, weight=14];
          battchg_batt_in -> charger_reg [style=invis, weight=10];
        }

        subgraph cluster_power_protection {
          label="Power Protection";
          style="filled,rounded";
          fillcolor="#A9C7E6";
          color="#5B65C9";
          penwidth=2;

          restore_power [label="Restore power", fillcolor="#BDFB9B", color="#166534"];
          detect_oc [label="Detect overcurrent", fillcolor="#BDFB9B", color="#166534"];
          detect_ov [label="Detect\novervoltage", fillcolor="#BDFB9B", color="#166534"];
          cut_off_in_w  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          cut_off_in_nw [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          cut_off_in_n  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          cut_off_power [label="Cut off power", fillcolor="#BDFB9B", color="#166534"];
          protection_ina_out [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          protection_pc_out [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];

          restore_power -> detect_oc [style=invis, weight=8];
          detect_oc -> detect_ov [style=invis, weight=8];
          detect_oc -> cut_off_in_nw [style=invis, weight=7];
          detect_ov -> cut_off_in_n [style=invis, weight=7];
          cut_off_in_w -> cut_off_power [style=invis, weight=14];
          cut_off_in_nw -> cut_off_power [style=invis, weight=14];
          cut_off_in_n -> cut_off_power [style=invis, weight=14];
          restore_power -> protection_ina_out [style=invis, weight=8];
          cut_off_power -> protection_pc_out [style=invis, weight=12];
          protection_ina_out -> protection_pc_out [style=invis, weight=10];
        }
      }

      subgraph cluster_regulator_block {
        label="Regulator";
        style="filled";
        fillcolor="#FFF8BF";
        color="#D1B24A";
        penwidth=2;

        regulator_phys_in  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        regulator_phys_out [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];

        subgraph cluster_regulator {
          label="Regulator";
          style="filled,rounded";
          fillcolor="#A9C7E6";
          color="#5B65C9";
          penwidth=2;

          regulator_out [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          regulate_voltage [label="Regulate\nvoltage", fillcolor="#BDFB9B", color="#166534"];

          regulate_voltage -> regulator_out [style=invis, weight=10];
        }
      }

      connector_terminal [label="Connector\nTerminal", fillcolor="#FFF8BF", color="#D1B24A", penwidth=2];

      subgraph cluster_ina219 {
        label="INA219";
        style="filled";
        fillcolor="#FFF8BF";
        color="#D1B24A";
        penwidth=2;

        ina_phys_in  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        ina_phys_out [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];

        subgraph cluster_batt_monitoring {
          label="Battery monitoring";
          style="filled,rounded";
          fillcolor="#A9C7E6";
          color="#5B65C9";
          penwidth=2;

          ina_power_in  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_signal_in [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_in_v   [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_in_i   [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_req_1  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_req_2  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_req_3  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_out_1  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_out_2  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_resp_out_3  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
          ina_measure_v [label="Measure voltage", fillcolor="#BDFB9B", color="#166534"];
          ina_measure_i [label="Measure current", fillcolor="#BDFB9B", color="#166534"];
          ina_respond   [label="Respond to I2C Requests", fillcolor="#BDFB9B", color="#166534"];

          ina_resp_in_v -> ina_respond [style=invis, weight=10];
          ina_resp_in_i -> ina_respond [style=invis, weight=10];
          ina_resp_req_1 -> ina_respond [style=invis, weight=12];
          ina_resp_req_2 -> ina_respond [style=invis, weight=12];
          ina_resp_req_3 -> ina_respond [style=invis, weight=12];
          ina_respond -> ina_resp_out_1 [style=invis, weight=12];
          ina_respond -> ina_resp_out_2 [style=invis, weight=12];
          ina_respond -> ina_resp_out_3 [style=invis, weight=12];
        }
      }
    }

    subgraph cluster_xiao {
      label="XIAO ESP32";
      style="filled";
      fillcolor="#FFF8BF";
      color="#D1B24A";
      penwidth=2;

      subgraph cluster_loop {
        label="Loop";
        style="filled,rounded";
        fillcolor="#A9C7E6";
        color="#5B65C9";
        penwidth=2;

        xiao_read_v    [label="Read voltage", fillcolor="#BDFB9B", color="#166534"];
        xiao_read_i    [label="Read current", fillcolor="#BDFB9B", color="#166534"];
        xiao_process_i [label="Process\ncurrent", fillcolor="#BDFB9B", color="#166534"];
        xiao_process_v [label="Process\nvoltage", fillcolor="#BDFB9B", color="#166534"];
        xiao_collect   [label="Collect PDS measurements", fillcolor="#BDFB9B", color="#166534"];
        xiao_log       [label="Log measurements via Serial0", fillcolor="#BDFB9B", color="#166534"];
      }

      subgraph cluster_setup {
        label="Setup";
        style="filled,rounded";
        fillcolor="#A9C7E6";
        color="#5B65C9";
        penwidth=2;

        xiao_pwr_5v   [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        xiao_i2c_port [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        xiao_pwr_3v3  [label="", shape=box, width=0.01, height=0.01, fixedsize=true, style=invis, margin=0];
        xiao_get_init [label="Get\nINA219\ninit state", fillcolor="#BDFB9B", color="#166534"];
        xiao_collect_init [label="Collect\nperipheral init\nstates", fillcolor="#BDFB9B", color="#166534"];
        xiao_init_bus [label="Init Serial0 and\nI2C", fillcolor="#BDFB9B", color="#166534"];
      }
    }
  }


  // Vertical composition of main architecture
  batt_store -> batt_provide [style=invis, weight=15];
  battpack_jst -> battery_jst [style=invis, weight=24];
  battery_jst -> batt_store [style=invis, weight=20];
  charger_usb -> charger_power [style=invis, weight=18];
  battchg_usb_in -> charger_reg [style=invis, weight=18];
  battchg_batt_in -> charger_reg [style=invis, weight=18];
  protection_usb_anchor -> battchg_usb_in [style=invis, weight=26];
  protection_batt_anchor -> battchg_batt_in [style=invis, weight=26];
  charger_reg -> restore_power [style=invis, weight=15];
  protection_phys_out -> restore_power [style=invis, weight=20];
  protection_pc_out -> restore_power [style=invis, weight=20];
  protection_ina_out -> restore_power [style=invis, weight=18];
  restore_power -> cut_off_power [style=invis, weight=15];
  cut_off_power -> protection_pc_out [style=invis, weight=20];
  protection_pc_out -> protection_ina_out [style=invis, weight=20];
  ina_measure_v -> ina_measure_i [style=invis, weight=10];
  ina_measure_v -> ina_respond [style=invis, weight=18];
  ina_measure_i -> ina_respond [style=invis, weight=18];
  restore_power -> ina_measure_v [style=invis, weight=55];
  regulate_voltage -> ina_measure_i [style=invis, weight=55];
  regulate_voltage -> regulator_out [style=invis, weight=18];
  regulator_phys_in -> regulator_out [style=invis, weight=20];
  regulator_phys_out -> regulator_out [style=invis, weight=24];
  regulator_out -> connector_terminal [style=invis, weight=42];
  connector_terminal -> ina_respond [style=invis, weight=55];
  ina_phys_in -> ina_measure_v [style=invis, weight=18];
  ina_phys_out -> ina_respond [style=invis, weight=18];
  ina_power_in -> ina_measure_v [style=invis, weight=18];
  ina_signal_in -> ina_measure_i [style=invis, weight=18];
  xiao_i2c_port -> xiao_get_init [style=invis, weight=18];
  xiao_pwr_3v3 -> xiao_get_init [style=invis, weight=16];
  xiao_pwr_5v -> xiao_read_i [style=invis, weight=16];
  xiao_get_init -> xiao_collect_init [style=invis, weight=12];
  xiao_collect_init -> xiao_init_bus [style=invis, weight=12];
  ina_respond -> xiao_collect_init [style=invis, weight=12];
  xiao_read_v -> ina_respond [style=invis, weight=12];
  xiao_read_i -> ina_respond [style=invis, weight=12];
  ina_respond -> xiao_process_v [style=invis, weight=12];
  ina_respond -> xiao_process_i [style=invis, weight=12];
  xiao_process_v -> xiao_collect [style=invis, weight=10];
  xiao_process_i -> xiao_collect [style=invis, weight=10];
  xiao_collect -> xiao_log [style=invis, weight=12];

  batt_provide -> regulate_voltage [style=invis, weight=80];
  regulate_voltage -> xiao_collect [style=invis, weight=90];
  charger_power -> user_on [style=invis, weight=16];
  user_on -> user_off [style=invis, weight=12];
  note_energy -> charger_usb [style=invis, weight=12];
  charger_power -> note_prob [style=invis, weight=10];
  note_prob -> user_on [style=invis, weight=10];

  { rank=same; note_energy; battpack_jst; battery_jst; batt_store; batt_provide; }
  { rank=same; protection_usb_anchor; battchg_usb_in; protection_batt_anchor; battchg_batt_in; charger_reg; regulate_voltage; regulator_phys_in; regulator_out; regulator_phys_out; }
  { rank=same; note_prob; restore_power; detect_oc; detect_ov; cut_off_power; protection_ina_out; protection_pc_out; protection_phys_out; }
  { rank=same; ina_phys_in; ina_power_in; ina_measure_v; ina_measure_i; connector_terminal; ina_signal_in; ina_phys_out; }
  { rank=same; xiao_pwr_5v; xiao_i2c_port; xiao_pwr_3v3; xiao_get_init; xiao_read_v; xiao_read_i; }
  { rank=same; xiao_process_i; xiao_process_v; }
  { rank=same; xiao_collect; }

  // Lane guidance
  charger_usb -> protection_usb_anchor [style=invis, weight=50];
  charger_power -> charger_reg [style=invis, weight=80];
  battpack_jst -> protection_batt_anchor [style=invis, weight=50];
  batt_store -> charger_reg [style=invis, weight=65];
  protection_phys_out -> ina_phys_in [style=invis, weight=95];
  ina_phys_out -> regulator_phys_in [style=invis, weight=90];
  batt_provide -> regulate_voltage [style=invis, weight=90];
  connector_terminal -> xiao_pwr_3v3 [style=invis, weight=115];
  connector_terminal -> xiao_pwr_5v [style=invis, weight=115];
  connector_terminal -> xiao_get_init [style=invis, weight=115];
  ina_respond -> xiao_process_v [style=invis, weight=120];
  user_on -> restore_power [style=invis, weight=16];
  note_energy -> batt_store [style=invis, weight=8];
  note_prob -> detect_oc [style=invis, weight=8];

  // Functional exchanges (green)
  user_on  -> restore_power [
    color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=e, headport=w
  ];
  user_off -> cut_off_power [
    color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=e, headport=w
  ];
  detect_oc -> cut_off_power [
    color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=e, headport=w
  ];
  detect_ov -> cut_off_power [
    color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=w, headport=e
  ];
  charger_reg -> batt_store [
    color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=1,
    tailport=n, headport=s
  ];
  batt_provide -> charger_reg [
    color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=s, headport=n
  ];
  batt_provide -> regulate_voltage [
    color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=s, headport=n
  ];

  xiao_process_v -> xiao_collect [
    xlabel="Result", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=s, headport=ne
  ];
  xiao_process_i -> xiao_collect [
    xlabel="Result", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=s, headport=nw
  ];
  xiao_collect -> xiao_log [
    xlabel="LoRa", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false,
    tailport=s, headport=n
  ];

  xiao_get_init -> ina_respond [
    xlabel="Req", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=2,
    tailport=w, headport=ne
  ];
  xiao_read_v -> ina_respond [
    xlabel="Req", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=2,
    tailport=sw, headport=ne
  ];
  xiao_read_i -> ina_respond [
    xlabel="Req", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=2,
    tailport=sw, headport=ne
  ];
  ina_measure_v -> ina_respond [
    xlabel="V", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=1,
    tailport=s, headport=nw
  ];
  ina_measure_i -> ina_respond [
    xlabel="I", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=1,
    tailport=s, headport=ne
  ];
  ina_respond -> xiao_collect_init [
    xlabel="Result", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=2,
    tailport=se, headport=w
  ];
  ina_respond -> xiao_process_v [
    xlabel="Resp", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=2,
    tailport=se, headport=w
  ];
  ina_respond -> xiao_process_i [
    xlabel="Resp", color="#1F7A4D", fontcolor="#1F7A4D", constraint=false, minlen=2,
    tailport=se, headport=w
  ];

  // Physical/component exchanges (red)
  charger_usb -> protection_usb_anchor [
    xlabel="USB-C Cable",
    color="#E11D28",
    fontcolor="#E11D28",
    ltail=cluster_charger,
    lhead=cluster_protection,
    constraint=false,
    minlen=1,
    dir=none,
    tailport=e,
    headport=w
  ];
  battpack_jst -> protection_batt_anchor [
    xlabel="Battery Cable",
    color="#E11D28",
    fontcolor="#E11D28",
    ltail=cluster_battpack,
    lhead=cluster_protection,
    constraint=false,
    minlen=1,
    dir=none,
    tailport=s,
    headport=n
  ];
  protection_phys_out -> ina_phys_in [
    xlabel="PC Out trace",
    color="#E11D28",
    fontcolor="#E11D28",
    ltail=cluster_protection,
    lhead=cluster_ina219,
    constraint=false,
    minlen=1,
    dir=none,
    tailport=s,
    headport=nw
  ];
  ina_phys_out -> regulator_phys_in [
    xlabel="INA Out / GND",
    color="#E11D28",
    fontcolor="#E11D28",
    ltail=cluster_ina219,
    lhead=cluster_regulator_block,
    constraint=false,
    minlen=1,
    dir=none,
    tailport=ne,
    headport=sw
  ];
  regulator_phys_out -> connector_terminal [
    xlabel="3V3 / 5V / GND",
    color="#E11D28",
    fontcolor="#E11D28",
    ltail=cluster_regulator_block,
    constraint=false,
    minlen=1,
    dir=none,
    tailport=se,
    headport=n
  ];
  ina_phys_out -> xiao_i2c_port [
    xlabel="I2C Cables",
    color="#E11D28",
    fontcolor="#E11D28",
    ltail=cluster_ina219,
    lhead=cluster_xiao,
    constraint=false,
    minlen=1,
    dir=none,
    tailport=e,
    headport=nw
  ];
  connector_terminal -> xiao_pwr_5v [
    xlabel="5V / GND",
    color="#E11D28",
    fontcolor="#E11D28",
    ltail=cluster_board,
    lhead=cluster_xiao,
    constraint=false,
    minlen=1,
    dir=none,
    tailport=e,
    headport=ne
  ];

  // Constraints / notes
  note_energy -> batt_store [style=dashed, color="#333333", constraint=false];
  note_prob   -> detect_oc  [style=dashed, color="#333333", constraint=false];
  note_prob   -> detect_ov  [style=dashed, color="#333333", constraint=false];
}
