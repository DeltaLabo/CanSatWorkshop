vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional allocation view — AMS-VV-CE-001 I2C component-exchange analysis functions
# Verification references: IVV, AMS-R1 (BME280), AMS-R2 (I2C).
# IADT: Analysis. SSIV: AMS v1.0 final acceptance.
# Traceability: AMS-UC-MeasureAtmosphere; AMS-UC-InitializePeripheral; AMS-FE-SensorBusFault.
# Show UUT functions plus VV-only analysis, evidence, and review functions. No CEs/FEs/PLs in PV3.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-CE-001 I2C CE analysis\nAMS v1.0 final acceptance\nRefs: IVV, AMS-R1, AMS-R2" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: down
    grid-columns: 1

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        bme280: "[PC] BME280" {
          class: pc
          direction: down

          ams_sensing: "[LC] AMS Sensing" {
            class: lc
            direction: down
            grid-columns: 3

            measure_pressure: "[F] Measure\npressure" { class: func }
            measure_temperature: "[F] Measure\ntemp." { class: func }
            respond_i2c_requests: "[F] Respond to I2C\nRequests" { class: func }
          }

          note_accuracy_pressure: "[C] Accuracy\n< 1 hPa" {
            class: note
            shape: page
          }
          note_accuracy_temperature: "[C] Accuracy < 0.5 Celsius,\n10-40 °C range" {
            class: note
            shape: page
          }
        }

        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        grid-columns: 2

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down

          ams_processing: "[LC] AMS Processing" {
            class: lc
            direction: down
            grid-columns: 4

            get_bme280_init_state: "[F] Get BME280\ninit state" { class: func }
            read_pressure: "[F] Read\npressure" { class: func }
            read_temperature: "[F] Read\ntemperature" { class: func }
            calculate_altitude: "[F] Calculate\naltitude" { class: func }
            process_temperature: "[F] Process\ntemperature" { class: func }

            note_resolution: "[C] Resolution\n< 10m" {
              class: note
              shape: page
            }
          }

          obcc: "[LC] OBCC" {
            class: lc
            direction: down
            grid-columns: 1

            collect_peripheral_init_states: "[F] Collect peripheral\ninit states" { class: func }
            collect_measurements: "[F] Collect\nmeasurements" { class: func }
          }

          i2c_ce_analysis_record: "[LC] I2C CE\nAnalysis Record\n(VV-only)" {
            class: lc
            direction: down
            grid-columns: 2

            generate_ce_coverage_matrix: "[F] Generate 1/1 CE\ncoverage matrix" { class: func }
            map_model_endpoints: "[F] Map modeled\nI2C endpoints" { class: func }
            map_chain_crossings: "[F] Map six I2C\nfunctional crossings" { class: func }
            inspect_schematic_netlist: "[F] Inspect schematic /\nnetlist evidence" { class: func }
            inspect_firmware_config: "[F] Inspect firmware\nI2C config" { class: func }
            assess_protocol_consistency: "[F] Assess protocol,\nrole, address config" { class: func }
            assess_fault_policy_presence: "[F] Assess bounded\nfault-policy presence" { class: func }
            compare_model_implementation: "[F] Compare model ↔\nimplementation" { class: func }
            record_ce_anomalies: "[F] Record CE\nanomalies" { class: func }
            archive_ce_evidence: "[F] Archive CE\nevidence" { class: func }
          }
        }

        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }

        note_variable_getter: "[C] Implement each\n(Read X, Process X) or\n(Read X, Calculate Y)\npair as a Variable\nGetter template" {
          class: note
          shape: page
        }
        note_i2c_timeout: "[C] All I2C read\nfunctions must have\na timeout ≤ 5 ms" {
          class: note
          shape: page
        }
        note_process_time: "[C] All Process or\nCalculate functions\nmust take < 5 ms" {
          class: note
          shape: page
        }
        note_no_blocking: "[C] No blocking\noperations besides\nI2C or UART comms" {
          class: note
          shape: page
        }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      grid-columns: 1

      ams_headers: "[PC] 2mm 2x6 AMS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }
  }
}

system.cansat.ams_module.ams_pcb.bme280.note_accuracy_pressure -> system.cansat.ams_module.ams_pcb.bme280.ams_sensing.measure_pressure { class: cstr }
system.cansat.ams_module.ams_pcb.bme280.note_accuracy_temperature -> system.cansat.ams_module.ams_pcb.bme280.ams_sensing.measure_temperature { class: cstr }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing.note_resolution -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing.calculate_altitude { class: cstr }

system.cansat.obcc_module.obcc_pcb.note_variable_getter -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_i2c_timeout -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_process_time -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }
system.cansat.obcc_module.obcc_pcb.note_no_blocking -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing { class: cstr }



analysis_operator: "[EA] AMS-VV CE\nAnalysis Operator" {
  class: ea
  direction: down
  grid-columns: 2

  identify_final_article: "[F] Identify final\narticle / baseline" { class: func }
  run_ce_analysis_procedure: "[F] Run CE analysis\nprocedure" { class: func }
  record_anomalies: "[F] Record\nanomalies" { class: func }
  archive_evidence: "[F] Archive\nevidence" { class: func }
}

analysis_workstation: "[EA] Host PC /\nAnalysis Workstation" {
  class: ea
  direction: down
  grid-columns: 2

  generate_matrix: "[F] Generate CE\ncoverage matrix" { class: func }
  map_implementation_paths: "[F] Map I2C\nimplementation paths" { class: func }
  compare_model_to_implementation: "[F] Compare model to\nimplementation" { class: func }
  produce_report_inputs: "[F] Produce report\ninputs" { class: func }
}

code_schematic_repo: "[EA] Code / Schematic\nEvidence Repository" {
  class: ea
  direction: down
  grid-columns: 1

  provide_firmware_i2c_config: "[F] Provide firmware\nI2C config" { class: func }
  provide_schematic_netlist_bom: "[F] Provide schematic /\nnetlist / BOM" { class: func }
  provide_bme280_address_evidence: "[F] Provide BME280 address /\nbus parameter evidence" { class: func }
}

qa_reviewer: "[EA] QA Witness /\nReviewer" {
  class: ea
  direction: down
  grid-columns: 1

  review_ce_coverage: "[F] Review 1/1\nCE coverage" { class: func }
  confirm_exclusions: "[F] Confirm\nexclusions" { class: func }
  confirm_anomaly_disposition: "[F] Confirm anomaly\ndisposition" { class: func }
}

evidence_repository: "[EA] Evidence Repository /\nChecklist Tool" {
  class: ea
  direction: down
  grid-columns: 1

  store_ce_matrix: "[F] Store CE\nmatrix" { class: func }
  store_evidence_bundle: "[F] Store analysis\nevidence bundle" { class: func }
  store_report_inputs: "[F] Store report\ninputs" { class: func }
}

note_final_acceptance: "[C] AMS v1.0 final acceptance: analyze the\ncontrolled v1.0 model and as-built/as-coded\nconfiguration evidence" {
  class: note
  shape: page
}
note_scope: "[C] Target count: 1/1 modeled UUT CE — [CE] I2C\nbetween full-path AMS Sensing and AMS Processing;\nVV-only analysis LC/functions are not flight functionality" {
  class: note
  shape: page
}
note_crossings: "[C] Functional context: 6/6 modeled I2C crossings —\npressure req/response, temperature req/response,\ninit-state req/response" {
  class: note
  shape: page
}
note_pass_protocol: "[C] Pass iff implementation uses I2C, not UART/SPI/GPIO/\nanalog/proxy exchange, with modeled endpoints and no\nunmodeled bypass or foreign LC carrying the exchange" {
  class: note
  shape: page
}
note_pass_config: "[C] Pass iff AMS Processing is the I2C master/requester;\nBME280/AMS Sensing is the addressed responder; bus\ninstance, address, pullups, and 3V3 compatibility are evidenced" {
  class: note
  shape: page
}
note_fault_hardening: "[C] Fault-hardening analysis: NACK, absent BME280,\nstuck SDA/SCL, clock-stretch/no-response, address/config\nmismatch, bounded status/error behavior presence" {
  class: note
  shape: page
}
note_exclusions: "[C] Excludes PL integrity/solder/continuity from AMS-VV-PL-001\nand detailed ≤5 ms timing/recovery proof from AMS-VV-CON-003;\nPointers/Returns are CE-002/CE-003" {
  class: note
  shape: page
}
note_fail: "[C] Fail or controlled waiver/model update required for\nmissing/ambiguous evidence, wrong protocol, wrong endpoint,\nwrong direction, address conflict, missing fault policy, or bypass" {
  class: note
  shape: page
}

note_final_acceptance -> analysis_operator.identify_final_article { class: cstr }
note_final_acceptance -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record.generate_ce_coverage_matrix { class: cstr }
note_scope -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record.map_model_endpoints { class: cstr }
note_scope -> qa_reviewer.review_ce_coverage { class: cstr }
note_crossings -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record.map_chain_crossings { class: cstr }
note_pass_protocol -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record.assess_protocol_consistency { class: cstr }
note_pass_config -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record.inspect_firmware_config { class: cstr }
note_pass_config -> code_schematic_repo.provide_bme280_address_evidence { class: cstr }
note_fault_hardening -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record.assess_fault_policy_presence { class: cstr }
note_exclusions -> qa_reviewer.confirm_exclusions { class: cstr }
note_fail -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record.record_ce_anomalies { class: cstr }
note_fail -> qa_reviewer.confirm_anomaly_disposition { class: cstr }

# Layout-only edges to stack the VV actors and constraint notes below the UUT allocation.
system -> analysis_operator { style: { opacity: 0 } }
analysis_operator -> analysis_workstation { style: { opacity: 0 } }
analysis_workstation -> code_schematic_repo { style: { opacity: 0 } }
code_schematic_repo -> qa_reviewer { style: { opacity: 0 } }
qa_reviewer -> evidence_repository { style: { opacity: 0 } }
evidence_repository -> note_final_acceptance { style: { opacity: 0 } }
note_final_acceptance -> note_scope { style: { opacity: 0 } }
note_scope -> note_crossings { style: { opacity: 0 } }
note_crossings -> note_pass_protocol { style: { opacity: 0 } }
note_pass_protocol -> note_pass_config { style: { opacity: 0 } }
note_pass_config -> note_fault_hardening { style: { opacity: 0 } }
note_fault_hardening -> note_exclusions { style: { opacity: 0 } }
note_exclusions -> note_fail { style: { opacity: 0 } }
