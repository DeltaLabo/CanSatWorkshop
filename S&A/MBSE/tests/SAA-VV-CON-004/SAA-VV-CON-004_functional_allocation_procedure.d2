vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-CON-004 verification-only Physical Architecture PV3.
# Functional allocation/procedure view for assembly/printing screw-type, precision and infill process constraint verification.
# References cited in the rendered system title: IVV, SAA-R3, SAA-R5.
# Functions and LCs here define the verification activity only; they are not baseline S&A design edits.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" {
  class: ea
  direction: down
  grid-columns: 1
  select_gate: "[F] Select v0.1 process\nreadiness or v1.0 flight\nacceptance gate" { class: func }
  identify_article: "[F] Identify article,\nprinted batch, baseline copy\nand evidence folder" { class: func }
  inspect_screw_tray: "[F] Inspect screw tray,\nBOM and installed screw locations" { class: func }
  execute_cycles: "[F] Execute representative\nscrew / fit cycles at controlled\ntorque" { class: func }
  record_anomaly: "[F] Record anomaly, waiver,\nhold, rework or re-run need" { class: func }
}

process_reviewer: "[EA] Manufacturing / Process\nReviewer" {
  class: ea
  direction: down
  grid-columns: 1
  review_profile: "[F] Review slicer profile,\nprinter setup and build logs" { class: func }
  verify_infill: "[F] Verify 15% infill or\napproved controlled deviation" { class: func }
  review_batch_drift: "[F] Review printer/material\nbatch drift and reprint history" { class: func }
}

witness: "[EA] QA Witness" {
  class: ea
  direction: down
  grid-columns: 1
  witness_setup: "[F] Witness equipment,\nambient, calibration and batch setup" { class: func }
  witness_cycles: "[F] Witness no-strip,\nno-crack and alignment checks" { class: func }
  approve_gate: "[F] Approve pass, fail,\nhold or re-run disposition" { class: func }
}

screw_inventory: "[EA] Screw Inventory /\nBOM Tray" {
  class: ea
  direction: down
  grid-columns: 1
  provide_screw_records: "[F] Provide controlled\nself-tapping screw BOM,\nlabels and supplier data" { class: func }
  support_type_count: "[F] Support count of\nunique screw types by geometry\nand material" { class: func }
}

printer_records: "[EA] Printer Profile /\nBuild Record Set" {
  class: ea
  direction: down
  grid-columns: 1
  provide_profile: "[F] Provide slicer profile,\nG-code summary, material and\nprinter IDs" { class: func }
  provide_infill_evidence: "[F] Provide infill/print-fill\nrecord and affected part IDs" { class: func }
}

calipers: "[EA] Calipers / Micrometer /\nFeature Gauges" {
  class: ea
  direction: down
  grid-columns: 1
  measure_features: "[F] Measure boss, hole,\nslot, standoff, bay and\nalignment features" { class: func }
  calculate_guardband: "[F] Calculate |error| + U\nagainst 0.2 mm precision limit" { class: func }
}

torque_tool: "[EA] Torque Driver /\nInsert-Cycle Tool" {
  class: ea
  direction: down
  grid-columns: 1
  set_torque: "[F] Set and record\ncontrolled torque/tool settings" { class: func }
  apply_screw_cycles: "[F] Apply screw insertion /\nremoval or representative fit cycles" { class: func }
}

ambient_meter: "[EA] Ambient Thermo-\nHygrometer" {
  class: ea
  direction: down
  grid-columns: 1
  record_ambient: "[F] Record temperature and\nhumidity before repetitions begin" { class: func }
}

camera: "[EA] Photo / Video\nEvidence Camera" {
  class: ea
  direction: down
  grid-columns: 1
  capture_evidence: "[F] Capture screw counts,\nprofiles, measurements, cycles\nand anomalies" { class: func }
}

repo: "[EA] Evidence Repository" {
  class: ea
  direction: down
  grid-columns: 1
  store_package: "[F] Store report-by-reference\npackage under results/SAA-VV-CON-004/" { class: func }
}

system: "[System] SAA-VV-CON-004 Functional Allocation / Assembly-Printing Procedure\nRefs: IVV; SAA-R3; SAA-R5" {
  class: sys
  direction: down
  grid-columns: 1

  v01_process_article: "[PC] v0.1 Printed Process\nReadiness Article" {
    class: pc
    direction: down
    grid-columns: 1

    v01_screw_lc: "[LC] v0.1 Screw-Type\nReadiness Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_stack_screws: "[F] Present stack screws\nand screw-boss locations for census" { class: func }
      expose_extra_screws: "[F] Expose any third screw\ntype, adapter screw or untraceable bin" { class: func }
    }

    v01_print_lc: "[LC] v0.1 Print Profile and\nCoupon Process Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_coupons: "[F] Present at least 3 coupons\nor modules per printer/material batch" { class: func }
      expose_build_records: "[F] Expose slicer profile,\n15% infill record and batch ID" { class: func }
      expose_critical_features: "[F] Expose screw bosses,\nmodule alignment and backplane slot\nfeatures for measurement" { class: func }
    }

    v01_cycle_lc: "[LC] v0.1 Screw-Boss\nProcess Screen\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      accept_cycle_screen: "[F] Accept representative\nscrew cycles without strip, crack\nor loss of alignment" { class: func }
      expose_process_drift: "[F] Expose weak infill,\nwarped slot or printer/material drift" { class: func }
    }
  }

  v10_acceptance_article: "[PC] v1.0 Final Printed / Module\nHardware Acceptance Article" {
    class: pc
    direction: down
    grid-columns: 1

    v10_screw_lc: "[LC] v1.0 Screw-Type\nAcceptance Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_installed_screws: "[F] Present installed stack,\nPCB standoff and top-module screws\nfor type census" { class: func }
      reject_unapproved_types: "[F] Reject extra or\nundocumented self-tapping screw types" { class: func }
    }

    v10_print_lc: "[LC] v1.0 Final Print\nProfile Acceptance\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_final_parts: "[F] Present final printed\nADS/AMS/OBCC/PDS/ESS and top-module\nhardware" { class: func }
      trace_parts_to_build: "[F] Trace final part IDs\nto 15% infill build records or\napproved deviation" { class: func }
    }

    v10_precision_lc: "[LC] v1.0 Critical Feature\nPrecision Acceptance\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_bosses_slots: "[F] Present screw bosses,\nPCB standoffs, backplane slots and\nalignment features" { class: func }
      maintain_precision: "[F] Maintain 0.2 mm\nprecision with uncertainty guard band" { class: func }
      maintain_alignment: "[F] Maintain post-cycle\nstack, PCB and backplane alignment" { class: func }
    }

    v10_cycle_lc: "[LC] v1.0 Assembly Cycle\nFault-hardening Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      tolerate_torque_cycles: "[F] Tolerate representative\nscrew/fit cycles without strip,\ncrack or torque damage" { class: func }
      expose_faults: "[F] Expose stripped bosses,\nwarped slots, weak infill and\nloose alignment" { class: func }
    }
  }

  verification_records: "[PC] SAA-VV-CON-004 Control\nand Evidence Package\nverification-only" {
    class: pc
    direction: down
    grid-columns: 1
    evidence_lc: "[LC] Evidence / Anomaly /\nAcceptance Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      apply_pass_fail: "[F] Apply screw-type,\n15% infill, 0.2 mm precision and\ncycle pass/fail constraints" { class: func }
      classify_gate: "[F] Classify v0.1 and v1.0\npass, fail, hold or re-run" { class: func }
      bind_evidence: "[F] Bind baseline copies,\nBOMs, profiles, measurements,\ncycles, photos and witness decision" { class: func }
      require_rerun: "[F] Require re-run after\nreprint, rework, batch change,\nwaiver rejection or configuration change" { class: func }
    }
  }

  pass_fail: "[C] Pass/fail constraint:\nSelf-tapping screw type count ≤ 2; profile/build records show 15% infill or\ncontrolled deviation; critical features satisfy |measured - nominal| + U ≤ 0.2 mm\nunless stricter drawing tolerance applies; representative screw/fit cycles at\ncontrolled torque cause no stripped boss, crack, weak-infill failure, warped slot,\ntorque damage, loose standoff or loss of alignment. Missing evidence or open\nanomaly is hold/fail." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\n100% screw-type census for selected gate; at least 3 coupons/modules per\nprinter/material batch for process screen; measurements are continuous data with\nuncertainty guard bands; 29 independent screw-hole trials are required only for a\nR90/C95 reliability claim. Smaller cycle counts are workmanship screens." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nDetect hidden third screw type, stripped bosses, warped backplane slots, weak\ninfill, torque damage, batch/printer drift, unapproved build-record deviation,\npost-cycle misalignment, ambiguous photos and evidence-control escape." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental/equipment condition:\nRecord ambient temperature/humidity, printer/material batch ID, equipment IDs,\ncalibration status, torque setting, screw type IDs, camera field of view and\nwitness identity before measurements or repetitions begin. Hold if ambient/tool\nstate invalidates measurements or material behavior." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nModeled Assembly / printing constraint; SAA-UC-IntegratedAssembly;\nSAA-FE-StructuralLoosening; SAA-FE-EnvelopeNonCompliance;\nSAA-FE-LandingDamage." {
    class: note
    shape: page
  }
}

system.pass_fail -> system.v01_process_article.v01_screw_lc.present_stack_screws { class: cstr }
system.pass_fail -> system.v01_process_article.v01_print_lc.expose_build_records { class: cstr }
system.pass_fail -> system.v01_process_article.v01_cycle_lc.accept_cycle_screen { class: cstr }
system.pass_fail -> system.v10_acceptance_article.v10_screw_lc.reject_unapproved_types { class: cstr }
system.pass_fail -> system.v10_acceptance_article.v10_print_lc.trace_parts_to_build { class: cstr }
system.pass_fail -> system.v10_acceptance_article.v10_precision_lc.maintain_precision { class: cstr }
system.pass_fail -> system.v10_acceptance_article.v10_cycle_lc.tolerate_torque_cycles { class: cstr }
system.pass_fail -> system.verification_records.evidence_lc.apply_pass_fail { class: cstr }
system.statistical -> system.v01_process_article.v01_print_lc.present_coupons { class: cstr }
system.statistical -> system.v10_acceptance_article.v10_precision_lc.present_bosses_slots { class: cstr }
system.fault_hardening -> system.v01_process_article.v01_cycle_lc.expose_process_drift { class: cstr }
system.fault_hardening -> system.v10_acceptance_article.v10_cycle_lc.expose_faults { class: cstr }
system.fault_hardening -> system.verification_records.evidence_lc.require_rerun { class: cstr }
system.conditions -> system.verification_records.evidence_lc.bind_evidence { class: cstr }
system.traceability -> system.verification_records.evidence_lc.classify_gate { class: cstr }

# Layout-only edges keep actors and system allocations in procedure order.
operator -> process_reviewer { style: { opacity: 0 } }
process_reviewer -> witness { style: { opacity: 0 } }
witness -> screw_inventory { style: { opacity: 0 } }
screw_inventory -> printer_records { style: { opacity: 0 } }
printer_records -> calipers { style: { opacity: 0 } }
calipers -> torque_tool { style: { opacity: 0 } }
torque_tool -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> camera { style: { opacity: 0 } }
camera -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.v01_process_article -> system.v10_acceptance_article { style: { opacity: 0 } }
system.v10_acceptance_article -> system.verification_records { style: { opacity: 0 } }
system.verification_records -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.conditions { style: { opacity: 0 } }
system.conditions -> system.traceability { style: { opacity: 0 } }
