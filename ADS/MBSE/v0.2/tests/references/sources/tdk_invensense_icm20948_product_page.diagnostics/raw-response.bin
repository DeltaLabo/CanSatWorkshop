t_translation_changed\":\"1771652671\",\"field_description\":\"\u003cp\u003eMapping, environmental surveys, geological analysis, and wildlife conservation\u0026nbsp;\u003c/p\u003e\",\"field_read_more_link\":null,\"field_select_product\":[],\"field_sub_category_grid_icon\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-02/drones-scientific.jpg?VersionId=U8y3Dob2XsiUFDW2vsWY2rlgSLW1T8VV\",\"alt\":\"Small modern drone hovering taking picture of a sunrise in a mountain range\"},\"field_sub_category_grid_subtitle\":null,\"field_title\":\"Scientific\"}],\"field_sub_category_intro_paras\":[],\"field_sub_category_intro_title\":null,\"field_sub_category_section_subti\":null,\"field_sub_category_section_title\":\" Discover what’s possible and build with TDK digital microphones \",\"field_video_alignment\":null},{\"id\":\"39\",\"label\":\"Wearables\",\"slug\":\"/wearables\",\"tid\":\"39\",\"uuid\":\"485a5cdc-e085-4a1d-bcd9-4b840ece472e\",\"langcode\":\"en\",\"vid\":{\"id\":\"application_categories\",\"label\":\"Application Categories\"},\"status\":\"1\",\"name\":\"Wearables\",\"description\":null,\"weight\":\"0\",\"parent\":[],\"metatag\":[null,null,null],\"path\":null,\"content_translation_created\":\"1764226810\",\"field_about_us_section\":{\"id\":\"68\",\"label\":\"Wearables \u003e About us section\",\"uuid\":\"504ca878-e560-48ce-ac61-f83fcbe81f85\",\"langcode\":\"en\",\"type\":{\"id\":\"about_section_with_image_left\",\"label\":\"Paragraph section with image\"},\"status\":\"1\",\"created\":\"1764226810\",\"parent_id\":\"39\",\"parent_type\":\"taxonomy_term\",\"parent_field_name\":\"field_about_us_section\",\"content_translation_changed\":null,\"field_custom_tags\":[],\"field_image_alignment\":\"Left\",\"field_left_side_image\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-02/wearables-intro.jpg?VersionId=Fe4CepFEPL.Du.hG1HNefTC1JkRX4u9_\",\"alt\":\"Close-up photo of a person interacting with their smart watch\"},\"field_paragraph_sub_title\":null,\"field_read_more_link\":{\"title\":\"Contact Us \",\"url\":\"#contact\"},\"field_section_description\":\"\u003cp\u003eWearables bring intelligence closer to the human body. Devices like fitness bands, smartwatches, rings and more, deliver real-time insights and seamless interactions. By continuously sensing motion, orientation, sound, and context, wearables turn everyday activity into meaningful, personalized experiences.\u003c/p\u003e\u003cp\u003eTDK powers the next generation of wearables with a complete, ultra-low-power sensing platform spanning motion, magnetic, audio, and ultrasonic time-of-flight technologies. Our MEMS sensors and embedded software enable designers to create smaller, smarter devices with longer battery life and more intuitive human-machine interaction.\u003c/p\u003e\",\"field_section_title\":\"Sensors for smarter, more intuitive wearables     \",\"field_select_product\":[]},\"field_app_bento_section_subtitle\":null,\"field_app_bento_section_title\":null,\"field_app_key_highlight_sub_titl\":\"Explore features enabled by TDK sensors\",\"field_app_key_highlight_title\":\"A comprehensive sensing foundation for next-gen wearables  \",\"field_application_section_title\":\"Core sensing technologies powering the wearable-future \",\"field_app_section_paragraphs\":[{\"id\":\"139\",\"label\":\"Wearables \u003e Applications section paragraphs\",\"uuid\":\"548b9d7e-f7b9-438d-9739-2ec2dd45ee72\",\"langcode\":\"en\",\"type\":{\"id\":\"about_section_with_image_left\",\"label\":\"Paragraph section with image\"},\"status\":\"1\",\"created\":\"1764226810\",\"parent_id\":\"39\",\"parent_type\":\"taxonomy_term\",\"parent_field_name\":\"field_app_section_paragraphs\",\"content_translation_changed\":null,\"field_custom_tags\":[{\"id\":\"1270\",\"label\":\"Wearables \u003e Applications section paragraphs \u003e Custom tags\",\"uuid\":\"a6dcd25f-b428-4fc9-b382-dd19cf656398\",\"langcode\":\"en\",\"type\":{\"id\":\"custom_tags\",\"label\":\"Custom tags\"},\"status\":\"1\",\"created\":\"1773773404\",\"parent_id\":\"139\",\"parent_type\":\"paragraph\",\"parent_field_name\":\"field_custom_tags\",\"content_translation_changed\":\"1773773404\",\"field_paragraph_custom_tag\":{\"title\":\"PositionSense\",\"url\":\"/positionsense-0\"}},{\"id\":\"1271\",\"label\":\"Wearables \u003e Applications section paragraphs \u003e Custom tags\",\"uuid\":\"50fde70a-3b57-477f-86cc-3fb1b41a32c2\",\"langcode\":\"en\",\"type\":{\"id\":\"custom_tags\",\"label\":\"Custom tags\"},\"status\":\"1\",\"created\":\"1773773413\",\"parent_id\":\"139\",\"parent_type\":\"paragraph\",\"parent_field_name\":\"field_custom_tags\",\"content_translation_changed\":\"1773773413\",\"field_paragraph_custom_tag\":{\"title\":\"VibeSense360\",\"url\":\"/vibesense360\"}},{\"id\":\"1272\",\"label\":\"Wearables \u003e Applications section paragraphs \u003e Custom tags\",\"uuid\":\"b098a884-95f6-4485-b627-c04f39bd1c56\",\"langcode\":\"en\",\"type\":{\"id\":\"custom_tags\",\"label\":\"Custom tags\"},\"status\":\"1\",\"created\":\"1773773463\",\"parent_id\":\"139\",\"parent_type\":\"paragraph\",\"parent_field_name\":\"field_custom_tags\",\"content_translation_changed\":\"1773780901\",\"field_paragraph_custom_tag\":{\"title\":\"ICM-42670-P\",\"url\":\"/products/6-axis/icm-42670-p\"}},{\"id\":\"1273\",\"label\":\"Wearables \u003e Applications section paragraphs \u003e Custom tags\",\"uuid\":\"33e3a2e6-d4c3-46ca-866a-2024b3558954\",\"langcode\":\"en\",\"type\":{\"id\":\"custom_tags\",\"label\":\"Custom tags\"},\"status\":\"1\",\"created\":\"1773773522\",\"parent_id\":\"139\",\"parent_type\":\"paragraph\",\"parent_field_name\":\"field_custom_tags\",\"content_translation_changed\":\"1773780901\",\"field_paragraph_custom_tag\":{\"title\":\"ICM-45686\",\"url\":\"/products/6-axis/icm-45686\"}}],\"field_image_alignment\":\"Left\",\"field_left_side_image\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-02/paragraph-product-smartmotion.jpg?VersionId=iASgDQOnJ0ybnm0jRRxiR3RuBnQ1jf3w\",\"alt\":\"An enlarged TDK microchip next to a classic gyroscope\"},\"field_paragraph_sub_title\":\"Motion sensing for wearable interaction and spatial awareness\",\"field_read_more_link\":{\"title\":\"Learn more \",\"url\":\"/inertial-sensors\"},\"field_section_description\":\"\u003cp\u003eSmartMotion MEMS sensors deliver precise motion and orientation data for wearable systems, enabling responsive interaction, spatial awareness, and advanced motion analytics across next-generation platforms.\u003c/p\u003e\u003cul\u003e\u003cli data-list-item-id=\\\"e4095a4cd8f102d7bd3dca6a52da2d43a\\\"\u003eEnable always-on motion awareness with compact 6-axis IMUs and sensor fusion\u003c/li\u003e\u003cli data-list-item-id=\\\"eef5922ede802dca6861022cb665606c1\\\"\u003eSupport intuitive interaction through head tracking, gesture recognition, and controller motion sensing\u003c/li\u003e\u003cli data-list-item-id=\\\"e4c347dabbebe20a843590d496e072955\\\"\u003eEnable navigation and immersive experiences with advanced 9-axis sensing (IMU + TMR)\u003c/li\u003e\u003cli data-list-item-id=\\\"ee765c3e32eb160a243dda434ccda4042\\\"\u003eSupport vibration sensing and vocal vibration detection with VibeSense360™\u003c/li\u003e\u003c/ul\u003e\u003cp\u003e\u0026nbsp;\u003c/p\u003e\",\"field_section_title\":\"SmartMotion® \",\"field_select_product\":[]},{\"id\":\"467\",\"label\":\"Wearables \u003e Applications section paragraphs\",\"uuid\":\"6d208977-ab8d-463b-9887-b0ff0db42d5d\",\"langcode\":\"en\",\"type\":{\"id\":\"about_section_with_image_left\",\"label\":\"Paragraph section with image\"},\"status\":\"1\",\"created\":\"1769814363\",\"parent_id\":\"39\",\"parent_type\":\"taxonomy_term\",\"parent_field_name\":\"field_app_section_paragraphs\",\"content_translation_changed\":null,\"field_custom_tags\":[],\"field_image_alignment\":\"Right\",\"field_left_side_image\":{\"url\":\"https://d17t6iyxenbwp1.cloudfront.net/s3fs-public/2026-02/paragraph-product-smartsound.jpg?VersionId=2kt0ecF8Lv9_mApTVl1C2eLYLfFGInqp\",\"alt\":\"An enlarged TDK microchip next to a classic microphone\"},\"field_paragraph_sub_title\":\"Voice and acoustic sensing for wearable voice interfaces\\r\\n\",\"field_read_more_link\":{\"title\":\"Learn more \",\"url\":\"/microphone\"},\"field_section_description\":\"\u003cp\u003eSmartSound™ MEMS microphones provide high-fidelity acoustic sensing for wearable systems, enabling clear voice capture, always-on sensing, and reliable human-machine interaction.\u003c/p\u003e\u003cul\u003e\u003cli data-list-item-id=\\\"e7ba42b782021d7bb1a67a11c03ae047a\\\"\u003eEnable voice interfaces with high SNR, sensitivity, and high acoustic overload point (AOP)\u003c/li\u003e\u003cli data-list-item-id=\\\"e29971a3c6ddcca15ccdeb13311f84e56\\\"\u003eSupport always-on voice sensing with Acoustic Activity Detect (AAD)\u003c/li\u003e\u003cli data-list-item-id=\\\"ed7f0cc8d76f48aa57af0fdf431a4bc21\\\"\u003eIntegrate easily into compact wearable platforms with power-efficient, small form-factor designs\u003c/li\u003e\u003c/ul\u003e\",\"field_section_title\":\"SmartSound™ \",\"field_select_product\":[{\"id\":\"20\",\"label\":\"T5848\",\"slug\":\"/products/microphone/t5848\",\"product_id\":\"20\",\"uuid\":\"b973d5c3-5ccc-42cd-9279-b64a2c0579ae\",\"langcode\":\"en\",\"type\":{\"id\":\"microphone\",\"label\":\"Microphone\"},\"uid\":{\"id\":\"1\",\"label\":\"admin-invensense\"},\"status\":\"1\",\"title\":\"T5848\",\"variations\":[],\"default_variation\":null,\"path\":null,\"created\":\"1767854760\",\"metatag\":[null,null,null],\"field_a_d\":\"Digital\",\"field_additional_help_section\":[],\"field_add_other_product_specific\":[{\"id\":\"282\",\"label\":\"T5848 \u003e Add extra product specifications\"}],\"field_aop\":\"133.00\",\"field_applications_listing\":[{\"id\":\"87\",\"label\":\"Smart Home \u0026 Building\"},{\"id\":\"39\",\"label\":\"Wearables\"}],\"field_buy_now_link\":{\"title\":\"Shop now\",\"url\":\"https://dilp.netcomponents.com/tdkcorp_result.html?lang=en\u0026mode=1\u0026partnumber1=MMICT5848\u0026partnumber2=EV_T5848-FX2\"},\"field_category\":{\"id\":\"19\",\"label\":\"Microphone\"},\"field_description\":\"\u003cp\u003eThe T5848 has multiple modes of operation: High Quality, Low Power (AlwaysOn), and Sleep along with new AlwaysOn modes: Acoustic Activity Detect (AAD) Analog and Digital. The T5848 has high SNR in all operational modes. It has 133 dB SPL AOP in High Quality Mode and 119 dB SPL AOP in Low Power Mode.\u003c/p\u003e\",\"field_documentation_resource\":[{\"id\":\"8499\",\"label\":\"DS-000479 – T5848 Datasheet\"},{\"id\":\"281\",\"label\":\"AN-100 – MEMS Microphone Handling and Assembly Guide\"},{\"id\":\"285\",\"label\":\"AN-1003 – Recommendations for Mounting and Connecting InvenSense MEMS Microphones\"},{\"id\":\"251\",\"label\":\"AN-0078 – High-Performance Digital MEMS Microphone Simple Interface to SigmaDSP Audio Codec\"},{\"id\":\"292\",\"label\":\"AN-1112 – Microphone Specifications Explained\"},{\"id\":\"283\",\"label\":\"AN-1124 – Recommendations for Sealing InvenSense Bottom-Port MEMS Microphones from Dust and Liquid Ingress\"},{\"id\":\"284\",\"label\":\"AN-1140 – Microphone Array Beamforming\"},{\"id\":\"288\",\"label\":\"Understanding Microphone Sensitivity\"},{\"id\":\"252\",\"label\":\"AN-000048 – PDM Digital Output MEMS Microphone Flex Evaluation Board User Guide\"},{\"id\":\"8655\",\"label\":\"AN-000298 – TDK T58xx Series MEMS Microphone Acoustic Activity Detect User Guide\"},{\"id\":\"279\",\"label\":\"AN-000376 – T5848 Flex EVB User Guide\"}],\"field_embedded_processor_s\":null,\"field_features\":\"\u003cul\u003e\u003cli data-list-item-id=\\\"e638930105dee4bcb283a26c4ef474444\\\"\u003eIndustry leading, first high SNR and high dynamic range I2S output microphone, High SNR and AOP in all operational modes\u003c/li\u003e\u003cli data-list-item-id=\\\"ea78fc79844e95fd847fdfd7c1eba9fd0\\\"\u003eUltra low power consumption in high quality mode and low power mode, 50 – 70% lower than competitors\u003c/li\u003e\u003cli data-list-item-id=\\\"e80bbbd3f1335d1ec7cccd04020fd7ea6\\\"\u003eI²S output allows direct connection to a wide variety of SoCs, MCUs\u003c/li\u003e\u003cli data-list-item-id=\\\"ec334a44b86991f3f6fa4a824adc83b02\\\"\u003eAcoustic Activity Detect w/ programmable thresholds \u0026amp; filters with power consumption\u0026nbsp;as low as 20 uA\u003c/li\u003e\u003c/ul\u003e\",\"field_features_and_benefits\":null,\"field_features_listing\":[],\"field_high_quality_mode_current\":null,\"field_interface_microphone\":\"I²S\",\"field_key_attribute\":null,\"field_learn_more\":{\"title\":\"Learn more\",\"url\":\"/products/T5848\"},\"field_lf_cutoff\":\"28\",\"field_low_power_mode_current\":null,\"field_meta_tags\":null,\"field_output_type\":\"I²S\",\"field_part_number\":\"T5848\",\"field_port_location\":\"Bottom\",\"field_power_modes\":null,\"field_product_image\":[{\"id\":\"551\",\"label\":\"product-img-t5848.png\"}],\"field_product_key_features\":[{\"id\":\"283\",\"label\":\"T5848 \u003e Product key features\"}],\"field_product_segment\":\"Normal Product(ex: Ics)\",\"field_products_thumbnail_image\":{\"id\":\"552\",\"label\":\"thumbnail-t5848.jpg\"},\"field_related_products\":[],\"field_sensitivity_1_khz_94_db_sp\":\"-37\",\"field_sensitivity_db_fs_1_db\":\"-37.00\",\"field_short_description\":\"\u003cp\u003eThe T5848\u0026nbsp;is a low noise, high AOP I²S microphone with a 24‑bit PCM output for direct connection to a wide variety of SoCs. It also features Acoustic Activity Detect (AAD), a new ultra-low power edge processing feature consuming as low as 20\u0026nbsp;µA.\u003c/p\u003e\",\"field_size_d\":\"0.98\",\"field_size_l\":\"3.50\",\"field_size_w\":\"2.65\",\"field_snr\":null,\"field_software_downloads\":[],\"field_specification_short_descri\":null,\"field_status\":\"Production\",\"field_sub_title\":\"Bottom Port I²S Digital Output Multi‑Mode Microphone\",\"field_supply_voltage_vdd\":null,\"field_support_and_resources\":[],\"field_tar