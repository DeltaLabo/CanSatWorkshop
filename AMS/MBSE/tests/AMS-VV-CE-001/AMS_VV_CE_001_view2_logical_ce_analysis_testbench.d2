vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Logical view — AMS-VV-CE-001 I2C component-exchange analysis testbench
# Verification references: IVV, AMS-R1 (BME280), AMS-R2 (I2C).
# IADT: Analysis. SSIV: AMS v1.0 final acceptance.
# Traceability: AMS-UC-MeasureAtmosphere; AMS-UC-InitializePeripheral; AMS-FE-SensorBusFault.
# Show the target [CE] I2C, context CEs, and VV-only analysis/evidence exchanges.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-CE-001 I2C CE analysis\nAMS v1.0 final acceptance\nRefs: IVV, AMS-R1, AMS-R2" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: down
    grid-columns: 1

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down
        grid-columns: 2

        bme280: "[PC] BME280" {
          class: pc
          direction: down

          ams_sensing: "[LC] AMS Sensing" { class: lc }
        }

        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down
        grid-columns: 2

        xiao: "[PC] XIAO ESP32-S3" {
          class: pc
          direction: down

          ams_processing: "[LC] AMS Processing" { class: lc }
          obcc: "[LC] OBCC" { class: lc }
          i2c_ce_analysis_record: "[LC] I2C CE\nAnalysis Record\n(VV-only)" { class: lc }
        }

        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }

      }
    }

    backplane_pcb: "[PC] Backplane PCB" { class: pc }
  }
}


analysis_operator: "[EA] AMS-VV CE\nAnalysis Operator" { class: ea }
analysis_workstation: "[EA] Host PC /\nAnalysis Workstation" { class: ea }
code_schematic_repo: "[EA] Code / Schematic\nEvidence Repository" { class: ea }
qa_reviewer: "[EA] QA Witness /\nReviewer" { class: ea }
evidence_repository: "[EA] Evidence Repository /\nChecklist Tool" { class: ea }

note_scope: "[C] Scope: 1/1 target CE — [CE] I2C between\nAMS Sensing and AMS Processing; six modeled I2C\nfunctional crossings; VV-only evidence CEs excluded" {
  class: note
  shape: page
}
note_pass: "[C] Pass iff implemented exchange is I2C with modeled\nendpoints, requester/responder roles, address/bus config,\n3V3/pullup intent, bounded fault policy, and no bypass" {
  class: note
  shape: page
}
note_exclusions: "[C] Excludes PL integrity from AMS-VV-PL-001 and\ndetailed ≤5 ms timing/recovery proof from AMS-VV-CON-003" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb.bme280.ams_sensing -> system.cansat.obcc_module.obcc_pcb.xiao.ams_processing: "[CE] I2C ↔\nTARGET 1/1" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Pointers\n(context only)" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.ams_processing -> system.cansat.obcc_module.obcc_pcb.xiao.obcc: "[CE] Returns\n(context only)" { class: ce }

analysis_operator -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record: "[CE] procedure" { class: ce }
analysis_workstation -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record: "[CE] comparison" { class: ce }
code_schematic_repo -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record: "[CE] evidence" { class: ce }
qa_reviewer -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record: "[CE] review" { class: ce }
system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record -> evidence_repository: "[CE] archive" { class: ce }

note_scope -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record { class: cstr }
note_pass -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record { class: cstr }
note_exclusions -> system.cansat.obcc_module.obcc_pcb.xiao.i2c_ce_analysis_record { class: cstr }

# Layout-only edges to keep analysis actors and constraints in readable bands.
analysis_operator -> analysis_workstation { style: { opacity: 0 } }
analysis_workstation -> code_schematic_repo { style: { opacity: 0 } }
code_schematic_repo -> qa_reviewer { style: { opacity: 0 } }
qa_reviewer -> evidence_repository { style: { opacity: 0 } }
evidence_repository -> note_scope { style: { opacity: 0 } }
note_scope -> note_pass { style: { opacity: 0 } }
note_pass -> note_exclusions { style: { opacity: 0 } }
