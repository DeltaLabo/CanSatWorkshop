vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Analysis/test setup view for ADS-IVV-C-NOBLOCK.
# Defines verification equipment, temporary physical links, high-level CEs, and execution constraints.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-C-NOBLOCK\nNo-unintended-blocking analysis/test setup\nRefs: IVV; ADS MBSE plan; SW/stats; GPS/UBX; IMU/I2C" {
  class: sys
  direction: down

  uut: "[PC] Selected ADS UUT\none version per execution" {
    class: pc
    direction: right
    grid-columns: 2
    v01: "[PC] v0.1 GPS + XIAO\nprototype" { class: pc }
    v02: "[PC] v0.2 GPS + IMU + XIAO\nprototype" { class: pc }
    v03: "[PC] v0.3 ADS PCB\nN/A for runtime behavior" { class: pc }
    v10: "[PC] v1.0 integrated\nCanSat / ADS / OBCC" { class: pc }
  }
}

conductor: "[EA] IVV no-blocking\ntest conductor\n(human operator)" { class: ea }
review_station: "[EA] Code/model\nreview station" { class: ea }
timing_tool: "[EA] Timing analysis\ntool" { class: ea }
watchdog: "[EA] Runtime watchdog /\nheartbeat instrumentation" { class: ea }
logger: "[EA] Serial / OBCC\nlogger" { class: ea }
gps_fault: "[EA] GPS silent /\nmalformed fault injector" { class: ea }
imu_fault: "[EA] IMU NACK /\nstuck-bus fault injector\nv0.2 and v1.0" { class: ea }
power_monitor: "[EA] Bench supply and\nambient thermometer / hygrometer" { class: ea }

note_pass: "[C] Pass/fail intent\nPass only if all non-I2C/non-UART functions are shown not to block\nwhile waiting for external data; UART/I2C blocking is bounded by\ntimeout/error behavior; Loop or ADS Processing progress remains\nobservable under GPS and I2C faults; no hidden wait state is found." { class: note; shape: page }
note_access: "[C] Execution access constraint\nIf firmware source, build map, or runtime instrumentation access is absent,\nexecution cannot claim pass. Record blocked/limited until source or\nequivalent instrumentation evidence is available." { class: note; shape: page }
note_environment: "[C] Required execution conditions\nRecord ADS version, source copy, hardware revision, firmware commit,\ninstrumentation build, logger timebase, bench voltage/current, ambient\ntemperature/humidity, and fault-injector configuration." { class: note; shape: page }
note_stats_faults: "[C] Viewpoints\nStatistics: timing/deadline evidence uses representative samples; use n=59\nzero-violation samples for any formal 95/95 deadline claim. Fault hardening:\nsilent/malformed GPS, UART timeout, IMU NACK, stuck I2C bus, partial read,\nrecovery, and hidden waits." { class: note; shape: page }
note_v03: "[C] v0.3 N/A condition\nPass/N/A after confirming source_views/v0.3 is PV1-only PCB delivery\nwith no LC/functions/chains and no no-blocking constraint.\nDo not execute runtime blocking tests on v0.3 alone." { class: note; shape: page }

# Temporary physical links used by the verification setup.
watchdog -- system.uut: "[PL] heartbeat probe" { class: pl }
logger -- system.uut: "[PL] log cable" { class: pl }
gps_fault -- system.uut: "[PL] UART fault harness" { class: pl }
imu_fault -- system.uut: "[PL] I2C fault harness" { class: pl }
power_monitor -- system.uut: "[PL] power and ambient probes" { class: pl }

# High-level verification component exchanges and records.
conductor -> system.uut: "[CE] run sheet / baseline" { class: ce }
review_station -> timing_tool: "[CE] review findings" { class: ce }
system.uut -> logger: "[CE] runtime logs" { class: ce }
logger -> timing_tool: "[CE] timing evidence" { class: ce }
timing_tool -> conductor: "[CE] analysis report" { class: ce }

# Layout-only rank hints. Keep means above the UUT and constraints below it.
conductor -> review_station { style: { opacity: 0 } }
review_station -> timing_tool { style: { opacity: 0 } }
timing_tool -> watchdog { style: { opacity: 0 } }
watchdog -> logger { style: { opacity: 0 } }
logger -> gps_fault { style: { opacity: 0 } }
gps_fault -> imu_fault { style: { opacity: 0 } }
imu_fault -> power_monitor { style: { opacity: 0 } }
power_monitor -> system { style: { opacity: 0 } }
system -> note_pass { style: { opacity: 0 } }
note_pass -> note_access { style: { opacity: 0 } }
note_access -> note_environment { style: { opacity: 0 } }
note_environment -> note_stats_faults { style: { opacity: 0 } }
note_stats_faults -> note_v03 { style: { opacity: 0 } }
