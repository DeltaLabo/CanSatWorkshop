vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view: all-version PC/PL inspection setup for ADS-IVV-I-PCPL-ALL.
# Exact per-version PC/PL inventories remain in the copied source PV1 views under source_views/.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-I-PCPL-ALL\nPhysical component/link inspection setup\nRefs: IVV; NASA-SE; Workmanship; ADS MBSE plan" {
  class: sys
  direction: down

  selected_article: "[PC] Selected ADS article\n(one version inspected at a time)" {
    class: pc
    direction: right
    v01: "[PC] v0.1 GPS + XIAO\nprototype inventory" { class: pc }
    v02: "[PC] v0.2 GPS + IMU + XIAO\nprototype inventory" { class: pc }
    v03: "[PC] v0.3 ADS PCB\ndelivery inventory" { class: pc }
    v10: "[PC] v1.0 integrated CanSat / ADS / OBCC\ninventory" { class: pc }
  }
}

serial_host: "[EA] USB serial host PC\n(v0.1/v0.2 endpoint)" { class: ea }
dmm: "[EA] Continuity / isolation DMM\n(calibrated)" { class: ea }
supply: "[EA] Current-limited 3V3\nbench supply" { class: ea }
fixture: "[EA] 2mm 2x6 header / cable\nprobe fixture" { class: ea }

note_v01: "[C] v0.1 inventory source\nsource_views/v0.1/*view1_physical.d2\nPCs: GPS, XIAO; EA endpoint: PC.\nPLs: UART cables, 3V3, GND, USB-C." { class: note; shape: page }
note_v02: "[C] v0.2 inventory source\nsource_views/v0.2/*view1_physical.d2\nPCs: GPS, XIAO, ICM20948; EA endpoint: PC.\nPLs: UART, I2C, 3V3, GND, USB-C." { class: note; shape: page }
note_v03: "[C] v0.3 inventory source\nsource_views/v0.3/*view1_physical.d2\nPCs: ADS PCB, GPS, ICM20948, connector.\nPLs: footprints, UART/I2C/3V3 traces." { class: note; shape: page }
note_v10: "[C] v1.0 inventory source\nsource_views/v1.0/*view1_physical.d2\nPCs: CanSat, modules, PCBs, sensors,\nconnectors, headers, spine, XIAO.\nPLs: screws, fixtures, footprints,\nUART/I2C/3V3 traces, parallel cables." { class: note; shape: page }
note_coverage: "[C] Pass/fail coverage\n100% of the selected version's modeled PCs\nand PLs are inspected and evidenced.\nFail on any missing, wrong, damaged, loose,\nor uninspected PC/PL." { class: note; shape: page }
note_electrical: "[C] Electrical PL checks\nUART/I2C/3V3/GND/cable/trace paths\nmust be continuous to modeled endpoints\nand isolated from unintended shorts.\nFail on open, short, swapped, reversed,\nor weak power/ground path." { class: note; shape: page }
note_environment: "[C] Bench conditions\nRecord ambient temperature/humidity before\narticle or batch inspection. Defer if\ncondensation, unsafe ESD state, or equipment\ncalibration is unresolved." { class: note; shape: page }

# Temporary verification physical links to the selected article.
serial_host -- system.selected_article: "[PL] USB-C" { class: pl }
dmm -- system.selected_article: "[PL] DMM probes" { class: pl }
supply -- system.selected_article: "[PL] 3V3 leads" { class: pl }
fixture -- system.selected_article: "[PL] Header fixture" { class: pl }

note_v01 -> system.selected_article.v01 { class: cstr }
note_v02 -> system.selected_article.v02 { class: cstr }
note_v03 -> system.selected_article.v03 { class: cstr }
note_v10 -> system.selected_article.v10 { class: cstr }
note_coverage -> system.selected_article { class: cstr }
note_electrical -> dmm { class: cstr }
note_electrical -> supply { class: cstr }
note_environment -> system { class: cstr }

# Layout-only rank hints.
serial_host -> dmm { style: { opacity: 0 } }
dmm -> supply { style: { opacity: 0 } }
supply -> fixture { style: { opacity: 0 } }
system -> note_v01 { style: { opacity: 0 } }
note_v01 -> note_v02 { style: { opacity: 0 } }
note_v02 -> note_v03 { style: { opacity: 0 } }
note_v03 -> note_v10 { style: { opacity: 0 } }
note_v10 -> note_coverage { style: { opacity: 0 } }
note_coverage -> note_electrical { style: { opacity: 0 } }
note_electrical -> note_environment { style: { opacity: 0 } }
