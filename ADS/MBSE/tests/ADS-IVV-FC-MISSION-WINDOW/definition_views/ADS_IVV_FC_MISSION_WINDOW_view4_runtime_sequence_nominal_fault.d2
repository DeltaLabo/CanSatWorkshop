vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional-chain style runtime sequence for ADS-IVV-FC-MISSION-WINDOW.
# Includes nominal mission-window flow, fault-monitor branch, v0.3 N/A branch, and analysis closure.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

chain: "ADS-IVV-FC-MISSION-WINDOW\nRuntime mission-window verification sequence\nRefs: IVV; NASA-SE; GEVS; ESA-CANSAT; SW/stats" {
  class: chain
  direction: down

  select_version: "[F] Select ADS version\nand copied source baseline" { class: func }
  confirm_applicability: "[F] Confirm runtime applicability\nor v0.3 PCB-only N/A" { class: func }
  record_v03_na: "[F] v0.3 branch:\nrecord PCB-only N/A rationale" { class: func }
  set_acceptance: "[F] Set mission duration,\ncadence/frame rule, max gap" { class: func }
  configure_run: "[F] Configure ambient monitor, power,\nlogger, timebase, GPS/IMU truth, fault markers" { class: func }
  boot_and_init: "[F] Boot ADS and collect\nperipheral init states" { class: func }
  start_window: "[F] Start representative\nmission/descent window timer" { class: func }
  nominal_runtime: "[F] Nominal branch:\nrun GPS/IMU/attitude chains and deliver\nSerial0 or OBCC records" { class: func }
  capture_records: "[F] Capture ADS, truth, health,\npower, ambient, and timer records" { class: func }
  monitor_health: "[F] Monitor reset, loop progress,\nfield freshness, and window end" { class: func }
  fault_branch: "[F] Fault-monitor branch:\ninject silent/corrupt/stall cases and verify\ninvalid data handling / recovery" { class: func }
  close_window: "[F] Close mission window\nand freeze evidence set" { class: func }
  analyze_coverage: "[F] Analyze expected fields,\ntime correlation, cycles/frames, gaps" { class: func }
  analyze_fault_result: "[F] Analyze reset/stall,\nperipheral, and corrupt-data behavior" { class: func }
  decide_verdict: "[F] Decide pass/fail, N/A,\nor BLOCKED verdict" { class: func }
  record_report: "[F] Record report reference,\ndeviations, anomalies, retest" { class: func }

  c_version: "[C] Version-specific expected fields\nv0.1: GPS + UBX init + Serial0.\nv0.2: GPS + IMU angular rate + attitude + init + Serial0.\nv1.0: GPS + IMU angular rate + attitude + init + OBCC delivery.\nv0.3: no runtime chain, N/A." { class: note; shape: page }
  c_pass: "[C] Pass/fail constraints\nPass only if no reset/stuck loop/unrecovered peripheral failure occurs,\nall expected modeled fields are present and time-correlated, at least\n95% of expected cycles/frames are present when cadence is claimed,\nand no observed gap exceeds the selected maximum." { class: note; shape: page }
  c_blocked: "[C] Blocked verdict rule\nIf mission duration, expected cycle/frame definition, or maximum allowed\ngap is not project-defined before execution, the run may be recorded\nbut final mission-window verdict remains BLOCKED." { class: note; shape: page }
  c_stats: "[C] Statistical significance viewpoint\nUse complete logs for the mission window. Repeated frames on one article\nare sustained-performance screening. Use exact binomial/PDR bounds only\nwhen making population delivery claims; use n=59 for 95/95 deadline claims." { class: note; shape: page }
  c_faults: "[C] Fault-hardening viewpoint\nSilent sensor, malformed/corrupt measurement, UART/I2C timeout, stale data,\nstuck loop, reset/brownout, and v1.0 pointer/return faults must not be\naccepted as valid nominal data or cause unrecovered mission-window failure." { class: note; shape: page }
}

chain.select_version -> chain.confirm_applicability: "[FE]" { class: fe }
chain.confirm_applicability -> chain.record_v03_na: "[FE] v0.3" { class: fe }
chain.record_v03_na -> chain.record_report: "[FE] N/A" { class: fe }
chain.confirm_applicability -> chain.set_acceptance: "[FE] runtime" { class: fe }
chain.set_acceptance -> chain.configure_run: "[FE]" { class: fe }
chain.configure_run -> chain.boot_and_init: "[FE]" { class: fe }
chain.boot_and_init -> chain.start_window: "[FE]" { class: fe }
chain.start_window -> chain.nominal_runtime: "[FE]" { class: fe }
chain.nominal_runtime -> chain.capture_records: "[FE]" { class: fe }
chain.capture_records -> chain.monitor_health: "[FE]" { class: fe }
chain.monitor_health -> chain.fault_branch: "[FE] fault" { class: fe }
chain.fault_branch -> chain.close_window: "[FE] evidence" { class: fe }
chain.monitor_health -> chain.close_window: "[FE] window done" { class: fe }
chain.close_window -> chain.analyze_coverage: "[FE]" { class: fe }
chain.analyze_coverage -> chain.analyze_fault_result: "[FE]" { class: fe }
chain.analyze_fault_result -> chain.decide_verdict: "[FE]" { class: fe }
chain.decide_verdict -> chain.record_report: "[FE]" { class: fe }

chain.c_version -> chain.confirm_applicability { class: cstr }
chain.c_pass -> chain.decide_verdict { class: cstr }
chain.c_blocked -> chain.set_acceptance { class: cstr }
chain.c_stats -> chain.analyze_coverage { class: cstr }
chain.c_faults -> chain.analyze_fault_result { class: cstr }
