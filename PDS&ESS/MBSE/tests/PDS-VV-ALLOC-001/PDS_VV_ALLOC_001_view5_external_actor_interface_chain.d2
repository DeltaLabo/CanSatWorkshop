vars: {
  d2-config: {
    layout-engine: elk
  }
}

# PV5 — ALLOC-003 external actor interface analysis chain (charger / user).
# References: IVV; CON-001; CON-003; PC-001; FC-001; CON-004.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 }
  }
  fe: { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce: { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

charger_eq: "[EA] Charger / certified source" {
  class: ea
  direction: down
  grid-columns: 1
  present_cert: "[F] Present charger certification / limits" { class: func }
  apply_limits: "[F] Apply 4.2 V and 0.5 A setup" { class: func }
  deliver_power: "[F] Deliver power" { class: func }
  stop_if_bad_setup: "[F] Hold before energize if bad cert/setup" { class: func }
}

user_eq: "[EA] User / mission operator" {
  class: ea
  direction: down
  grid-columns: 1
  identify_safe_switch: "[F] Identify safe switch/access path" { class: func }
  switch_on: "[F] Switch power on" { class: func }
  switch_off: "[F] Switch power off" { class: func }
  confirm_safe_state: "[F] Confirm safe-off state" { class: func }
}

safety_observer: "[EA] Safety observer / witness" {
  class: ea
  authorize: "[F] Authorize test path" { class: func }
  block_if_unsafe: "[F] Block ambiguous or unsafe operation" { class: func }
}

test_operator: "[EA] Test operator" {
  class: ea
  direction: down
  grid-columns: 1
  log_interlock: "[F] Log interlock and ambient" { class: func }
  archive: "[F] Archive actor-interface evidence" { class: func }
}

system: "[System] PDS-VV-ALLOC-001 external actor interface analysis\nPDS & ESS v1.0; ALLOC-003 coverage with existing CON-001/CON-003/CON-004 and FC-001 evidence references" {
  class: sys
  direction: right

  actor_interface_chain: "[Chain] Actor interface chain" {
    class: chain
    direction: down
    charger_setup: "[F] Charger setup and authorization" { class: func }
    wrong_charger_hold: "[F] Wrong/uncertified charger hold" { class: func }
    unsafe_switch_assess: "[F] Ambiguous switch/access assessment" { class: func }
    command_on: "[F] Command power on" { class: func }
    command_off: "[F] Command safe power off" { class: func }
    controlled_restore: "[F] Controlled restore criteria check" { class: func }
    blocker_waiver_path: "[F] Blocker/waiver path for missing hardware detail" { class: func }
  }

  interface_evidence: "[PC] Actor-interface evidence/control" {
    class: pc
    direction: down
    grid-columns: 1
    record_current_limits: "[LC] Record current/voltage limits" { class: lc }
    record_liion_docs: "[LC] Record Li-ion prerequisite evidence" { class: lc }
    check_wrong_restart: "[LC] Check unsafe restore/restart blocked" { class: lc }
    record_discrepancies: "[LC] Record discrepancy / waiver" { class: lc }
  }

  expected_chain: "[PC] Pass/fail assertions" {
    class: pc
    direction: down
    grid-columns: 1
    explicit_interfaces: "[LC] Explicit actor/procedure interfaces" { class: lc }
    safe_poweroff: "[LC] Power-off leaves system safe" { class: lc }
    no_undescribed_paths: "[LC] No undocumented power-control paths" { class: lc }
    no_ambiguous_master_switch: "[LC] No ambiguous/missing master-switch path tolerated without waiver" { class: lc }
  }

  gap_reference: "[C] Source-model / allocation caveat\nPhysical master switch/access mechanism is not explicit in source model.\nThis chain requires an approved procedure control or waiver before actor-control testing is closed." {
    class: note
    shape: page
  }
}

# Actor ownership assertions.
charger_eq.present_cert -> system.interface_evidence.record_current_limits: "[FE] Pre-charge constraint" { class: fe }
charger_eq.apply_limits -> system.actor_interface_chain.charger_setup: "[FE] Apply safe envelope" { class: fe }
charger_eq.stop_if_bad_setup -> system.actor_interface_chain.wrong_charger_hold: "[FE] Hold/abort" { class: fe }
user_eq.identify_safe_switch -> system.actor_interface_chain.unsafe_switch_assess: "[FE] Safety assessment" { class: fe }
user_eq.switch_on -> system.actor_interface_chain.command_on: "[FE] Execute power-on command" { class: fe }
user_eq.switch_off -> system.actor_interface_chain.command_off: "[FE] Execute power-off command" { class: fe }
user_eq.confirm_safe_state -> system.expected_chain.safe_poweroff: "[FE] Verify safe-off state" { class: fe }
system.actor_interface_chain.charger_setup -> system.expected_chain.explicit_interfaces: "[FE] Expected output" { class: fe }
system.actor_interface_chain.wrong_charger_hold -> system.actor_interface_chain.blocker_waiver_path: "[FE] Block to waiver" { class: fe }
system.actor_interface_chain.unsafe_switch_assess -> system.actor_interface_chain.blocker_waiver_path: "[FE] Blocker decision" { class: fe }
system.actor_interface_chain.command_off -> system.actor_interface_chain.controlled_restore: "[FE] Safe-off then controlled restore check" { class: fe }
system.actor_interface_chain.blocker_waiver_path -> system.expected_chain.no_ambiguous_master_switch: "[FE] Exception handling" { class: fe }

system.actor_interface_chain.controlled_restore -> system.interface_evidence.check_wrong_restart: "[FE] No unsafe restart" { class: fe }
system.interface_evidence.record_liion_docs -> system.expected_chain.explicit_interfaces: "[FE] Document prerequisite" { class: fe }
system.interface_evidence.record_discrepancies -> safety_observer.block_if_unsafe: "[FE] Discrepancy disposition" { class: fe }

charger_eq.deliver_power -> system.interface_evidence.record_current_limits: "[CE] Charge power / current-voltage profile" { class: ce }
user_eq.switch_on -> system.interface_evidence.record_current_limits: "[CE] User command / procedure context" { class: ce }
user_eq.switch_off -> system.interface_evidence.record_discrepancies: "[CE] Safe-off evidence event" { class: ce }

safety_observer.authorize -> test_operator.log_interlock: "[FE] Test authorization context" { class: fe }
safety_observer.block_if_unsafe -> system.interface_evidence.record_discrepancies: "[FE] Unsafe condition hold" { class: fe }
test_operator.archive -> system.expected_chain.no_undescribed_paths: "[FE] Evidence closure for actor paths" { class: fe }

system.gap_reference -> system.expected_chain.no_ambiguous_master_switch: "[CSTR] Model gap applies to ALLOC-003" { class: cstr }
system.expected_chain.no_ambiguous_master_switch -> system.actor_interface_chain.blocker_waiver_path: "[CSTR] Waiver required if source remains unchanged" { class: cstr }
system.actor_interface_chain.wrong_charger_hold -> system.gap_reference: "[CSTR] Documented blocker path" { class: cstr }
system.expected_chain.explicit_interfaces -> system.actor_interface_chain.charger_setup: "[CSTR] Explicit procedures recorded" { class: cstr }

# Layout order hints.
charger_eq -> user_eq { style: { opacity: 0 } }
user_eq -> safety_observer { style: { opacity: 0 } }
safety_observer -> test_operator { style: { opacity: 0 } }
test_operator -> system { style: { opacity: 0 } }
system.actor_interface_chain -> system.interface_evidence { style: { opacity: 0 } }
system.interface_evidence -> system.expected_chain { style: { opacity: 0 } }
system.expected_chain -> system.gap_reference { style: { opacity: 0 } }
