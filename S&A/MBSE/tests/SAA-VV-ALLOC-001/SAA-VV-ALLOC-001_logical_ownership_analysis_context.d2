vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-ALLOC-001 verification-only Physical Architecture PV2.
# Logical ownership context for v1.0 S&A integration-function allocation analysis.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# These LCs and CEs define the allocation analysis only; they are not baseline S&A design edits.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

reviewer: "[EA] S&A Integration Reviewer" { class: ea }
subsystem_owners: "[EA] Subsystem Model Owners\nADS / AMS / OBCC / PDS / ESS / PDM" { class: ea }
configuration_repo: "[EA] Configuration / Evidence\nRepository\nresults/SAA-VV-ALLOC-001" { class: ea }

system: "[System] SAA-VV-ALLOC-001 Logical Ownership Analysis Context\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down

  uut: "[PC] v1.0 S&A Integration\nAllocation Analysis Boundary" {
    class: pc
    direction: down

    candidate_register: "[LC] Candidate S&A\nIntegration Function Register\nverification-only" { class: lc }
    physical_constraint_owner: "[LC] S&A Physical Constraint\nOwnership Candidate\nverification-only" { class: lc }
    subsystem_behavior_refs: "[LC] Subsystem Behavior\nOwner Cross-reference Set\nverification-only" { class: lc }
    decision_matrix: "[LC] Allocation Owner /\nDisposition Matrix\nverification-only" { class: lc }
    gap_register: "[LC] Foreign or Unowned\nFunction Gap Register\nverification-only" { class: lc }
    hazard_screen: "[LC] Allocation Fault-Hazard\nScreen\nverification-only" { class: lc }
  }

  verification_only: "[C] Verification-only context:\nBaseline S&A v1.0 physical view has no [LC], [F],\n[FE], [CE], or functional-chain source views. This\nactivity models the ownership analysis that decides\nwhether S&A needs explicit allocation views or whether\nsubsystem models own behavior and S&A owns physical\nintegration constraints only." {
    class: note
    shape: page
  }

  candidate_scope: "[C] Candidate function scope:\nmaintain envelope and mass budget; retain module stack;\naccommodate 44 mm × 44 mm PCBs; locate/mate backplane;\nexpose critical testpoints; provide top-module/backplane\nclearance; retain ESS battery; retain PDM servo connector;\nsupport parachute deployment clearance; assign environmental\nscreening ownership. Behavior such as sensing, command logic,\npower regulation, and bus protocol operation is foreign unless\nexplicitly assigned to S&A." {
    class: note
    shape: page
  }

  pass_fail: "[C] Pass/fail constraint:\nPass requires 100% owner/disposition review of all candidate\nS&A integration functions and every foreign/ambiguous function.\nNo ambiguous ownership may remain for backplane, harness/connector,\nretention, deployment clearance, physical fit, testpoint access,\nor environmental screening. Each S&A-owned function is either\nallocated in an explicit S&A LC/function view or dispositioned as\na physical constraint with a controlled rationale. Each subsystem-\nowned behavior has a model/evidence cross-reference. Missing owner,\nmissing disposition, or unowned foreign function = hold/fail." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\n100% model/ownership review of v1.0 candidate functions,\nconstraints, and relevant owner responses. This analysis is a\ncensus review and makes no sampling or reliability-population claim." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nMissed ownership can create unverified backplane fit/mate hazards,\nretention escapes, battery or connector release, blocked parachute\nclearance, unverified physical-fit or mass/envelope noncompliance,\nand environmental-screening gaps before flight readiness." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability targets:\nSAA-UC-IntegratedAssembly; SAA-UC-BackplaneIntegration;\nSAA-UC-ParachuteClearance; SAA-FE-EnvelopeNonCompliance;\nSAA-FE-BackplaneMisMate; SAA-FE-StructuralLoosening;\nSAA-FE-LandingDamage; v1.0 envelope, module, backplane,\nand assembly/printing constraints." {
    class: note
    shape: page
  }
}

reviewer -> system.uut.candidate_register: "[CE] Kickoff checklist\n+ baseline interpretation" { class: ce }
reviewer -> system.uut.decision_matrix: "[CE] Ownership decision\ncriteria" { class: ce }
subsystem_owners -> system.uut.subsystem_behavior_refs: "[CE] Model refs, owner\nresponses, waivers" { class: ce }
configuration_repo -> system.uut.candidate_register: "[CE] Baseline copies,\nconstraints, prior IVV plan" { class: ce }

system.uut.candidate_register -> system.uut.physical_constraint_owner: "[CE] Candidate physical\nintegration functions" { class: ce }
system.uut.candidate_register -> system.uut.subsystem_behavior_refs: "[CE] Candidate foreign\nbehavior functions" { class: ce }
system.uut.physical_constraint_owner -> system.uut.decision_matrix: "[CE] S&A owner/disposition\nrecommendations" { class: ce }
system.uut.subsystem_behavior_refs -> system.uut.decision_matrix: "[CE] Subsystem owner\ncross-references" { class: ce }
system.uut.candidate_register -> system.uut.gap_register: "[CE] Ambiguous or extra\nfunction candidates" { class: ce }
system.uut.gap_register -> system.uut.hazard_screen: "[CE] Open ownership\ngaps" { class: ce }
system.uut.hazard_screen -> system.uut.decision_matrix: "[CE] Hazard-screened\ndispositions" { class: ce }
system.uut.decision_matrix -> reviewer: "[CE] Pass/hold/fail\nallocation decision" { class: ce }
system.uut.decision_matrix -> configuration_repo: "[CE] Released matrix,\nmodel-change requests, report index" { class: ce }

system.verification_only -> system.uut.candidate_register { class: cstr }
system.candidate_scope -> system.uut.candidate_register { class: cstr }
system.pass_fail -> system.uut.decision_matrix { class: cstr }
system.pass_fail -> system.uut.gap_register { class: cstr }
system.statistical -> system.uut.candidate_register { class: cstr }
system.fault_hardening -> system.uut.hazard_screen { class: cstr }
system.traceability -> system.uut.decision_matrix { class: cstr }

# Layout-only edges keep reviewer/owners, analysis boundary, repository, and constraints in reading order.
reviewer -> subsystem_owners { style: { opacity: 0 } }
subsystem_owners -> system { style: { opacity: 0 } }
system -> configuration_repo { style: { opacity: 0 } }
system.uut.candidate_register -> system.uut.physical_constraint_owner { style: { opacity: 0 } }
system.uut.physical_constraint_owner -> system.uut.subsystem_behavior_refs { style: { opacity: 0 } }
system.uut.subsystem_behavior_refs -> system.uut.decision_matrix { style: { opacity: 0 } }
system.uut.decision_matrix -> system.uut.gap_register { style: { opacity: 0 } }
system.uut.gap_register -> system.uut.hazard_screen { style: { opacity: 0 } }
system.uut -> system.verification_only { style: { opacity: 0 } }
system.verification_only -> system.candidate_scope { style: { opacity: 0 } }
system.candidate_scope -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.traceability { style: { opacity: 0 } }
