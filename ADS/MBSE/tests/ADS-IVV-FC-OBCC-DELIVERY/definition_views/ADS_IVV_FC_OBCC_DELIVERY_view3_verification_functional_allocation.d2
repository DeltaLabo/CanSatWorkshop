vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Verification-only functional allocation for ADS-IVV-FC-OBCC-DELIVERY.
# PV3-style view: allocated UUT/test/human/analysis functions; no exchanges shown.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-FC-OBCC-DELIVERY\nverification functional allocation\nRefs: IVV; ADS MBSE plan; NASA-SE; SW/stats" {
  class: sys
  direction: down

  uut: "[PC] v1.0 integrated CanSat / ADS / OBCC UUT" {
    class: pc
    direction: down

    xiao: "[PC] OBCC XIAO ESP32-S3\nexecution target" {
      class: pc
      direction: down
      grid-columns: 3

      ads_processing: "[LC] ADS Processing\nsource producer" {
        class: lc
        direction: down
        grid-columns: 2
        acquire_gps: "[F] Read/store GPS\nlat, lon, init state" { class: func }
        acquire_imu: "[F] Read/process IMU\nvel, accel, field" { class: func }
        calculate_attitude: "[F] Calculate\npitch, roll, yaw" { class: func }
        expose_pointers: "[F] Expose modeled ADS\ndata handles via Pointers" { class: func }
        provide_returns: "[F] Provide Returns\nstatus/error semantics" { class: func }
        enforce_lifetime: "[F] Enforce ownership,\nlifetime, freshness metadata" { class: func }
        note_contract: "[C] Interface contract\nOBCC obtains modeled ADS data/handles through\nPointers/Returns only; ownership, lifetime,\nfreshness, validity, and errors are explicit." { class: note; shape: page }
      }

      obcc: "[LC] OBCC\ncollection consumer" {
        class: lc
        direction: down
        grid-columns: 2
        call_pointers: "[F] Request ADS data\nthrough Pointers" { class: func }
        check_semantics: "[F] Check validity,\nfreshness, ownership" { class: func }
        collect_measurements: "[F] Collect GPS/IMU/\nattitude measurements" { class: func }
        reject_invalid: "[F] Reject null, dangling,\nstale, corrupt data as valid" { class: func }
        handle_returns: "[F] Handle Returns\nstatus and errors" { class: func }
        emit_obcc_log: "[F] Emit OBCC delivery\nverdict records" { class: func }
        note_faults: "[C] Fault-hardening pass/fail\nNull, dangling, stale, corrupt, invalid-return,\nand slow/stuck-call cases are rejected or reported\nas errors and are not consumed as valid." { class: note; shape: page }
      }

      verification_probe: "[LC] Verification-only\ndelivery observation probe" {
        class: lc
        direction: down
        grid-columns: 2
        timestamp_handoff: "[F] Timestamp Pointer/\nReturn transactions" { class: func }
        monitor_lifetime: "[F] Monitor pointer\nlifetime and freshness" { class: func }
        mark_faults: "[F] Mark injected fault\ncase boundaries" { class: func }
        expose_heartbeat: "[F] Expose loop progress\nand no-block heartbeat" { class: func }
        note_timing: "[C] Bounded/no-blocking\nApply Variable Getter, process/calculate <5 ms,\nUART/I2C read <=5 ms constraints. Delivery\nprogress/freshness max gap is 400 ms; no\nseparate watchdog threshold is used." { class: note; shape: page }
      }
    }
  }
}

test_conductor: "[EA] Human IVV test conductor" {
  class: ea
  direction: down
  grid-columns: 2
  select_baseline: "[F] Select v1.0 baseline,\nUUT, firmware commit" { class: func }
  start_nominal: "[F] Start nominal\ndelivery campaign" { class: func }
  command_faults: "[F] Command fault cases\nand recovery steps" { class: func }
  record_deviations: "[F] Record deviations,\nanomalies, waivers" { class: func }
}

code_reviewer: "[EA] Human software reviewer" {
  class: ea
  direction: down
  grid-columns: 2
  inspect_contract: "[F] Inspect Pointers/Returns\nAPI and ownership rules" { class: func }
  inspect_callers: "[F] Inspect OBCC callers\nfor unmodeled data paths" { class: func }
  inspect_timeouts: "[F] Inspect blocking and\ntimeout behavior" { class: func }
  approve_analysis: "[F] Approve supporting\nanalysis rationale" { class: func }
}

obcc_harness: "[EA] OBCC firmware / log harness" {
  class: ea
  direction: down
  grid-columns: 2
  load_firmware: "[F] Load instrumented\nADS/OBCC firmware" { class: func }
  capture_obcc_log: "[F] Capture OBCC\ncollection records" { class: func }
  capture_timing: "[F] Capture transaction\ntiming and heartbeat" { class: func }
  preserve_binary: "[F] Preserve firmware\nand build metadata" { class: func }
}

ads_stim_logger: "[EA] ADS data stimulus / logger" {
  class: ea
  direction: down
  grid-columns: 2
  provide_nominal_data: "[F] Provide or record\nGPS/IMU/attitude stimuli" { class: func }
  inject_corrupt_data: "[F] Inject corrupt, stale,\ninvalid data states" { class: func }
  inject_slow_call: "[F] Induce slow/stuck\nread-call conditions" { class: func }
  log_fault_markers: "[F] Log stimulus and\nfault markers" { class: func }
}

pointer_station: "[EA] Pointer lifetime / freshness\nmonitor and code-review station" {
  class: ea
  direction: down
  grid-columns: 2
  observe_handles: "[F] Observe handles, nulls,\naddresses, and epochs" { class: func }
  detect_dangling: "[F] Detect dangling or\nout-of-lifetime use" { class: func }
  compare_schema: "[F] Compare delivered fields\nagainst modeled inventory" { class: func }
  preserve_review: "[F] Preserve contract\nreview notes" { class: func }
}

power_supply: "[EA] Current-limited power supply" {
  class: ea
  direction: down
  grid-columns: 1
  set_power: "[F] Set and monitor\nvoltage/current limits" { class: func }
  log_power: "[F] Log resets, brownouts,\nand current anomalies" { class: func }
  note_power: "[C] Power condition\nRecord limits and anomalies; defer if\nUUT resets or supply configuration is unclear." { class: note; shape: page }
}

ambient_monitor: "[EA] Ambient monitor" {
  class: ea
  direction: down
  grid-columns: 1
  read_ambient: "[F] Read temperature and\nhumidity before/after runs" { class: func }
  log_ambient: "[F] Log ambient conditions\nwith calibration ID" { class: func }
  note_environment: "[C] Environment condition\nHuman conductor records ambient readings,\ncalibration ID, and actual conditions." { class: note; shape: page }
}

analysis_script: "[EA] Analysis script / report generator" {
  class: ea
  direction: down
  grid-columns: 2
  parse_records: "[F] Parse Pointer/Return\ndelivery records" { class: func }
  compute_coverage: "[F] Compute field, fault,\nand version coverage" { class: func }
  evaluate_timing: "[F] Evaluate bounded\ndelivery/no-blocking" { class: func }
  produce_report: "[F] Produce verdict and\nevidence index" { class: func }
  note_statistics: "[C] Statistical viewpoint\nMinimum nominal evidence: >=30 delivery observations\ncovering GPS, IMU, attitude, and init-state fields.\nFormal freshness/deadline claims use n=59 zero-violation\nrequest/response observations; PDR is separate." { class: note; shape: page }
}

quality: "[EA] Quality / configuration reviewer" {
  class: ea
  direction: down
  grid-columns: 1
  review_verdict: "[F] Review pass/fail,\nlimitations, retest status" { class: func }
}

system.uut.xiao.ads_processing.note_contract -> system.uut.xiao.ads_processing.expose_pointers { class: cstr }
system.uut.xiao.ads_processing.note_contract -> system.uut.xiao.ads_processing.provide_returns { class: cstr }
system.uut.xiao.ads_processing.note_contract -> system.uut.xiao.obcc.call_pointers { class: cstr }
system.uut.xiao.obcc.note_faults -> system.uut.xiao.obcc.reject_invalid { class: cstr }
system.uut.xiao.verification_probe.note_timing -> system.uut.xiao.verification_probe.expose_heartbeat { class: cstr }
system.uut.xiao.verification_probe.note_timing -> system.uut.xiao.verification_probe.timestamp_handoff { class: cstr }
power_supply.note_power -> power_supply.set_power { class: cstr }
ambient_monitor.note_environment -> ambient_monitor.read_ambient { class: cstr }
analysis_script.note_statistics -> analysis_script.compute_coverage { class: cstr }
analysis_script.note_statistics -> analysis_script.evaluate_timing { class: cstr }

# Layout-only ordering hints.
system -> test_conductor { style: { opacity: 0 } }
test_conductor -> code_reviewer { style: { opacity: 0 } }
code_reviewer -> obcc_harness { style: { opacity: 0 } }
obcc_harness -> ads_stim_logger { style: { opacity: 0 } }
ads_stim_logger -> pointer_station { style: { opacity: 0 } }
pointer_station -> power_supply { style: { opacity: 0 } }
power_supply -> ambient_monitor { style: { opacity: 0 } }
ambient_monitor -> analysis_script { style: { opacity: 0 } }
analysis_script -> quality { style: { opacity: 0 } }
