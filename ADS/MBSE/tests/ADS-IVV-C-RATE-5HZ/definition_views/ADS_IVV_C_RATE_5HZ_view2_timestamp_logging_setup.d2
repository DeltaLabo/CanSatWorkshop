vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Timestamp/logging setup for ADS-IVV-C-RATE-5HZ.
# Defines physical/logical verification means, temporary links, and execution conditions.
direction: down

classes: {
  func: { shape: rectangle; style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 } }
  lc: { style: { fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  pc: { style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 } }
  sys: { style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 } }
  ea: { shape: rectangle; style: { fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2; border-radius: 20; font-size: 40 } }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: { style: { fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2; border-radius: 20; font-size: 36 } }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] ADS-IVV-C-RATE-5HZ\nTimestamp and logging setup\nRefs: IVV; SW/stats; ADS MBSE plan" {
  class: sys
  direction: down

  uut: "[PC] Selected ADS UUT\none version per execution" {
    class: pc
    direction: right
    grid-columns: 2
    v01: "[PC] v0.1 prototype\n5 Hz applicable" { class: pc }
    v02: "[PC] v0.2 prototype\n5 Hz applicable" { class: pc }
    v03: "[PC] v0.3 PCB article\nN/A for behavior" { class: pc }
    v10: "[PC] v1.0 integrated article\nno explicit ADS 5 Hz" { class: pc }
  }
}

conductor: "[EA] IVV rate test conductor\n(human)" { class: ea }
serial_logger: "[EA] PC serial logger and\nhost timestamping tool" { class: ea }
firmware_tool: "[EA] Optional firmware\ntimestamp instrumentation" { class: ea }
reference_clock: "[EA] Reference clock /\ntimebase source" { class: ea }
analysis_script: "[EA] Rate analysis script\nperiod/gap/stale checks" { class: ea }
power_ambient: "[EA] Power and ambient\nmonitor" { class: ea }

note_period: "[C] 5 Hz timing target\nNominal collection period is 200 ms.\nEvaluate mean collection rate, every per-sample\nperiod, worst gap, stale values, and dropped values." { class: note; shape: page }
note_tolerance_gate: "[C] Pre-execution tolerance gate\nAllowed jitter and worst-gap limit must be selected\nand recorded before execution. If not selected, the\nrate verdict is BLOCKED/LIMITED; do not invent a\nhidden tolerance after data collection." { class: note; shape: page }
note_formal_claim: "[C] Formal deadline/tolerance claim\nIf claiming a deadline/tolerance, use n = 59\nrepresentative collection samples and require every\nsample period/gap to be inside the selected limit." { class: note; shape: page }
note_environment: "[C] Execution conditions\nRecord firmware commit/build, timestamp instrumentation\noverhead, logger configuration, reference-clock uncertainty,\nsupply voltage/current, ambient temperature/humidity,\nand calibration/function-check status before repetitions." { class: note; shape: page }
note_faults: "[C] Fault-hardening viewpoint\nFail or limit if the loop stalls, timestamps stop, stale\nor dropped values are unflagged, serial logging backpressure\nchanges UUT behavior unrecorded, or clock drift/wrap is unresolved." { class: note; shape: page }

# Temporary physical links used only by verification.
serial_logger -- system.uut: "[PL] USB-C / UART\nlog cable" { class: pl }
firmware_tool -- system.uut: "[PL] programming / debug\ninterface when used" { class: pl }
reference_clock -- serial_logger: "[PL] USB/NTP/1PPS\ntimebase link" { class: pl }
power_ambient -- system.uut: "[PL] power leads and\nambient probe placement" { class: pl }

# Verification exchanges and evidence records.
conductor -> system.uut: "[CE] run sheet, version\nselection, start/stop" { class: ce }
firmware_tool -> system.uut: "[CE] timestamp hooks\nand instrumentation config" { class: ce }
system.uut -> serial_logger: "[CE] ADS records\ncollection timestamp, sample ID,\nlat/lon/status, stale/drop markers" { class: ce }
reference_clock -> serial_logger: "[CE] timebase\ncalibration and drift record" { class: ce }
power_ambient -> serial_logger: "[CE] voltage/current/\nambient readings" { class: ce }
serial_logger -> analysis_script: "[CE] raw log and\nhost timestamps" { class: ce }
conductor -> analysis_script: "[CE] selected jitter and\nworst-gap tolerance" { class: ce }
analysis_script -> conductor: "[CE] rate analysis\nresult and limitations" { class: ce }

note_period -> analysis_script { class: cstr }
note_tolerance_gate -> conductor { class: cstr }
note_tolerance_gate -> analysis_script { class: cstr }
note_formal_claim -> analysis_script { class: cstr }
note_environment -> power_ambient { class: cstr }
note_environment -> reference_clock { class: cstr }
note_faults -> serial_logger { class: cstr }

# Layout-only rank hints to keep setup means and constraints readable.
system -> conductor { style: { opacity: 0 } }
conductor -> serial_logger { style: { opacity: 0 } }
serial_logger -> firmware_tool { style: { opacity: 0 } }
firmware_tool -> reference_clock { style: { opacity: 0 } }
reference_clock -> power_ambient { style: { opacity: 0 } }
power_ambient -> analysis_script { style: { opacity: 0 } }
analysis_script -> note_period { style: { opacity: 0 } }
note_period -> note_tolerance_gate { style: { opacity: 0 } }
note_tolerance_gate -> note_formal_claim { style: { opacity: 0 } }
note_formal_claim -> note_environment { style: { opacity: 0 } }
note_environment -> note_faults { style: { opacity: 0 } }
