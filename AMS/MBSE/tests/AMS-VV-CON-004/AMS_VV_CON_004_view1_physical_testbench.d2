vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view — AMS-VV-CON-004 processing timing and non-blocking testbench
# Verification references: IVV, AMS-R5 (statistics), PM&SE/IVV timing/fault semantics.
# IADT: Testing with supporting Analysis. SSIV: AMS v1.0 final acceptance.
# Traceability: timing constraints; AMS-UC-MeasureAtmosphere; AMS-FE-SensorBusFault; AMS-FE-SchedulerBlock.
# Scope note: I2C read timing itself is excluded and remains covered by AMS-VV-CON-003.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-VV-CON-004 processing timing / non-blocking\nAMS v1.0 final acceptance; Refs: IVV, AMS-R5, PM&SE/IVV" {
  class: sys
  direction: down

  cansat: "[PC] CanSat" {
    class: pc
    direction: right

    ams_module: "[PC] AMS Module" {
      class: pc
      direction: down

      ams_pcb: "[PC] AMS PCB" {
        class: pc
        direction: down

        bme280: "[PC] BME280" { class: pc }
        ams_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }

    backplane_pcb: "[PC] Backplane PCB" {
      class: pc
      direction: down
      grid-columns: 1

      ams_headers: "[PC] 2mm 2x6 AMS Headers" { class: pc }
      spine: "[PC] Spine" { class: pc }
      obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
    }

    obcc_module: "[PC] OBCC Module" {
      class: pc
      direction: down

      obcc_pcb: "[PC] OBCC PCB" {
        class: pc
        direction: down

        xiao: "[PC] XIAO ESP32-S3" { class: pc }
        obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
      }
    }
  }
}

host_pc: "[EA] Host PC\nProfiler / Logger" { class: ea }
timer_harness: "[EA] Instrumented Firmware /\nTimer Harness" { class: ea }
bench_supply: "[EA] Bench Power\nSupply" { class: ea }
fault_stimulus_injector: "[EA] Fault / Stimulus\nInjector (optional)" { class: ea }
evidence_repository: "[EA] Evidence\nRepository" { class: ea }

note_airflow: "[C] Block sunlight,\nallow airflow" {
  class: note
  shape: page
}
note_testbench: "[C] VV-only bench connections shall not bypass modeled AMS\nProcessing, getter, or OBCC call paths; I2C read timing/fault\nevidence is referenced to AMS-VV-CON-003 and pointer policy\nto AMS-VV-API-001" {
  class: note
  shape: page
}
note_instrumentation: "[C] Timer/profiler overhead shall be measured\nor bounded and included in U95 for each\nCalculate altitude and Process temperature claim" {
  class: note
  shape: page
}
note_power_env: "[C] Stable 3V3/common ground required;\nrecord voltage/current and ambient\nconditions before timing batches" {
  class: note
  shape: page
}
note_evidence: "[C] Raw timing logs, input vectors, static callable-path matrix,\nscheduler heartbeat/progress traces, shared-status propagation,\ninstrumentation overhead, and anomalies are archived under\nresults/AMS-VV-CON-004/" {
  class: note
  shape: page
}

system.cansat.ams_module.ams_pcb -- system.cansat.ams_module: "[PL] Screws" { class: pl }
system.cansat.obcc_module.obcc_pcb -- system.cansat.obcc_module: "[PL] Screws" { class: pl }

system.cansat.ams_module -- system.cansat.backplane_pcb: "[PL] Backplane\nFixture" { class: pl }
system.cansat.obcc_module -- system.cansat.backplane_pcb: "[PL] Backplane\nFixture" { class: pl }

system.cansat.ams_module.ams_pcb.bme280 -- system.cansat.ams_module.ams_pcb: "[PL] BME280\nFootprint" { class: pl }
system.cansat.ams_module.ams_pcb.ams_backplane_connector -- system.cansat.ams_module.ams_pcb: "[PL] Connector\nfootprint" { class: pl }
system.cansat.ams_module.ams_pcb.bme280 -- system.cansat.ams_module.ams_pcb.ams_backplane_connector: "[PL] I2C + 3V3\ntraces" { class: pl }
system.cansat.ams_module.ams_pcb.ams_backplane_connector -- system.cansat.backplane_pcb.ams_headers: "[PL] Parallel\nConnector" { class: pl }

system.cansat.obcc_module.obcc_pcb.xiao -- system.cansat.obcc_module.obcc_pcb: "[PL] XIAO\nFootprint" { class: pl }
system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector -- system.cansat.obcc_module.obcc_pcb: "[PL] Connector\nfootprint" { class: pl }
system.cansat.obcc_module.obcc_pcb.xiao -- system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] I2C + 3V3\ntraces" { class: pl }
system.cansat.obcc_module.obcc_pcb.obcc_backplane_connector -- system.cansat.backplane_pcb.obcc_headers: "[PL] Parallel\nCable" { class: pl }

system.cansat.backplane_pcb.ams_headers -- system.cansat.backplane_pcb.spine: "[PL] Footprint" { class: pl }
system.cansat.backplane_pcb.obcc_headers -- system.cansat.backplane_pcb.spine: "[PL] Footprint" { class: pl }

host_pc -- system.cansat.obcc_module.obcc_pcb.xiao: "[PL] USB CDC\nprofile log" { class: pl }
timer_harness -- system.cansat.obcc_module.obcc_pcb.xiao: "[PL] GPIO/timer\nprobe or debug" { class: pl }
fault_stimulus_injector -- system.cansat.obcc_module.obcc_pcb.xiao: "[PL] Test-vector\nstimulus" { class: pl }
bench_supply -- system.cansat.backplane_pcb: "[PL] 3V3/GND" { class: pl }
host_pc -- evidence_repository: "[PL] Network /\ncontrolled storage" { class: pl }

note_airflow -> system.cansat.ams_module { class: cstr }
note_testbench -> host_pc { class: cstr }
note_testbench -> timer_harness { class: cstr }
note_testbench -> fault_stimulus_injector { class: cstr }
note_instrumentation -> timer_harness { class: cstr }
note_power_env -> bench_supply { class: cstr }
note_power_env -> system.cansat.backplane_pcb { class: cstr }
note_evidence -> evidence_repository { class: cstr }
