vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 14 }
  }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 18
    }
  }
  fe: { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 12 } }
}

chain: "PDS v0.2 — Power chain" {
  class: chain
  direction: right

  charger_power: "[F] Provide power" { class: func }
  switch_on: "[F] Switch power on" { class: func }
  switch_off: "[F] Switch power off" { class: func }
  charger_regulate_voltage: "[F] Regulate\nvoltage" { class: func }
  store_energy: "[F] Store energy" { class: func }
  provide_power: "[F] Provide power" { class: func }
  restore_power: "[F] Restore power" { class: func }
  cut_off_power: "[F] Cut off power" { class: func }
  regulate_voltage: "[F] Regulate\nvoltage" { class: func }
}

chain.charger_power -> chain.charger_regulate_voltage: "[FE] Charger power" { class: fe }
chain.switch_on -> chain.restore_power: "[FE] Power-on command" { class: fe }
chain.switch_off -> chain.cut_off_power: "[FE] Power-off command" { class: fe }
chain.charger_regulate_voltage -> chain.store_energy: "[FE] Regulated power" { class: fe }
chain.provide_power -> chain.regulate_voltage: "[FE] Battery power" { class: fe }
