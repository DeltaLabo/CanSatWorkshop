vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-FC-003 verification-only Physical Architecture PV3.
# Functional allocation/procedure view for v1.0 parachute/top-module clearance and deployment-interference checks.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R3, SAA-R4, SAA-R5.
# Functions and LCs here define the verification activity only; they are not baseline S&A design edits.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" {
  class: ea
  direction: down
  identify_article: "[F] Identify v1.0 article,\nbuild record, baseline copy,\nand SAA-VV-FC-003 definition" { class: func }
  establish_safety: "[F] Establish safety zone,\nclear hands from deployment path,\nand brief no-assist rule" { class: func }
  pack_parachute: "[F] Pack parachute using\napproved pack/reset fixture\nand record pack condition" { class: func }
  command_deploy: "[F] Command open cap / servo\nor perform controlled manual actuation" { class: func }
  reset_service: "[F] Reset cap, servo,\nand parachute to serviceable\nclosed state after each trial" { class: func }
  record_anomaly: "[F] Record snag, rub,\ninterference, movement, hold,\nrework, or waiver condition" { class: func }
}

witness: "[EA] Safety / QA Witness" {
  class: ea
  direction: down
  witness_setup: "[F] Witness setup, equipment IDs,\npre/post screen status, and trial count" { class: func }
  witness_deployment: "[F] Witness no hand assistance,\nno forced release, and safe actuation" { class: func }
  approve_gate: "[F] Approve pass, fail,\nor execution hold" { class: func }
}

pack_fixture: "[EA] Parachute Pack /\nReset Fixture" {
  class: ea
  direction: down
  constrain_pack: "[F] Constrain repeatable fold,\nparachute orientation, and cap closed state" { class: func }
  support_reset: "[F] Support reset / serviceability\nwithout unapproved rework" { class: func }
}

servo_interface: "[EA] Servo Command Interface /\nManual Actuation Tool" {
  class: ea
  direction: down
  send_open_command: "[F] Send open command or\napply manual actuator input" { class: func }
  record_timing: "[F] Record command timestamp,\nactuation mode, and servo return state" { class: func }
}

camera: "[EA] High-speed / Video Camera" {
  class: ea
  direction: down
  setup_view: "[F] Set lighting, frame rate,\nfield of view, and focus markers" { class: func }
  capture_motion: "[F] Capture cap motion,\nservo horn/linkage, parachute extraction,\nand any snag/rub evidence" { class: func }
}

clearance_gauge: "[EA] Clearance Gauge /\nSnag Witness Markers" {
  class: ea
  direction: down
  check_path: "[F] Check cap/servo path\nagainst structure, backplane,\nand PDM servo connector keep-outs" { class: func }
  detect_rub: "[F] Detect rub, witness mark,\nblocked path, or snag contact" { class: func }
}

inspection_kit: "[EA] Pre/Post PC-PL\nInspection Kit" {
  class: ea
  direction: down
  inspect_before: "[F] Inspect stack screws,\ntop-module attachment, backplane fixture,\nPDM servo connector, PCB standoffs,\nand battery fixture before repetitions" { class: func }
  inspect_after: "[F] Inspect same PCs/PLs\nafter repetitions or environmental screens\nfor movement, looseness, or damage" { class: func }
}

env_screen_record: "[EA] Vibration / Drop\nScreen Record" {
  class: ea
  direction: down
  provide_context: "[F] Provide post-vibration/drop\ncondition reference when this activity\nis executed after environmental screens" { class: func }
}

ambient_meter: "[EA] Ambient Thermo-\nHygrometer" {
  class: ea
  direction: down
  record_ambient: "[F] Record ambient temperature\nand humidity before repetitions" { class: func }
}

repo: "[EA] Evidence Repository" {
  class: ea
  direction: down
  store_package: "[F] Store controlled report,\ntrial log, video, photos, inspection\nrecords, and dispositions" { class: func }
}

system: "[System] SAA-VV-FC-003 Functional Allocation / Deployment-Clearance Demonstration-Testing Procedure\nRefs: IVV; SAA-R1; SAA-R2; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down
  grid-columns: 1

  cansat: "[PC] v1.0 CanSat Assembly\nUUT" {
    class: pc
    direction: down

    standard_stack: "[PC] Standard Carrier\nModule Stack" {
      class: pc
      direction: down
      stack_retention_lc: "[LC] Stack and Module\nRetention\nverification-only" {
        class: lc
        direction: down
        maintain_stack: "[F] Maintain stack screws,\nmodule alignment, PCB standoffs,\nand battery fixture during deployments" { class: func }
        expose_movement: "[F] Expose any post-trial\nmodule or screw movement for inspection" { class: func }
      }
    }

    backplane_pcb: "[PC] Backplane PCB\nand PDM Servo Connector" {
      class: pc
      direction: down
      backplane_clearance_lc: "[LC] Backplane / Servo-Connector\nClearance Boundary\nverification-only" {
        class: lc
        direction: down
        define_keepout: "[F] Define backplane spine\nand PDM servo connector keep-out\nfor cap/servo/parachute path" { class: func }
        remain_secure: "[F] Remain seated and unmoved\nthrough deployment repetitions" { class: func }
        expose_interference: "[F] Expose backplane or connector\nrub, snag, unseat, or movement" { class: func }
      }
    }

    parachute_module: "[PC] Parachute / Top Module" {
      class: pc
      direction: down
      deployment_lc: "[LC] Deployment Mechanism\nverification-only" {
        class: lc
        direction: down
        present_packed: "[F] Present packed parachute,\nclosed cap, and ready servo state" { class: func }
        open_cap: "[F] Open cap and drive servo\nthrough deployment path" { class: func }
        extract_parachute: "[F] Allow parachute to extract\nwithout snagging or hand assistance" { class: func }
        reset_serviceable: "[F] Return cap, servo,\nand parachute to repeatable\nserviceable reset state" { class: func }
      }
      clearance_lc: "[LC] Top-Module Clearance\nand Snag Screening\nverification-only" {
        class: lc
        direction: down
        clear_structure: "[F] Clear top-module structure,\nstack opening, cap edge, and servo path" { class: func }
        reveal_pack_variability: "[F] Reveal packed-parachute\nvariability and snag risk" { class: func }
        hold_on_interference: "[F] Enter hold on rub,\nsnag, failed release, forced reset,\nor ambiguous observation" { class: func }
      }
    }

    acceptance_lc: "[LC] Deployment Clearance\nAcceptance Gate\nverification-only" {
      class: lc
      direction: down
      count_trials: "[F] Count 10/10 workshop screen\nor 29/29 R90/C95 zero-snag trials" { class: func }
      apply_pass_fail: "[F] Apply clearance, extraction,\nretention, serviceability, and evidence criteria" { class: func }
      require_rerun: "[F] Require disposition and\nre-run after anomaly, rework,\nwaiver, or evidence gap" { class: func }
      bind_evidence: "[F] Bind video, trial log,\npre/post PC-PL checks, ambient data,\nand witness decision" { class: func }
    }
  }

  pass_fail: "[C] Pass/fail constraint: Pass only if cap and servo\nmotion clear the structure, backplane spine and PDM\nservo connector; the parachute extracts without\nsnagging, hang-up, hand assistance, or dragging the\nassembly; reset/serviceability is preserved; no\nconnector, backplane, module, screw, PCB standoff or\nbattery-fixture movement is introduced; pre/post PC-PL\nchecks and evidence are complete; and all anomalies are\nclosed/re-run." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint: Workshop screen\nrequires 10 repeated deployments with all zero-snag\npasses. A reliability claim of R90/C95 requires 29\nrepresentative independent zero-snag trials; otherwise\nrepetitions are screen evidence only. Every trial\nrecords pack condition, command method, result and reset\nstatus." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint: Controls detect cap rub,\nservo travel limit, backplane/PDM servo connector\ninterference, packed-parachute variability,\npost-vibration/drop looseness, and evidence ambiguity.\nAny such finding triggers hold/disposition/re-run rather\nthan a pass." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental/equipment condition: Record ambient\ntemperature/humidity, camera frame rate/FOV/lighting,\ngauge IDs, pack/reset fixture setting, actuation method,\npre/post environmental-screen status and witness\nidentity before repetitions begin." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target: SAA-UC-ParachuteClearance;\nSAA-FE-StructuralLoosening; SAA-FE-LandingDamage; v1.0\nstack screws, backplane fixture + servo connector,\nparachute/top-module PCs, and modeled landing-impact /\nassembly constraints." {
    class: note
    shape: page
  }
}

system.pass_fail -> system.cansat.parachute_module.deployment_lc.open_cap { class: cstr }
system.pass_fail -> system.cansat.parachute_module.deployment_lc.extract_parachute { class: cstr }
system.pass_fail -> system.cansat.parachute_module.clearance_lc.clear_structure { class: cstr }
system.pass_fail -> system.cansat.backplane_pcb.backplane_clearance_lc.remain_secure { class: cstr }
system.pass_fail -> system.cansat.standard_stack.stack_retention_lc.maintain_stack { class: cstr }
system.pass_fail -> system.cansat.acceptance_lc.apply_pass_fail { class: cstr }
system.statistical -> system.cansat.acceptance_lc.count_trials { class: cstr }
system.fault_hardening -> system.cansat.parachute_module.clearance_lc.hold_on_interference { class: cstr }
system.fault_hardening -> system.cansat.backplane_pcb.backplane_clearance_lc.expose_interference { class: cstr }
system.conditions -> system.cansat.acceptance_lc.bind_evidence { class: cstr }
system.traceability -> system.cansat.acceptance_lc.apply_pass_fail { class: cstr }

# Layout-only edges keep actors and system allocations in procedure order.
operator -> witness { style: { opacity: 0 } }
witness -> pack_fixture { style: { opacity: 0 } }
pack_fixture -> servo_interface { style: { opacity: 0 } }
servo_interface -> camera { style: { opacity: 0 } }
camera -> clearance_gauge { style: { opacity: 0 } }
clearance_gauge -> inspection_kit { style: { opacity: 0 } }
inspection_kit -> env_screen_record { style: { opacity: 0 } }
env_screen_record -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.cansat.standard_stack -> system.cansat.backplane_pcb { style: { opacity: 0 } }
system.cansat.backplane_pcb -> system.cansat.parachute_module { style: { opacity: 0 } }
system.cansat.parachute_module -> system.cansat.acceptance_lc { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.conditions { style: { opacity: 0 } }
system.conditions -> system.traceability { style: { opacity: 0 } }
