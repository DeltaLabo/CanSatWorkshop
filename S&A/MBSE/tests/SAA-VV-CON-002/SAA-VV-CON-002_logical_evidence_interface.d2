vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-CON-002 verification-only Physical Architecture PV2.
# Logical/evidence interface view for modular-structure and 44 mm PCB accommodation constraint verification.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R3, SAA-R4, SAA-R5.
# These LCs and CEs define verification means only; they are not baseline S&A design exchanges.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
witness: "[EA] Safety / QA Witness" { class: ea }
fit_gauge_set: "[EA] 44 mm PCB Fit Gauge /\nDummy or Flight PCB Set" { class: ea }
caliper_feeler: "[EA] Calipers /\nFeeler Gauges" { class: ea }
keepout_probe: "[EA] Keepout and\nRemoval-Path Probe" { class: ea }
cycle_counter: "[EA] Insert / Remove\nCycle Counter" { class: ea }
camera: "[EA] Photo / Video\nEvidence Camera" { class: ea }
ambient_meter: "[EA] Ambient Thermo-\nHygrometer" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-CON-002" { class: ea }

system: "[System] SAA-VV-CON-002 Logical Evidence Interface\nRefs: IVV; SAA-R1; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down
  grid-columns: 1

  v01_article: "[PC] v0.1 Reusable Module Article\ntransition-readiness verification boundary" {
    class: pc
    direction: down
    grid-columns: 1
    v01_config_lc: "[LC] v0.1 Baseline and\nArticle Configuration Record\nverification-only" { class: lc }
    v01_type_lc: "[LC] v0.1 Type 1 / Type 2\nModule Census Record\nverification-only" { class: lc }
    v01_fit_lc: "[LC] v0.1 44 mm Dummy-PCB\nFit, Clearance, Retention and\nRemoval-Path Record\nverification-only" { class: lc }
  }

  v10_article: "[PC] v1.0 Integrated Module/PCB Article\nflight-readiness verification boundary" {
    class: pc
    direction: down
    grid-columns: 1
    v10_config_lc: "[LC] v1.0 As-Flown or\nFinal-Equivalent Configuration Record\nverification-only" { class: lc }
    v10_type_lc: "[LC] v1.0 Type 1 / Type 2\nModule Census Record\nverification-only" { class: lc }
    v10_fit_lc: "[LC] ADS/AMS/OBCC/PDS\n44 mm PCB Accommodation Record\nverification-only" { class: lc }
    v10_keepout_lc: "[LC] Integrated Backplane,\nBattery, Top-Module Keepout and\nRemoval-Path Record\nverification-only" { class: lc }
  }

  verification_records: "[PC] Modular-Constraint Verification\nControl and Evidence Package\nverification-only" {
    class: pc
    direction: down
    grid-columns: 1
    baseline_lc: "[LC] SSIV / Baseline Copy\nSelection Record\nverification-only" { class: lc }
    instrument_lc: "[LC] Gauge, Instrument and\nAmbient Condition Record\nverification-only" { class: lc }
    cycle_lc: "[LC] Insert/Remove Cycle\nScreen Record\nverification-only" { class: lc }
    viewpoint_lc: "[LC] Statistical and\nFault-Hardening Viewpoint Record\nverification-only" { class: lc }
    anomaly_lc: "[LC] Anomaly / Waiver /\nRe-run Disposition\nverification-only" { class: lc }
    acceptance_lc: "[LC] Modular-Structure\nAcceptance Gate\nverification-only" { class: lc }
    evidence_lc: "[LC] Report-by-Reference\nEvidence Package\nverification-only" { class: lc }
  }

  verification_scope: "[C] Verification-only interface scope:\nCEs carry configuration, module-type census, gauge/PCB identity, clearance,\nretention, keepout, cycle-screen, anomaly and evidence data for this activity only.\nThey do not close missing baseline S&A design CEs." {
    class: note
    shape: page
  }

  pass_fail: "[C] Pass/fail data required:\nType count ≤ 2; ADS/AMS/OBCC/PDS accommodations accept 44 mm gauges or flight\nPCBs without force; C_min - U_C > 0; retention remains acceptable; no keepout,\ninterference or removal-path blockage; evidence records complete." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\n100% census of every module instance and every mandatory ADS/AMS/OBCC/PDS\naccommodation. Clearance measurements use uncertainty guard bands. Insert/remove\ncycles are screening only, not reliability trials." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nExpose wrong type count, hidden adapters, tolerance stack, warped prints,\nunrepresentative gauges, forced fit, blocked removal path, integrated interference,\nstripped retention or evidence-control escape." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nModeled modular-structure constraint; SAA-UC-IntegratedAssembly;\nSAA-FE-EnvelopeNonCompliance; SAA-FE-StructuralLoosening." {
    class: note
    shape: page
  }
}

operator -> system.verification_records.baseline_lc: "[CE] start" { class: ce }
operator -> system.v01_article.v01_type_lc: "[CE] v0.1 census" { class: ce }
operator -> system.v10_article.v10_type_lc: "[CE] v1.0 census" { class: ce }
operator -> system.verification_records.anomaly_lc: "[CE] anomalies" { class: ce }
witness -> system.verification_records.acceptance_lc: "[CE] witness" { class: ce }

fit_gauge_set -> system.v01_article.v01_fit_lc: "[CE] v0.1 fit" { class: ce }
fit_gauge_set -> system.v10_article.v10_fit_lc: "[CE] v1.0 fit" { class: ce }
caliper_feeler -> system.verification_records.instrument_lc: "[CE] cal/U_C" { class: ce }
caliper_feeler -> system.v01_article.v01_fit_lc: "[CE] C_min" { class: ce }
caliper_feeler -> system.v10_article.v10_fit_lc: "[CE] C_min" { class: ce }
keepout_probe -> system.v10_article.v10_keepout_lc: "[CE] path" { class: ce }
cycle_counter -> system.verification_records.cycle_lc: "[CE] cycles" { class: ce }
camera -> system.verification_records.evidence_lc: "[CE] media" { class: ce }
ambient_meter -> system.verification_records.instrument_lc: "[CE] ambient" { class: ce }

system.verification_records.baseline_lc -> system.v01_article.v01_config_lc: "[CE] v0.1" { class: ce }
system.verification_records.baseline_lc -> system.v10_article.v10_config_lc: "[CE] v1.0" { class: ce }
system.v01_article.v01_config_lc -> system.v01_article.v01_fit_lc: "[CE] ADS-PDS" { class: ce }
system.v10_article.v10_config_lc -> system.v10_article.v10_fit_lc: "[CE] ADS-PDS" { class: ce }
system.v10_article.v10_fit_lc -> system.v10_article.v10_keepout_lc: "[CE] retained" { class: ce }
system.v01_article.v01_type_lc -> system.verification_records.acceptance_lc: "[CE] types" { class: ce }
system.v01_article.v01_fit_lc -> system.verification_records.acceptance_lc: "[CE] fit" { class: ce }
system.v10_article.v10_type_lc -> system.verification_records.acceptance_lc: "[CE] types" { class: ce }
system.v10_article.v10_keepout_lc -> system.verification_records.acceptance_lc: "[CE] fit/path" { class: ce }
system.verification_records.instrument_lc -> system.verification_records.acceptance_lc: "[CE] valid" { class: ce }
system.verification_records.cycle_lc -> system.verification_records.acceptance_lc: "[CE] screen" { class: ce }
system.verification_records.viewpoint_lc -> system.verification_records.acceptance_lc: "[CE] views" { class: ce }
system.verification_records.anomaly_lc -> system.verification_records.acceptance_lc: "[CE] status" { class: ce }
system.verification_records.acceptance_lc -> system.verification_records.evidence_lc: "[CE] result" { class: ce }
system.verification_records.evidence_lc -> repo: "[CE] package" { class: ce }
system.verification_records.anomaly_lc -> repo: "[CE] rerun" { class: ce }

system.verification_scope -> system.verification_records.baseline_lc { class: cstr }
system.pass_fail -> system.verification_records.acceptance_lc { class: cstr }
system.statistical -> system.verification_records.viewpoint_lc { class: cstr }
system.fault_hardening -> system.v10_article.v10_keepout_lc { class: cstr }
system.fault_hardening -> system.verification_records.evidence_lc { class: cstr }
system.traceability -> system.verification_records.acceptance_lc { class: cstr }

# Layout-only edges keep actors and records in a readable order.
operator -> witness { style: { opacity: 0 } }
witness -> fit_gauge_set { style: { opacity: 0 } }
fit_gauge_set -> caliper_feeler { style: { opacity: 0 } }
caliper_feeler -> keepout_probe { style: { opacity: 0 } }
keepout_probe -> cycle_counter { style: { opacity: 0 } }
cycle_counter -> camera { style: { opacity: 0 } }
camera -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.v01_article -> system.v10_article { style: { opacity: 0 } }
system.v10_article -> system.verification_records { style: { opacity: 0 } }
system.verification_scope -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.traceability { style: { opacity: 0 } }
