vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view
# Prefer a taller aspect ratio so the module stack and backplane connections stay legible.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

charger: "[EA] Charger" {
  class: ea
}

system: "[System] CanSat" {
  class: sys
  direction: down

  ess_module: "[PC] ESS Module" {
    class: pc
    direction: down
    battery_pack: "[PC] 1S1P Li-Ion" { class: pc }
  }

  pds_module: "[PC] PDS Module" {
    class: pc
    direction: down

    pds_pcb: "[PC] PDS PCB" {
      class: pc
      direction: right

      battery_connector: "[PC] Battery Connector" { class: pc }
      protection: "[PC] Protection Circuit" { class: pc }
      ina219: "[PC] INA219" { class: pc }
      regulator: "[PC] Regulator" { class: pc }
      pds_backplane_connector: "[PC] Backplane Connector" { class: pc }
    }
  }

  obcc_module: "[PC] OBCC Module" {
    class: pc
    direction: down

    obcc_pcb: "[PC] OBCC PCB" {
      class: pc
      direction: right

      xiao: "[PC] XIAO ESP32-S3" { class: pc }
      obcc_backplane_connector: "[PC] Backplane Connector" { class: pc }
    }
  }

  backplane_pcb: "[PC] Backplane PCB" {
    class: pc
    direction: down

    pds_headers: "[PC] 2mm 2x6 PDS Headers" { class: pc }
    spine: "[PC] Spine" { class: pc }
    obcc_headers: "[PC] 2mm 2x6 OBCC Headers" { class: pc }
  }

  pcb_cnc_note: "[C] All PCBs must be\nmachinable in a\nCarvera Air CNC" {
    class: note
    shape: page
  }
}

charger -- system.pds_module.pds_pcb.protection: "[PL] USB-C cable" { class: pl }
system.ess_module.battery_pack -- system.pds_module.pds_pcb.battery_connector: "[PL] Battery cable" { class: pl }

system.ess_module -- system.backplane_pcb: "[PL] Backplane fixture" { class: pl }
system.pds_module -- system.backplane_pcb: "[PL] Backplane fixture" { class: pl }
system.obcc_module -- system.backplane_pcb: "[PL] Backplane fixture" { class: pl }

system.pds_module.pds_pcb.protection -- system.pds_module.pds_pcb: "[PL] Footprint" { class: pl }
system.pds_module.pds_pcb.ina219 -- system.pds_module.pds_pcb: "[PL] Footprint" { class: pl }
system.pds_module.pds_pcb.regulator -- system.pds_module.pds_pcb: "[PL] Footprint" { class: pl }
system.pds_module.pds_pcb.battery_connector -- system.pds_module.pds_pcb: "[PL] Footprint" { class: pl }
system.pds_module.pds_pcb.pds_backplane_connector -- system.pds_module.pds_pcb: "[PL] Footprint" { class: pl }
system.obcc_module.obcc_pcb.xiao -- system.obcc_module.obcc_pcb: "[PL] XIAO footprint" { class: pl }
system.obcc_module.obcc_pcb.obcc_backplane_connector -- system.obcc_module.obcc_pcb: "[PL] Footprint" { class: pl }

system.pds_module.pds_pcb -- system.pds_module: "[PL] Screws" { class: pl }
system.obcc_module.obcc_pcb -- system.obcc_module: "[PL] Screws" { class: pl }

system.pds_module.pds_pcb.battery_connector -- system.pds_module.pds_pcb.protection: "[PL] Battery ± traces" { class: pl }
system.pds_module.pds_pcb.protection -- system.pds_module.pds_pcb.ina219: "[PL] PC out trace" { class: pl }
system.pds_module.pds_pcb.ina219 -- system.pds_module.pds_pcb.regulator: "[PL] INA out trace" { class: pl }
system.pds_module.pds_pcb.regulator -- system.pds_module.pds_pcb.pds_backplane_connector: "[PL] 5V / 3V3 traces" { class: pl }
system.obcc_module.obcc_pcb.xiao -- system.obcc_module.obcc_pcb.obcc_backplane_connector: "[PL] 3V3 / PWM traces" { class: pl }

system.pds_module.pds_pcb.pds_backplane_connector -- system.backplane_pcb.pds_headers: "[PL] Parallel cable" { class: pl }
system.obcc_module.obcc_pcb.obcc_backplane_connector -- system.backplane_pcb.obcc_headers: "[PL] Parallel cable" { class: pl }

system.pcb_cnc_note -> system.pds_module.pds_pcb { class: cstr }
system.pcb_cnc_note -> system.obcc_module.obcc_pcb { class: cstr }
system.pcb_cnc_note -> system.backplane_pcb { class: cstr }

# Layout-only edges to stack the module assemblies vertically.
system.ess_module -> system.pds_module { style: { opacity: 0 } }
system.pds_module -> system.obcc_module { style: { opacity: 0 } }
system.obcc_module -> system.backplane_pcb { style: { opacity: 0 } }
system.backplane_pcb -> system.pcb_cnc_note { style: { opacity: 0 } }
