vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-CON-001 verification-only Physical Architecture PV2.
# Logical/evidence interface view for 355 ml envelope, mass, and landing-impact constraint verification.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R2, SAA-R5.
# These LCs and CEs define verification means only; they are not baseline S&A design exchanges.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" { class: ea }
witness: "[EA] Safety / QA Witness" { class: ea }
envelope_gauge: "[EA] 355 ml Envelope /\nCan Gauge" { class: ea }
caliper_height: "[EA] Calibrated Caliper /\nHeight Gauge" { class: ea }
scale: "[EA] Calibrated Scale" { class: ea }
drop_fixture: "[EA] Drop / Landing-Impact\nScreen Fixture" { class: ea }
impact_surface: "[EA] Tailored Impact Surface /\nScreen-Level Record" { class: ea }
accel_logger: "[EA] Shock / Acceleration\nLogger or Witness Indicator" { class: ea }
inspection_kit: "[EA] Post-Impact\nInspection Kit" { class: ea }
camera: "[EA] Photo / Video\nEvidence Camera" { class: ea }
ambient_meter: "[EA] Ambient Thermo-\nHygrometer" { class: ea }
repo: "[EA] Evidence Repository\nresults/SAA-VV-CON-001" { class: ea }

system: "[System] SAA-VV-CON-001 Logical Evidence Interface\nRefs: IVV; SAA-R1; SAA-R2; SAA-R5" {
  class: sys
  direction: down
  grid-columns: 1

  v01_article: "[PC] v0.1 Structural Article\ntransition-readiness verification boundary" {
    class: pc
    direction: down
    grid-columns: 1
    v01_config_lc: "[LC] v0.1 Article / Ballast\nConfiguration Record\nverification-only" { class: lc }
    v01_envelope_lc: "[LC] v0.1 Envelope and\nReference-Mass Measurement\nRecord\nverification-only" { class: lc }
    v01_impact_lc: "[LC] v0.1 Structural Drop /\nLanding-Impact Screen\nRecord\nverification-only" { class: lc }
    v01_post_lc: "[LC] v0.1 Post-Screen\nStructural Integrity Record\nverification-only" { class: lc }
  }

  v10_article: "[PC] v1.0 Integrated Article\nflight-readiness verification boundary" {
    class: pc
    direction: down
    grid-columns: 1
    v10_config_lc: "[LC] v1.0 As-Flown\nConfiguration Record\nverification-only" { class: lc }
    v10_envelope_lc: "[LC] v1.0 Envelope\nMeasurement Record\nverification-only" { class: lc }
    v10_mass_lc: "[LC] v1.0 Guard-Banded\nMass Acceptance Record\nverification-only" { class: lc }
    v10_impact_lc: "[LC] v1.0 As-Flown Drop /\nLanding-Impact Screen\nRecord\nverification-only" { class: lc }
    v10_post_lc: "[LC] v1.0 Post-Impact\nIntegration Integrity Record\nverification-only" { class: lc }
  }

  verification_records: "[PC] Constraint Verification\nControl and Evidence Package\nverification-only" {
    class: pc
    direction: down
    grid-columns: 1
    baseline_lc: "[LC] Baseline / SSIV\nSelection Record\nverification-only" { class: lc }
    screen_definition_lc: "[LC] Tailored Impact Screen\nDefinition or Hold Rationale\nverification-only" { class: lc }
    acceptance_lc: "[LC] Constraint Acceptance Gate\nverification-only" { class: lc }
    anomaly_lc: "[LC] Anomaly / Waiver /\nRe-run Disposition\nverification-only" { class: lc }
    evidence_lc: "[LC] Report-by-Reference\nEvidence Package\nverification-only" { class: lc }
  }

  verification_scope: "[C] Verification-only interface scope:\nThese CEs carry configuration, measurement, screen-level, inspection,\nanomaly and evidence data for SAA-VV-CON-001 only. They do not close\nmissing baseline S&A design CEs." {
    class: note
    shape: page
  }

  pass_fail: "[C] Pass/fail data required:\nD_max + U_D ≤ 66.0 mm; H_max + U_H ≤ modeled 122.0 mm\nunless a stricter height limit is confirmed; v1.0 measured mass + U_M <\n350.0 g; impact/drop screen has approved level or controlled hold;\npost-impact inspection and remeasurement find no structural/integration failure." {
    class: note
    shape: page
  }

  version_rule: "[C] Version distinction:\nv0.1 closes structural/module/backplane-volume transition readiness only.\nMass is reference/ballasted structural evidence unless the article is final.\nv1.0 closes final acceptance using the full as-flown configuration and\nconservative mass guard band." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint in evidence:\nContinuous measurements require calibrated readings and expanded uncertainty.\nImpact outcomes are binary trials; do not state reliability unless an\napproved binomial plan, representative independent trials, and confidence\nclaim are included." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint in evidence:\nEvidence must expose false-pass risks from missing flight items, ballast\nmismatch, forced fit, ignored protrusions, unresolved drop level, hidden\ncracks, loose fasteners, battery/backplane/connector movement, jammed cap or\nparachute, ambiguous video, or incomplete post-impact inspection." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nModeled 355 ml envelope / mass / landing-impact constraint;\nSAA-FE-EnvelopeNonCompliance; SAA-FE-MassNonCompliance;\nSAA-FE-LandingDamage; SAA-UC-IntegratedAssembly;\nSAA-UC-ParachuteClearance." {
    class: note
    shape: page
  }
}

operator -> system.verification_records.baseline_lc: "[CE] Activity start,\narticle ID, selected baseline" { class: ce }
operator -> system.v01_article.v01_config_lc: "[CE] v0.1 article build,\nballast and handling state" { class: ce }
operator -> system.v10_article.v10_config_lc: "[CE] v1.0 as-flown build,\nbattery and ballast state" { class: ce }
operator -> system.verification_records.anomaly_lc: "[CE] Observed exceptions\nand operator notes" { class: ce }
witness -> system.verification_records.acceptance_lc: "[CE] Safety/QA witness\ndecision and holds" { class: ce }

envelope_gauge -> system.v01_article.v01_envelope_lc: "[CE] v0.1 free-fit /\nno-force result" { class: ce }
envelope_gauge -> system.v10_article.v10_envelope_lc: "[CE] v1.0 free-fit /\nno-force result" { class: ce }
caliper_height -> system.v01_article.v01_envelope_lc: "[CE] v0.1 D, H,\nU_D, U_H" { class: ce }
caliper_height -> system.v10_article.v10_envelope_lc: "[CE] v1.0 D, H,\nU_D, U_H" { class: ce }
scale -> system.v01_article.v01_envelope_lc: "[CE] v0.1 structural or\nballasted mass and U_M" { class: ce }
scale -> system.v10_article.v10_mass_lc: "[CE] v1.0 total as-flown\nmass and U_M" { class: ce }
drop_fixture -> system.v01_article.v01_impact_lc: "[CE] v0.1 release setup,\norientation and outcome" { class: ce }
drop_fixture -> system.v10_article.v10_impact_lc: "[CE] v1.0 release setup,\norientation and outcome" { class: ce }
impact_surface -> system.verification_records.screen_definition_lc: "[CE] Approved impact\nsurface, height/energy, or hold" { class: ce }
accel_logger -> system.v01_article.v01_impact_lc: "[CE] v0.1 shock/marker\nrecord if used" { class: ce }
accel_logger -> system.v10_article.v10_impact_lc: "[CE] v1.0 shock/marker\nrecord if used" { class: ce }
inspection_kit -> system.v01_article.v01_post_lc: "[CE] v0.1 post-screen\ncrack/retention/deformation status" { class: ce }
inspection_kit -> system.v10_article.v10_post_lc: "[CE] v1.0 post-impact\nPC/PL/connector/battery status" { class: ce }
camera -> system.verification_records.evidence_lc: "[CE] Photos/video and\nmeasurement/drop context" { class: ce }
ambient_meter -> system.v01_article.v01_envelope_lc: "[CE] v0.1 ambient\ntemperature/humidity" { class: ce }
ambient_meter -> system.v10_article.v10_envelope_lc: "[CE] v1.0 ambient\ntemperature/humidity" { class: ce }
ambient_meter -> system.verification_records.screen_definition_lc: "[CE] Environment flag for\nimpact screen" { class: ce }

system.verification_records.baseline_lc -> system.v01_article.v01_config_lc: "[CE] v0.1 baseline copy\nand readiness gate" { class: ce }
system.verification_records.baseline_lc -> system.v10_article.v10_config_lc: "[CE] v1.0 baseline copy\nand final gate" { class: ce }
system.v01_article.v01_config_lc -> system.v01_article.v01_envelope_lc: "[CE] Confirmed v0.1\nconfiguration" { class: ce }
system.v10_article.v10_config_lc -> system.v10_article.v10_envelope_lc: "[CE] Confirmed full\nas-flown configuration" { class: ce }
system.v10_article.v10_config_lc -> system.v10_article.v10_mass_lc: "[CE] Battery/ballast/flight\nitems included" { class: ce }
system.verification_records.screen_definition_lc -> system.v01_article.v01_impact_lc: "[CE] v0.1 tailored level\nor analysis-backed hold" { class: ce }
system.verification_records.screen_definition_lc -> system.v10_article.v10_impact_lc: "[CE] v1.0 tailored level\nor analysis-backed hold" { class: ce }
system.v01_article.v01_impact_lc -> system.v01_article.v01_post_lc: "[CE] v0.1 impact outcome\nrequires post-inspection" { class: ce }
system.v10_article.v10_impact_lc -> system.v10_article.v10_post_lc: "[CE] v1.0 impact outcome\nrequires post-inspection" { class: ce }
system.v01_article.v01_envelope_lc -> system.verification_records.acceptance_lc: "[CE] v0.1 guard-banded\nenvelope/reference mass" { class: ce }
system.v01_article.v01_post_lc -> system.verification_records.acceptance_lc: "[CE] v0.1 structural\npost-screen status" { class: ce }
system.v10_article.v10_envelope_lc -> system.verification_records.acceptance_lc: "[CE] v1.0 guard-banded\nenvelope" { class: ce }
system.v10_article.v10_mass_lc -> system.verification_records.acceptance_lc: "[CE] v1.0 conservative\nmass gate" { class: ce }
system.v10_article.v10_post_lc -> system.verification_records.acceptance_lc: "[CE] v1.0 post-impact\nintegration status" { class: ce }
system.verification_records.anomaly_lc -> system.verification_records.acceptance_lc: "[CE] Open/closed anomaly,\nwaiver or re-run status" { class: ce }
system.verification_records.acceptance_lc -> system.verification_records.evidence_lc: "[CE] Pass/fail/hold rationale\nand report index" { class: ce }
system.verification_records.evidence_lc -> repo: "[CE] Released report-by-reference\npackage" { class: ce }
system.verification_records.anomaly_lc -> repo: "[CE] Anomaly records,\nwaivers, rework and re-run evidence" { class: ce }

system.verification_scope -> system.verification_records.baseline_lc { class: cstr }
system.pass_fail -> system.verification_records.acceptance_lc { class: cstr }
system.pass_fail -> system.v10_article.v10_mass_lc { class: cstr }
system.pass_fail -> system.v10_article.v10_post_lc { class: cstr }
system.version_rule -> system.v01_article.v01_config_lc { class: cstr }
system.version_rule -> system.v10_article.v10_config_lc { class: cstr }
system.statistical -> system.verification_records.acceptance_lc { class: cstr }
system.fault_hardening -> system.v10_article.v10_post_lc { class: cstr }
system.fault_hardening -> system.verification_records.evidence_lc { class: cstr }
system.traceability -> system.verification_records.acceptance_lc { class: cstr }

# Layout-only edges keep actors and records in a readable order.
operator -> witness { style: { opacity: 0 } }
witness -> envelope_gauge { style: { opacity: 0 } }
envelope_gauge -> caliper_height { style: { opacity: 0 } }
caliper_height -> scale { style: { opacity: 0 } }
scale -> drop_fixture { style: { opacity: 0 } }
drop_fixture -> impact_surface { style: { opacity: 0 } }
impact_surface -> accel_logger { style: { opacity: 0 } }
accel_logger -> inspection_kit { style: { opacity: 0 } }
inspection_kit -> camera { style: { opacity: 0 } }
camera -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.v01_article -> system.v10_article { style: { opacity: 0 } }
system.v10_article -> system.verification_records { style: { opacity: 0 } }
system.verification_scope -> system.pass_fail { style: { opacity: 0 } }
system.pass_fail -> system.version_rule { style: { opacity: 0 } }
system.version_rule -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.traceability { style: { opacity: 0 } }
