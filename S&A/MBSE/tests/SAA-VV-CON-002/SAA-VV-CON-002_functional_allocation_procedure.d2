vars: {
  d2-config: {
    layout-engine: elk
  }
}

# SAA-VV-CON-002 verification-only Physical Architecture PV3.
# Functional allocation/procedure view for modular-structure and 44 mm PCB accommodation constraint verification.
# References cited in the rendered system title: IVV, SAA-R1, SAA-R3, SAA-R4, SAA-R5.
# Functions and LCs here define the verification activity only; they are not baseline S&A design edits.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

operator: "[EA] S&A Test Operator" {
  class: ea
  direction: down
  grid-columns: 1
  select_gate: "[F] Select v0.1 transition\nor v1.0 flight-readiness gate" { class: func }
  identify_article: "[F] Identify article,\nbaseline copy, build record\nand evidence folder" { class: func }
  count_types: "[F] Count module instances\nand classify Type 1 / Type 2" { class: func }
  insert_remove: "[F] Insert and remove\n44 mm gauges, dummy boards,\nor flight PCBs using service path" { class: func }
  record_anomaly: "[F] Record anomaly, waiver,\nhold, rework or re-run need" { class: func }
}

witness: "[EA] Safety / QA Witness" {
  class: ea
  direction: down
  grid-columns: 1
  witness_setup: "[F] Witness setup,\ncalibration, ambient record\nand type-count method" { class: func }
  witness_fit: "[F] Witness no-force\ninsertion, retention, clearance\nand removal-path checks" { class: func }
  approve_gate: "[F] Approve pass, fail,\nhold or re-run disposition" { class: func }
}

fit_gauge_set: "[EA] 44 mm PCB Fit Gauge /\nDummy or Flight PCB Set" {
  class: ea
  direction: down
  grid-columns: 1
  provide_gauge: "[F] Provide calibrated\n44.00 mm × 44.00 mm gauge,\ndummy PCB or released flight PCB" { class: func }
  identify_representativeness: "[F] Identify outline,\nthickness and keepout\nrepresentativeness" { class: func }
}

caliper_feeler: "[EA] Calipers /\nFeeler Gauges" {
  class: ea
  direction: down
  grid-columns: 1
  measure_clearance: "[F] Measure C_min\nand expanded uncertainty U_C" { class: func }
  verify_retention: "[F] Verify retained board\nhas no stress, rocking, loose\nfastener or warped-contact issue" { class: func }
}

keepout_probe: "[EA] Keepout and\nRemoval-Path Probe" {
  class: ea
  direction: down
  grid-columns: 1
  inspect_keepouts: "[F] Inspect backplane,\nheaders, battery, stack screws,\ntop module and service path" { class: func }
  detect_blockage: "[F] Detect interference,\nsnag, scrape, bent pin or\nblocked removal path" { class: func }
}

cycle_counter: "[EA] Insert / Remove\nCycle Counter" {
  class: ea
  direction: down
  grid-columns: 1
  count_cycles: "[F] Count N ≥ 3\ninsert/remove screen cycles\nper accommodation" { class: func }
}

camera: "[EA] Photo / Video\nEvidence Camera" {
  class: ea
  direction: down
  grid-columns: 1
  capture_evidence: "[F] Capture module count,\ngauge/PCB identity, insertion,\nclearance, keepout and anomaly evidence" { class: func }
}

ambient_meter: "[EA] Ambient Thermo-\nHygrometer" {
  class: ea
  direction: down
  grid-columns: 1
  record_ambient: "[F] Record temperature\nand humidity before fit\nrepetitions begin" { class: func }
}

repo: "[EA] Evidence Repository" {
  class: ea
  direction: down
  grid-columns: 1
  store_package: "[F] Store report-by-reference\npackage under results/SAA-VV-CON-002/" { class: func }
}

system: "[System] SAA-VV-CON-002 Functional Allocation / Modular Constraint Verification Procedure\nRefs: IVV; SAA-R1; SAA-R3; SAA-R4; SAA-R5" {
  class: sys
  direction: down
  grid-columns: 1

  v01_article: "[PC] v0.1 Reusable Module Article\ntransition-readiness UUT" {
    class: pc
    direction: down
    grid-columns: 1
    v01_type_lc: "[LC] v0.1 Module-Type\nControl\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_v01_modules: "[F] Present ADS/AMS/OBCC/PDS/ESS\nType 1 modules and Type 2\ntop module for census" { class: func }
      expose_variants: "[F] Expose any adapter,\nshim, variant or extra structural\nmodule family" { class: func }
    }
    v01_fit_lc: "[LC] v0.1 Dummy-PCB\nAccommodation Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_bays: "[F] Present ADS/AMS/OBCC/PDS\nstandard-module PCB accommodations\nfor dummy gauge insertion" { class: func }
      accept_dummy: "[F] Accept 44 mm dummy PCB\nwithout force or service-path blockage" { class: func }
      expose_clearance: "[F] Expose minimum clearance,\nretention features and keepouts\nfor measurement" { class: func }
    }
  }

  v10_article: "[PC] v1.0 Integrated Module/PCB Article\nflight-readiness UUT" {
    class: pc
    direction: down
    grid-columns: 1
    v10_type_lc: "[LC] v1.0 Module-Type\nControl\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_integrated_modules: "[F] Present ADS/AMS/OBCC/PDS/ESS\nType 1 modules and Type 2 top module\nwith contained hardware installed" { class: func }
      expose_extra_types: "[F] Expose any extra module type,\npermanent adapter, unmodeled shim\nor structural variant" { class: func }
    }
    v10_fit_lc: "[LC] v1.0 PCB Accommodation\nAcceptance Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      present_ads: "[F] Present ADS 44 mm PCB\nand standard module accommodation" { class: func }
      present_ams: "[F] Present AMS 44 mm PCB\nand standard module accommodation" { class: func }
      present_obcc: "[F] Present OBCC 44 mm PCB\nand standard module accommodation" { class: func }
      present_pds: "[F] Present PDS 44 mm PCB\nand standard module accommodation" { class: func }
      maintain_retention: "[F] Maintain intended standoff,\nscrew or retention engagement\nafter fit cycles" { class: func }
      expose_removal_path: "[F] Expose board removal path\naround backplane, headers, battery,\nstack and top-module neighbors" { class: func }
    }
  }

  verification_records: "[PC] Modular-Constraint Verification\nControl and Evidence Package\nverification-only" {
    class: pc
    direction: down
    grid-columns: 1
    evidence_lc: "[LC] Evidence and\nAnomaly Gate\nverification-only" {
      class: lc
      direction: down
      grid-columns: 1
      apply_pass_fail: "[F] Apply two-module-type,\n44 mm fit, positive clearance,\nretention and keepout constraints" { class: func }
      classify_gate: "[F] Classify v0.1 and v1.0\npass, fail, hold or re-run" { class: func }
      bind_evidence: "[F] Bind baseline copies,\ngauge/calibration/ambient data,\nmeasurements, cycles, photos/video\nand witness decision" { class: func }
      require_rerun: "[F] Require re-run after rework,\nconfiguration change, waiver rejection\nor temporary omission" { class: func }
    }
  }

  pass_fail: "[C] Pass/fail constraint:\nType count ≤ 2. ADS/AMS/OBCC/PDS accommodations accept 44 mm dummy/flight PCBs\nwithout forced fit. C_min - U_C > 0 at all applicable clearances. Retention remains\nacceptable after N ≥ 3 screen cycles. No keepout, interference, service-path blockage,\nblocked removal, open anomaly or missing evidence is allowed." {
    class: note
    shape: page
  }

  statistical: "[C] Statistical-significance viewpoint:\nInspect all module instances and all mandatory ADS/AMS/OBCC/PDS accommodations\nfor each selected gate. Clearance is a calibrated continuous measurement with\nuncertainty guard band. Insert/remove repetitions are screening only, not a\npopulation reliability demonstration." {
    class: note
    shape: page
  }

  fault_hardening: "[C] Fault-hardening viewpoint:\nDetect wrong module type count, hidden adapters, tolerance stack, warped print,\nundersized/unrepresentative gauge, forced fit, standoff/boss damage, blocked removal\npath, backplane/header/battery/top-module interference, temporary omission,\nambiguous photos or evidence-control escape." {
    class: note
    shape: page
  }

  conditions: "[C] Environmental/equipment condition:\nRecord ambient thermo-hygrometer readings, equipment IDs, calibration status,\ngauge/PCB identities, camera field of view and witness identity before repetitions\nbegin. Hold if conditions invalidate clearance interpretation or safe handling." {
    class: note
    shape: page
  }

  traceability: "[C] Traceability target:\nModeled modular-structure constraint; SAA-UC-IntegratedAssembly;\nSAA-FE-EnvelopeNonCompliance; SAA-FE-StructuralLoosening." {
    class: note
    shape: page
  }
}

system.pass_fail -> system.v01_article.v01_type_lc.present_v01_modules { class: cstr }
system.pass_fail -> system.v01_article.v01_fit_lc.accept_dummy { class: cstr }
system.pass_fail -> system.v10_article.v10_type_lc.present_integrated_modules { class: cstr }
system.pass_fail -> system.v10_article.v10_fit_lc.maintain_retention { class: cstr }
system.pass_fail -> system.verification_records.evidence_lc.apply_pass_fail { class: cstr }
system.statistical -> system.v10_article.v10_fit_lc.present_ads { class: cstr }
system.statistical -> system.v10_article.v10_fit_lc.present_ams { class: cstr }
system.statistical -> system.v10_article.v10_fit_lc.present_obcc { class: cstr }
system.statistical -> system.v10_article.v10_fit_lc.present_pds { class: cstr }
system.fault_hardening -> system.v10_article.v10_fit_lc.expose_removal_path { class: cstr }
system.fault_hardening -> system.verification_records.evidence_lc.require_rerun { class: cstr }
system.conditions -> system.verification_records.evidence_lc.bind_evidence { class: cstr }
system.traceability -> system.verification_records.evidence_lc.classify_gate { class: cstr }

# Layout-only edges keep actors and system allocations in procedure order.
operator -> witness { style: { opacity: 0 } }
witness -> fit_gauge_set { style: { opacity: 0 } }
fit_gauge_set -> caliper_feeler { style: { opacity: 0 } }
caliper_feeler -> keepout_probe { style: { opacity: 0 } }
keepout_probe -> cycle_counter { style: { opacity: 0 } }
cycle_counter -> camera { style: { opacity: 0 } }
camera -> ambient_meter { style: { opacity: 0 } }
ambient_meter -> system { style: { opacity: 0 } }
system -> repo { style: { opacity: 0 } }
system.v01_article -> system.v10_article { style: { opacity: 0 } }
system.v10_article -> system.verification_records { style: { opacity: 0 } }
system.pass_fail -> system.statistical { style: { opacity: 0 } }
system.statistical -> system.fault_hardening { style: { opacity: 0 } }
system.fault_hardening -> system.conditions { style: { opacity: 0 } }
system.conditions -> system.traceability { style: { opacity: 0 } }
