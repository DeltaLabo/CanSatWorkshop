vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Functional allocation view — AMS-V01-INTEG-001 inspection/review functions and pass/fail constraints
# IADT: Inspection with supporting Analysis. SSIV gate: AMS v0.1 breadboard/subsystem to v0.2 PCB delivery.
# References: IVV, AMS-R1 (BME280), AMS-R2 (I2C), AMS-R6 (CanSat build environment).
# Traceability: AMS-v0.1-to-v0.2-readiness; AMS-UC-MeasureAtmosphere; AMS-UC-InitializePeripheral; AMS-FE-SensorBusFault.
# PV3: no PL, CE, or FE edges; inspection/review interactions are modeled by allocated functions and constraints.
direction: down

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

system: "[System] AMS-V01-INTEG-001 allocation readiness analysis\nAMS v0.1 → v0.2 PCB gate\nRefs: IVV, AMS-R1, AMS-R2, AMS-R6" {
  class: sys
  direction: down
  grid-columns: 1

  bme280: "[PC] BME280" {
    class: pc
    direction: down

    ams_sensing: "[LC] AMS Sensing" {
      class: lc
      direction: down
      grid-columns: 3

      note_accuracy_pressure: "[C] Accuracy\n< 1 hPa" {
        class: note
        shape: page
      }
      measure_pressure: "[F] Measure\npressure" { class: func }
      note_accuracy_temperature: "[C] Accuracy < 0.5 °C\nover 10-40 °C" {
        class: note
        shape: page
      }
      measure_temperature: "[F] Measure\ntemperature" { class: func }
      respond_i2c_requests: "[F] Respond to I2C\nRequests" { class: func }
    }
  }

  xiao: "[PC] XIAO ESP32" {
    class: pc
    direction: down

    ams_processing: "[LC] AMS Processing" {
      class: lc
      direction: down
      grid-columns: 4

      get_bme280_init_state: "[F] Get BME280\ninit state" { class: func }
      read_pressure: "[F] Read\npressure" { class: func }
      read_temperature: "[F] Read\ntemperature" { class: func }
      note_resolution: "[C] Resolution\n< 10 m" {
        class: note
        shape: page
      }
      calculate_altitude: "[F] Calculate\naltitude" { class: func }
      process_temperature: "[F] Process\ntemperature" { class: func }
      collect_peripheral_init_states: "[F] Collect peripheral\ninit states" { class: func }
      collect_measurements: "[F] Collect\nmeasurements" { class: func }
      init_serial0_serial1: "[F] Init Serial0 and\nSerial1 with interrupts" { class: func }
      log_serial0: "[F] Log via\nSerial0" { class: func }
    }

    note_no_blocking: "[C] No blocking\noperations besides\nI2C or UART comms" {
      class: note
      shape: page
    }
    note_variable_getter: "[C] Implement each\n(Read X, Process X) or\n(Read X, Calculate Y)\npair as a Variable\nGetter template" {
      class: note
      shape: page
    }
    note_i2c_timeout: "[C] All I2C read\nfunctions must have\na timeout ≤ 5 ms" {
      class: note
      shape: page
    }
    note_process_time: "[C] All Process or\nCalculate functions\nmust take < 5 ms" {
      class: note
      shape: page
    }
  }
}

test_operator: "[EA] Test operator" {
  class: ea
  direction: down
  grid-columns: 2

  identify_breadboard_items: "[F] Identify BME280,\nXIAO, and host PC" { class: func }
  perform_visual_inspection: "[F] Inspect breadboard\nplacement and jumpers" { class: func }
  command_i2c_scan: "[F] Command I2C\nscan/capture" { class: func }
  disposition_anomalies: "[F] Disposition anomalies\nfor v0.2 gate" { class: func }
}

esd_bench: "[EA] ESD bench" {
  class: ea
  direction: down
  grid-columns: 1

  maintain_esd_control: "[F] Maintain ESD-safe\nwork area" { class: func }
  fixture_breadboard: "[F] Fixture breadboard\nwithout strain" { class: func }
}

bench_power: "[EA] Bench power" {
  class: ea
  direction: down
  grid-columns: 1

  deliver_controlled_power: "[F] Deliver controlled\nUSB/5V power" { class: func }
  read_supply_limits: "[F] Read supply\nvoltage/current" { class: func }
}

dmm: "[EA] DMM / continuity meter" {
  class: ea
  direction: down
  grid-columns: 2

  measure_3v3_gnd: "[F] Measure 3V3\nand GND polarity" { class: func }
  check_i2c_continuity: "[F] Check SDA/SCL\ncontinuity" { class: func }
  check_no_shorts: "[F] Check no open,\nshort, or reversal" { class: func }
  record_meter_readings: "[F] Record meter\nreadings" { class: func }
}

logic_analyzer: "[EA] I2C scanner / logic analyzer" {
  class: ea
  direction: down
  grid-columns: 2

  scan_i2c_address: "[F] Scan BME280\nI2C address" { class: func }
  capture_sda_scl: "[F] Capture SDA/SCL\nactivity" { class: func }
  confirm_i2c_roles: "[F] Confirm requester /\nresponder roles" { class: func }
  archive_bus_capture: "[F] Archive bus\ncapture" { class: func }
}

host_pc: "[EA] PC / USB host\nserial terminal" {
  class: ea
  direction: down
  grid-columns: 2

  open_serial_terminal: "[F] Open serial\nterminal" { class: func }
  log_init_output: "[F] Log init-state\noutput" { class: func }
  log_measurement_output: "[F] Log measurement\noutput" { class: func }
  archive_serial_log: "[F] Archive serial\nlog" { class: func }
}

evidence_repo: "[EA] Evidence repository /\nreadiness checklist" {
  class: ea
  direction: down
  grid-columns: 2

  compile_pc_pl_matrix: "[F] Compile PC/PL\ncoverage matrix" { class: func }
  assess_i2c_ce_consistency: "[F] Assess I2C CE\nconsistency" { class: func }
  assess_allocation_matrix: "[F] Assess function\nallocation matrix" { class: func }
  assess_pcb_trace_readiness: "[F] Assess PCB trace\nreadiness" { class: func }
  record_constraints_status: "[F] Record constraint\ncoverage status" { class: func }
  store_report_inputs: "[F] Store report\ninputs" { class: func }
}

note_identity: "[C] Pass iff BME280, XIAO ESP32, and host PC\nidentities are verified against the v0.1 baseline;\nwrong, ambiguous, damaged, or substituted items fail." {
  class: note
  shape: page
}
note_wiring: "[C] Pass iff 3V3, GND, SDA, and SCL\nare connected to the modeled endpoints with correct\npin identity, polarity, and documented route." {
  class: note
  shape: page
}
note_open_short: "[C] Fail on any open, short, reversed line,\nintermittent jumper, loose contact, or unapproved\nparallel/bypass connection." {
  class: note
  shape: page
}
note_usb_serial: "[C] Pass iff USB serial link is present and\nhost PC logs init and measurement output; serial\nlogging is evidence, not an I2C substitute." {
  class: note
  shape: page
}
note_ce_consistency: "[C] I2C CE pass condition: modeled endpoints,\nprotocol, bus direction/roles, address evidence,\nand request/response intent are consistent enough\nto proceed to PCB implementation." {
  class: note
  shape: page
}
note_no_foreign_allocation: "[C] Allocation pass condition: AMS Sensing owns\nmeasure/respond functions; AMS Processing owns read,\nprocess, collect, and serial functions; no foreign\nfunction allocation or hidden proxy is accepted." {
  class: note
  shape: page
}
note_pcb_ready: "[C] Advancement pass condition: breadboard\ninspection and analysis provide enough controlled\nevidence to translate I2C, 3V3, GND, and USB links\ninto v0.2 PCB traces/connectors." {
  class: note
  shape: page
}
note_constraint_scope: "[C] Existing performance/timing constraints are\nreviewed for coverage and non-contradiction at this\ngate; full statistical verification remains future\nconstraint-specific testing." {
  class: note
  shape: page
}
note_environment: "[C] Environment: ESD-controlled bench, strain-free\nbreadboard fixture, current-limited USB/5V power, and\npower-off continuity checks unless scan/log capture is active." {
  class: note
  shape: page
}
note_stat_fault: "[C] Statistical viewpoint: 100% census review of\n3 PCs, 4 PLs, 1 CE, 2 LCs, and all v0.1 allocated\nfunctions. Fault hardening: wrong item, wrong pin,\nopen/short/reversal, wrong I2C role, missing timeout\npolicy, or unapproved bypass fails or requires waiver." {
  class: note
  shape: page
}

system.bme280.ams_sensing.note_accuracy_pressure -> system.bme280.ams_sensing.measure_pressure { class: cstr }
system.bme280.ams_sensing.note_accuracy_temperature -> system.bme280.ams_sensing.measure_temperature { class: cstr }
system.xiao.ams_processing.note_resolution -> system.xiao.ams_processing.calculate_altitude { class: cstr }
system.xiao.note_no_blocking -> system.xiao.ams_processing { class: cstr }
system.xiao.note_variable_getter -> system.xiao.ams_processing { class: cstr }
system.xiao.note_i2c_timeout -> system.xiao.ams_processing.read_pressure { class: cstr }
system.xiao.note_i2c_timeout -> system.xiao.ams_processing.read_temperature { class: cstr }
system.xiao.note_i2c_timeout -> system.xiao.ams_processing.get_bme280_init_state { class: cstr }
system.xiao.note_process_time -> system.xiao.ams_processing.calculate_altitude { class: cstr }
system.xiao.note_process_time -> system.xiao.ams_processing.process_temperature { class: cstr }

note_identity -> test_operator.identify_breadboard_items { class: cstr }
note_identity -> system.bme280 { class: cstr }
note_identity -> system.xiao { class: cstr }
note_identity -> host_pc.open_serial_terminal { class: cstr }
note_wiring -> dmm.measure_3v3_gnd { class: cstr }
note_wiring -> dmm.check_i2c_continuity { class: cstr }
note_open_short -> dmm.check_no_shorts { class: cstr }
note_usb_serial -> host_pc.log_init_output { class: cstr }
note_usb_serial -> host_pc.log_measurement_output { class: cstr }
note_usb_serial -> system.xiao.ams_processing.log_serial0 { class: cstr }
note_ce_consistency -> logic_analyzer.scan_i2c_address { class: cstr }
note_ce_consistency -> logic_analyzer.confirm_i2c_roles { class: cstr }
note_ce_consistency -> evidence_repo.assess_i2c_ce_consistency { class: cstr }
note_no_foreign_allocation -> evidence_repo.assess_allocation_matrix { class: cstr }
note_no_foreign_allocation -> system.bme280.ams_sensing { class: cstr }
note_no_foreign_allocation -> system.xiao.ams_processing { class: cstr }
note_pcb_ready -> evidence_repo.assess_pcb_trace_readiness { class: cstr }
note_constraint_scope -> evidence_repo.record_constraints_status { class: cstr }
note_environment -> esd_bench.maintain_esd_control { class: cstr }
note_environment -> bench_power.deliver_controlled_power { class: cstr }
note_stat_fault -> evidence_repo.compile_pc_pl_matrix { class: cstr }
note_stat_fault -> test_operator.disposition_anomalies { class: cstr }

# Layout-only edges to stack VV actors and constraints below the UUT allocation.
system -> test_operator { style: { opacity: 0 } }
test_operator -> esd_bench { style: { opacity: 0 } }
esd_bench -> bench_power { style: { opacity: 0 } }
bench_power -> dmm { style: { opacity: 0 } }
dmm -> logic_analyzer { style: { opacity: 0 } }
logic_analyzer -> host_pc { style: { opacity: 0 } }
host_pc -> evidence_repo { style: { opacity: 0 } }
evidence_repo -> note_identity { style: { opacity: 0 } }
note_identity -> note_wiring { style: { opacity: 0 } }
note_wiring -> note_open_short { style: { opacity: 0 } }
note_open_short -> note_usb_serial { style: { opacity: 0 } }
note_usb_serial -> note_ce_consistency { style: { opacity: 0 } }
note_ce_consistency -> note_no_foreign_allocation { style: { opacity: 0 } }
note_no_foreign_allocation -> note_pcb_ready { style: { opacity: 0 } }
note_pcb_ready -> note_constraint_scope { style: { opacity: 0 } }
note_constraint_scope -> note_environment { style: { opacity: 0 } }
note_environment -> note_stat_fault { style: { opacity: 0 } }
