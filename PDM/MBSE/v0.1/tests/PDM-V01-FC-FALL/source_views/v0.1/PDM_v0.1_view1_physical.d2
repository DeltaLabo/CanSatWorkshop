vars: {
  d2-config: {
    layout-engine: elk
  }
}

# Physical view reconstructed from PDM/PDM_v0.1_S.png.
# Historical v0.1 names are preserved: Dummy CanSat and Top module.
direction: right

classes: {
  func: {
    shape: rectangle
    style: { fill: "#BDFB9B"; stroke: "#166534"; stroke-width: 2; font-size: 36 }
  }
  lc: {
    style: {
      fill: "#A9C7E6"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  pc: {
    style: { fill: "#FFF8BF"; stroke: "#D1B24A"; stroke-width: 2; font-size: 40 }
  }
  sys: {
    style: { fill: "#E6E6E6"; stroke: "#9A9A9A"; stroke-width: 2; font-size: 48 }
  }
  ea: {
    shape: rectangle
    style: {
      fill: "#BFEAF4"; stroke: "#5B65C9"; stroke-width: 2
      border-radius: 20; font-size: 40
    }
  }
  note: { style: { fill: "#FFF5B0"; stroke: "#D1B24A"; font-size: 32 } }
  chain: {
    style: {
      fill: "#FFFFFF"; stroke: "#D1B24A"; stroke-width: 2
      border-radius: 20; font-size: 36
    }
  }
  fe:   { style: { stroke: "#1F7A4D"; font-color: "#1F7A4D"; stroke-width: 2; font-size: 30 } }
  ce:   { style: { stroke: "#5B65C9"; font-color: "#5B65C9"; stroke-width: 2; font-size: 30 } }
  pl:   { style: { stroke: "#E11D28"; font-color: "#E11D28"; stroke-width: 2; font-size: 30 } }
  cstr: { style: { stroke: "#333333"; stroke-dash: 3; font-size: 26 } }
}

dummy_cansat: "[PC] Dummy CanSat" {
  class: pc
  direction: down

  top_module: "[PC] Top module" {
    class: pc
    direction: down

    parachute: "[PC] Parachute" { class: pc }
  }
}

same_weight: "[C] Same weight as\nfinal estimate\n(+/-5% or +/-10 g,\nwhichever is tighter)" { class: note; shape: page }
scale_resolution: "[C] Mass scale resolution\n<= 1 g\nor uncertainty proves\njudgement" { class: note; shape: page }
foldable_deployed_manually: "[C] Foldable, but\ndeployed manually" { class: note; shape: page }
accepted_segment: "[C] Accepted segment\nafter parachute open\nand stable descent\nbefore ground-effect\nand landing disturbance" { class: note; shape: page }
video_timebase: "[C] Retained video with\nknown frame rate\nor timestamped frames\n>= 30 fps\nunless calibrated\ntimebase used" { class: note; shape: page }
distance_calibration: "[C] Distance calibration\nuncertainty <= 5%" { class: note; shape: page }
wind_environment: "[C] Wind/environment\n<= 3 m/s\nor justified\nindoor/still-air\nequivalent" { class: note; shape: page }

same_weight -> dummy_cansat { class: cstr }
scale_resolution -> dummy_cansat { class: cstr }
foldable_deployed_manually -> dummy_cansat.top_module.parachute { class: cstr }
accepted_segment -> dummy_cansat.top_module.parachute { class: cstr }
video_timebase -> dummy_cansat.top_module.parachute { class: cstr }
distance_calibration -> dummy_cansat.top_module.parachute { class: cstr }
wind_environment -> dummy_cansat.top_module.parachute { class: cstr }
